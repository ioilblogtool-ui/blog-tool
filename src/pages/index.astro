                  <rect x="22" y="6" width="7" height="30" rx="1" fill="rgba(255,255,255,0.58)"></rect>
                  <rect x="42" y="2" width="8" height="34" rx="1" fill="rgba(255,255,255,0.92)"></rect>
                </svg>
              </div>
              <div class="home-report-card__body">
                <p class="home-report-card__title">결혼비용 2016 vs 2026</p>
                <p class="home-report-card__desc">10년 사이 결혼 비용 변화 비교</p>
                <div class="home-report-card__footer">
                  <span class="home-report-card__badge">인터랙티브 리포트</span>
                  <span class="home-report-card__link">보기 →</span>
                </div>
              </div>
            </a>
            <a class="home-report-card" href={withBase("/reports/seoul-84-apartment-prices/")} data-report-category="estate">
              <div class="home-report-card__head">
                <span class="home-report-card__cat-label">부동산</span>
                <svg class="home-report-card__chart" width="52" height="36" viewBox="0 0 52 36" fill="none" aria-hidden="true">
                  <polyline points="2,34 13,26 26,16 38,10 50,4" stroke="rgba(255,255,255,0.38)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></polyline>
                  <circle cx="50" cy="4" r="3" fill="white"></circle>
                </svg>
              </div>
