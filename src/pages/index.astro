---
import { tools } from "../data/tools";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const orderedTools = [...tools].sort((a, b) => a.order - b.order);
const spotlight = orderedTools.find((tool) => tool.slug === "bonus-simulator") ?? orderedTools[0];
---

<BaseLayout title="비교계산소" description="비교해서 더 잘 판단하게 만드는 계산 도구">
  <SiteHeader />

  <main class="container page-shell">
    <section class="hero hero--home hero--magazine">
      <p class="hero__eyebrow">비교계산소</p>
      <h1 class="hero__title">계산은 빠르게, 비교는 명확하게</h1>
      <p class="hero__description">
        자주 마주치는 숫자를 빠르게 계산하고,
        상황별로 비교해볼 수 있게 만들었습니다.
      </p>
      <div class="home-actions">
        <a class="button button--primary" href={withBase("/tools/")}>전체 도구 보기</a>
      </div>
    </section>

    <section class="home-spotlight">
      <article class="panel home-spotlight__feature">
        <div class="tool-card__head">
          <p class="tool-card__eyebrow">추천 도구</p>
          {
            spotlight.badges && spotlight.badges.length > 0 && (
              <div class="tool-badges">
                {spotlight.badges.map((badge) => <span class="tool-badge">{badge}</span>)}
              </div>
            )
          }
        </div>
        <h2>{spotlight.title}</h2>
        <p>{spotlight.description}</p>
        <a class="button button--secondary" href={withBase(`/tools/${spotlight.slug}/`)}>바로 열기</a>
      </article>
      <div class="home-spotlight__stats">
        <article class="metric-card">
          <p>등록 도구 수</p>
          <strong>{orderedTools.length}개</strong>
        </article>
        <article class="metric-card">
          <p>브랜드 포지션</p>
          <strong>판단 보조 도구</strong>
        </article>
      </div>
    </section>

    <section class="tool-showcase tool-showcase--grid tool-showcase--magazine">
      {
        orderedTools.map((tool) => (
          <a class="tool-card tool-card--feature" href={withBase(`/tools/${tool.slug}/`)}>
            <div class="tool-card__head">
              <p class="tool-card__eyebrow">{tool.eyebrow ?? "Tool"}</p>
              {
                tool.badges && tool.badges.length > 0 && (
                  <div class="tool-badges">
                    {tool.badges.map((badge) => <span class="tool-badge">{badge}</span>)}
                  </div>
                )
              }
            </div>
            <h2>{tool.title}</h2>
            <p>{tool.description}</p>
            <span class="tool-card__meta">바로 이동</span>
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
