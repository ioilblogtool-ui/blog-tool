];

const homeFaqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: homeFaq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="비교계산소 | 연봉·성과급·육아휴직·투자 계산기"
  description="연봉, 성과급, 육아휴직, 출산지원금, 투자, 부동산 계산기를 한곳에서 찾고 기준일, 가정, 해석 방법까지 함께 확인하세요."
  jsonLd={homeFaqJsonLd}
>
  <SiteHeader />

  <main class="container page-shell">
    <section class="hero hero--home">
      <p class="hero__eyebrow">비교계산소</p>
      <h1 class="hero__title">숫자로 더 잘<br />판단하세요</h1>
      <p class="hero__description">연봉·성과급·육아휴직·출산지원금까지 자주 보는 숫자를 빠르게 계산하고 비교합니다.</p>

      <div class="hero-search hero-search--desktop">
        <input
          class="hero-search__input"
          type="search"
          id="hero-search-input"
          placeholder="계산기 검색 — 예) 연봉, 퇴직금, 육아휴직"
          autocomplete="off"
        />
        <div class="hero-search__chips">
          <button class="hero-search__chip" data-search="연봉 티어">연봉 티어</button>
          <button class="hero-search__chip" data-search="성과급">성과급 시뮬레이터</button>
          <button class="hero-search__chip" data-search="육아휴직">육아휴직</button>
          <button class="hero-search__chip" data-search="파이어">파이어족</button>
        </div>
      </div>

      <div class="hero-counters">
        <div class="hero-counter">
          <strong class="hero-counter__num">{toolCount}<span class="hero-counter__unit">개</span></strong>
          <span class="hero-counter__label">계산기</span>
        </div>
        <div class="hero-counter">
          <strong class="hero-counter__num">{categories.length}<span class="hero-counter__unit">개</span></strong>
          <span class="hero-counter__label">카테고리</span>
        </div>
        <div class="hero-counter">
          <strong class="hero-counter__num">{reportCount}<span class="hero-counter__unit">개</span></strong>
          <span class="hero-counter__label">리포트</span>
        </div>
      </div>
      <div class="home-actions">
        <a class="button button--primary" href={withBase("/tools/")}>계산기 보기</a>
        <a class="home-actions__link" href={withBase("/reports/")}>리포트 보기</a>
      </div>
    </section>

    <section class="home-section home-intro">
      <div class="home-section__head home-section__head--stack">
        <div>
          <p class="home-section__eyebrow">사이트 안내</p>
          <h2>비교계산소는 숫자 판단을 돕는 계산기 허브입니다</h2>
        </div>
        <div class="home-section__copy">
          <p>비교계산소는 연봉, 성과급, 출산·육아 제도, 투자, 부동산처럼 생활 속에서 자주 비교해야 하는 숫자를 한국어 계산기와 리포트로 정리합니다. 검색에서 바로 들어온 사용자도 입력값, 계산 기준, 결과 해석을 한 화면에서 이해할 수 있도록 구성하는 것이 목표입니다.</p>
          <p>계산 결과는 중요한 결정을 앞두고 빠르게 방향을 잡기 위한 참고 정보입니다. 공식 기준이 있는 항목은 원문 기준을 우선하고, 생활비·투자수익률·성과급처럼 변동성이 큰 항목은 추정 또는 시뮬레이션으로 구분해 안내합니다.</p>
        </div>
      </div>
      <div class="home-intro-grid">
        {homeIntroPoints.map((item) => (
          <article class="home-info-card">
            <strong>{item.title}</strong>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="home-section">
      <div class="home-section__head">
        <h2>처음이라면 여기부터</h2>
      </div>
      <div class="home-feat-grid">
        <a class="home-feat-card" href={withBase("/tools/salary-tier/")}>
          <div class="home-feat-card__header">
            <span class="home-feat-card__icon" aria-hidden="true">📊</span>
            <span class="home-feat-card__cat home-feat-card__cat--salary">연봉·이직</span>
          </div>
          <div class="home-feat-card__body-wrap">
            <h3 class="home-feat-card__title">연봉 티어 계산기</h3>
            <p class="home-feat-card__sub">내 연봉의 상위 % 즉시 확인</p>
          </div>
          <span class="home-feat-card__link">→</span>
        </a>

        <a class="home-feat-card" href={withBase("/tools/bonus-simulator/")}>
          <div class="home-feat-card__header">
            <span class="home-feat-card__icon" aria-hidden="true">🏢</span>
            <span class="home-feat-card__cat home-feat-card__cat--bonus">성과급 비교</span>
          </div>
          <div class="home-feat-card__body-wrap">
            <h3 class="home-feat-card__title">대기업 성과급 시뮬레이터</h3>
            <p class="home-feat-card__sub">삼성·SK·현대 성과급 비교</p>
          </div>
          <span class="home-feat-card__link">→</span>
        </a>

        <a class="home-feat-card" href={withBase("/tools/household-income/")}>
          <div class="home-feat-card__header">
            <span class="home-feat-card__icon" aria-hidden="true">🏠</span>
            <span class="home-feat-card__cat home-feat-card__cat--salary">연봉·이직</span>
          </div>
          <div class="home-feat-card__body-wrap">
            <h3 class="home-feat-card__title">가구 소득 계산기</h3>
            <p class="home-feat-card__sub">맞벌이 실수령 계산</p>
          </div>
          <span class="home-feat-card__link">→</span>
        </a>

        <a class="home-feat-card" href={withBase("/tools/fire-calculator/")}>
          <div class="home-feat-card__header">
            <span class="home-feat-card__icon" aria-hidden="true">🔥</span>
            <span class="home-feat-card__cat home-feat-card__cat--invest">투자·재테크</span>
          </div>
          <div class="home-feat-card__body-wrap">
            <h3 class="home-feat-card__title">파이어족 계산기</h3>
            <p class="home-feat-card__sub">조기 은퇴 시뮬레이션</p>
          </div>
          <span class="home-feat-card__link">→</span>
        </a>
      </div>
    </section>

    <section class="home-section home-compare">
      <div class="home-section__head home-section__head--stack">
        <div>
          <p class="home-section__eyebrow">비교표</p>
          <h2>계산기 결과를 비교표로 한 번 더 확인하세요</h2>
        </div>
        <p class="home-section__summary">개별 계산기에서 숫자를 확인한 뒤, 회사별·업종별·지원제도별 차이를 한 화면에서 비교할 수 있도록 묶었습니다.</p>
      </div>
      <div class="home-compare-grid">
        {homeCompareCards.map((item) => (
          <a class={`home-compare-card${item.featured ? " home-compare-card--featured" : ""}`} href={withBase(item.href)}>
            <span class="home-compare-card__label">{item.label}</span>
            <strong>{item.title}</strong>
            <p>{item.desc}</p>
            <div class="home-compare-card__meta">
              {item.meta.map((meta) => <span>{meta}</span>)}
            </div>
            <em>바로 보기 →</em>
          </a>
        ))}
      </div>
    </section>

    <section class="home-section home-journey">
      <div class="home-section__head home-section__head--stack">
        <div>
          <p class="home-section__eyebrow">상황별 계산 흐름</p>
          <h2>하나만 보고 나가지 않도록 다음 계산까지 이어집니다</h2>
        </div>
        <p class="home-section__summary">검색으로 들어온 목적에 맞춰 계산기와 리포트를 순서대로 묶었습니다.</p>
      </div>
      <div class="home-journey-grid">
        {homeJourneys.map((journey) => (
          <article class={`home-journey-card home-journey-card--${journey.accent}`}>
            <div class="home-journey-card__head">
              <span>{journey.label}</span>
              <strong>{journey.title}</strong>
            </div>
            <ol class="home-journey-card__steps">
              {journey.steps.map((step, index) => (
                <li>
                  <a href={withBase(step.href)}>
                    <span>{String(index + 1).padStart(2, "0")}</span>
                    {step.label}
                  </a>
                </li>
              ))}
            </ol>
          </article>
        ))}
      </div>
    </section>

    <section class="home-section">
      <div class="home-section__head home-section__head--stack">
        <div>
          <p class="home-section__eyebrow">계산 기준</p>
          <h2>공식 기준과 추정값을 나눠서 봅니다</h2>
        </div>
        <p class="home-section__summary">제도형 계산기는 기준일과 출처 확인이 중요하고, 생활형 계산기는 입력값 변화에 따른 범위 해석이 중요합니다.</p>
      </div>
      <div class="home-basis-grid">
        {homeBasisCards.map((item) => (
          <article class="home-info-card">
            <strong>{item.title}</strong>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="home-section">
      <div class="home-section__head home-section__head--stack">
