---
import { tools } from "../data/tools";
import { reports } from "../data/reports";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const orderedTools = [...tools].sort((a, b) => a.order - b.order);
const orderedReports = [...reports].sort((a, b) => a.order - b.order);

const toolCount = orderedTools.length;
const reportCount = orderedReports.length || 2;

const topicBySlug: Record<string, string> = {
  salary: "연봉·이직",
  retirement: "연봉·이직",
  negotiation: "연봉·이직",
  "household-income": "연봉·이직",
  "parental-leave": "육아휴직·출산",
  "bonus-simulator": "성과급 비교",
  "samsung-bonus": "성과급 비교",
  "sk-hynix-bonus": "성과급 비교",
  "hyundai-bonus": "성과급 비교",
  "birth-support-total": "육아휴직·출산",
  "single-parental-leave-total": "육아휴직·출산",
  "parental-leave-pay": "육아휴직·출산",
  "six-plus-six": "육아휴직·출산",
  "parental-leave-short-work-calculator": "육아휴직·출산",
  "diaper-cost": "육아·양육",
  "formula-cost": "육아·양육",
  "baby-growth-percentile-calculator": "육아·양육",
  "child-tutoring-cost-calculator": "육아·양육",
  "fetal-insurance-calculator": "육아·복지·출산",
  "home-purchase-fund": "부동산·내집마련",
  "jeonwolse-conversion": "부동산·내집마련",
  "apt-cheonyak-gajum-calculator": "부동산·내집마련",
  "salary-tier": "연봉·이직",
  "wedding-budget-calculator": "결혼·웨딩",
  "wedding-gift-break-even-calculator": "결혼·웨딩",
  "dca-investment-calculator": "투자·재테크",
  "fire-calculator": "투자·재테크",
  "national-pension-calculator": "투자·재테크",
  "irp-pension-calculator": "투자·재테크",
  "coin-tax-calculator": "투자·재테크",
  "domestic-stock-capital-gains-tax": "투자·재테크",
  "ai-stack-cost-calculator": "AI·생산성",
  "ai-automation-hourly-roi": "AI·생산성",
};

const categories = [...new Set(orderedTools.map((t) => topicBySlug[t.slug]).filter(Boolean))];
type HomeReportCategory = "salary" | "estate" | "asset" | "life" | "culture";

type HomeReportMeta = {
  category: HomeReportCategory;
  isNew: boolean;
};

const reportMetaBySlug: Record<string, HomeReportMeta> = {
  "new-employee-salary-2026": { category: "salary", isNew: false },
  "it-salary-top10": { category: "salary", isNew: false },
  "it-si-sm-salary-comparison-2026": { category: "salary", isNew: true },
  "insurance-salary-bonus-comparison-2026": { category: "salary", isNew: true },
  "construction-salary-bonus-comparison-2026": { category: "salary", isNew: true },
  "large-company-salary-growth-by-years-2026": { category: "salary", isNew: true },
  "police-salary-2026": { category: "salary", isNew: true },
  "firefighter-salary-2026": { category: "salary", isNew: true },
  "nurse-salary-2026": { category: "salary", isNew: true },
  "seoul-housing-2016-vs-2026": { category: "estate", isNew: true },
  "seoul-84-apartment-prices": { category: "estate", isNew: true },
  "wedding-cost-2016-vs-2026": { category: "life", isNew: true },
  "salary-asset-2016-vs-2026": { category: "asset", isNew: true },
  "baby-cost-guide-first-year": { category: "life", isNew: true },
  "baby-cost-2016-vs-2026": { category: "life", isNew: true },
  "elementary-school-ready-cost-2026": { category: "life", isNew: true },
  "lee-jaemyung-government-officials-assets-salary-2026": { category: "asset", isNew: true },
  "korea-rich-top10-assets": { category: "asset", isNew: false },
  "seoul-apartment-jeonse-report": { category: "estate", isNew: true },
  "seoul-jeonwolse-ratio-2026": { category: "estate", isNew: true },
  "us-rich-top10-patterns": { category: "asset", isNew: false },
  "korean-movie-break-even-profit": { category: "culture", isNew: true },
  "semiconductor-etf-2026": { category: "asset", isNew: true },
  "semiconductor-value-chain": { category: "asset", isNew: true },
  "bitcoin-gold-sp500-10year-comparison-2026": { category: "asset", isNew: true },
  "teacher-salary-2026": { category: "salary", isNew: true },
  "postpartum-center-cost-2026": { category: "life", isNew: true },
  "fetal-insurance-guide-2026": { category: "life", isNew: true },
  "national-pension-generational-comparison-2026": { category: "asset", isNew: true },
  "pension-irp-comparison-2026": { category: "asset", isNew: true },
  "ai-job-salary-impact-2026": { category: "salary", isNew: true },
  "etf-vs-direct-stock-10year-2026": { category: "asset", isNew: true },
};

const reportCategoryLabels: Record<HomeReportCategory, string> = {
  salary: "연봉",
  estate: "부동산",
  asset: "자산",
  life: "생활",
  culture: "문화·엔터",
};

const reportFilterOrder: Array<HomeReportCategory | "new"> = ["salary", "estate", "asset", "life", "culture", "new"];
const finalShowcase = orderedTools.slice(0, 4);

const trustLinks = [
  { href: withBase("/about/"), title: "비교계산소 소개", desc: "운영 기준과 계산기 구성 방식을 확인합니다." },
  { href: withBase("/privacy/"), title: "개인정보처리방침", desc: "쿠키·외부 서비스·수집 정보 처리 원칙" },
  { href: withBase("/contact/"), title: "문의 안내", desc: "오류 제보·기능 제안·제휴 문의 범위" },
  { href: withBase("/disclaimer/"), title: "이용안내 및 면책", desc: "결과 해석 방법과 실제 지급액 차이 안내" },
];
---

<BaseLayout
  title="비교계산소 — 연봉·성과급·육아휴직 계산기"
  description="연봉, 퇴직금, 성과급, 육아휴직처럼 자주 확인하는 수치를 빠르게 계산하고 비교할 수 있도록 정리한 정보형 계산 사이트입니다."
>
  <SiteHeader />

  <main class="container page-shell">
    <section class="hero hero--home">
      <p class="hero__eyebrow">비교계산소</p>
      <h1 class="hero__title">숫자로 더 잘<br />판단하세요</h1>
      <p class="hero__description">연봉·성과급·육아휴직·출산지원금까지 자주 보는 숫자를 빠르게 계산하고 비교합니다.</p>

      <div class="hero-search hero-search--desktop">
        <input
          class="hero-search__input"
          type="search"
          id="hero-search-input"
          placeholder="계산기 검색 — 예) 연봉, 퇴직금, 육아휴직"
          autocomplete="off"
        />
        <div class="hero-search__chips">
          <button class="hero-search__chip" data-search="연봉 티어">연봉 티어</button>
          <button class="hero-search__chip" data-search="성과급">성과급 시뮬레이터</button>
          <button class="hero-search__chip" data-search="육아휴직">육아휴직</button>
          <button class="hero-search__chip" data-search="파이어">파이어족</button>
        </div>
      </div>

      <div class="hero-counters">
        <div class="hero-counter">
          <strong class="hero-counter__num">{toolCount}<span class="hero-counter__unit">개</span></strong>
          <span class="hero-counter__label">계산기</span>
        </div>
        <div class="hero-counter">
          <strong class="hero-counter__num">{categories.length}<span class="hero-counter__unit">개</span></strong>
          <span class="hero-counter__label">카테고리</span>
        </div>
        <div class="hero-counter">
          <strong class="hero-counter__num">{reportCount}<span class="hero-counter__unit">개</span></strong>
          <span class="hero-counter__label">리포트</span>
        </div>
      </div>
      <div class="home-actions">
        <a class="button button--primary" href={withBase("/tools/")}>계산기 보기</a>
        <a class="home-actions__link" href={withBase("/reports/")}>리포트 보기</a>
      </div>
    </section>

    <section class="home-section">
      <div class="home-section__head">
        <h2>처음이라면 여기부터</h2>
      </div>
      <div class="home-feat-grid">
        <a class="home-feat-card" href={withBase("/tools/salary-tier/")}>
          <div class="home-feat-card__header">
            <span class="home-feat-card__icon" aria-hidden="true">📊</span>
            <span class="home-feat-card__cat home-feat-card__cat--salary">연봉·이직</span>
          </div>
          <div class="home-feat-card__body-wrap">
            <h3 class="home-feat-card__title">연봉 티어 계산기</h3>
            <p class="home-feat-card__sub">내 연봉의 상위 % 즉시 확인</p>
          </div>
          <span class="home-feat-card__link">→</span>
        </a>

        <a class="home-feat-card" href={withBase("/tools/bonus-simulator/")}>
          <div class="home-feat-card__header">
            <span class="home-feat-card__icon" aria-hidden="true">🏢</span>
            <span class="home-feat-card__cat home-feat-card__cat--bonus">성과급 비교</span>
          </div>
          <div class="home-feat-card__body-wrap">
            <h3 class="home-feat-card__title">대기업 성과급 시뮬레이터</h3>
            <p class="home-feat-card__sub">삼성·SK·현대 성과급 비교</p>
          </div>
          <span class="home-feat-card__link">→</span>
        </a>

        <a class="home-feat-card" href={withBase("/tools/household-income/")}>
          <div class="home-feat-card__header">
            <span class="home-feat-card__icon" aria-hidden="true">🏠</span>
            <span class="home-feat-card__cat home-feat-card__cat--salary">연봉·이직</span>
          </div>
          <div class="home-feat-card__body-wrap">
            <h3 class="home-feat-card__title">가구 소득 계산기</h3>
            <p class="home-feat-card__sub">맞벌이 실수령 계산</p>
          </div>
          <span class="home-feat-card__link">→</span>
        </a>

        <a class="home-feat-card" href={withBase("/tools/fire-calculator/")}>
          <div class="home-feat-card__header">
            <span class="home-feat-card__icon" aria-hidden="true">🔥</span>
            <span class="home-feat-card__cat home-feat-card__cat--invest">투자·재테크</span>
          </div>
          <div class="home-feat-card__body-wrap">
            <h3 class="home-feat-card__title">파이어족 계산기</h3>
            <p class="home-feat-card__sub">조기 은퇴 시뮬레이션</p>
          </div>
          <span class="home-feat-card__link">→</span>
        </a>
      </div>
    </section>

    <section class="home-section">
      <div class="home-section__head">
        <h2>전체 계산기 <span class="home-section__count">{toolCount}개</span></h2>
        <a href={withBase("/tools/")}>전체 보기 →</a>
      </div>

      <div class="home-filter">
        <button class="home-filter__chip is-active" data-cat="전체">전체</button>
        {categories.map((cat) => (
          <button class="home-filter__chip" data-cat={cat}>{cat}</button>
        ))}
      </div>

      <div class="home-tools-list">
        {orderedTools.map((tool) => (
          <a
            class="home-tool-row"
            href={withBase(`/tools/${tool.slug}/`)}
            data-category={topicBySlug[tool.slug] ?? "기타"}
          >
            <div class="home-tool-row__info">
              <span class="home-tool-row__title">{tool.title}</span>
              <span class="home-tool-row__cat">{topicBySlug[tool.slug] ?? "기타"}</span>
            </div>
            <span class="home-tool-row__arrow">→</span>
          </a>
        ))}
      </div>
    </section>

    <section class="home-section">
      <div class="home-section__head">
        <h2>비교 리포트 <span class="home-section__count">{reportCount}개</span></h2>
        <a href={withBase("/reports/")}>전체 보기 →</a>
      </div>

      <div class="home-filter home-filter--reports">
        <button class="home-filter__chip home-filter__chip--report is-active" data-report-filter="all">전체</button>
        {reportFilterOrder.map((filterKey) => (
          <button class="home-filter__chip home-filter__chip--report" data-report-filter={filterKey}>
            {filterKey === "new" ? "신규" : reportCategoryLabels[filterKey]}
          </button>
        ))}
      </div>

      <div class="home-reports">
        {orderedReports.length > 0 ? orderedReports.map((report) => {
          const reportMeta = reportMetaBySlug[report.slug];
          const cat = reportMeta?.category ?? "other";
          const reportCategory = reportMeta ? reportCategoryLabels[reportMeta.category] : "기타";
          const useBar = ["salary", "life", "culture", "other"].includes(cat);
          return (
            <a
              class="home-report-card"
              href={withBase(`/reports/${report.slug}/`)}
              data-report-category={cat}
              data-report-is-new={reportMeta?.isNew ? "true" : "false"}
            >
              <div class="home-report-card__head">
                <span class="home-report-card__cat-label">{reportCategory}</span>
                {useBar ? (
                  <svg class="home-report-card__chart" width="52" height="36" viewBox="0 0 52 36" fill="none" aria-hidden="true">
                    <rect x="2" y="22" width="7" height="14" rx="1" fill="rgba(255,255,255,0.22)"></rect>
                    <rect x="12" y="14" width="7" height="22" rx="1" fill="rgba(255,255,255,0.38)"></rect>
                    <rect x="22" y="6" width="7" height="30" rx="1" fill="rgba(255,255,255,0.58)"></rect>
                    <rect x="32" y="10" width="7" height="26" rx="1" fill="rgba(255,255,255,0.74)"></rect>
                    <rect x="42" y="2" width="8" height="34" rx="1" fill="rgba(255,255,255,0.92)"></rect>
                  </svg>
                ) : (
                  <svg class="home-report-card__chart" width="52" height="36" viewBox="0 0 52 36" fill="none" aria-hidden="true">
                    <polyline points="2,34 13,26 26,16 38,10 50,4" stroke="rgba(255,255,255,0.38)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></polyline>
                    <circle cx="2" cy="34" r="2.5" fill="rgba(255,255,255,0.48)"></circle>
                    <circle cx="13" cy="26" r="2.5" fill="rgba(255,255,255,0.62)"></circle>
                    <circle cx="26" cy="16" r="2.5" fill="rgba(255,255,255,0.78)"></circle>
                    <circle cx="38" cy="10" r="2.5" fill="rgba(255,255,255,0.9)"></circle>
                    <circle cx="50" cy="4" r="3" fill="white"></circle>
                  </svg>
                )}
              </div>
              <div class="home-report-card__body">
                <p class="home-report-card__title">{report.title}</p>
                <p class="home-report-card__desc">{report.description}</p>
                <div class="home-report-card__footer">
                  <span class="home-report-card__badge">인터랙티브 리포트</span>
                  <span class="home-report-card__link">보기 →</span>
                </div>
              </div>
            </a>
          );
        }) : (
          <Fragment>
            <a class="home-report-card" href={withBase("/reports/it-salary-top10/")} data-report-category="salary">
              <div class="home-report-card__head">
                <span class="home-report-card__cat-label">연봉</span>
                <svg class="home-report-card__chart" width="52" height="36" viewBox="0 0 52 36" fill="none" aria-hidden="true">
                  <rect x="2" y="22" width="7" height="14" rx="1" fill="rgba(255,255,255,0.22)"></rect>
                  <rect x="12" y="14" width="7" height="22" rx="1" fill="rgba(255,255,255,0.38)"></rect>
                  <rect x="22" y="6" width="7" height="30" rx="1" fill="rgba(255,255,255,0.58)"></rect>
                  <rect x="32" y="10" width="7" height="26" rx="1" fill="rgba(255,255,255,0.74)"></rect>
                  <rect x="42" y="2" width="8" height="34" rx="1" fill="rgba(255,255,255,0.92)"></rect>
                </svg>
              </div>
              <div class="home-report-card__body">
                <p class="home-report-card__title">IT 업계 신입 초봉 TOP 10</p>
                <p class="home-report-card__desc">국내 주요 IT 기업 신입 초봉 비교</p>
                <div class="home-report-card__footer">
                  <span class="home-report-card__badge">인터랙티브 리포트</span>
                  <span class="home-report-card__link">보기 →</span>
                </div>
              </div>
            </a>
            <a class="home-report-card" href={withBase("/reports/wedding-cost-2016-vs-2026/")} data-report-category="life">
              <div class="home-report-card__head">
                <span class="home-report-card__cat-label">생활</span>
                <svg class="home-report-card__chart" width="52" height="36" viewBox="0 0 52 36" fill="none" aria-hidden="true">
                  <rect x="2" y="22" width="7" height="14" rx="1" fill="rgba(255,255,255,0.22)"></rect>
                  <rect x="22" y="6" width="7" height="30" rx="1" fill="rgba(255,255,255,0.58)"></rect>
                  <rect x="42" y="2" width="8" height="34" rx="1" fill="rgba(255,255,255,0.92)"></rect>
                </svg>
              </div>
              <div class="home-report-card__body">
                <p class="home-report-card__title">결혼비용 2016 vs 2026</p>
                <p class="home-report-card__desc">10년 사이 결혼 비용 변화 비교</p>
                <div class="home-report-card__footer">
                  <span class="home-report-card__badge">인터랙티브 리포트</span>
                  <span class="home-report-card__link">보기 →</span>
                </div>
              </div>
            </a>
            <a class="home-report-card" href={withBase("/reports/seoul-84-apartment-prices/")} data-report-category="estate">
              <div class="home-report-card__head">
                <span class="home-report-card__cat-label">부동산</span>
                <svg class="home-report-card__chart" width="52" height="36" viewBox="0 0 52 36" fill="none" aria-hidden="true">
                  <polyline points="2,34 13,26 26,16 38,10 50,4" stroke="rgba(255,255,255,0.38)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></polyline>
                  <circle cx="50" cy="4" r="3" fill="white"></circle>
                </svg>
              </div>
              <div class="home-report-card__body">
                <p class="home-report-card__title">서울 국평 아파트 가격 비교</p>
                <p class="home-report-card__desc">서울 구별 84㎡ 아파트 실거래가 비교</p>
                <div class="home-report-card__footer">
                  <span class="home-report-card__badge">인터랙티브 리포트</span>
                  <span class="home-report-card__link">보기 →</span>
                </div>
              </div>
            </a>
          </Fragment>
        )}
      </div>
    </section>

    <section class="home-section">
      <div class="home-section__head">
        <h2>이용 안내</h2>
      </div>
      <div class="home-trust">
        {trustLinks.map((link) => (
          <a class="home-trust-card" href={link.href}>
            <p class="home-trust-card__title">{link.title}</p>
            <p class="home-trust-card__desc">{link.desc}</p>
          </a>
        ))}
      </div>
      <p class="home-trust__notice">
        계산 결과는 공개 기준과 입력값을 바탕으로 한 참고용 추정치입니다.
        중요한 결정 전에는 원문 공지와 공식 자료를 함께 확인해주세요.
      </p>
    </section>
  </main>

  <script is:inline>
    var searchInput = document.getElementById("hero-search-input");
    var toolRows = document.querySelectorAll(".home-tool-row");

    function filterToolsByQuery(q) {
      var normalized = q.trim().toLowerCase();
      toolRows.forEach(function (row) {
        var titleEl = row.querySelector(".home-tool-row__title");
        var catEl = row.querySelector(".home-tool-row__cat");
        var text = ((titleEl ? titleEl.textContent : "") + " " + (catEl ? catEl.textContent : "")).toLowerCase();
        row.style.display = !normalized || text.includes(normalized) ? "" : "none";
      });
      if (normalized) {
        document.querySelectorAll('.home-filter__chip[data-cat]').forEach(function (b) { b.classList.remove("is-active"); });
        var allChip = document.querySelector('.home-filter__chip[data-cat="전체"]');
        if (allChip) allChip.classList.add("is-active");
      }
    }

    if (searchInput) {
      searchInput.addEventListener("input", function () { filterToolsByQuery(this.value); });
      searchInput.addEventListener("search", function () { filterToolsByQuery(this.value); });
    }

    document.querySelectorAll(".hero-search__chip").forEach(function (chip) {
      chip.addEventListener("click", function () {
        document.querySelectorAll(".hero-search__chip").forEach(function (c) { c.classList.remove("is-active"); });
        chip.classList.add("is-active");
        var term = chip.getAttribute("data-search");
        if (searchInput) {
          searchInput.value = term;
          filterToolsByQuery(term);
          var toolsSection = document.querySelector(".home-tools-list");
          if (toolsSection) toolsSection.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }
      });
    });

    document.querySelectorAll(".home-filter__chip").forEach(function (btn) {
      btn.addEventListener("click", function () {
        if (btn.hasAttribute("data-cat")) {
          document.querySelectorAll(".home-filter__chip[data-cat]").forEach(function (b) {
            b.classList.remove("is-active");
          });
          btn.classList.add("is-active");
          var cat = btn.getAttribute("data-cat");
          document.querySelectorAll(".home-tool-row").forEach(function (row) {
            row.style.display = cat === "전체" || row.getAttribute("data-category") === cat ? "" : "none";
          });
        }

        if (btn.hasAttribute("data-report-filter")) {
          document.querySelectorAll(".home-filter__chip[data-report-filter]").forEach(function (b) {
            b.classList.remove("is-active");
          });
          btn.classList.add("is-active");
          var reportFilter = btn.getAttribute("data-report-filter");
          document.querySelectorAll(".home-report-card").forEach(function (card) {
            var matchesCategory = reportFilter === "all" || card.getAttribute("data-report-category") === reportFilter;
            var matchesNew = reportFilter === "new" && card.getAttribute("data-report-is-new") === "true";
            card.style.display = matchesCategory || matchesNew ? "" : "none";
          });
        }
      });
    });
  </script>
</BaseLayout>
