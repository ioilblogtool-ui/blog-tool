  </main>

  <BackToTop />

  <script is:inline>
    var searchInput = document.getElementById("hero-search-input");
    var toolRows = document.querySelectorAll(".home-tool-row");
    var reportCards = document.querySelectorAll(".home-report-card");

    function filterToolsByQuery(q) {
      var normalized = q.trim().toLowerCase();

      toolRows.forEach(function (row) {
        var titleEl = row.querySelector(".home-tool-row__title");
        var catEl = row.querySelector(".home-tool-row__cat");
        var text = ((titleEl ? titleEl.textContent : "") + " " + (catEl ? catEl.textContent : "")).toLowerCase();
        row.style.display = !normalized || text.includes(normalized) ? "" : "none";
      });

      reportCards.forEach(function (card) {
        var titleEl = card.querySelector(".home-report-card__title");
        var descEl = card.querySelector(".home-report-card__desc");
        var catEl = card.querySelector(".home-report-card__cat-label");
        var text = (
          (titleEl ? titleEl.textContent : "") + " " +
          (descEl ? descEl.textContent : "") + " " +
          (catEl ? catEl.textContent : "")
        ).toLowerCase();
        card.style.display = !normalized || text.includes(normalized) ? "" : "none";
      });

      if (normalized) {
        document.querySelectorAll('.home-filter__chip[data-cat]').forEach(function (b) { b.classList.remove("is-active"); });
        var allChip = document.querySelector('.home-filter__chip[data-cat="전체"]');
        if (allChip) allChip.classList.add("is-active");

        document.querySelectorAll('.home-filter__chip[data-report-filter]').forEach(function (b) { b.classList.remove("is-active"); });
        var allReportChip = document.querySelector('.home-filter__chip[data-report-filter="all"]');
        if (allReportChip) allReportChip.classList.add("is-active");
      }
    }

    if (searchInput) {
      searchInput.addEventListener("input", function () { filterToolsByQuery(this.value); });
      searchInput.addEventListener("search", function () { filterToolsByQuery(this.value); });
    }

    document.querySelectorAll(".hero-search__chip").forEach(function (chip) {
      chip.addEventListener("click", function () {
        document.querySelectorAll(".hero-search__chip").forEach(function (c) { c.classList.remove("is-active"); });
        chip.classList.add("is-active");
        var term = chip.getAttribute("data-search");
        if (searchInput) {
          searchInput.value = term;
          filterToolsByQuery(term);
          var toolsSection = document.querySelector(".home-tools-list");
          if (toolsSection) toolsSection.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }
      });
    });

    document.querySelectorAll(".home-filter__chip").forEach(function (btn) {
      btn.addEventListener("click", function () {
        if (btn.hasAttribute("data-cat")) {
          document.querySelectorAll(".home-filter__chip[data-cat]").forEach(function (b) {
            b.classList.remove("is-active");
          });
          btn.classList.add("is-active");
          var cat = btn.getAttribute("data-cat");
          document.querySelectorAll(".home-tool-row").forEach(function (row) {
            row.style.display = cat === "전체" || row.getAttribute("data-category") === cat ? "" : "none";
          });
          var toolsList = document.querySelector(".home-tools-list");
          if (toolsList) toolsList.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        if (btn.hasAttribute("data-report-filter")) {
          document.querySelectorAll(".home-filter__chip[data-report-filter]").forEach(function (b) {
            b.classList.remove("is-active");
          });
          btn.classList.add("is-active");
          var reportFilter = btn.getAttribute("data-report-filter");
          document.querySelectorAll(".home-report-card").forEach(function (card) {
            var matchesCategory = reportFilter === "all" || card.getAttribute("data-report-category") === reportFilter;
            var matchesNew = reportFilter === "new" && card.getAttribute("data-report-is-new") === "true";
            card.style.display = matchesCategory || matchesNew ? "" : "none";
          });
          var reportsList = document.querySelector(".home-reports");
          if (reportsList) reportsList.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });
  </script>
</BaseLayout>
