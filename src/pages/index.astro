---
import { tools } from "../data/tools";
import { reports } from "../data/reports";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const orderedTools = [...tools].sort((a, b) => a.order - b.order);
const orderedReports = [...reports].sort((a, b) => a.order - b.order);

const toolCount = orderedTools.length;
const reportCount = orderedReports.length || 2;

const topicBySlug: Record<string, string> = {
  salary: "연봉·이직",
  retirement: "연봉·이직",
  negotiation: "연봉·이직",
  "household-income": "연봉·이직",
  "parental-leave": "육아휴직·출산",
  "bonus-simulator": "성과급 비교",
  "samsung-bonus": "성과급 비교",
  "sk-hynix-bonus": "성과급 비교",
  "hyundai-bonus": "성과급 비교",
  "birth-support-total": "육아휴직·출산",
  "single-parental-leave-total": "육아휴직·출산",
  "parental-leave-pay": "육아휴직·출산",
  "six-plus-six": "육아휴직·출산",
  "parental-leave-short-work-calculator": "육아휴직·출산",
  "diaper-cost": "육아·양육",
  "formula-cost": "육아·양육",
  "baby-growth-percentile-calculator": "육아·양육",
  "home-purchase-fund": "부동산·내집마련",
  "salary-tier": "연봉·이직",
  "wedding-budget-calculator": "결혼·웨딩",
  "wedding-gift-break-even-calculator": "결혼·웨딩",
  "dca-investment-calculator": "투자·재테크",
  "fire-calculator": "투자·재테크"
};

const categories = [...new Set(orderedTools.map(t => topicBySlug[t.slug]).filter(Boolean))];
type HomeReportCategory = "salary" | "estate" | "asset" | "life" | "culture";

type HomeReportMeta = {
  category: HomeReportCategory;
  isNew: boolean;
};

const reportMetaBySlug: Record<string, HomeReportMeta> = {
  "new-employee-salary-2026": { category: "salary", isNew: false },
  "it-salary-top10": { category: "salary", isNew: false },
  "it-si-sm-salary-comparison-2026": { category: "salary", isNew: true },
  "insurance-salary-bonus-comparison-2026": { category: "salary", isNew: true },
  "construction-salary-bonus-comparison-2026": { category: "salary", isNew: true },
  "large-company-salary-growth-by-years-2026": { category: "salary", isNew: true },
  "police-salary-2026": { category: "salary", isNew: true },
  "firefighter-salary-2026": { category: "salary", isNew: true },
  "nurse-salary-2026": { category: "salary", isNew: true },
  "seoul-housing-2016-vs-2026": { category: "estate", isNew: true },
  "seoul-84-apartment-prices": { category: "estate", isNew: true },
  "wedding-cost-2016-vs-2026": { category: "life", isNew: true },
  "salary-asset-2016-vs-2026": { category: "asset", isNew: true },
  "baby-cost-guide-first-year": { category: "life", isNew: true },
  "baby-cost-2016-vs-2026": { category: "life", isNew: true },
  "lee-jaemyung-government-officials-assets-salary-2026": { category: "asset", isNew: true },
  "korea-rich-top10-assets": { category: "asset", isNew: false },
  "seoul-apartment-jeonse-report": { category: "estate", isNew: true },
  "us-rich-top10-patterns": { category: "asset", isNew: false },
  "korean-movie-break-even-profit": { category: "culture", isNew: true },
  "semiconductor-etf-2026": { category: "asset", isNew: true },
  "semiconductor-value-chain": { category: "asset", isNew: true },
  "teacher-salary-2026": { category: "salary", isNew: true },
};

const reportCategoryLabels: Record<HomeReportCategory, string> = {
  salary: "연봉",
  estate: "부동산",
  asset: "자산",
  life: "생활",
  culture: "문화·엔터"
};

const reportFilterOrder: Array<HomeReportCategory | "new"> = ["salary", "estate", "asset", "life", "culture", "new"];
const finalShowcase = orderedTools.slice(0, 4);

const trustLinks = [
  { href: withBase("/about/"),      title: "비교계산소 소개",    desc: "운영 기준과 계산기 구성 방식을 확인합니다." },
  { href: withBase("/privacy/"),    title: "개인정보처리방침",   desc: "쿠키·외부 서비스·수집 정보 처리 원칙" },
  { href: withBase("/contact/"),    title: "문의 안내",          desc: "오류 제보·기능 제안·제휴 문의 범위" },
  { href: withBase("/disclaimer/"), title: "이용안내 및 면책",   desc: "결과 해석 방법과 실제 지급액 차이 안내" },
];
---

<BaseLayout
  title="비교계산소 — 연봉·성과급·육아휴직 계산기"
  description="연봉, 퇴직금, 성과급, 육아휴직처럼 자주 확인하는 수치를 빠르게 계산하고 비교할 수 있도록 정리한 정보형 계산 사이트입니다."
>
  <SiteHeader />

  <main class="container page-shell">

    <!-- ① hero -->
    <section class="hero hero--home">
      <p class="hero__eyebrow">비교계산소</p>
      <h1 class="hero__title">세상의 궁금한 숫자,<br>한 번에 비교 계산하세요</h1>
      <p class="hero__description">연봉·성과급·육아휴직·출산지원금까지 자주 보는 숫자를 빠르게 계산하고 비교합니다.</p>
      <div class="home-actions">
        <a class="button button--primary" href={withBase("/tools/")}>운영 중인 계산기 보기</a>
      </div>
    </section>

    <!-- ② stats -->
    <section class="home-stats">
      <div class="home-stats__card home-stats__card--hl">
        <p class="home-stats__num">{toolCount}</p>
        <p class="home-stats__label">운영 중 계산기</p>
        <p class="home-stats__source">계속 추가 중</p>
      </div>
      <div class="home-stats__card">
        <p class="home-stats__num">{categories.length}</p>
        <p class="home-stats__label">카테고리</p>
        <p class="home-stats__source">{categories.slice(0, 2).join("·")} 등</p>
      </div>
      <div class="home-stats__card">
        <p class="home-stats__num">{reportCount}</p>
        <p class="home-stats__label">비교 리포트</p>
        <p class="home-stats__source">인터랙티브 리포트</p>
      </div>
    </section>

    <!-- ③ 추천 계산기 -->
    <section class="home-section">
      <div class="home-section__head">
        <h2>처음이라면 여기부터</h2>
      </div>
      <div class="home-showcase">
        {finalShowcase.map((tool, i) => (
          <a
            class={`home-tool-card${i === 0 ? " home-tool-card--feat" : ""}`}
            href={withBase(`/tools/${tool.slug}/`)}
          >
            <p class="home-tool-card__cat">{topicBySlug[tool.slug] ?? "도구"}</p>
            <h3 class="home-tool-card__title">{tool.title}</h3>
            {tool.badges && tool.badges.length > 0 && (
              <div class="home-tool-card__chips">
                {tool.badges.slice(0, 3).map(tag => (
                  <span class="home-tool-card__chip">{tag}</span>
                ))}
              </div>
            )}
            <p class="home-tool-card__desc">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- ④ 전체 계산기 -->
    <section class="home-section">
      <div class="home-section__head">
        <h2>전체 계산기 <span class="home-section__count">{toolCount}개</span></h2>
        <a href={withBase("/tools/")}>전체 보기 →</a>
      </div>

      <div class="home-filter">
        <button class="home-filter__chip is-active" data-cat="전체">전체</button>
        {categories.map(cat => (
          <button class="home-filter__chip" data-cat={cat}>{cat}</button>
        ))}
      </div>

      <div class="home-tools-list">
        {orderedTools.map(tool => (
          <a
            class="home-tool-row"
            href={withBase(`/tools/${tool.slug}/`)}
            data-category={topicBySlug[tool.slug] ?? "기타"}
          >
            <div class="home-tool-row__info">
              <span class="home-tool-row__title">{tool.title}</span>
              <span class="home-tool-row__cat">{topicBySlug[tool.slug] ?? "기타"}</span>
            </div>
            <span class="home-tool-row__arrow">→</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ⑤ 리포트 -->
    <section class="home-section">
      <div class="home-section__head">
        <h2>비교 리포트 <span class="home-section__count">{reportCount}개</span></h2>
        <a href={withBase("/reports/")}>전체 보기 →</a>
      </div>

      <div class="home-filter home-filter--reports">
        <button class="home-filter__chip home-filter__chip--report is-active" data-report-filter="all">전체</button>
        {reportFilterOrder.map(filterKey => (
          <button class="home-filter__chip home-filter__chip--report" data-report-filter={filterKey}>
            {filterKey === "new" ? "신규" : reportCategoryLabels[filterKey]}
          </button>
        ))}
      </div>

      <div class="home-reports">
        {orderedReports.length > 0 ? orderedReports.map(report => {
          const reportMeta = reportMetaBySlug[report.slug];
          const reportCategory = reportMeta ? reportCategoryLabels[reportMeta.category] : "기타";
          return (
          <a
            class="home-report-card"
            href={withBase(`/reports/${report.slug}/`)}
            data-report-category={reportMeta?.category ?? "other"}
            data-report-is-new={reportMeta?.isNew ? "true" : "false"}
          >
            <span class="home-report-card__badge">인터랙티브 리포트</span>
            <p class="home-report-card__cat">{reportCategory}</p>
            <p class="home-report-card__title">{report.title}</p>
            <p class="home-report-card__desc">{report.description}</p>
          </a>
          );
        }) : (
          <Fragment>
            <a class="home-report-card" href={withBase("/reports/korea-rich-top10-assets/")}>
              <span class="home-report-card__badge">인터랙티브 리포트</span>
              <p class="home-report-card__title">한국 부자 TOP 10 자산 비교 리포트</p>
              <p class="home-report-card__desc">원화 기준 TOP 10 · 서울 국평·그랜저 환산값</p>
            </a>
            <a class="home-report-card" href={withBase("/reports/us-rich-top10-patterns/")}>
              <span class="home-report-card__badge">인터랙티브 리포트</span>
              <p class="home-report-card__title">미국 부자 TOP 10 성공 패턴 리포트</p>
              <p class="home-report-card__desc">자산·학력·업종·창업 배경 비교 읽기</p>
            </a>
          </Fragment>
        )}
      </div>
    </section>

    <!-- ⑥ 이용안내 -->
    <section class="home-section">
      <div class="home-section__head">
        <h2>이용 안내</h2>
      </div>
      <div class="home-trust">
        {trustLinks.map(link => (
          <a class="home-trust-card" href={link.href}>
            <p class="home-trust-card__title">{link.title}</p>
            <p class="home-trust-card__desc">{link.desc}</p>
          </a>
        ))}
      </div>
      <p class="home-trust__notice">
        계산 결과는 공개 기준과 입력값을 바탕으로 한 참고용 추정치입니다.
        중요한 결정 전에는 원문 공지와 공식 자료를 함께 확인해주세요.
      </p>
    </section>

  </main>

  <script is:inline>
    document.querySelectorAll('.home-filter__chip').forEach(function(btn) {
      btn.addEventListener('click', function() {
        if (btn.hasAttribute('data-cat')) {
          document.querySelectorAll('.home-filter__chip[data-cat]').forEach(function(b) {
            b.classList.remove('is-active');
          });
          btn.classList.add('is-active');
          var cat = btn.getAttribute('data-cat');
          document.querySelectorAll('.home-tool-row').forEach(function(row) {
            row.style.display = (cat === '전체' || row.getAttribute('data-category') === cat) ? '' : 'none';
          });
        }

        if (btn.hasAttribute('data-report-filter')) {
          document.querySelectorAll('.home-filter__chip[data-report-filter]').forEach(function(b) {
            b.classList.remove('is-active');
          });
          btn.classList.add('is-active');
          var reportFilter = btn.getAttribute('data-report-filter');
          document.querySelectorAll('.home-report-card').forEach(function(card) {
            var matchesCategory = reportFilter === 'all' || card.getAttribute('data-report-category') === reportFilter;
            var matchesNew = reportFilter === 'new' && card.getAttribute('data-report-is-new') === 'true';
            card.style.display = (matchesCategory || matchesNew) ? '' : 'none';
          });
        }
      });
    });
  </script>
</BaseLayout>




