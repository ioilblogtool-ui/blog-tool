---
import { tools } from "../data/tools";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${normalizedBase}${path.replace(/^\//, "")}`;
const featured = [...tools].sort((a, b) => a.order - b.order).slice(0, 4);
---

<BaseLayout title="Web Pages" description="링크 또는 iframe으로 활용할 수 있는 독립 웹페이지 모음">
  <SiteHeader />

  <main class="container page-shell">
    <section class="hero hero--home">
      <p class="hero__eyebrow">Embedded Utilities</p>
      <h1 class="hero__title">블로그 글에 바로 붙일 수 있는 도구형 웹페이지 저장소</h1>
      <p class="hero__description">
        계산기, 비교 시뮬레이터, 간단한 인터랙티브 페이지를 주제별로 계속 추가하고,
        링크 또는 iframe으로 바로 활용할 수 있도록 정리한 배포용 정적 프로젝트입니다.
      </p>
      <div class="home-actions">
        <a class="button button--primary" href={withBase("/tools/")}>도구 목록 보기</a>
      </div>
    </section>

    <section class="tool-showcase">
      {
        featured.map((tool) => (
          <a class="tool-card" href={withBase(`/tools/${tool.slug}/`)}>
            <p class="tool-card__eyebrow">{tool.eyebrow ?? "Tool"}</p>
            <h2>{tool.title}</h2>
            <p>{tool.description}</p>
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
