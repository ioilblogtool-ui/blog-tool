                  <span class="home-report-card__badge">인터랙티브 리포트</span>
                  <span class="home-report-card__link">보기 →</span>
                </div>
              </div>
            </a>
          );
        }) : (
          <Fragment>
            <a class="home-report-card" href={withBase("/reports/it-salary-top10/")} data-report-category="salary">
              <div class="home-report-card__head">
                <span class="home-report-card__cat-label">연봉</span>
                <svg class="home-report-card__chart" width="52" height="36" viewBox="0 0 52 36" fill="none" aria-hidden="true">
                  <rect x="2" y="22" width="7" height="14" rx="1" fill="rgba(255,255,255,0.22)"></rect>
                  <rect x="12" y="14" width="7" height="22" rx="1" fill="rgba(255,255,255,0.38)"></rect>
                  <rect x="22" y="6" width="7" height="30" rx="1" fill="rgba(255,255,255,0.58)"></rect>
                  <rect x="32" y="10" width="7" height="26" rx="1" fill="rgba(255,255,255,0.74)"></rect>
                  <rect x="42" y="2" width="8" height="34" rx="1" fill="rgba(255,255,255,0.92)"></rect>
                </svg>
              </div>
              <div class="home-report-card__body">
                <p class="home-report-card__title">IT 업계 신입 초봉 TOP 10</p>
                <p class="home-report-card__desc">국내 주요 IT 기업 신입 초봉 비교</p>
                <div class="home-report-card__footer">
                  <span class="home-report-card__badge">인터랙티브 리포트</span>
                  <span class="home-report-card__link">보기 →</span>
                </div>
