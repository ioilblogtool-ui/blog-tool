---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  INV800T_META,
  INV800T_MEGA_PROJECTS,
  INV800T_SUMMARY,
  INV800T_COMPANY_COMPARE,
  INV800T_CAPEX_IMPACT,
  INV800T_SECTORS,
  INV800T_CHECKLIST,
  INV800T_RISKS,
  INV800T_FAQ,
  INV800T_SEO_INTRO,
  INV800T_SEO_CRITERIA,
} from "../../data/samsungSkhynix800tInvestment2026";

const badgeClass = (badge?: string) => {
  if (badge === "공식") return "inv800t-badge--official";
  if (badge === "보도 기반") return "inv800t-badge--ref";
  return "inv800t-badge--estimate";
};

const timingBadgeClass = (badge: string) => {
  if (badge === "즉시") return "inv800t-badge--immediate";
  if (badge === "단기") return "inv800t-badge--short";
  if (badge === "중기") return "inv800t-badge--mid";
  return "inv800t-badge--long";
};

const riskClass = (severity: string) => {
  if (severity === "높음") return "inv800t-risk-card--high";
  if (severity === "중간") return "inv800t-risk-card--mid";
  return "inv800t-risk-card--low";
};

const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteUrl}/reports/samsung-skhynix-800t-investment-comparison-2026/`;

const title = "삼성전자·SK하이닉스 800조 투자 비교 2026 | 직원·주주가 봐야 할 포인트";
const description = "삼성전자와 SK하이닉스의 반도체 800조 투자 내용을 직원·투자자 관점으로 비교합니다. 성과급 영향, 수혜 업종, 반도체 ETF 접근법 포함.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": pageUrl,
  url: pageUrl,
  headline: title,
  description,
  inLanguage: "ko-KR",
  datePublished: "2026-07-02",
  dateModified: "2026-07-02",
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiteHeader />
  <main class="container page-shell inv800t-page">

    <CalculatorHero
      eyebrow="반도체 메가투자"
      title="삼성전자·SK하이닉스 800조 반도체 투자 비교 2026"
      description="3대 메가프로젝트 발표 내용을 직원·주주 관점으로 정리합니다. 성과급 영향, 삼성 vs 하이닉스 수혜 비교, 관련 업종까지 한눈에."
    />

    <InfoNotice
      title="투자 권유가 아닙니다"
      lines={[INV800T_META.notice]}
    />

    <!-- ── 섹션 1: 3대 메가프로젝트 ──────────────── -->
    <section class="content-section" aria-labelledby="mega-title">
      <p class="inv800t-eyebrow">3대 메가프로젝트</p>
      <h2 id="mega-title" class="inv800t-section-title">이재명 정부 3대 메가프로젝트란?</h2>
      <p class="inv800t-section-desc">
        {INV800T_META.announceDate} '{INV800T_META.eventName}'에서 발표된 국가 전략 투자 방향입니다.
      </p>
      <div class="inv800t-mega-grid">
        {INV800T_MEGA_PROJECTS.map((m) => (
          <article class="inv800t-mega-card">
            <span class="inv800t-mega-card__icon">{m.icon}</span>
            <p class="inv800t-mega-card__name">{m.name}</p>
            <p class="inv800t-mega-card__desc">{m.desc}</p>
            <span class="inv800t-mega-card__point">{m.point}</span>
          </article>
        ))}
      </div>
    </section>

    <!-- ── 섹션 2: 800조 투자 요약 ────────────────── -->
    <section class="content-section" aria-labelledby="summary-title">
      <p class="inv800t-eyebrow">투자 내용</p>
      <h2 id="summary-title" class="inv800t-section-title">800조 투자, 구체적으로 무엇인가?</h2>
      <p class="inv800t-section-desc">
        "800조"는 즉각 집행되는 금액이 아닙니다. 10년에 걸친 누적 CAPEX이며 실제 매출 기여는 2030년 이후입니다.
      </p>
      <div class="inv800t-summary-table-wrap">
        <table class="inv800t-summary-table">
          <tbody>
            {INV800T_SUMMARY.map((row) => (
              <tr>
                <td>{row.label}</td>
                <td>
                  {row.badge && (
                    <span class={`inv800t-badge ${badgeClass(row.badge)}`}>{row.badge}</span>
                  )}
                  {" "}{row.value}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ── 섹션 3: 삼성 vs 하이닉스 비교 ★ ─────── -->
    <section class="content-section" aria-labelledby="compare-title">
      <p class="inv800t-eyebrow">핵심 비교</p>
      <h2 id="compare-title" class="inv800t-section-title">삼성전자 vs SK하이닉스, 수혜 차이는?</h2>
      <p class="inv800t-section-desc">두 회사 모두 정책 수혜는 높지만 단기 모멘텀과 리스크 구조가 다릅니다.</p>
      <div class="inv800t-compare-wrap">
        <table class="inv800t-compare-table">
          <thead>
            <tr>
              <th>항목</th>
              <th class="inv800t-th--samsung">삼성전자</th>
              <th class="inv800t-th--hynix">SK하이닉스</th>
            </tr>
          </thead>
          <tbody>
            {INV800T_COMPANY_COMPARE.map((row) => (
              <tr>
                <td>{row.item}</td>
                <td class="inv800t-col--samsung">
                  {row.samsung}
                  {row.samsungScore !== undefined && (
                    <div class="inv800t-score-bar">
                      {[1,2,3,4,5].map((i) => (
                        <span class={`inv800t-score-dot${i <= row.samsungScore! ? " inv800t-score-dot--on-samsung" : ""}`}></span>
                      ))}
                    </div>
                  )}
                </td>
                <td class="inv800t-col--hynix">
                  {row.hynix}
                  {row.hynixScore !== undefined && (
                    <div class="inv800t-score-bar">
                      {[1,2,3,4,5].map((i) => (
                        <span class={`inv800t-score-dot${i <= row.hynixScore! ? " inv800t-score-dot--on-hynix" : ""}`}></span>
                      ))}
                    </div>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="inv800t-note">모든 수치는 공시·보도 기반 분석이며 투자 권유가 아닙니다.</p>
      <div class="inv800t-cta-group">
        <a href="/tools/semiconductor-bonus-comparison/" class="inv800t-cta-btn inv800t-cta-btn--outline">
          반도체 성과급 비교 계산기 →
        </a>
      </div>
    </section>

    <!-- ── 섹션 4: 성과급 영향 ────────────────────── -->
    <section class="content-section" aria-labelledby="capex-title">
      <p class="inv800t-eyebrow">재직자 관점</p>
      <h2 id="capex-title" class="inv800t-section-title">성과급에 어떤 영향이 있을까?</h2>
      <p class="inv800t-section-desc">CAPEX 사이클과 성과급 재원은 반대로 움직이는 경향이 있습니다.</p>
      <div class="inv800t-capex-cards">
        {INV800T_CAPEX_IMPACT.map((c) => (
          <div class={`inv800t-capex-card inv800t-capex-card--${c.key}`}>
            <span class="inv800t-capex-card__icon">{c.icon}</span>
            <p class="inv800t-capex-card__phase">{c.phase}</p>
            <p class="inv800t-capex-card__title">{c.title}</p>
            <p class="inv800t-capex-card__desc">{c.desc}</p>
          </div>
        ))}
      </div>
      <InfoNotice
        title="참고 목적 분석입니다"
        lines={["CAPEX와 성과급의 관계는 회사 정책, 영업이익 수준, 지급 방식에 따라 달라집니다. 확정 정보가 아닙니다."]}
      />
      <div class="inv800t-cta-group">
        <a href="/tools/samsung-bonus/" class="inv800t-cta-btn inv800t-cta-btn--primary">
          삼성전자 DS 성과급 계산기 →
        </a>
        <a href="/tools/sk-hynix-bonus/" class="inv800t-cta-btn inv800t-cta-btn--teal">
          SK하이닉스 성과급 계산기 →
        </a>
        <a href="/tools/samsung-electro-mechanics-bonus-calculator-2026/" class="inv800t-cta-btn inv800t-cta-btn--outline">
          삼성전기 성과급 계산기 →
        </a>
      </div>
    </section>

    <!-- ── 섹션 5: 수혜 업종 ──────────────────────── -->
    <section class="content-section" aria-labelledby="sector-title">
      <p class="inv800t-eyebrow">수혜 업종</p>
      <h2 id="sector-title" class="inv800t-section-title">반도체 투자 수혜 업종 TOP 5</h2>
      <p class="inv800t-section-desc">수혜 강도는 추정이며 개별 종목 추천이 아닙니다.</p>
      <div class="inv800t-sector-grid">
        {INV800T_SECTORS.map((s) => (
          <article class="inv800t-sector-card">
            <p class="inv800t-sector-card__sector">{s.sector}</p>
            <p class="inv800t-sector-card__strength">
              수혜 강도: <strong>{s.strengthLabel}</strong>
            </p>
            <div class="inv800t-score-bar" style="margin-bottom: 0.5rem;">
              {[1,2,3,4,5].map((i) => (
                <span class={`inv800t-score-dot${i <= s.strength ? " inv800t-score-dot--on-samsung" : ""}`}></span>
              ))}
            </div>
            <p class="inv800t-sector-card__reason">{s.reason}</p>
            <p class="inv800t-sector-card__timing">
              <span class={`inv800t-badge ${timingBadgeClass(s.badge)}`}>{s.badge}</span>
              {" "}{s.timing}
            </p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── 섹션 6: ETF CTA ────────────────────────── -->
    <section class="content-section" aria-labelledby="etf-title">
      <p class="inv800t-eyebrow">ETF 접근</p>
      <h2 id="etf-title" class="inv800t-section-title">ETF로 분산 접근하면?</h2>
      <div class="inv800t-etf-box">
        <p class="inv800t-etf-box__desc">
          반도체 개별 종목은 사이클 리스크가 크고 종목 선택 난도가 높습니다.
          SOXX·SMH(미국) 또는 TIGER·RISE·ACE(국내) 반도체 ETF로
          분산 접근하면 특정 종목 리스크를 줄일 수 있습니다.
          구성 종목, 수익률, 총보수 비교는 아래 리포트에서 확인하세요.
        </p>
        <div class="inv800t-cta-group">
          <a href="/reports/semiconductor-etf-2026/" class="inv800t-cta-btn inv800t-cta-btn--primary">
            반도체 ETF 구성·수익률 비교 리포트 →
          </a>
          <a href="/reports/semiconductor-stock-2026/" class="inv800t-cta-btn inv800t-cta-btn--outline">
            미·한·대만 반도체 주식 수익률 랭킹 →
          </a>
        </div>
      </div>
    </section>

    <!-- ── 섹션 7: 투자자 체크리스트 ──────────────── -->
    <section class="content-section" aria-labelledby="checklist-title">
      <p class="inv800t-eyebrow">투자자 체크리스트</p>
      <h2 id="checklist-title" class="inv800t-section-title">투자 전 확인해야 할 5가지</h2>
      <ul class="inv800t-checklist">
        {INV800T_CHECKLIST.map((item) => (
          <li class="inv800t-checklist__item">
            <span class="inv800t-checklist__icon">✓</span>
            {item}
          </li>
        ))}
      </ul>
    </section>

    <!-- ── 섹션 8: 리스크 ─────────────────────────── -->
    <section class="content-section" aria-labelledby="risk-title">
      <p class="inv800t-eyebrow">리스크</p>
      <h2 id="risk-title" class="inv800t-section-title">주의해야 할 리스크</h2>
      <div class="inv800t-risk-list">
        {INV800T_RISKS.map((r) => (
          <div class={`inv800t-risk-card ${riskClass(r.severity)}`}>
            <div>
              <p class="inv800t-risk-card__risk">{r.risk}</p>
              <p class="inv800t-risk-card__content">{r.content}</p>
            </div>
            <span class="inv800t-risk-card__severity">{r.severity}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ── FAQ ───────────────────────────────────── -->
    <section class="content-section" aria-labelledby="faq-title">
      <p class="inv800t-eyebrow">FAQ</p>
      <h2 id="faq-title" class="inv800t-section-title">자주 묻는 질문</h2>
      <div class="inv800t-faq">
        {INV800T_FAQ.map((f) => (
          <details class="inv800t-faq__item">
            <summary class="inv800t-faq__q">{f.q}</summary>
            <p class="inv800t-faq__a">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="삼성전자·SK하이닉스 800조 투자 핵심 정리"
      intro={[INV800T_SEO_INTRO]}
      criteria={INV800T_SEO_CRITERIA}
      faq={INV800T_FAQ.map((f) => ({ question: f.q, answer: f.a }))}
      related={[
        { href: "/tools/semiconductor-bonus-comparison/", label: "반도체 성과급 비교 계산기" },
        { href: "/tools/samsung-bonus/", label: "삼성전자 DS 성과급 계산기" },
        { href: "/tools/sk-hynix-bonus/", label: "SK하이닉스 성과급 계산기" },
        { href: "/tools/samsung-electro-mechanics-bonus-calculator-2026/", label: "삼성전기 성과급 계산기 2026" },
        { href: "/reports/semiconductor-etf-2026/", label: "반도체 ETF 비교 리포트" },
        { href: "/reports/samsung-ds-bonus-calculation-guide/", label: "삼성 DS 성과급 계산 가이드" },
        { href: "/reports/sk-hynix-bonus-2027/", label: "SK하이닉스 2027 성과급 전망" },
        { href: "/reports/large-company-salary-growth-by-years-2026/", label: "대기업 연차별 연봉 성장 비교" },
      ]}
    />

  </main>
</BaseLayout>
