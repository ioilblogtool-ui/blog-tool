---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  SLC_CREDIT_RECOMMENDATIONS,
  SLC_FAQ,
  SLC_HIGH_COST_DEBT_SCENARIOS,
  SLC_JOB_RECOMMENDATIONS,
  SLC_LOAN_TYPES,
  SLC_META,
  SLC_PLAN_CHECKLIST,
  SLC_POLICY_CHECKS,
  SLC_PREFERENTIAL_RATE_CONDITIONS,
  SLC_REFINANCE_SCENARIOS,
  SLC_RELATED_LINKS,
  SLC_REJECTION_REASONS,
  SLC_REPAYMENT_ROWS,
  SLC_SALARY_LIMIT_SCENARIOS,
  SLC_SOURCE_LINKS,
  SLC_SUMMARY_CARDS,
  SLC_TRUST_PANELS,
  estimateSimpleInterest,
  formatWon,
  type LoanCategory,
  type SourceLabel,
} from "../../data/salariedLoanComparison2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const loanGroup = (id: LoanCategory) => {
  if (id === "credit" || id === "minus") return "credit";
  if (id === "mortgage" || id === "jeonse") return "mortgage";
  return "policy";
};

const sourceClass = (source: SourceLabel) => {
  if (source === "공식") return "official";
  if (source === "추정") return "estimate";
  if (source === "참고") return "reference";
  return "check";
};

const faqItems = SLC_FAQ.map((item) => ({ question: item.question, answer: item.answer }));
const highCostRows = SLC_HIGH_COST_DEBT_SCENARIOS.map((item) => ({
  ...item,
  cardLoanInterest: estimateSimpleInterest(item.amount, item.cardLoanRate, item.months),
  revolvingInterest: estimateSimpleInterest(item.amount, item.revolvingRate, item.months),
  creditLoanInterest: estimateSimpleInterest(item.amount, item.creditLoanRate, item.months),
}));

const chartSeed = {
  loans: SLC_LOAN_TYPES,
  salaryScenarios: SLC_SALARY_LIMIT_SCENARIOS,
  highCostRows,
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": SLC_META.title,
      "description": SLC_META.description,
      "inLanguage": "ko-KR",
      "dateModified": "2026-05-19",
      "mainEntityOfPage": `https://bigyocalc.com/reports/${SLC_META.slug}/`,
      "author": { "@type": "Organization", "name": "비교계산소" },
      "publisher": { "@type": "Organization", "name": "비교계산소" },
    },
    {
      "@type": "FAQPage",
      "mainEntity": SLC_FAQ.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": { "@type": "Answer", "text": item.answer },
      })),
    },
  ],
};
---

<BaseLayout title={SLC_META.title} description={SLC_META.description} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page slc-page" data-report="2026-salaried-loan-comparison">
    <CalculatorHero
      eyebrow="금융/대출 리포트"
      title={SLC_META.h1}
      description="신용대출·마이너스통장·주담대·전세대출·사잇돌·햇살론을 금리·한도·조건·총비용 기준으로 비교합니다."
      badges={["금융/대출", "2026", "금리 확인 필요", "추정 포함"]}
    />

    <InfoNotice
      title="대출 비교 기준 안내"
      lines={[
        "이 페이지는 금융상품 가입 권유가 아니라 비교 정보 제공용 콘텐츠입니다.",
        "금리와 한도는 기준일, 금융회사 심사, 신용점수, 기존 부채, 재직기간, 소득 증빙에 따라 달라질 수 있습니다.",
        "연봉별 한도와 카드론·리볼빙 총비용은 구조 이해를 위한 추정 시뮬레이션입니다.",
        "정책금융과 DSR 기준은 신청 전 공식 기관과 금융회사에서 최종 확인해야 합니다.",
      ]}
    />

    <section class="content-section slc-trust-section">
      <div class="slc-trust-grid">
        {SLC_TRUST_PANELS.map((item) => (
          <article class="slc-trust-card">
            <span>{item.label}</span>
            <strong>{item.title}</strong>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section slc-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 요약</p>
        <h2>직장인 대출은 받을 수 있나보다 어떤 순서로 비교할지가 중요합니다</h2>
        <p>급전, 주거, 대환, 정책금융은 먼저 봐야 할 기준이 다릅니다. 금리만 보지 말고 총비용과 DSR을 함께 확인하세요.</p>
      </div>
      <div class="slc-summary-grid">
        {SLC_SUMMARY_CARDS.map((item) => (
          <article class={`slc-summary-card slc-summary-card--${item.tone}`}>
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <p>{item.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section slc-section" id="market">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">2026 대출 시장</p>
        <h2>금리 인하 기대보다 DSR과 기존 부채가 한도를 더 크게 흔듭니다</h2>
        <p>신용대출·주담대·전세대출은 금리 변동이 빠르고 은행별 한도 관리도 달라집니다. 이 리포트의 금리 범위는 차트 이해를 위한 참고값이며 실시간 금리 비교가 필요합니다.</p>
      </div>
      <div class="slc-market-grid">
        <article>
          <strong>금리</strong>
          <p>기준금리, COFIX, 은행채 금리 흐름에 따라 신규 대출과 대환 조건이 달라집니다.</p>
        </article>
        <article>
          <strong>DSR</strong>
          <p>은행권 DSR 40% 구조에서는 기존 대출 월 상환액이 새 한도를 직접 줄일 수 있습니다.</p>
        </article>
        <article>
          <strong>대환</strong>
          <p>금리차가 보여도 중도상환수수료, 인지세, 보증료를 빼야 실제 이익이 보입니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section slc-section" id="loan-types">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">대출 유형 비교</p>
        <h2>직장인이 가장 많이 보는 대출 6종</h2>
        <p>금리·한도·자격·상환방식·DSR 영향을 한 번에 비교합니다.</p>
      </div>

      <div class="slc-filter-row" role="tablist" aria-label="대출 유형">
        <button class="slc-filter-btn is-active" type="button" data-slc-filter="all" aria-selected="true">전체</button>
        <button class="slc-filter-btn" type="button" data-slc-filter="credit" aria-selected="false">신용·마통</button>
        <button class="slc-filter-btn" type="button" data-slc-filter="mortgage" aria-selected="false">주거대출</button>
        <button class="slc-filter-btn" type="button" data-slc-filter="policy" aria-selected="false">정책금융</button>
      </div>

      <div class="slc-chart-wrap">
        <canvas id="slcRateRangeChart" aria-label="대출 유형별 금리 범위 차트"></canvas>
      </div>

      <div class="slc-loan-grid">
        {SLC_LOAN_TYPES.map((item) => (
          <article class="slc-loan-card" data-slc-group={loanGroup(item.id)}>
            <div class="slc-loan-card__top">
              <span class={`slc-source-badge slc-source-badge--${sourceClass(item.sourceLabel)}`}>{item.sourceLabel}</span>
              <span class="slc-dsr-badge">DSR {item.dsrImpact}</span>
            </div>
            <h3>{item.name}</h3>
            <p>{item.purpose}</p>
            <dl>
              <div><dt>금리</dt><dd>{item.rateRangeLabel}</dd></div>
              <div><dt>한도</dt><dd>{item.limitLabel}</dd></div>
              <div><dt>자격</dt><dd>{item.eligibility}</dd></div>
              <div><dt>상환</dt><dd>{item.repayment}</dd></div>
            </dl>
            <p class="slc-card-caution">{item.caution}</p>
            {item.sourceUrl && <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer">공식/비교 정보 확인</a>}
          </article>
        ))}
      </div>
    </section>

    <section class="content-section slc-section" id="salary-limits">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">한도 시뮬레이션</p>
        <h2>연봉 3천·5천·8천만 원이면 어느 정도까지 볼 수 있나</h2>
        <p>아래 금액은 실제 승인 한도가 아니라 구조 이해를 위한 추정입니다.</p>
      </div>
      <div class="slc-chart-wrap slc-chart-wrap--short">
        <canvas id="slcSalaryLimitChart" aria-label="연봉별 신용대출 한도 추정 차트"></canvas>
      </div>
      <div class="slc-table-wrap">
        <table class="slc-wide-table">
          <thead>
            <tr>
              <th>연봉</th>
              <th>신용대출 보수적</th>
              <th>신용대출 공격적</th>
              <th>주담대 DSR 40%</th>
              <th>코멘트</th>
            </tr>
          </thead>
          <tbody>
            {SLC_SALARY_LIMIT_SCENARIOS.map((row) => (
              <tr>
                <td><strong>{row.salaryLabel}</strong></td>
                <td>{formatWon(row.conservativeCreditLimit)}</td>
                <td class="is-highlight">{formatWon(row.aggressiveCreditLimit)}</td>
                <td>{row.mortgageLimitLabel}</td>
                <td>{row.comment}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="slc-data-note"><strong>추정</strong> 연소득 배수 시뮬레이션이며 실제 승인 한도는 금융회사 심사로 확정됩니다.</p>
    </section>

    <section class="content-section slc-section" id="credit-score">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">신용점수별 추천</p>
        <h2>점수 구간에 따라 먼저 볼 상품이 달라집니다</h2>
      </div>
      <div class="slc-credit-grid">
        {SLC_CREDIT_RECOMMENDATIONS.map((row) => (
          <article class={`slc-credit-card slc-credit-card--${row.tier.replace("+", "plus")}`}>
            <span>{row.scoreLabel}</span>
            <h3>{row.firstChoice}</h3>
            <p>{row.secondChoice}</p>
            <small>{row.caution}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section slc-section" id="job-type">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">직장 유형별 추천</p>
        <h2>내 직장 유형이면 무엇부터 비교해야 할까</h2>
      </div>
      <div class="slc-job-filter-row">
        {SLC_JOB_RECOMMENDATIONS.map((item, index) => (
          <button class={`slc-filter-btn${index === 0 ? " is-active" : ""}`} type="button" data-slc-job-filter={item.id}>
            {item.label}
          </button>
        ))}
      </div>
      <div class="slc-job-grid">
        {SLC_JOB_RECOMMENDATIONS.map((item, index) => (
          <article class="slc-job-card" data-slc-job-card={item.id} hidden={index !== 0}>
            <h3>{item.label}</h3>
            <ul>
              {item.firstCheck.map((check) => <li>{check}</li>)}
            </ul>
            <p>{item.reason}</p>
            <small>{item.caution}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section slc-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">상환 방식</p>
        <h2>월 부담과 총이자는 상환 방식에서 갈립니다</h2>
      </div>
      <div class="slc-table-wrap">
        <table class="slc-wide-table">
          <thead>
            <tr>
              <th>방식</th>
              <th>월 부담</th>
              <th>총이자</th>
              <th>적합한 경우</th>
            </tr>
          </thead>
          <tbody>
            {SLC_REPAYMENT_ROWS.map((row) => (
              <tr>
                <td><strong>{row.type}</strong></td>
                <td>{row.monthlyBurden}</td>
                <td>{row.totalInterest}</td>
                <td>{row.fit}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="slc-calculator-cta">
      <p class="slc-cta-eyebrow">갈아타기 판단</p>
      <h2>금리차만 보지 말고 비용 회수 기간을 계산하세요</h2>
      <p>중도상환수수료, 보증료, 인지세를 합산해 몇 개월 만에 이자 절감액으로 회수되는지 확인해야 합니다.</p>
      <div class="slc-refinance-grid">
        {SLC_REFINANCE_SCENARIOS.map((row) => (
          <article>
            <span>금리차 {(row.rateGap * 100).toFixed(1)}%p</span>
            <strong>{row.breakEvenMonths}개월</strong>
            <p>1억 원 기준 연 {formatWon(row.yearlySaving)} 절감, 비용 {formatWon(row.estimatedCost)} 가정</p>
          </article>
        ))}
      </div>
      <div class="slc-cta-actions">
        <a href={withBase("/tools/loan-refinancing-calculator/")} class="slc-cta-button">대출 갈아타기 계산하기</a>
        <a href={withBase("/tools/mortgage-prepayment-penalty/")} class="slc-cta-button slc-cta-button--secondary">중도상환수수료 계산하기</a>
      </div>
    </section>

    <section class="content-section slc-section" id="policy-loans">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">정책금융 체크</p>
        <h2>햇살론·사잇돌은 공식 자격과 보증심사가 먼저입니다</h2>
      </div>
      <div class="slc-checklist-grid">
        {SLC_POLICY_CHECKS.map((item) => (
          <article class="slc-checklist-card"><p>{item}</p></article>
        ))}
      </div>
    </section>

    <section class="content-section slc-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">거절 사유 TOP5</p>
        <h2>거절 사유는 대부분 DSR·재직·신용·증빙에서 나옵니다</h2>
      </div>
      <div class="slc-rank-list">
        {SLC_REJECTION_REASONS.map((item) => (
          <article>
            <span>{item.rank}</span>
            <strong>{item.title}</strong>
            <p>{item.solution}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section slc-section" id="high-cost-debt">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">고금리 채무 비교</p>
        <h2>카드론·리볼빙은 월 납입액보다 총비용을 봐야 합니다</h2>
      </div>
      <div class="slc-warning-box">
        카드론·리볼빙은 사용 편의성이 높지만 금리와 신용점수 부담이 커질 수 있습니다. 기존 고금리 채무가 있다면 신용대출, 정책금융, 대환대출 순서로 총비용을 비교하세요.
      </div>
      <div class="slc-chart-wrap slc-chart-wrap--short">
        <canvas id="slcDebtCostChart" aria-label="카드론 리볼빙 신용대출 총이자 비교 차트"></canvas>
      </div>
      <div class="slc-table-wrap">
        <table class="slc-wide-table">
          <thead>
            <tr>
              <th>금액/기간</th>
              <th>카드론 이자 추정</th>
              <th>리볼빙 이자 추정</th>
              <th>신용대출 이자 추정</th>
            </tr>
          </thead>
          <tbody>
            {highCostRows.map((row) => (
              <tr>
                <td><strong>{formatWon(row.amount)} / {row.months}개월</strong></td>
                <td>{formatWon(row.cardLoanInterest)}</td>
                <td>{formatWon(row.revolvingInterest)}</td>
                <td class="is-highlight">{formatWon(row.creditLoanInterest)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section slc-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">우대금리</p>
        <h2>우대금리는 조건을 못 채우면 사라질 수 있습니다</h2>
      </div>
      <div class="slc-condition-grid">
        {SLC_PREFERENTIAL_RATE_CONDITIONS.map((item) => (
          <article>
            <strong>{item.condition}</strong>
            <p>{item.desc}</p>
            <small>{item.risk}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section slc-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">2026 DSR 기준</p>
        <h2>한도가 안 나오는 이유는 금리보다 DSR일 수 있습니다</h2>
        <p>DSR은 연소득 대비 모든 대출의 연간 원리금 상환액 비율입니다. 은행권 40%, 제2금융권 50% 구조가 기본 축이며, 스트레스 DSR은 향후 금리 상승 가능성을 반영해 한도를 더 보수적으로 계산합니다.</p>
      </div>
      <div class="slc-dsr-board">
        <strong>확인 순서</strong>
        <ol>
          <li>기존 대출의 월 원리금 상환액을 합산합니다.</li>
          <li>새 대출의 예상 원리금 상환액을 더합니다.</li>
          <li>연소득 대비 비율이 규제 기준 안에 들어오는지 봅니다.</li>
          <li>마이너스통장 약정 한도와 카드론·리볼빙 영향도 함께 확인합니다.</li>
        </ol>
      </div>
    </section>

    <section class="content-section slc-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">신청 전 체크리스트</p>
        <h2>대출 계획은 금액보다 상환 가능성부터 봅니다</h2>
      </div>
      <ol class="slc-plan-list">
        {SLC_PLAN_CHECKLIST.map((item) => <li>{item}</li>)}
      </ol>
    </section>

    <section class="content-section slc-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">다음 단계</p>
        <h2>공식 정보와 계산기를 함께 확인하세요</h2>
      </div>
