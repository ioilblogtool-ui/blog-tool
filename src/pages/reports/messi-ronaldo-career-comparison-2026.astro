---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  MRCC_META,
  MRCC_PLAYERS,
  MRCC_RECORDS,
  MRCC_RECENT_FORM,
  MRCC_FAQ,
  MRCC_RELATED_LINKS,
} from "../../data/messiRonaldoCareerComparison2026";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${MRCC_META.slug}/`;
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const messi = MRCC_PLAYERS.find((p) => p.id === "messi")!;
const ronaldo = MRCC_PLAYERS.find((p) => p.id === "ronaldo")!;

const categories: { id: string; label: string }[] = [
  { id: "scoring", label: "득점·도움" },
  { id: "awards", label: "개인 수상" },
  { id: "trophies", label: "팀 트로피" },
  { id: "nationalTeam", label: "국가대표" },
  { id: "income", label: "연봉·수입" },
];

const kpiIds = ["combined-goals", "ballon-dor", "worldcup", "total-income"];
const kpiRecords = kpiIds
  .map((id) => MRCC_RECORDS.find((r) => r.id === id))
  .filter((r): r is (typeof MRCC_RECORDS)[number] => Boolean(r));

const messiRecent = MRCC_RECENT_FORM.find((f) => f.playerId === "messi");
const ronaldoRecent = MRCC_RECENT_FORM.find((f) => f.playerId === "ronaldo");

const leaderLabel = (leaderId?: string) => {
  if (leaderId === "messi") return "메시 우위";
  if (leaderId === "ronaldo") return "호날두 우위";
  if (leaderId === "tie") return "비슷함";
  return null;
};

const reportData = {
  records: MRCC_RECORDS,
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: MRCC_META.title,
    description: MRCC_META.seoDescription,
    dateModified: MRCC_META.updatedAt,
    mainEntityOfPage: reportUrl,
    author: { "@type": "Organization", name: "비교계산소" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: MRCC_FAQ.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
      { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
      { "@type": "ListItem", position: 3, name: MRCC_META.title, item: reportUrl },
    ],
  },
];
---

<BaseLayout title={MRCC_META.seoTitle} description={MRCC_META.seoDescription} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page mrcc-page" data-report={MRCC_META.slug}>
    <CalculatorHero
      eyebrow="스포츠 레전드 비교 리포트"
      title="메시 vs 호날두, 숫자로 보는 통산 기록 비교"
      description="통산 골, 발롱도르, 월드컵 성적, 현재 연봉까지 항목별로 비교합니다. 최근 경기 기록도 함께 업데이트합니다."
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        `이 리포트는 누가 'GOAT(역대 최고)'인지 결론을 내리는 자료가 아니라, 통산 기록과 연봉을 항목별 숫자로 정리한 비교표입니다.`,
        `통산 골·도움 등 누적 기록은 ${MRCC_META.dataAsOf} 시점 종합 추정치이며, 집계 기준(공식전/친선경기 포함 여부, 클럽+국가대표 합산 방식)에 따라 매체별로 다를 수 있습니다.`,
        MRCC_META.dataNote,
      ]}
    />

    <section class="content-section mrcc-recent-section" aria-labelledby="mrcc-recent-title">
      <div class="mrcc-section-heading">
        <p>최근 업데이트</p>
        <h2 id="mrcc-recent-title">최근 경기 기록</h2>
        <span>두 선수 모두 현역으로 뛰고 있어, 주요 경기 결과가 나올 때마다 이 영역을 갱신합니다.</span>
      </div>
      <div class="mrcc-recent-grid">
        {[messiRecent, ronaldoRecent].map((entry) => entry && (
          <article class:list={["mrcc-recent-card", `mrcc-recent-card--${entry.playerId}`]}>
            <div class="mrcc-recent-card__head">
              <span>{entry.playerId === "messi" ? "🇦🇷 메시" : "🇵🇹 호날두"}</span>
              <em>{entry.date}</em>
            </div>
            <strong>{entry.result}</strong>
            <p>{entry.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section mrcc-profile-section" aria-labelledby="mrcc-profile-title">
      <div class="mrcc-section-heading">
        <p>선수 프로필</p>
        <h2 id="mrcc-profile-title">메시와 호날두, 지금 어디서 뛰고 있을까</h2>
      </div>
      <div class="mrcc-profile-grid">
        {[messi, ronaldo].map((player) => (
          <article class:list={["mrcc-profile-card", `mrcc-profile-card--${player.id}`]}>
            <div class="mrcc-profile-card__head">
              <span>{player.flag}</span>
              <div>
                <strong>{player.nameKo}</strong>
                <small>{player.nameEn}</small>
              </div>
            </div>
            <dl class="mrcc-profile-card__meta">
              <div>
                <dt>생년월일</dt>
                <dd>{player.birthDate}</dd>
              </div>
              <div>
                <dt>현재 소속</dt>
                <dd>{player.currentClub} ({player.currentLeague})</dd>
              </div>
              <div>
                <dt>포지션</dt>
                <dd>{player.position}</dd>
              </div>
            </dl>
            <p class="mrcc-profile-card__summary">{player.oneLineSummary}</p>
            <p class="mrcc-profile-card__clubs">주요 소속 클럽: {player.careerClubs.join(" → ")}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section mrcc-kpi-section" aria-labelledby="mrcc-kpi-title">
      <div class="mrcc-section-heading">
        <p>핵심 비교 한눈에</p>
        <h2 id="mrcc-kpi-title">검색 수요가 가장 큰 4가지 지표</h2>
      </div>
      <div class="mrcc-kpi-grid">
        {kpiRecords.map((record) => (
          <article class="mrcc-kpi-card">
            <span>{record.labelKo}</span>
            <div class="mrcc-kpi-card__row">
              <div>
                <em>메시</em>
                <strong>{record.messiValue}</strong>
              </div>
              <div>
                <em>호날두</em>
                <strong>{record.ronaldoValue}</strong>
              </div>
            </div>
            {leaderLabel(record.leaderId) && (
              <small class:list={["mrcc-leader-tag", record.leaderId && `mrcc-leader-tag--${record.leaderId}`]}>
                {leaderLabel(record.leaderId)}
              </small>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="content-section mrcc-table-section" aria-labelledby="mrcc-table-title">
      <div class="mrcc-section-heading">
        <p>항목별 비교표</p>
        <h2 id="mrcc-table-title">카테고리를 선택해 자세히 비교해보세요</h2>
        <span>모든 항목이 한쪽의 절대 우위를 의미하지는 않습니다. 집계 기준이 다른 항목은 우위 표시 없이 참고용으로만 제공합니다.</span>
      </div>

      <div class="mrcc-tab-list" role="tablist" aria-label="비교 카테고리 선택">
        {categories.map((cat, index) => (
          <button
            type="button"
            class:list={["mrcc-tab-btn", index === 0 && "is-active"]}
            role="tab"
            data-category-tab={cat.id}
          >
            {cat.label}
          </button>
        ))}
      </div>

      {categories.map((cat, index) => (
        <div class:list={["mrcc-table-wrap", index === 0 && "is-active"]} data-category-panel={cat.id}>
          <table class="mrcc-table">
            <caption>메시 vs 호날두 — {cat.label} 비교</caption>
            <thead>
              <tr>
                <th>항목</th>
                <th>메시</th>
                <th>호날두</th>
                <th>비교</th>
              </tr>
            </thead>
            <tbody>
              {MRCC_RECORDS.filter((r) => r.category === cat.id).map((record) => (
                <tr>
                  <td>
                    <strong>{record.labelKo}</strong>
                    {record.note && <small>{record.note}</small>}
                  </td>
                  <td>{record.messiValue}</td>
                  <td>{record.ronaldoValue}</td>
                  <td>
                    <span class:list={["mrcc-badge", `mrcc-badge--${record.sourceBadge.replace(/\s/g, "-")}`]}>
                      {record.sourceBadge}
                    </span>
                    {leaderLabel(record.leaderId) && (
                      <em class:list={["mrcc-leader-tag", record.leaderId && `mrcc-leader-tag--${record.leaderId}`]}>
                        {leaderLabel(record.leaderId)}
                      </em>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </section>

    <section class="content-section mrcc-guide-section" aria-labelledby="mrcc-guide-title">
      <div class="mrcc-section-heading">
        <p>이 리포트를 읽는 법</p>
        <h2 id="mrcc-guide-title">왜 '결론'을 내리지 않을까요</h2>
      </div>
      <div class="mrcc-guide-box">
        <p>
          이 리포트는 항목별 숫자를 비교한 자료입니다. 득점력, 수상 경력, 국가대표 성적, 수입 구조가 서로 다른 영역이라
          전체를 단순 합산해 한 명이 '더 위대하다'고 결론 내리기는 어렵습니다. 메시는 월드컵 우승과 발롱도르 최다 수상,
          통산 도움 부문에서 강점을 보이고, 호날두는 통산 골 양과 챔피언스리그 우승 횟수, A매치 출전·득점에서 강점을 보입니다.
          각자 강한 영역이 다르다는 점을 참고해주세요.
        </p>
      </div>
    </section>

    <section class="content-section mrcc-related-section" aria-labelledby="mrcc-related-title">
      <div class="mrcc-section-heading">
        <p>같이 보기</p>
        <h2 id="mrcc-related-title">스포츠 연봉 리포트 더 보기</h2>
      </div>
      <div class="mrcc-related-grid">
        {MRCC_RELATED_LINKS.map((link) => (
          <a href={withBase(link.href)}>{link.label}</a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="메시 vs 호날두 비교를 보는 방법"
      intro={[
        "메시의 최근 해트트릭 등 활약이 화제가 되면서 '메시 vs 호날두 GOAT 논쟁'이 다시 떠오르고 있습니다. 두 선수는 2000년대 후반부터 가장 오랜 기간 동시에 최상위권 기록을 유지해온 사례라, 비교 검색 수요가 항상 꾸준히 발생합니다.",
        "이 리포트는 '누가 더 위대한가'를 결론 내리는 콘텐츠가 아니라, 통산 골, 발롱도르, 월드컵 성적, 연봉을 항목별로 비교하는 자료입니다. 항목마다 우위가 다르게 나타나기 때문에, 전체를 합산해 한쪽이 이겼다고 보기보다는 항목별 숫자를 그대로 읽는 것이 더 정확합니다.",
        "메시는 발롱도르 최다 수상(8회)과 2022 카타르 월드컵 우승, 통산 도움 부문에서 강점을 보이고, 호날두는 통산 골 양과 챔피언스리그 우승 횟수(5회), A매치 출전·득점에서 강점을 보입니다. 두 선수가 서로 다른 영역에서 강한 만큼, 단순 비교보다는 항목별 맥락을 함께 보는 것이 중요합니다.",
        "통산 기록은 집계 시점과 매체별 기준(공식전 only, 친선경기 포함 여부 등)에 따라 달라질 수 있고, 연봉과 수입은 공식 계약 공개가 아닌 보도 기준 추정입니다. 두 선수 모두 현역으로 활동 중이라 수치는 발행 이후에도 계속 갱신될 예정입니다.",
      ]}
      inputPoints={[
        "메시와 호날두의 통산 골, 발롱도르, 월드컵 성적을 항목별로 한눈에 비교할 수 있습니다.",
        "카테고리 탭을 선택해 득점·수상·트로피·국가대표·연봉 항목을 자세히 볼 수 있습니다.",
        "최근 해트트릭 등 최신 경기 기록을 별도 영역에서 확인할 수 있습니다.",
      ]}
      criteria={[
        "이 리포트는 누가 더 위대한지 결론을 내리는 자료가 아닙니다.",
        "통산 골·도움 등 누적 기록은 기준 시점과 집계 방식에 따라 차이가 있을 수 있습니다.",
        "연봉과 수입은 공식 계약 공개가 아닌 보도 기준 추정입니다.",
        "두 선수 모두 현역이라 수치가 계속 갱신될 수 있습니다.",
      ]}
      faq={MRCC_FAQ}
      related={MRCC_RELATED_LINKS}
    />

    <script type="application/json" id="mrcc-data" set:html={JSON.stringify(reportData)} />
    <script src={withBase("scripts/messi-ronaldo-career-comparison-2026.js")} defer></script>
  </main>
</BaseLayout>
