---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  BFC_FAQ,
  BFC_META,
  BFC_RELATED_LINKS,
  BRANDS,
  CUMULATIVE_COST_ROWS,
  MONTHLY_CONSUMPTION,
  PURCHASE_CHANNELS,
  SUBSCRIPTION_BENEFITS,
} from "../../data/babyFormulaBrandCostComparison2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const won = (n: number) => n.toLocaleString("ko-KR") + "원";
const manWon = (n: number) => {
  const m = Math.floor(n / 10000);
  const r = n % 10000;
  return m > 0 ? (r > 0 ? `${m}만 ${r.toLocaleString()}원` : `${m}만 원`) : won(n);
};

// 국내 브랜드 5개, 해외 브랜드 4개
const domesticBrands = BRANDS.filter((b) => b.origin === "domestic");
const importedBrands = BRANDS.filter((b) => b.origin === "imported");

// 최저·최고 누적 비용
const minCost = Math.min(...CUMULATIVE_COST_ROWS.map((r) => r.totalCost));
const maxCost = Math.max(...CUMULATIVE_COST_ROWS.map((r) => r.totalCost));
const costDiff = maxCost - minCost;
const cheapestRow = CUMULATIVE_COST_ROWS.find((r) => r.totalCost === minCost) ?? CUMULATIVE_COST_ROWS[0];
const priciestRow = CUMULATIVE_COST_ROWS.find((r) => r.totalCost === maxCost) ?? CUMULATIVE_COST_ROWS[CUMULATIVE_COST_ROWS.length - 1];
const domesticCostRows = CUMULATIVE_COST_ROWS.filter((row) => !row.brand.includes("직구"));
const importedCostRows = CUMULATIVE_COST_ROWS.filter((row) => row.brand.includes("직구"));
const averageDomesticCost = Math.round(domesticCostRows.reduce((sum, row) => sum + row.totalCost, 0) / domesticCostRows.length);
const averageImportedCost = Math.round(importedCostRows.reduce((sum, row) => sum + row.totalCost, 0) / importedCostRows.length);

// JSON-LD
const faqSchema = BFC_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: { "@type": "Answer", text: item.answer },
}));

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: BFC_META.seoTitle,
      description: BFC_META.description,
      inLanguage: "ko-KR",
      dateModified: BFC_META.updatedAt,
      mainEntityOfPage: `https://bigyocalc.com/reports/${BFC_META.slug}/`,
      publisher: { "@type": "Organization", name: "비교계산소", url: "https://bigyocalc.com" },
    },
    { "@type": "FAQPage", mainEntity: faqSchema },
  ],
};

// 차트 데이터 (인라인 스크립트용)
const lineChartData = {
  labels: MONTHLY_CONSUMPTION.map((r) => `${r.age}개월`),
  // 대표 3개 브랜드: 아이엠마더(저가), 베베쿡 유기농(중가), 임페리얼드림(고가)
  datasets: [
    {
      label: "아이엠마더 (일반)",
      pricePerHundredG: 3250,
      borderColor: "#0F6E56",
    },
    {
      label: "베베쿡 유기농",
      pricePerHundredG: 4500,
      borderColor: "#B45309",
    },
    {
      label: "임페리얼드림 (프리미엄)",
      pricePerHundredG: 6250,
      borderColor: "#B91C1C",
    },
  ],
};

const barChartData = {
  labels: CUMULATIVE_COST_ROWS.map((r) => r.brand),
  data: CUMULATIVE_COST_ROWS.map((r) => r.totalCost),
  colors: CUMULATIVE_COST_ROWS.map((r) => (r.isLowest ? "#0F6E56" : "#93C5BE")),
};
---

<BaseLayout
  title={BFC_META.seoTitle}
  description={BFC_META.description}
  ogImage="/og/og-home.png"
  jsonLd={jsonLd}
>
  <SiteHeader />

  <main class="container page-shell report-page bfc-page">
    <CalculatorHero
      eyebrow="분유 브랜드 비교 리포트"
      title="2026 분유 브랜드별 실비용 완전 비교"
      description="아이엠마더·앱솔루트·압타밀·시밀락 등 9개 브랜드를 단가·월 비용·12개월 누적 기준으로 비교합니다."
      badges={["분유", "브랜드 비교", "12개월 비용", "추정"]}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        BFC_META.dataNote,
        "해외 직구 가격은 배송비·관세 포함 추정값이며 환율·시기에 따라 크게 달라질 수 있습니다.",
        "어떤 분유가 '더 좋다'는 절대적인 기준은 없습니다. 아기의 소화 반응과 가족의 예산을 함께 고려하세요.",
      ]}
    />
    <!-- ① 핵심 요약 카드 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">한눈에 보는 결론</p>
        <h2>분유는 브랜드명보다 100g 단가와 구매 채널이 비용을 가릅니다</h2>
        <p>아기가 잘 먹고 소화하는 분유를 우선하되, 같은 선택지 안에서는 단가·정기배송·직구 실비용을 같이 봐야 합니다.</p>
      </div>
      <div class="bfc-summary-grid">
        <div class="bfc-summary-card bfc-summary-card--accent">
          <span class="bfc-summary-label">가장 저렴한 브랜드</span>
          <span class="bfc-summary-value">{cheapestRow.brand}</span>
          <span class="bfc-summary-note">12개월 누적 약 {manWon(minCost)} (쿠팡 기준, 추정)</span>
        </div>
        <div class="bfc-summary-card">
          <span class="bfc-summary-label">브랜드 간 최대 차이</span>
          <span class="bfc-summary-value">약 {manWon(costDiff)}</span>
          <span class="bfc-summary-note">어떤 분유를 선택하느냐에 따른 12개월 누적 비용 차이 (추정)</span>
        </div>
        <div class="bfc-summary-card bfc-summary-card--warn">
          <span class="bfc-summary-label">직구 시 주의</span>
          <span class="bfc-summary-value">실비용 확인 필수</span>
          <span class="bfc-summary-note">배송비·관세 포함하면 국내 프리미엄 분유보다 비쌀 수 있음</span>
        </div>
        <div class="bfc-summary-card">
          <span class="bfc-summary-label">절약 팁</span>
          <span class="bfc-summary-value">정기배송 최대 10%</span>
          <span class="bfc-summary-note">쿠팡 정기배송 할인 적용 시 12개월 약 6~10만 원 절감 (추정)</span>
        </div>
      </div>
    </section>

    <DesignTrustPanel updatedAt="2026년 5월" />

    <section class="content-section bfc-conclusion">
      <p class="section-header__eyebrow">30초 결론</p>
      <h2>국산 일반 라인은 70만 원 안팎, 직구·프리미엄은 110만 원대부터 봐야 합니다</h2>
      <div class="bfc-conclusion-grid">
        <article>
          <strong>가성비 기준</strong>
          <p>{cheapestRow.brand} 기준 12개월 누적 약 {manWon(cheapestRow.totalCost)}입니다. 국내 일반 라인은 단가가 낮고 수급이 안정적입니다.</p>
        </article>
        <article>
          <strong>프리미엄·직구 기준</strong>
          <p>{priciestRow.brand} 기준 약 {manWon(priciestRow.totalCost)}까지 올라갑니다. 배송비, 관세, 환율을 포함한 실구매가 확인이 핵심입니다.</p>
        </article>
        <article>
          <strong>실전 구매 기준</strong>
          <p>처음부터 대량 구매하기보다 1~2캔으로 반응을 본 뒤, 소비량이 잡히면 정기배송이나 공식몰 구독으로 전환하는 편이 안전합니다.</p>
        </article>
      </div>
    </section>

    <!-- ② 분유 선택이 왜 중요한가 -->
    <section class="content-section bfc-copy-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">비용 판단 기준</p>
        <h2>분유 선택이 왜 중요한가</h2>
      </div>
      <p>분유 선택은 아기의 영양과 직결되는 결정이지만, 동시에 12개월 동안 수십만 원에서 100만 원 이상 차이가 날 수 있는 가계 지출 결정이기도 합니다. 어떤 브랜드를 선택하느냐에 따라 12개월 누적 분유 비용이 약 65만 원에서 130만 원까지 달라질 수 있습니다. (추정)</p>
      <p>가격 비교에서 흔히 놓치는 포인트는 <strong>100g당 단가</strong>입니다. 같은 브랜드라도 800g과 400g 캔은 단위 가격이 다를 수 있고, 쿠팡 정기배송 할인을 적용하면 마트 판매가보다 저렴해지는 경우가 많습니다. 이 리포트에서는 100g당 단가를 기준 지표로 삼아 브랜드별 실질 가격을 비교합니다.</p>
    </section>

    <!-- ② 국내 브랜드 라인업 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">국내 브랜드</p>
        <h2>국내 분유 브랜드 라인업</h2>
        <p>국내 브랜드 5개의 가격은 쿠팡 기준 추정값입니다. 오프라인 접근성과 정기배송 편의성이 강점입니다.</p>
      </div>
      <div class="bfc-brand-grid">
        {domesticBrands.map((brand) => (
          <article class="bfc-brand-card">
            <h3 class="bfc-brand-name">{brand.name}</h3>
            <div class="bfc-brand-tags">
              <span class="bfc-brand-tag bfc-brand-tag--domestic">국산</span>
              {brand.grade === "organic" && <span class="bfc-brand-tag bfc-brand-tag--organic">유기농</span>}
              {brand.grade === "premium" && <span class="bfc-brand-tag bfc-brand-tag--premium">프리미엄</span>}
            </div>
            <p class="bfc-brand-price">
              1단 기준 약 {brand.stages[0].coupangPrice.toLocaleString("ko-KR")}원 / 800g
              <small class="bfc-muted">100g당 약 {brand.stages[0].pricePerHundredG.toLocaleString("ko-KR")}원, 추정</small>
            </p>
            <ul class="bfc-brand-pros">
              {brand.pros.map((p) => <li>{p}</li>)}
            </ul>
            <p class="bfc-brand-best"><strong>추천 대상:</strong> {brand.bestFor}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ③ 해외 직구 분유 현황 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">해외 직구</p>
        <h2>해외 직구 분유 현황</h2>
        <p>배송비와 관세를 포함한 실비용으로 계산하면 국내 프리미엄 분유와 비슷하거나 오히려 비싼 경우가 많습니다.</p>
      </div>
      <div class="bfc-brand-grid">
        {importedBrands.map((brand) => (
          <article class="bfc-brand-card">
            <h3 class="bfc-brand-name">{brand.name} <small class="bfc-brand-name-en">({brand.nameEn})</small></h3>
            <div class="bfc-brand-tags">
              <span class="bfc-brand-tag bfc-brand-tag--imported">수입</span>
              {brand.grade === "organic" && <span class="bfc-brand-tag bfc-brand-tag--organic">유기농</span>}
              {brand.grade === "premium" && <span class="bfc-brand-tag bfc-brand-tag--premium">프리미엄</span>}
            </div>
            <p class="bfc-brand-price">
              약 {brand.stages[0].directImportPrice?.toLocaleString("ko-KR")}원 / 800g
              <small class="bfc-muted">배송·관세 포함 추정</small>
            </p>
            <ul class="bfc-brand-pros">
              {brand.pros.map((p) => <li>{p}</li>)}
            </ul>
            <p class="bfc-brand-best"><strong>추천 대상:</strong> {brand.bestFor}</p>
            <p class="bfc-brand-note">{brand.note}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- ④ 단계별 가격 비교표 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">단가 비교</p>
        <h2>단계별 가격 비교표 <span class="badge badge--warning">추정</span></h2>
        <p>800g 캔 기준 1단 가격 비교입니다. 실제 구매가는 시기·플랫폼에 따라 달라집니다.</p>
      </div>
      <div class="bfc-table-wrap">
        <table class="bfc-compare-table">
          <thead>
            <tr>
              <th>브랜드</th>
              <th>구분</th>
              <th>월령</th>
              <th>정가</th>
              <th>쿠팡 최저</th>
              <th>마트</th>
              <th>100g 단가</th>
              <th>구매</th>
            </tr>
          </thead>
          <tbody>
            {BRANDS.map((brand) =>
              brand.stages.map((stage, si) => (
                <tr>
                  {si === 0 && (
                    <td rowspan={brand.stages.length} class="bfc-brand-cell">
                      {brand.name}
                      {brand.origin === "imported" && <span>직구 추정가</span>}
                    </td>
                  )}
                  <td>{stage.stage}단</td>
                  <td>{stage.ageRange}</td>
                  <td>{stage.listPrice.toLocaleString("ko-KR")}원</td>
                  <td>{stage.coupangPrice.toLocaleString("ko-KR")}원</td>
                  <td>{stage.martPrice.toLocaleString("ko-KR")}원</td>
                  <td class={stage.pricePerHundredG <= 3300 ? "bfc-lowest" : stage.pricePerHundredG >= 6000 ? "bfc-highest" : ""}>
                    {stage.pricePerHundredG.toLocaleString("ko-KR")}원
                  </td>
                  <td>
                    {stage.coupaUrl
                      ? <a class="bfc-buy-btn" href={stage.coupaUrl} target="_blank" rel="noopener sponsored">쿠팡 보기</a>
                      : <span class="bfc-empty">-</span>
                    }
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
      <p class="bfc-table-note">※ 100g 단가 초록색: 최저 구간 / 빨간색: 최고 구간. 모든 가격은 추정값입니다.</p>
    </section>

    <!-- ⑤ 월령별 월 비용 환산 차트 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">월령별 흐름</p>
        <h2>월령별 분유 비용 추이</h2>
        <p>4~5개월에 분유 소비량이 최대에 달하고, 이유식이 시작되는 6개월 이후부터 점차 줄어듭니다.</p>
      </div>
      <div class="bfc-chart-panel">
        <div class="bfc-chart-wrap">
          <canvas id="bfcLineChart" aria-label="대표 3개 분유 브랜드 월령별 비용 추이 차트"></canvas>
        </div>
      </div>
      <p class="bfc-chart-note">전체 브랜드 비교는 위 가격 비교표를 참고하세요.</p>
    </section>

    <!-- ⑥ 12개월 누적 비용 차트 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">12개월 누적</p>
        <h2>브랜드별 12개월 누적 분유 비용 비교 <span class="badge badge--warning">추정</span></h2>
        <p>월령별 권장 소비량(총 약 20,160g) 기준 12개월 누적 비용입니다. 실제 소비량과 구매가에 따라 달라집니다.</p>
      </div>
      <div class="bfc-cost-split">
        <article>
          <span>국내 브랜드 평균</span>
          <strong>약 {manWon(averageDomesticCost)}</strong>
        </article>
        <article>
          <span>직구 브랜드 평균</span>
          <strong>약 {manWon(averageImportedCost)}</strong>
        </article>
        <article>
          <span>평균 차이</span>
          <strong>약 {manWon(averageImportedCost - averageDomesticCost)}</strong>
        </article>
      </div>
      <div class="bfc-chart-panel">
        <div class="bfc-bar-chart-wrap">
          <canvas id="bfcBarChart" aria-label="브랜드별 12개월 누적 분유 비용 비교 차트"></canvas>
        </div>
      </div>
      <div class="bfc-cta-box">
        <span class="bfc-cta-text">내 아기 월령 기준으로 남은 기간 비용을 직접 계산해보세요.</span>
        <a href={withBase("/tools/breastfeeding-vs-formula-cost/")} class="bfc-cta-btn">분유 비용 계산기</a>
      </div>
    </section>

    <!-- ⑦ 유기농·프리미엄 vs 일반 가성비 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">등급별 판단</p>
        <h2>유기농·프리미엄 vs 일반 분유 가성비 비교</h2>
        <p>800g 1단 기준 등급별 평균 단가와 12개월 누적 비용 차이입니다. (추정값)</p>
      </div>
      <div class="bfc-grade-compare">
        <div class="bfc-grade-card bfc-grade-card--standard">
          <span class="bfc-grade-label">일반 분유</span>
          <div class="bfc-grade-price">약 2.6~2.8만 원</div>
          <div class="bfc-grade-annual">12개월 누적 약 65~70만 원</div>
        </div>
        <div class="bfc-grade-card bfc-grade-card--organic">
          <span class="bfc-grade-label">유기농 분유</span>
          <div class="bfc-grade-price">약 3.6~5.5만 원</div>
          <div class="bfc-grade-annual">12개월 누적 약 90~130만 원</div>
        </div>
        <div class="bfc-grade-card bfc-grade-card--premium">
          <span class="bfc-grade-label">프리미엄 분유</span>
          <div class="bfc-grade-price">약 5.0~6.2만 원</div>
          <div class="bfc-grade-annual">12개월 누적 약 113~126만 원</div>
        </div>
      </div>
