<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script define:vars={{ lineChartData, barChartData, MONTHLY_CONSUMPTION }}>
  window.addEventListener("load", () => {
    if (typeof window.Chart === "undefined") return;

    // ── 라인 차트 (월령별 월 비용) ──────────────────────
    const lineCtx = document.getElementById("bfcLineChart");
    if (lineCtx) {
      const labels = MONTHLY_CONSUMPTION.map((r) => `${r.age}개월`);
      const datasets = lineChartData.datasets.map((ds) => ({
        label: ds.label,
        data: MONTHLY_CONSUMPTION.map((r) => Math.round((r.monthlyGrams / 800) * ds.pricePerHundredG * 100)),
        borderColor: ds.borderColor,
        backgroundColor: ds.borderColor + "18",
        borderWidth: 2,
        pointRadius: 3,
        tension: 0.35,
      }));

      new window.Chart(lineCtx, {
        type: "line",
        data: { labels, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: "index", intersect: false },
          plugins: {
            legend: { position: "top", labels: { font: { size: 12 }, padding: 12 } },
            tooltip: {
              callbacks: {
                label: (ctx) => `${ctx.dataset.label}: ${Math.round(ctx.parsed.y / 100).toLocaleString("ko-KR")}원`,
              },
            },
          },
          scales: {
            x: { grid: { display: false } },
            y: {
              ticks: {
                callback: (v) => Math.round(Number(v) / 100 / 1000) + "만",
              },
            },
          },
        },
      });
    }

    // ── 가로 막대 차트 (12개월 누적 비용) ───────────────
    const barCtx = document.getElementById("bfcBarChart");
    if (barCtx) {
      new window.Chart(barCtx, {
        type: "bar",
        data: {
          labels: barChartData.labels,
          datasets: [{
            label: "12개월 누적 비용 (추정)",
            data: barChartData.data,
            backgroundColor: barChartData.colors,
            borderRadius: 4,
          }],
        },
        options: {
          indexAxis: "y",
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx) => ` 약 ${Math.round(Number(ctx.parsed.x) / 10000).toLocaleString("ko-KR")}만 원`,
              },
            },
          },
          scales: {
            x: {
              ticks: {
                callback: (v) => Math.round(Number(v) / 10000) + "만",
              },
            },
            y: { grid: { display: false } },
          },
        },
      });
    }
  });
</script>
