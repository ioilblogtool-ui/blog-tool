---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import CalculatorHero from '../../components/CalculatorHero.astro';
import InfoNotice from '../../components/InfoNotice.astro';
import SeoContent from '../../components/SeoContent.astro';
import '../../styles/scss/pages/_elementary-school-ready-cost-2026.scss';
import {
  CHECKLIST_ITEMS,
  ITEM_COST_ROWS,
  FIRST_MONTH_SCENARIOS,
  AFTER_SCHOOL_COMPARE,
  PRE_LEARNING_ROWS,
  CARE_FLOW_STEPS,
  SUPPORT_ROWS,
  REGRET_ITEMS,
  SIBLING_TIP_ROWS,
  YEAR_COMPARE_ROWS,
  FAQ_ITEMS,
} from '../../data/elementarySchoolReadyCost2026';

const normalizedBase = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, '')}`;

const requiredItems = CHECKLIST_ITEMS.filter((i) => i.category === 'required');
const schoolItems = CHECKLIST_ITEMS.filter((i) => i.category === 'school_specific');
const optionalItems = CHECKLIST_ITEMS.filter((i) => i.category === 'optional');

const totalCount = CHECKLIST_ITEMS.length;

const faqItems = FAQ_ITEMS.map((f) => ({ question: f.q, answer: f.a }));

const tierBadgeMap: Record<string, string> = {
  frugal: 'frugal',
  average: 'average',
  premium: 'premium',
};
---

<BaseLayout
  title="2026 초등학교 입학 준비 완벽 가이드 | 체크리스트·비용·지원금 총정리"
  description="2026년 초등학교 입학 준비를 앞둔 부모를 위한 실전 가이드. 취학통지서 일정, 준비물 체크리스트, 책가방·학용품 비용, 방과후·학원 비교, 초등 돌봄 신청, 국가 지원금까지 한 번에 정리했습니다."
  ogImage="/og/elementary-school-ready-cost-2026.png"
>
  <SiteHeader />

  <main class="container page-shell report-page esr-page">

    <CalculatorHero
      eyebrow="육아·교육 리포트"
      title="초등입학 전 체크리스트·비용 총정리 2026"
      description="일정 확인부터 준비물, 비용, 돌봄, 지원금까지 한 번에 확인하는 초등 입학 실전 가이드"
      badges={['초등입학', '준비물', '체크리스트', '2026']}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        '준비물·비용은 학교·브랜드·지역에 따라 다를 수 있습니다.',
        '가격은 2026년 1~3월 온라인 커머스 기준 추정값이며, 학교 안내문 확인 후 구매하세요.',
        '국가 지원금 수급 요건은 복지로(bokjiro.go.kr) 및 학교 공지를 직접 확인해 주세요.',
      ]}
    />

    <!-- 상단 KPI 4개 -->
    <section class="content-section esr-kpi-section">
      <div class="esr-kpi-grid">
        <article class="esr-kpi-card">
          <p class="esr-kpi-card__label">준비물 일회성 비용</p>
          <strong class="esr-kpi-card__value">12만~60만 원</strong>
          <span class="esr-kpi-card__note">절약형~확장형 기준</span>
          <span class="esr-badge esr-badge--estimate">추정</span>
        </article>
        <article class="esr-kpi-card">
          <p class="esr-kpi-card__label">첫 달 총 예상 비용</p>
          <strong class="esr-kpi-card__value">17만~120만 원</strong>
          <span class="esr-kpi-card__note">준비물 + 월 고정지출</span>
          <span class="esr-badge esr-badge--estimate">추정</span>
        </article>
        <article class="esr-kpi-card">
          <p class="esr-kpi-card__label">월 고정지출 예상</p>
          <strong class="esr-kpi-card__value">5만~60만 원+</strong>
          <span class="esr-kpi-card__note">방과후·학원·급식비 포함</span>
          <span class="esr-badge esr-badge--estimate">추정</span>
        </article>
        <article class="esr-kpi-card">
          <p class="esr-kpi-card__label">놓치면 안 되는 지원금</p>
          <strong class="esr-kpi-card__value">3종 이상</strong>
          <span class="esr-kpi-card__note">아동수당·교육급여·교육비 지원</span>
          <span class="esr-badge esr-badge--ref">참고</span>
        </article>
      </div>
    </section>

    <!-- 섹션 1: 입학 대상·취학통지서 일정 타임라인 -->
    <section class="content-section" id="esr-section-timeline">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">입학 준비 일정</p>
        <h2>취학통지서부터 입학식까지 4단계 타임라인</h2>
        <p>12월 취학통지서 발급을 시작으로 3월 입학까지 단계별로 준비합니다.</p>
      </div>
      <div class="esr-timeline">
        <div class="esr-timeline__step">
          <div class="esr-timeline__badge">12월</div>
          <div class="esr-timeline__content">
            <strong>취학통지서 확인</strong>
            <p>정부24(gov.kr) 온라인 발급 또는 주민센터 우편 수령. 배정 학교·입학 예정일을 확인합니다.</p>
          </div>
        </div>
        <div class="esr-timeline__step">
          <div class="esr-timeline__badge">1월</div>
          <div class="esr-timeline__content">
            <strong>예비소집 참석 · 준비물 쇼핑 시작</strong>
            <p>예비소집에서 학교별 안내문을 받아 준비물 목록을 확정합니다. 세일 시즌 구매로 비용 절감 가능.</p>
          </div>
        </div>
        <div class="esr-timeline__step">
          <div class="esr-timeline__badge">2월</div>
          <div class="esr-timeline__content">
            <strong>준비물 완료 · 돌봄·방과후 신청</strong>
            <p>이름라벨 부착 완료, 돌봄·방과후 신청 마감 전 신청. 학교 납부금 안내 확인.</p>
          </div>
        </div>
        <div class="esr-timeline__step">
          <div class="esr-timeline__badge">3월</div>
          <div class="esr-timeline__content">
            <strong>입학식 · 생활 패턴 적응</strong>
            <p>등하교 경로 확인, 적응 기간 충분히 부여. 첫 주는 학교 생활 파악에 집중합니다.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 섹션 2: 준비물 체크리스트 -->
    <section class="content-section" id="esr-section-checklist">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">준비물 체크리스트</p>
        <h2>필수·학교별·선택 항목을 그룹별로 체크하세요</h2>
        <p>체크 상태는 브라우저에 저장되어 다음 방문 시에도 유지됩니다. 학교별 확인 항목은 안내문 수령 후 구매하세요.</p>
      </div>
      <div class="esr-checklist-counter" id="esrCounter">
        {totalCount}개 중 <strong id="esrCounterNum">0</strong>개 완료
      </div>
      <div class="esr-checklist" id="esrChecklist">

        <!-- 필수 준비물 -->
        <div class="esr-checklist__group">
          <div class="esr-checklist__group-header">
            <span class="esr-badge esr-badge--required">필수</span>
            <strong>필수 준비물</strong>
            <span class="esr-checklist__group-count">({requiredItems.length}개)</span>
          </div>
          {requiredItems.map((item) => (
            <label class="esr-checklist__item" data-id={item.id}>
              <input type="checkbox" class="esr-checklist__checkbox" data-item-id={item.id} />
              <span class="esr-checklist__name">{item.name}</span>
              {item.note && <span class="esr-checklist__note">{item.note}</span>}
            </label>
          ))}
        </div>

        <!-- 학교별 확인 필요 -->
        <div class="esr-checklist__group">
          <div class="esr-checklist__group-header">
            <span class="esr-badge esr-badge--school">학교별</span>
            <strong>학교별 확인 필요</strong>
            <span class="esr-checklist__group-count">({schoolItems.length}개)</span>
          </div>
          {schoolItems.map((item) => (
            <label class="esr-checklist__item" data-id={item.id}>
              <input type="checkbox" class="esr-checklist__checkbox" data-item-id={item.id} />
              <span class="esr-checklist__name">{item.name}</span>
              {item.note && <span class="esr-checklist__note">{item.note}</span>}
            </label>
          ))}
        </div>

        <!-- 선택 항목 -->
        <div class="esr-checklist__group">
          <div class="esr-checklist__group-header">
            <span class="esr-badge esr-badge--optional">선택</span>
            <strong>있으면 편한 항목</strong>
            <span class="esr-checklist__group-count">({optionalItems.length}개)</span>
          </div>
          {optionalItems.map((item) => (
            <label class="esr-checklist__item" data-id={item.id}>
              <input type="checkbox" class="esr-checklist__checkbox" data-item-id={item.id} />
              <span class="esr-checklist__name">{item.name}</span>
              {item.note && <span class="esr-checklist__note">{item.note}</span>}
            </label>
          ))}
        </div>

      </div>
    </section>

    <!-- 섹션 3: 품목별 평균 비용 -->
    <section class="content-section" id="esr-section-cost">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">품목별 비용</p>
        <h2>절약형 / 평균형 / 확장형 3단 비교</h2>
        <p>아래 가격은 2026년 1~3월 온라인 커머스 기준 추정값입니다. 학교별 요구 사항에 따라 달라질 수 있습니다.</p>
      </div>
      <div class="esr-cost-table-wrap">
        <table class="esr-cost-table">
          <thead>
            <tr>
              <th>품목</th>
              <th class="esr-cost-table__tier esr-cost-table__tier--frugal">절약형</th>
              <th class="esr-cost-table__tier esr-cost-table__tier--average">평균형</th>
              <th class="esr-cost-table__tier esr-cost-table__tier--premium">확장형</th>
              <th>비고</th>
            </tr>
          </thead>
          <tbody>
            {ITEM_COST_ROWS.map((row) => (
              <tr>
                <td><strong>{row.item}</strong></td>
                <td>{row.frugal}</td>
                <td>{row.average}</td>
                <td>{row.premium}</td>
                <td class="esr-cost-table__note">{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="esr-footnote">
        <span class="esr-badge esr-badge--estimate">추정</span>
        가격은 2026년 1~3월 온라인 커머스 기준 추정값. 학교별 상이.
      </p>
    </section>

    <!-- 섹션 4: 첫 달 총비용 시나리오 -->
    <section class="content-section" id="esr-section-scenario">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">첫 달 총비용</p>
        <h2>절약형 / 평균형 / 확장형 시나리오 비교</h2>
        <p>방과후·학원비·학교 납부금 수준에 따라 첫 달 총비용이 크게 달라집니다.</p>
      </div>
      <div class="esr-scenario-grid">
        {FIRST_MONTH_SCENARIOS.map((s) => (
          <article class={`esr-scenario-card esr-scenario-card--${s.tier}`}>
            <div class="esr-scenario-card__head">
              <strong class="esr-scenario-card__label">{s.label}</strong>
              <span class="esr-badge esr-badge--estimate">추정</span>
            </div>
            <dl class="esr-scenario-card__dl">
              <div>
                <dt>일회성 준비물</dt>
                <dd>{s.oneTime}</dd>
              </div>
              <div>
                <dt>월 고정지출</dt>
                <dd>{s.monthly}</dd>
              </div>
              <div class="esr-scenario-card__total">
                <dt>첫 달 합계</dt>
                <dd><strong>{s.total}</strong></dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
      <p class="esr-footnote">방과후·학원비·학교 납부금(교재비·급식비 등) 포함 수준에 따라 달라짐.</p>
    </section>

    <!-- 섹션 5: 방과후·돌봄·학원 비교 -->
    <section class="content-section" id="esr-section-afterschool">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">방과후·학원 비교</p>
        <h2>방과후 / 돌봄 / 학원 / 학습지 선택 기준</h2>
        <p>1학년은 학교 적응을 우선하고, 방과후부터 시작하는 순서를 권장합니다.</p>
      </div>
      <div class="esr-compare-table-wrap">
        <table class="esr-compare-table">
          <thead>
            <tr>
              <th>구분</th>
              <th>비용 수준</th>
              <th>장점</th>
              <th>단점</th>
              <th>추천 대상</th>
            </tr>
          </thead>
          <tbody>
            {AFTER_SCHOOL_COMPARE.map((row) => (
              <tr>
                <td><strong>{row.type}</strong></td>
                <td>{row.costLevel}</td>
                <td>{row.pros}</td>
                <td>{row.cons}</td>
                <td>{row.recommended}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- 섹션 6: 입학 전 학습 준비 비용 -->
    <section class="content-section" id="esr-section-learning">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">학습 준비 비용</p>
        <h2>입학 전 학습 준비 방식별 비용 비교</h2>
        <p>선행보다는 생활 습관·한글 읽기·기초 수 개념 정도를 권장합니다.</p>
      </div>
      <div class="esr-learning-table-wrap">
        <table class="esr-learning-table">
          <thead>
            <tr>
              <th>방식</th>
              <th>월 비용</th>
              <th>특징</th>
              <th>추천도</th>
            </tr>
          </thead>
          <tbody>
            {PRE_LEARNING_ROWS.map((row) => (
              <tr>
                <td><strong>{row.method}</strong></td>
                <td>{row.monthlyCost}</td>
                <td>{row.feature}</td>
                <td>
                  <span class={`esr-badge ${
                    row.recommended === '높음'
                      ? 'esr-badge--high'
                      : row.recommended === '중간'
                      ? 'esr-badge--mid'
                      : 'esr-badge--optional'
                  }`}>{row.recommended}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- 섹션 7: 초등 돌봄 신청 플로우 -->
    <section class="content-section" id="esr-section-care">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">돌봄 신청 가이드</p>
        <h2>초등 돌봄 신청 5단계 플로우</h2>
        <p>정원이 한정되어 있으므로 학교 공지 즉시 신청하는 것이 중요합니다.</p>
      </div>
      <div class="esr-care-flow">
        {CARE_FLOW_STEPS.map((s) => (
          <div class="esr-care-flow__step">
            <div class="esr-care-flow__badge">{s.step}</div>
            <div class="esr-care-flow__content">
              <strong class="esr-care-flow__title">{s.title}</strong>
              <p class="esr-care-flow__desc">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="esr-footnote">
        <span class="esr-badge esr-badge--ref">참고</span>
        늘봄학교 정책이 지역 연계형으로 확대 중 (2026). 지역별 운영 형태 상이.
      </p>
    </section>

    <!-- 섹션 8: 국가 지원금 총정리 -->
    <section class="content-section" id="esr-section-support">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">국가 지원금</p>
        <h2>초등 입학 전후 활용 가능한 국가 지원금 총정리</h2>
        <p>소득·연령·지역 요건은 복지로(bokjiro.go.kr) 및 학교 공지를 직접 확인하세요.</p>
      </div>
      <div class="esr-support-table-wrap">
        <table class="esr-support-table">
          <thead>
            <tr>
              <th>제도</th>
              <th>대상</th>
              <th>주요 내용</th>
              <th>신청 채널</th>
            </tr>
          </thead>
          <tbody>
            {SUPPORT_ROWS.map((row) => (
              <tr>
                <td>
                  <strong>{row.name}</strong>
                  <span class={`esr-badge ${row.badge === '공식' ? 'esr-badge--official' : 'esr-badge--ref'}`}>{row.badge}</span>
                </td>
                <td>{row.target}</td>
                <td>{row.content}</td>
                <td>{row.channel}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="esr-footnote">수급 요건·금액은 정책 변경에 따라 달라질 수 있습니다. 복지로(bokjiro.go.kr)에서 최신 정보 확인 권장.</p>
    </section>

    <!-- 섹션 9: 후회한 준비물 TOP5 -->
    <section class="content-section" id="esr-section-regret">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">후회 줄이기</p>
        <h2>선배 부모들이 후회한 준비물 TOP 5</h2>
        <p>온라인 커뮤니티·육아 블로그 취합 기준입니다. 사전에 알면 불필요한 지출을 줄일 수 있습니다.</p>
      </div>
      <div class="esr-regret-list">
        {REGRET_ITEMS.map((r) => (
          <div class="esr-regret-item">
            <div class="esr-regret-item__rank">{r.rank}</div>
            <div class="esr-regret-item__content">
              <strong class="esr-regret-item__name">{r.item}</strong>
              <p class="esr-regret-item__reason">{r.reason}</p>
              <p class="esr-regret-item__tip">💡 {r.tip}</p>
            </div>
          </div>
        ))}
      </div>
