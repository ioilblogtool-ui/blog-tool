---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  EMPLOYEE_TAX_INSURANCE_FAQ,
  EMPLOYEE_TAX_INSURANCE_META,
  EMPLOYEE_TAX_INSURANCE_RELATED,
  INSURANCE_RATE_ITEMS,
  PAYROLL_DEDUCTION_ITEMS,
  PAYROLL_READING_STEPS,
  SALARY_EXAMPLES_2026,
  formatWon,
} from "../../data/employeeTaxInsuranceRates2026";

const site = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const faqSchema = EMPLOYEE_TAX_INSURANCE_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: {
    "@type": "Answer",
    text: item.answer,
  },
}));

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: "2026 직장인 세금·4대보험 요율표",
      description: EMPLOYEE_TAX_INSURANCE_META.subtitle,
      inLanguage: "ko-KR",
      dateModified: "2026-06-03",
      author: { "@type": "Organization", name: "비교계산소" },
      publisher: { "@type": "Organization", name: "비교계산소" },
      mainEntityOfPage: `${site}/reports/employee-tax-insurance-rates-2026/`,
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "홈", item: `${site}/` },
        { "@type": "ListItem", position: 2, name: "리포트", item: `${site}/reports/` },
        { "@type": "ListItem", position: 3, name: "2026 직장인 세금·4대보험 요율표", item: `${site}/reports/employee-tax-insurance-rates-2026/` },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  ],
};
---

<BaseLayout
  title="2026 직장인 세금·4대보험 요율표 | 급여명세서 공제 항목 정리"
  description="2026년 국민연금, 건강보험, 장기요양보험, 고용보험 요율과 근로소득세·지방소득세가 월급에서 어떻게 공제되는지 급여명세서 기준으로 정리했습니다."
  jsonLd={jsonLd}
>
  <SiteHeader />

  <main class="container page-shell report-page etir-page">
    <CalculatorHero
      eyebrow="급여명세서 해석"
      title={EMPLOYEE_TAX_INSURANCE_META.title}
      description={EMPLOYEE_TAX_INSURANCE_META.subtitle}
    />

    <InfoNotice
      title="기준 안내"
      lines={[
        EMPLOYEE_TAX_INSURANCE_META.updatedAt,
        "4대보험 요율은 2026년 공개 기준을 바탕으로 정리했으며, 실제 급여 공제액은 회사의 보수월액 신고·정산 방식에 따라 달라질 수 있습니다.",
        "근로소득세 예시는 급여명세서 이해를 돕기 위한 간이 추정이며 국세청 간이세액표 원천징수액과 다를 수 있습니다.",
      ]}
    />

    <section class="content-section etir-hero-grid">
      <article class="etir-lead">
        <p class="etir-eyebrow">월급에서 빠지는 돈의 구조</p>
        <h2>직장인 급여 공제는 4대보험과 세금으로 나눠서 읽어야 합니다</h2>
        <p>
          급여명세서에서 국민연금, 건강보험, 장기요양보험, 고용보험은 사회보험료입니다.
          근로소득세와 지방소득세는 세금입니다. 두 묶음을 분리해서 보면 월급이 왜 줄어드는지 훨씬 빠르게 이해할 수 있습니다.
        </p>
        <div class="etir-cta-row">
          <a class="button button--primary" href={withBase("/tools/four-insurance-calculator/")}>내 월급 4대보험 계산하기</a>
          <a class="button button--secondary" href="#etir-rates">2026 요율표 보기</a>
        </div>
      </article>

      <div class="etir-summary-grid" aria-label="핵심 요약">
        {PAYROLL_DEDUCTION_ITEMS.map((item) => (
          <article class="etir-summary-card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" id="etir-rates">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">2026 요율표</p>
        <h2>근로자 부담과 회사 부담을 따로 봅니다</h2>
        <p>직장인이 실제 실수령액에서 체감하는 금액은 근로자 부담분입니다. 회사 부담분은 인건비 구조를 이해할 때 참고합니다.</p>
      </div>

      <div class="etir-table-wrap">
        <table class="etir-table">
          <thead>
            <tr>
              <th>항목</th>
              <th>계산 기준</th>
              <th>근로자 부담</th>
              <th>회사 부담</th>
              <th>해석 포인트</th>
            </tr>
          </thead>
          <tbody>
            {INSURANCE_RATE_ITEMS.map((item) => (
              <tr>
                <th>{item.name}</th>
                <td>{item.base}</td>
                <td>{item.displayEmployee}</td>
                <td>{item.displayEmployer}</td>
                <td>{item.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">월급 예시</p>
        <h2>월급 300만·400만·500만원이면 얼마나 빠질까</h2>
        <p>비과세 20만원, 부양가족 1명 기준의 간이 예시입니다. 소득세는 실제 원천징수액과 다를 수 있습니다.</p>
      </div>

      <div class="etir-example-grid">
        {SALARY_EXAMPLES_2026.map((item) => (
          <article class="etir-example-card">
            <p class="etir-example-card__label">월급 {formatWon(item.monthlySalary)}</p>
            <strong>{formatWon(item.estimatedNetPay)}</strong>
            <span>예상 실수령액</span>
            <dl>
              <div><dt>4대보험</dt><dd>{formatWon(item.nationalPension + item.healthInsurance + item.longTermCare + item.employmentInsurance)}</dd></div>
              <div><dt>간이 세금</dt><dd>{formatWon(item.estimatedIncomeTax + item.estimatedLocalTax)}</dd></div>
              <div><dt>총 공제</dt><dd>{formatWon(item.totalDeduction)}</dd></div>
            </dl>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section etir-reading-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">급여명세서 읽기</p>
        <h2>공제 항목은 이 순서로 확인하면 헷갈리지 않습니다</h2>
      </div>
      <ol class="etir-step-list">
        {PAYROLL_READING_STEPS.map((step) => <li>{step}</li>)}
      </ol>
    </section>

    <section class="content-section etir-tool-cta">
      <div>
        <p class="etir-eyebrow">계산기로 이어보기</p>
        <h2>내 월급 기준 공제액은 계산기로 바로 확인하세요</h2>
        <p>월 급여, 비과세 금액, 부양가족 수를 입력하면 국민연금·건강보험·장기요양·고용보험과 간이 세금, 예상 실수령액을 한 화면에서 볼 수 있습니다.</p>
      </div>
      <a class="button button--primary" href={withBase("/tools/four-insurance-calculator/")}>4대보험 계산기 열기</a>
    </section>

    <SeoContent
      introTitle="2026 직장인 세금·4대보험 요율표를 보는 법"
      intro={[
        "직장인 급여명세서에서 가장 먼저 봐야 할 것은 공제 항목의 성격입니다. 국민연금, 건강보험, 장기요양보험, 고용보험은 사회보험료이고 근로소득세와 지방소득세는 세금입니다.",
        "국민연금은 기준소득월액 상한·하한 때문에 월급에 단순 비율만 곱한 금액과 다를 수 있습니다. 건강보험은 보수월액에 요율을 곱하고, 장기요양보험은 산출된 건강보험료에 다시 요율을 곱하는 구조입니다.",
        "소득세는 부양가족 수, 비과세 금액, 회사의 간이세액표 선택률에 따라 달라집니다. 따라서 이 페이지의 월급별 예시는 급여명세서를 이해하기 위한 참고값으로 보는 것이 좋습니다.",
      ]}
      inputPoints={[
        "월급 공제 항목을 4대보험과 세금으로 나눠 읽을 수 있습니다.",
        "근로자 부담과 회사 부담을 구분해 급여명세서 오해를 줄일 수 있습니다.",
        "내 월급 기준의 예상 공제액은 4대보험 계산기로 이어서 확인할 수 있습니다.",
      ]}
      criteria={[
        "국민연금은 2026년 사업장가입자 근로자 부담 4.75% 기준입니다.",
        "건강보험은 2026년 직장가입자 근로자 부담 3.595% 기준입니다.",
        "장기요양보험은 건강보험료에 13.14%를 곱하는 방식으로 안내합니다.",
        "근로소득세 예시는 국세청 간이세액표 원리를 단순화한 추정값입니다.",
      ]}
      faq={EMPLOYEE_TAX_INSURANCE_FAQ}
      related={EMPLOYEE_TAX_INSURANCE_RELATED}
    />
  </main>
</BaseLayout>

