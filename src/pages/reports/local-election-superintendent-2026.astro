---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SeoContent from "../../components/SeoContent.astro";
import { EDU_META, SUPERINTENDENTS } from "../../data/localElectionSuperintendent2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const TITLE       = "2026 교육감 당선자 지도 — 17개 시도 교육 공약 완전 정리";
const DESCRIPTION = "서울 정근식 재선 등 2026 교육감 당선자를 지도에서 클릭하면 진보·보수 성향·공약·이력이 한 번에 나옵니다.";

function getEduClass(orientation: string) {
  if (orientation === "진보") return "progressive";
  if (orientation === "보수") return "conservative";
  if (orientation === "중도") return "moderate";
  return "pending";
}

const confirmedCount = SUPERINTENDENTS.filter(s => s.badge !== "확정대기").length;

const faqItems = [
  { question: "교육감 선거에는 정당 표시가 없나요?",
    answer: "네, 교육의 정치적 중립을 위해 교육감은 정당 추천 없이 선출됩니다. 하지만 후보의 공약과 이력으로 진보/보수 성향을 파악할 수 있습니다." },
  { question: "진보·보수 성향 분류 기준은 무엇인가요?",
    answer: "학생인권조례 입장, 무상급식 범위, 자사고·외고 정책, 혁신학교 찬반 등 공약과 이력을 종합해 비교계산소 편집부가 분류합니다. 공식 지표가 아닌 참고용입니다." },
  { question: "서울 교육감 정근식은 어떤 정책을 추진했나요?",
    answer: "학생인권조례 유지·강화, 혁신학교 확대, 방과후 공공화, 무상급식 전면 실시 등 진보 성향 교육 정책을 추진했습니다. 2022년 초선 이후 재선에 성공했습니다." },
  { question: "교육감 임기는 몇 년인가요?",
    answer: "4년입니다. 2026년 당선자는 2026년 7월 1일부터 2030년 6월 30일까지 임기를 수행합니다. 3선 연임은 가능합니다." },
  { question: "교육감이 결정하는 정책은 어떤 것들이 있나요?",
    answer: "시도 교육청 예산 편성, 교원 인사, 학교 신설·폐교, 무상급식 범위, 방과후·돌봄 운영, 학생인권조례 시행 등을 관장합니다." },
];
---

<BaseLayout title={TITLE} description={DESCRIPTION}>
  <SiteHeader />
  <main class="container page-shell report-page edu-page">

    <!-- A. Hero -->
    <section class="edu-hero">
      <p class="edu-hero__eyebrow">2026 지방선거 · 교육감</p>
      <h1 class="edu-hero__title">{TITLE}</h1>
      <p class="edu-hero__sub">
        지도에서 지역을 클릭하면 교육감 성향·공약·이력이 한 번에 보입니다.<br/>
        <span class="edu-hero__note">[편집부 분류] 진보/보수 성향은 공약·이력 기반 참고용입니다.</span>
      </p>
      <span class="edu-hero__date-badge">{EDU_META.dataAsOf}</span>
    </section>

    <!-- B. 데이터 안내 -->
    <div class="edu-notice">
      <span>⚠️</span>
      <span>
        서울 정근식(진보, 재선)만 확정. 나머지 {EDU_META.pendingCount}개 시도는 선관위 최종 발표 후 업데이트됩니다.
        성향 분류는 편집부 기준이며 공식 정당 기준이 아닙니다.
      </span>
      <a href="https://info.nec.go.kr" target="_blank" rel="noopener noreferrer" class="edu-notice__link">선관위 →</a>
    </div>

    <!-- C. KPI -->
    <section class="edu-kpi content-section" aria-label="핵심 지표">
      <div class="edu-kpi__grid">
        <div class="edu-kpi__card edu-kpi__card--progressive">
          <p class="edu-kpi__label">진보 성향</p>
          <p class="edu-kpi__value">{EDU_META.progressiveCount}명</p>
          <p class="edu-kpi__sub">서울 정근식 확정</p>
        </div>
        <div class="edu-kpi__card edu-kpi__card--conservative">
          <p class="edu-kpi__label">보수 성향</p>
          <p class="edu-kpi__value">{EDU_META.conservativeCount}명</p>
          <p class="edu-kpi__sub">확정 대기</p>
        </div>
        <div class="edu-kpi__card edu-kpi__card--pending">
          <p class="edu-kpi__label">확정 대기</p>
          <p class="edu-kpi__value">{EDU_META.pendingCount}개</p>
          <p class="edu-kpi__sub">선관위 확정 후 업데이트</p>
        </div>
        <div class="edu-kpi__card">
          <p class="edu-kpi__label">전체 교육감</p>
          <p class="edu-kpi__value">{EDU_META.totalRegions}명</p>
          <p class="edu-kpi__sub">17개 시도</p>
        </div>
      </div>
    </section>

    <!-- D. 지도 + 패널 -->
    <section class="edu-map-section content-section" aria-labelledby="edu-map-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">교육감 지도</p>
        <h2 id="edu-map-title">지역을 클릭하면 교육감 상세가 나옵니다</h2>
        <p>진보(파랑) / 보수(주황) / 확정대기(회색) 색상 구분. [편집부 분류]</p>
      </div>

      <!-- 모바일 탭 -->
      <div class="edu-tabs" role="tablist">
        <button id="edu-tab-map"  class="edu-tab edu-tab--active" role="tab" aria-selected="true">🗺 지도</button>
        <button id="edu-tab-list" class="edu-tab"                 role="tab" aria-selected="false">📋 목록</button>
      </div>

      <div class="edu-layout">
        <!-- SVG 지도 (시도지사 지도와 동일 SVG 구조 재사용) -->
        <div id="edu-map-view" class="edu-map-wrap">
          <div class="edu-map-container">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 560 660"
              id="edu-map-svg" class="edu-map__svg"
              aria-label="전국 교육감 당선자 지도">
              <title>2026 교육감 당선자 지도</title>
              <g class="edu-map__regions">
                {SUPERINTENDENTS.map((s) => {
                  const cls = getEduClass(s.orientation);
                  return (
                    <path
                      id={`edu-region-${s.regionId}`}
                      data-region-id={s.regionId}
                      class={`edu-map__region edu-map__region--${cls}`}
                      tabindex="0"
                      role="button"
                      aria-label={`${s.regionNameKo} — ${s.name === "TODO" ? "확정대기" : s.name}`}
                      d="M0 0"
                    />
                  );
                })}
              </g>
              <g class="edu-map__labels" aria-hidden="true">
                <text class="edu-map__label" x="200" y="194">서울</text>
                <text class="edu-map__label" x="160" y="195">인천</text>
                <text class="edu-map__label" x="182" y="218">경기</text>
                <text class="edu-map__label" x="345" y="192">강원</text>
                <text class="edu-map__label" x="185" y="330">세종</text>
                <text class="edu-map__label" x="242" y="305">충북</text>
                <text class="edu-map__label" x="120" y="308">충남</text>
                <text class="edu-map__label" x="164" y="335">대전</text>
                <text class="edu-map__label" x="138" y="372">전북</text>
                <text class="edu-map__label" x="148" y="415">광주·전남</text>
                <text class="edu-map__label" x="328" y="325">경북</text>
                <text class="edu-map__label" x="263" y="355">대구</text>
                <text class="edu-map__label" x="365" y="368">울산</text>
                <text class="edu-map__label" x="320" y="402">부산</text>
                <text class="edu-map__label" x="246" y="428">경남</text>
                <text class="edu-map__label" x="170" y="545">제주</text>
              </g>
            </svg>
            <div id="edu-tooltip" class="edu-tooltip" aria-hidden="true"></div>
          </div>

          <!-- 범례 -->
          <div class="edu-legend">
            <span class="edu-legend__item edu-legend__item--progressive">진보 [편집부]</span>
            <span class="edu-legend__item edu-legend__item--conservative">보수 [편집부]</span>
            <span class="edu-legend__item edu-legend__item--pending">확정대기</span>
          </div>
        </div>

        <!-- 목록 뷰 -->
        <div id="edu-list-view" class="edu-list is-hidden">
          <div class="edu-list__grid">
            {SUPERINTENDENTS.map((s) => (
              <button
                type="button"
                class={`edu-list__btn edu-list__btn--${getEduClass(s.orientation)}`}
                data-region-id={s.regionId}
              >
                <span class="edu-list__region">{s.regionNameKo}</span>
                <span class="edu-list__name">{s.name === "TODO" ? "확인 중" : s.name}</span>
                {s.badge !== "확정대기" && (
                  <span class="edu-list__orientation">{s.orientation}</span>
                )}
              </button>
            ))}
          </div>
        </div>

        <!-- 상세 패널 -->
        <div id="edu-panel" class="edu-panel" role="dialog" aria-label="교육감 상세 정보">
          <p class="edu-panel__hint">
            지도에서 지역을 클릭하면<br/>교육감 정보가 나옵니다.
          </p>
        </div>
      </div>
    </section>

    <!-- E. 빠른 탐색 버튼 -->
    <section class="edu-quick content-section" aria-labelledby="edu-quick-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">빠른 탐색</p>
        <h2 id="edu-quick-title">지역 바로가기</h2>
      </div>
      <div class="edu-quick__grid">
        {SUPERINTENDENTS.map((s) => (
          <button
            type="button"
            class={`edu-quick__btn edu-quick__btn--${getEduClass(s.orientation)}`}
            data-region-id={s.regionId}
          >
            {s.regionNameKo}
          </button>
        ))}
      </div>
    </section>

    <!-- F. 성향 현황 차트 -->
    <section class="edu-chart-section content-section" aria-labelledby="edu-chart-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">성향 현황 <span style="font-weight:400;color:#999">[편집부 분류]</span></p>
        <h2 id="edu-chart-title">교육감 진보·보수 성향 분포</h2>
        <p>선관위 최종 확정 후 업데이트됩니다.</p>
      </div>
      <div class="edu-chart-wrap">
        <canvas id="edu-orientation-chart"
          data-progressive={EDU_META.progressiveCount}
          data-conservative={EDU_META.conservativeCount}
          data-pending={EDU_META.pendingCount}
        ></canvas>
      </div>
    </section>

    <!-- G. FAQ -->
    <section class="edu-faq content-section" aria-labelledby="edu-faq-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">자주 묻는 질문</p>
        <h2 id="edu-faq-title">교육감 선거 FAQ</h2>
      </div>
      <div class="edu-faq__list" itemscope itemtype="https://schema.org/FAQPage">
        {faqItems.map((item) => (
          <div class="edu-faq__item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <button class="edu-faq__q" itemprop="name" aria-expanded="false">
              {item.question}
              <span class="edu-faq__icon">▼</span>
            </button>
            <div class="edu-faq__a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" hidden>
              <p itemprop="text">{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- H. 관련 콘텐츠 -->
    <section class="edu-related content-section" aria-labelledby="edu-related-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">이번 선거 시리즈</p>
        <h2 id="edu-related-title">같이 보면 좋은 콘텐츠</h2>
      </div>
      <div class="ts-link-grid">
        <a class="ts-link-card" href={withBase("/reports/local-election-governor-2026/")}>
          <span class="ts-link-card__eyebrow">지방선거 시리즈</span>
          <strong>시도지사 당선자 지도</strong>
          <p>민주 12 vs 국힘 4 — 전국 시도지사 공약.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/local-election-seoul-2026/")}>
          <span class="ts-link-card__eyebrow">지방선거 시리즈</span>
          <strong>서울 25개 구청장 지도</strong>
          <p>우리 동네 구청장 교육 공약 확인.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/local-election-byeollection-2026/")}>
          <span class="ts-link-card__eyebrow">지방선거 시리즈</span>
          <strong>재보궐 14개 지역구</strong>
          <p>한동훈 부산 북구갑 당선 등 재보궐 결과.</p>
        </a>
        <a class="ts-link-card" href={withBase("/tools/child-tutoring-cost-calculator/")}>
          <span class="ts-link-card__eyebrow">관련 계산기</span>
          <strong>아이 사교육비 계산기</strong>
          <p>교육 정책과 연계한 가구별 교육비 확인.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/daycare-kindergarten-cost-2026/")}>
          <span class="ts-link-card__eyebrow">관련 리포트</span>
          <strong>어린이집·유치원 실비용</strong>
          <p>돌봄 정책 공약과 연계한 실비용 비교.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/lee-jaemyung-government-officials-assets-salary-2026/")}>
          <span class="ts-link-card__eyebrow">관련 리포트</span>
          <strong>이재명 정부 공직자 재산·보수</strong>
          <p>이재명 정부 핵심 공직자 재산 공개 내역 비교.</p>
        </a>
      </div>
    </section>

    <SeoContent
      introTitle="2026 교육감 당선자 공약 완전 정리"
      intro={[
        "서울시 교육감 정근식(진보 성향)이 재선에 성공했습니다. 학생인권조례 유지·혁신학교 확대·무상급식 전면 실시 등 진보 교육 정책을 계속 추진할 예정입니다.",
        "교육감 선거는 정당 표시 없이 치러지지만, 후보의 공약과 이력으로 진보·보수 성향을 파악할 수 있습니다. 비교계산소는 각 교육감의 공약을 6개 카테고리(교육과정·학생인권·교원처우·돌봄·디지털교육·직업교육)로 정리합니다.",
        "나머지 16개 시도 교육감 데이터는 선관위 최종 확정 후 순차적으로 업데이트될 예정입니다.",
      ]}
      criteria={[
        "서울 정근식 당선은 선관위 개표 결과 기준 (2026-06-04 99.79% 집계)",
        "진보/보수 성향 분류는 공약·이력 기반 편집부 기준 — 공식 지표 아님",
        "나머지 16개 시도 교육감은 선관위 최종 확정 후 업데이트 예정",
        "공약은 선관위 정책·공약마당 기반 요약 예정",
      ]}
      faq={faqItems.map(f => ({ question: f.question, answer: f.answer }))}
      related={[
        { href: "/reports/local-election-governor-2026/",        label: "2026 시도지사 당선자 공약 지도" },
        { href: "/reports/local-election-seoul-2026/",           label: "서울 25개 구청장 당선자 지도 2026" },
        { href: "/reports/local-election-byeollection-2026/",    label: "2026 재보궐선거 당선자 총정리" },
        { href: "/tools/child-tutoring-cost-calculator/",        label: "아이 사교육비 계산기" },
      ]}
    />

  </main>

  <script define:vars={{ eduData: SUPERINTENDENTS, eduMeta: EDU_META }}>
    window.EDU_DATA = eduData;
    window.EDU_META = eduMeta;
  </script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="/scripts/local-election-superintendent-2026.js" defer></script>
</BaseLayout>
