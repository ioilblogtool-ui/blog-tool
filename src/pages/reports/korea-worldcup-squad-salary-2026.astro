---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  KWSS_META,
  KWSS_MATCH_CONTEXT,
  KWSS_EXCHANGE_RATES,
  KWSS_PLAYERS,
  KWSS_FAQ,
  KWSS_RELATED_LINKS,
} from "../../data/koreaWorldcupSquadSalary2026";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${KWSS_META.slug}/`;
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const rates = Object.fromEntries(KWSS_EXCHANGE_RATES.map((rate) => [rate.code, rate.krwRate]));
const toKrw = (amount: number, currency: string) => Math.round(amount * (rates[currency] ?? 1));
const players = KWSS_PLAYERS
  .map((player) => ({ ...player, krwSalary: toKrw(player.salaryAmount, player.salaryCurrency) }))
  .sort((a, b) => b.krwSalary - a.krwSalary);
const featuredPlayers = players.filter((player) => player.isFeatured).slice(0, 6);
const totalTop10 = players.slice(0, 10).reduce((sum, player) => sum + player.krwSalary, 0);
const topPlayer = players[0];
const overseasTotal = players
  .filter((player) => player.league !== "K리그1")
  .reduce((sum, player) => sum + player.krwSalary, 0);
const positionTotals = ["FW", "MF", "DF", "GK"].map((position) => ({
  position,
  total: players.filter((player) => player.position === position).reduce((sum, player) => sum + player.krwSalary, 0),
}));
const maxPositionTotal = Math.max(...positionTotals.map((item) => item.total));

const formatEok = (value: number) => `${(value / 100000000).toFixed(value >= 1000000000 ? 0 : 1)}억`;
const formatOriginalSalary = (amount: number, currency: string) => {
  if (currency === "KRW") return formatEok(amount);
  const symbols: Record<string, string> = { USD: "$", EUR: "€", GBP: "£" };
  return `${symbols[currency] ?? ""}${(amount / 1000000).toFixed(amount >= 1000000 ? 1 : 2)}M`;
};

const reportData = {
  rates,
  players: KWSS_PLAYERS,
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: KWSS_META.title,
    description: KWSS_META.description,
    dateModified: KWSS_META.updatedAt,
    mainEntityOfPage: reportUrl,
    author: { "@type": "Organization", name: "비교계산소" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: KWSS_FAQ.map((f) => ({
      "@type": "Question",
      name: f.question,
      acceptedAnswer: { "@type": "Answer", text: f.answer },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
      { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
      { "@type": "ListItem", position: 3, name: KWSS_META.title, item: reportUrl },
    ],
  },
];
---

<BaseLayout title={KWSS_META.seoTitle} description={KWSS_META.seoDescription} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page kwss-page" data-report="korea-worldcup-squad-salary-2026">
    <CalculatorHero
      eyebrow="월드컵·스포츠 연봉 리포트"
      title={KWSS_META.title}
      description="첫 경기 승리로 관심이 커진 대한민국 대표팀 주요 선수의 보도 기준 추정 연봉을 원화, 월급, 일급, 경기 90분 기준으로 환산합니다."
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        KWSS_META.dataNote,
        "경기 90분 기준 금액은 실제 출전 수당이 아니라 연봉을 시간 단위로 나눈 체감용 단순 환산입니다.",
        "연봉 출처 신뢰도가 낮은 선수는 확인 필요 배지로 분리했습니다.",
      ]}
    />

    <section class="content-section kwss-match-card" aria-labelledby="kwss-match-title">
      <div>
        <p class="kwss-eyebrow">경기 맥락</p>
        <h2 id="kwss-match-title">{KWSS_MATCH_CONTEXT.matchLabel}</h2>
        <p>{KWSS_MATCH_CONTEXT.summary}</p>
      </div>
      <a href={KWSS_MATCH_CONTEXT.sourceUrl} target="_blank" rel="noopener noreferrer" class="kwss-source-link">
        {KWSS_MATCH_CONTEXT.sourceLabel}
      </a>
    </section>

    <section class="content-section kwss-controls" aria-labelledby="kwss-controls-title">
      <div class="kwss-section-heading">
        <p>환율 조정</p>
        <h2 id="kwss-controls-title">환율을 바꾸면 원화 순위가 다시 계산됩니다</h2>
        <span>기본값은 참고용입니다. 발행일과 실제 조회 시점의 환율은 다를 수 있습니다.</span>
      </div>
      <div class="kwss-control-grid">
        <label>
          <span>USD 환율</span>
          <input type="number" inputmode="numeric" min="100" max="3000" value={rates.USD} data-rate-input="USD" />
        </label>
        <label>
          <span>EUR 환율</span>
          <input type="number" inputmode="numeric" min="100" max="3000" value={rates.EUR} data-rate-input="EUR" />
        </label>
        <label>
          <span>GBP 환율</span>
          <input type="number" inputmode="numeric" min="100" max="3000" value={rates.GBP} data-rate-input="GBP" />
        </label>
        <label>
          <span>보기 단위</span>
          <select data-view-mode>
            <option value="annual">연봉</option>
            <option value="monthly">월급</option>
            <option value="daily">일급</option>
            <option value="match90">90분 기준</option>
          </select>
        </label>
      </div>
      <div class="kwss-control-actions">
        <button type="button" data-reset-rates>기본 환율로 되돌리기</button>
        <button type="button" data-copy-link>현재 설정 링크 복사</button>
        <span data-copy-status aria-live="polite"></span>
      </div>
    </section>

    <section class="content-section kwss-kpi-section" aria-label="대표팀 연봉 요약">
      <div class="kwss-kpi-grid">
        <article class="kwss-kpi-card kwss-kpi-card--primary">
          <span>추정 1위</span>
          <strong>{topPlayer.nameKo}</strong>
          <small data-kpi="top-player">{formatEok(topPlayer.krwSalary)} · {topPlayer.sourceBadge}</small>
        </article>
        <article class="kwss-kpi-card">
          <span>TOP 10 합계</span>
          <strong data-kpi="top10-total">{formatEok(totalTop10)}</strong>
          <small>주요 선수 기준 추정 합계</small>
        </article>
        <article class="kwss-kpi-card">
          <span>해외파 합계</span>
          <strong data-kpi="overseas-total">{formatEok(overseasTotal)}</strong>
          <small>해외 리그 소속 선수 기준</small>
        </article>
        <article class="kwss-kpi-card">
          <span>출처 주의</span>
          <strong>전원 배지 표기</strong>
          <small>보도 기준·추정·확인 필요</small>
        </article>
      </div>
    </section>

    <section class="content-section kwss-featured-section" aria-labelledby="kwss-featured-title">
      <div class="kwss-section-heading">
        <p>주요 선수</p>
        <h2 id="kwss-featured-title">검색 수요가 큰 선수 먼저 보기</h2>
        <span>각 카드는 기본 환율 기준이며, 위 환율 입력을 바꾸면 함께 갱신됩니다.</span>
      </div>
      <div class="kwss-featured-grid">
        {featuredPlayers.map((player) => (
          <article class="kwss-player-card" data-player-card={player.id}>
            <div class="kwss-player-card__top">
              <div>
                <strong>{player.nameKo}</strong>
                <span>{player.club} · {player.position}</span>
              </div>
              <em class:list={["kwss-badge", `kwss-badge--${player.sourceBadge.replace(/\s/g, "-")}`]}>
                {player.sourceBadge}
              </em>
            </div>
            <div class="kwss-player-card__money">
              <span>원화 환산 연봉</span>
              <strong data-player-value={player.id}>{formatEok(player.krwSalary)}</strong>
              <small>{formatOriginalSalary(player.salaryAmount, player.salaryCurrency)} · {player.salaryCurrency}</small>
            </div>
            <div class="kwss-player-card__meta">
              <p><span>월급</span><strong data-player-monthly={player.id}>{formatEok(player.krwSalary / 12)}</strong></p>
              <p><span>90분</span><strong data-player-match90={player.id}>{Math.round(player.krwSalary / 365 / 24 / 60 * 90).toLocaleString()}원</strong></p>
            </div>
            <p class="kwss-player-note">{player.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section kwss-ranking-section" aria-labelledby="kwss-ranking-title">
      <div class="kwss-section-heading">
        <p>추정 순위</p>
        <h2 id="kwss-ranking-title">대표팀 주요 선수 추정 연봉 TOP 12</h2>
        <span>동일 기준 비교를 위해 모든 금액을 원화로 환산했습니다.</span>
      </div>
      <div class="kwss-table-wrap">
        <table class="kwss-ranking-table">
          <caption>대한민국 월드컵 대표팀 주요 선수 추정 연봉 순위</caption>
          <thead>
            <tr>
              <th>순위</th>
              <th>선수</th>
              <th>소속</th>
              <th>원 통화</th>
              <th>원화 환산</th>
              <th>월급</th>
              <th>90분 기준</th>
              <th>출처</th>
            </tr>
          </thead>
          <tbody data-ranking-body>
            {players.map((player, index) => (
              <tr data-player-row={player.id}>
                <td data-rank-cell>{index + 1}</td>
                <td>
                  <strong>{player.nameKo}</strong>
                  <small>{player.position} · {player.nameEn}</small>
                </td>
                <td>{player.club}<small>{player.league}</small></td>
                <td>{formatOriginalSalary(player.salaryAmount, player.salaryCurrency)}</td>
                <td data-table-annual={player.id}>{formatEok(player.krwSalary)}</td>
                <td data-table-monthly={player.id}>{formatEok(player.krwSalary / 12)}</td>
                <td data-table-match90={player.id}>{Math.round(player.krwSalary / 365 / 24 / 60 * 90).toLocaleString()}원</td>
                <td>
                  <span class:list={["kwss-badge", `kwss-badge--${player.sourceBadge.replace(/\s/g, "-")}`]}>
                    {player.sourceBadge}
                  </span>
                  <small>{player.sourceLabel}</small>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section kwss-position-section" aria-labelledby="kwss-position-title">
      <div class="kwss-section-heading">
        <p>포지션별 합계</p>
        <h2 id="kwss-position-title">공격수와 수비수의 보수 구조가 다르게 보입니다</h2>
        <span>선수 표본이 제한적이므로 포지션 전체 평균이 아니라 이 페이지에 포함된 선수 기준 합계입니다.</span>
      </div>
      <div class="kwss-position-list">
        {positionTotals.map((item) => (
          <div class="kwss-position-row" data-position-row={item.position}>
            <div>
              <strong>{item.position}</strong>
              <span data-position-total={item.position}>{formatEok(item.total)}</span>
            </div>
            <div class="kwss-position-track">
              <span style={`width:${Math.max((item.total / maxPositionTotal) * 100, 6)}%`} data-position-bar={item.position}></span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="content-section kwss-limit-section" aria-labelledby="kwss-limit-title">
      <div class="kwss-section-heading">
        <p>읽는 법</p>
        <h2 id="kwss-limit-title">이 숫자를 공식 연봉처럼 읽으면 안 됩니다</h2>
      </div>
      <div class="kwss-limit-grid">
        <article>
          <strong>세전 단순 환산</strong>
          <p>세금, 보너스, 초상권, 광고 수입, 환율 체결 시점은 반영하지 않았습니다.</p>
        </article>
        <article>
          <strong>출처 등급 분리</strong>
          <p>신뢰도가 높은 보도는 보도 기준, 출처 차이가 큰 값은 추정 또는 확인 필요로 표시했습니다.</p>
        </article>
        <article>
          <strong>대표팀 전체 평균 아님</strong>
          <p>연봉 출처가 확인되는 주요 선수 위주로 시작한 리포트입니다. 최종 명단 전체 평균으로 해석하면 안 됩니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section kwss-related-section" aria-labelledby="kwss-related-title">
      <div class="kwss-section-heading">
        <p>같이 보기</p>
        <h2 id="kwss-related-title">스포츠와 연봉 리포트 더 보기</h2>
      </div>
      <div class="kwss-related-grid">
        {KWSS_RELATED_LINKS.map((link) => (
          <a href={withBase(link.href)}>{link.label}</a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="월드컵 대표팀 연봉 순위를 볼 때 주의할 점"
      intro={[
        "월드컵 첫 경기 승리 이후에는 득점 장면, 다음 경기 일정, 선수 개인 기록과 함께 대표팀 선수들의 연봉과 소속팀을 검색하는 수요가 크게 늘어납니다. 이 리포트는 경기 해설보다 숫자 환산에 초점을 맞춥니다. 손흥민, 김민재, 이강인처럼 해외 리그에서 뛰는 선수의 보도 기준 연봉을 원화로 바꾸고, 월급·일급·경기 90분 기준으로 다시 나눠 체감할 수 있게 구성했습니다.",
        "다만 축구 선수 연봉은 국내 공무원 봉급표나 상장사 사업보고서처럼 같은 양식으로 공개되지 않습니다. 일부 리그는 선수협이나 언론 보도를 통해 보수가 알려지지만, 많은 선수는 샐러리 DB와 현지 보도를 교차해 추정해야 합니다. 그래서 이 페이지는 모든 금액을 공식 연봉이 아니라 보도 기준 또는 추정값으로 표시합니다.",
        "결과를 읽을 때는 원화 환산값의 크기보다 출처 등급과 통화 기준을 함께 봐야 합니다. 달러, 유로, 파운드로 표시된 금액은 환율이 바뀌면 원화 순위도 달라질 수 있습니다. 90분 기준 금액은 실제 출전 수당이 아니라 연봉을 시간으로 나눈 체감용 계산이므로 경기력 평가나 보너스 추정으로 사용하면 안 됩니다.",
        "이 리포트는 선수의 실제 실수령액을 추정하지 않습니다. 세금, 에이전트 수수료, 보너스, 초상권, 광고 계약, 대표팀 포상금은 모두 제외했습니다. 연봉이 공개되지 않은 선수는 확인 필요로 분리했고, 월드컵 기간 중 소속팀과 계약 보도가 바뀌면 업데이트가 필요합니다.",
      ]}
      inputPoints={[
        "주요 선수의 보도 기준 추정 연봉을 원화로 비교할 수 있습니다.",
        "달러·유로·파운드 환율을 직접 바꿔 원화 순위 변화를 확인할 수 있습니다.",
        "연봉을 월급, 일급, 경기 90분 기준으로 환산해 체감할 수 있습니다.",
      ]}
      criteria={[
        "연봉은 세전 단순 환산이며 실제 실수령액이 아닙니다.",
        "출처가 약한 선수는 확인 필요 배지로 분리했습니다.",
        "경기 90분 기준 금액은 실제 경기 수당이나 승리 포상금이 아닙니다.",
      ]}
      faq={KWSS_FAQ}
      related={KWSS_RELATED_LINKS}
    />

    <script type="application/json" id="kwss-data" set:html={JSON.stringify(reportData)} />
    <script src={withBase("/scripts/korea-worldcup-squad-salary-2026.js")} defer></script>
  </main>
</BaseLayout>
