---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import OwnershipTree from "../../components/OwnershipTree.astro";
import {
  LOTTE_META,
  LOTTE_TREE_NODES,
  LOTTE_OWNERSHIP_FACTS,
  LOTTE_FAQ,
  LOTTE_SEO_INTRO,
  LOTTE_SEO_CRITERIA,
  LOTTE_KPI_CARDS,
  LOTTE_DUAL_AXIS,
  LOTTE_KOREA_JAPAN_COMPARISON,
  LOTTE_HOTEL_ROLE_ROWS,
  LOTTE_OWNER_STAKE_GUIDE,
  LOTTE_TIMELINE,
  LOTTE_BUSINESS_AXES,
  LOTTE_NAV_FORMULA_ROWS,
  LOTTE_HOTEL_IPO_SIMULATION_ROWS,
  LOTTE_STOCK_DRIVER_ROWS,
  LOTTE_GROUP_COMPARISON,
  LOTTE_LISTED_DETAIL_ROWS,
} from "../../data/lotteGroupOwnership2026";
import type { SourceConfidence } from "../../data/groupOwnershipTypes";

const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteUrl}/reports/lotte-group-ownership-2026/`;

const title = "롯데그룹 지분구조 2026 완전 정리 | 롯데지주·일본 롯데 연결 구조";
const description =
  "롯데지주 중심 국내 지배구조와 일본 롯데홀딩스·호텔롯데 연결을 분리해 정리. 신동빈 지분, 호텔롯데 상장 변수, 상장 계열사 목록 포함.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": pageUrl,
  url: pageUrl,
  headline: title,
  description,
  inLanguage: "ko-KR",
  datePublished: LOTTE_META.updatedAt,
  dateModified: LOTTE_META.updatedAt,
};

function confidenceLabel(c: SourceConfidence): string {
  if (c === "HIGH") return "높음";
  if (c === "MEDIUM") return "중간";
  return "낮음";
}
function confidenceClass(c: SourceConfidence): string {
  if (c === "HIGH") return "high";
  if (c === "MEDIUM") return "medium";
  return "low";
}
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiteHeader />
  <main class="container page-shell lto-page">

    <CalculatorHero
      eyebrow="롯데그룹"
      title="롯데그룹 지분구조 2026 완전 정리"
      description="롯데지주 중심 국내 지배구조와 호텔롯데를 통한 한·일 연결 구조를 나눠서 정리했습니다."
    />

    <InfoNotice
      title="데이터 안내"
      lines={[
        LOTTE_META.dataSourceNotice,
        `계열사·상장사 수 기준일: ${LOTTE_META.affiliateCountBaseDate} (공정거래위원회 지정)`,
        `콘텐츠 업데이트: ${LOTTE_META.updatedAt}`,
      ]}
    />

    <!-- 섹션 1: 지주회사 체제인가 -->
    <section class="content-section lto-holding-note" aria-labelledby="holding-title">
      <h2 id="holding-title">롯데는 지주회사 체제인가?</h2>
      <p>{LOTTE_META.holdingCompanyNote}</p>
    </section>

    <section class="content-section" aria-labelledby="kpi-title">
      <h2 id="kpi-title">롯데 지배구조 핵심 KPI</h2>
      <div class="lto-kpi-grid">
        {
          LOTTE_KPI_CARDS.map((card) => (
            <article class="lto-kpi-card">
              <span>{card.label}</span>
              <strong>{card.value}</strong>
              <p>{card.note}</p>
            </article>
          ))
        }
      </div>
      <p class="lto-small-note">
        위 항목은 비교계산소가 공개자료를 기준으로 정리한 참고 지표입니다. 공식 신용평가나 법률 판단이 아닙니다.
      </p>
    </section>

    <!-- 섹션 1-2: 왜 일본 롯데 연결이 남아있나? (롯데그룹 전용 섹션) -->
    <section class="content-section lto-japan-note" aria-labelledby="japan-title">
      <h2 id="japan-title">국내 지분 축과 한·일 연결 축을 나눠 봐야 하는 이유</h2>
      <p>
        호텔롯데는 롯데지주의 주요 주주이지만, 롯데지주의 지배구조 전체를 일본 롯데홀딩스→호텔롯데 한 줄로만
        설명하기는 어렵습니다. 롯데지주는 신동빈 회장 개인, 최대주주 및 특수관계인, 호텔롯데, 일본 롯데홀딩스 등
        여러 주주가 함께 얽혀 있으므로 국내 주주 구조와 호텔롯데를 통한 한·일 연결을 분리해 보는 편이 정확합니다.
      </p>
      <div class="lto-axis-pair">
        {
          LOTTE_DUAL_AXIS.map((axis) => (
            <article>
              <h3>{axis.title}</h3>
              <div class="lto-axis-flow">
                {axis.path.map((item, index) => (
                  <>
                    <span>{item}</span>
                    {index < axis.path.length - 1 && <b>→</b>}
                  </>
                ))}
              </div>
              <p>{axis.note}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="nationality-title">
      <h2 id="nationality-title">롯데는 한국 기업인가, 일본 기업인가?</h2>
      <p class="lto-section-lead">
        롯데는 한국과 일본에 각각 법인과 사업 기반을 둔 기업집단으로 봐야 합니다. 국내 주요 상장 계열사는 한국 법인이며
        롯데지주를 중심으로 정리돼 있지만, 비상장 핵심회사인 호텔롯데의 주주 구조에는 일본 롯데홀딩스와 L투자회사들이 연결돼 있습니다.
      </p>
      <table class="lto-fact-table">
        <thead>
          <tr>
            <th>항목</th>
            <th>한국 롯데</th>
            <th>일본 롯데</th>
          </tr>
        </thead>
        <tbody>
          {
            LOTTE_KOREA_JAPAN_COMPARISON.map((row) => (
              <tr>
                <td>{row.label}</td>
                <td>{row.korea}</td>
                <td>{row.japan}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <p class="lto-small-note">
        “전적으로 일본 기업이다”와 “일본과 아무 관계 없는 국내 기업이다”는 둘 다 과도한 단순화입니다.
      </p>
    </section>

    <!-- 섹션 2: 지분 연결도 -->
    <section class="content-section" aria-labelledby="tree-title">
      <h2 id="tree-title">지분 연결도: 국내 축과 한·일 축 분리</h2>
      <OwnershipTree nodes={LOTTE_TREE_NODES} ariaLabel="롯데그룹 지분 연결도" />
      <p class="lto-tree-note">
        일본 롯데홀딩스를 전체 그룹의 단일 최상위 루트로 두면 롯데지주를 일직선으로 직접 지배하는 것처럼 보일 수 있습니다.
        그래서 국내 최대주주 등→롯데지주 축과 일본 롯데홀딩스·L투자회사→호텔롯데 축을 분리했습니다.
      </p>
    </section>

    <section class="content-section" aria-labelledby="hotel-title">
      <h2 id="hotel-title">비상장사 호텔롯데가 중요한 이유</h2>
      <p class="lto-section-lead">
        호텔롯데는 단순한 지분 보유용 회사가 아니라 호텔·면세점 등 사업을 운영하는 비상장 사업회사이면서,
        한국 롯데와 일본 롯데를 연결하는 지분구조상의 핵심회사입니다.
      </p>
      <div class="lto-insight-grid">
        {
          LOTTE_HOTEL_ROLE_ROWS.map((row) => (
            <article class="lto-insight-card">
              <h3>{row.reason}</h3>
              <p>{row.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="owner-guide-title">
      <h2 id="owner-guide-title">신동빈 회장 지분은 이렇게 구분해야 합니다</h2>
      <table class="lto-fact-table">
        <thead>
          <tr>
            <th>구분</th>
            <th>표시값</th>
            <th>주의점</th>
          </tr>
        </thead>
        <tbody>
          {
            LOTTE_OWNER_STAKE_GUIDE.map((row) => (
              <tr>
                <td>{row.type}</td>
                <td>{row.value}</td>
                <td>{row.caution}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <!-- 섹션 3: 오너·핵심 연결 표 -->
    <section class="content-section" aria-labelledby="facts-title">
      <h2 id="facts-title">오너 및 핵심 지분 연결</h2>
      <table class="lto-fact-table">
        <thead>
          <tr>
            <th>연결</th>
            <th>지분율</th>
            <th>기준일</th>
            <th>출처</th>
            <th>신뢰도</th>
          </tr>
        </thead>
        <tbody>
          {
            LOTTE_OWNERSHIP_FACTS.map((f) => (
              <tr>
                <td>{f.label}</td>
                <td>{f.ratePercent}%</td>
                <td>{f.baseDate}</td>
                <td><a href={f.sourceUrl} target="_blank" rel="noopener noreferrer">{f.sourceLabel}</a></td>
                <td>
                  <span class={`lto-confidence-badge lto-confidence-badge--${confidenceClass(f.confidence)}`}>
                    {confidenceLabel(f.confidence)}
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="timeline-title">
      <h2 id="timeline-title">국내 순환출자 해소 전후 타임라인</h2>
      <div class="lto-timeline">
        {
          LOTTE_TIMELINE.map((item) => (
            <article>
              <span>{item.period}</span>
              <strong>{item.change}</strong>
              <p>{item.meaning}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="business-title">
      <h2 id="business-title">사업축별 그룹 지도</h2>
      <div class="lto-business-grid">
        {
          LOTTE_BUSINESS_AXES.map((axis) => (
            <article>
              <h3>{axis.axis}</h3>
              <p>{axis.companies}</p>
              <small>{axis.note}</small>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="nav-title">
      <h2 id="nav-title">롯데지주 NAV 할인은 어떻게 계산하나?</h2>
      <p class="lto-section-lead">
        롯데지주는 여러 자회사에 분산 투자하는 효과가 있지만, 특정 사업에 직접 투자하는 것과는 다릅니다.
        자회사 가치가 상승하더라도 지주회사 할인, 순차입금, 배당 유입 규모에 따라 롯데지주 주가 반영 정도가 달라질 수 있습니다.
      </p>
      <div class="lto-formula-card">
        {LOTTE_NAV_FORMULA_ROWS.map((row) => <p>{row}</p>)}
      </div>
      <div class="lto-formula-card lto-formula-card--plain">
        <strong>지주회사 할인율 = 1 - 롯데지주 시가총액 ÷ 추정 NAV</strong>
      </div>
    </section>

    <section class="content-section" aria-labelledby="ipo-title">
      <h2 id="ipo-title">호텔롯데 상장 시뮬레이션은 무엇을 봐야 하나?</h2>
      <p class="lto-section-lead">
        실제 호텔롯데 상장 계획, 기업가치, 신주 발행 조건을 예측하는 것이 아니라 사용자가 가정값을 넣어 지분 희석과 유통비중 변화를 보는 방식이 적절합니다.
      </p>
      <table class="lto-fact-table">
        <thead>
          <tr>
            <th>입력값</th>
            <th>확인 결과</th>
          </tr>
        </thead>
        <tbody>
          {
            LOTTE_HOTEL_IPO_SIMULATION_ROWS.map((row) => (
              <tr>
                <td>{row.input}</td>
                <td>{row.result}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <div class="lto-formula-card lto-formula-card--plain">
        <strong>상장 후 기존 주주 지분율 = 상장 전 지분율 × 기존 주식 수 ÷ 상장 후 전체 주식 수</strong>
      </div>
    </section>

    <section class="content-section" aria-labelledby="driver-title">
      <h2 id="driver-title">롯데지주와 자회사 주가는 왜 따로 움직이나?</h2>
      <table class="lto-fact-table">
        <thead>
          <tr>
            <th>종목</th>
            <th>주가 핵심 변수</th>
          </tr>
        </thead>
        <tbody>
          {
            LOTTE_STOCK_DRIVER_ROWS.map((row) => (
              <tr>
                <td>{row.stock}</td>
                <td>{row.driver}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <!-- 섹션 4: 상장 계열사 목록 -->
    <section class="content-section" aria-labelledby="listed-title">
      <h2 id="listed-title">상장 계열사 목록 ({LOTTE_META.listedAffiliateCount}개 확인)</h2>
      <table class="lto-listed-table">
        <thead>
          <tr>
            <th>회사명</th>
            <th>종목코드</th>
            <th>사업 분야</th>
            <th>연결 상위사</th>
            <th>구조상 역할</th>
          </tr>
        </thead>
        <tbody>
          {
            LOTTE_LISTED_DETAIL_ROWS.map((c) => (
              <tr>
                <td>{c.name}</td>
                <td>{c.code}</td>
                <td>{c.business}</td>
                <td>{c.parent}</td>
                <td>{c.role}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <p class="lto-small-note">
        롯데렌탈처럼 거래소 상장 여부와 롯데 기업집단 편입 상태를 동일 기준일로 재확인해야 하는 항목은 확정 목록에서 제외했습니다.
      </p>
    </section>

    <section class="content-section" aria-labelledby="compare-title">
      <h2 id="compare-title">삼성·SK·LG·현대차·한화와 비교</h2>
      <table class="lto-fact-table">
        <thead>
          <tr>
            <th>그룹</th>
            <th>법적 지주회사</th>
            <th>핵심 특징</th>
            <th>대표 투자 이슈</th>
          </tr>
        </thead>
        <tbody>
          {
            LOTTE_GROUP_COMPARISON.map((row) => (
              <tr>
                <td>{row.group}</td>
                <td>{row.legalHolding}</td>
                <td>{row.keyword}</td>
                <td>{row.issue}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <!-- 섹션 5: CTA -->
    <section class="content-section" aria-labelledby="cta-title">
      <h2 id="cta-title">이어서 확인하면 좋은 콘텐츠</h2>
      <div class="lto-cta-group">
        <a href="/reports/samsung-group-ownership-2026/">삼성그룹 지분구조 →</a>
        <a href="/reports/sk-group-ownership-2026/">SK그룹 지분구조 →</a>
        <a href="/reports/hyundai-motor-group-ownership-2026/">현대차그룹 지분구조 →</a>
        <a href="/reports/lg-group-ownership-2026/">LG그룹 지분구조 →</a>
        <a href="/reports/hanwha-group-ownership-2026/">한화그룹 지분구조 →</a>
        <a href="/reports/hd-hyundai-group-ownership-2026/">HD현대그룹 지분구조 →</a>
        <a href="/reports/ls-group-ownership-2026/">LS그룹 지분구조 →</a>
        <a href="/reports/doosan-group-ownership-2026/">두산그룹 지분구조 →</a>
        <a href="/reports/group-ownership-hub-2026/">9개 그룹 비교 허브 →</a>
        <a href="/tools/">계산기 전체 보기 →</a>
        <a href="/reports/">리포트 전체 보기 →</a>
      </div>
    </section>

    <SeoContent
      introTitle="롯데그룹 지분구조, 국경을 넘어가는 지배구조"
      intro={LOTTE_SEO_INTRO}
      criteria={LOTTE_SEO_CRITERIA}
      faq={LOTTE_FAQ.map((f) => ({ question: f.question, answer: f.answer }))}
      related={[
        { href: "/reports/samsung-group-ownership-2026/", label: "삼성그룹 지분구조 2026" },
        { href: "/reports/sk-group-ownership-2026/", label: "SK그룹 지분구조 2026" },
        { href: "/reports/hyundai-motor-group-ownership-2026/", label: "현대차그룹 지분구조 2026" },
        { href: "/reports/lg-group-ownership-2026/", label: "LG그룹 지분구조 2026" },
        { href: "/reports/hanwha-group-ownership-2026/", label: "한화그룹 지분구조 2026" },
        { href: "/reports/hd-hyundai-group-ownership-2026/", label: "HD현대그룹 지분구조 2026" },
        { href: "/reports/ls-group-ownership-2026/", label: "LS그룹 지분구조 2026" },
        { href: "/reports/doosan-group-ownership-2026/", label: "두산그룹 지분구조 2026" },
        { href: "/reports/group-ownership-hub-2026/", label: "9개 그룹 지분구조 비교 허브" },
        { href: "/reports/", label: "리포트 전체 보기" },
        { href: "/tools/", label: "계산기 전체 보기" },
      ]}
    />
  </main>
</BaseLayout>
