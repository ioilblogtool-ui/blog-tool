---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  GMAP_APARTMENTS,
  GMAP_AREA_CARDS,
  GMAP_CONTEXT,
  GMAP_FAQ,
  GMAP_META,
  GMAP_METHOD,
  GMAP_RELATED_LINKS,
  GMAP_RISKS,
  GMAP_SEO_CRITERIA,
  GMAP_SEO_INTRO,
  formatEok,
} from "../../data/gangseoMagokApartmentPrice2026";
import { withBase } from "../../utils/base";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${GMAP_META.slug}/`;
const defaultApartment = GMAP_APARTMENTS[0];
const maxLatest = Math.max(...GMAP_APARTMENTS.map((row) => row.latestTradePriceManwon));
const maxGain = GMAP_APARTMENTS.reduce((max, row) => (row.estimatedGainManwon > max.estimatedGainManwon ? row : max), defaultApartment);
const magokCount = GMAP_APARTMENTS.filter((row) => row.areaGroup === "마곡·발산권").length;
const westCount = GMAP_APARTMENTS.filter((row) => row.areaGroup === "우장산·화곡권" || row.areaGroup === "가양·등촌권").length;

const summaryCards = [
  { label: "데이터 기준", value: GMAP_META.updatedAt, note: GMAP_META.dataAsOf },
  { label: "최고 기준가", value: formatEok(maxLatest), note: "국토교통부 원문 재검증 필요" },
  { label: "최대 평가차익(추정)", value: formatEok(maxGain.estimatedGainManwon), note: `${maxGain.complexName} 참고` },
  { label: "마곡·발산권 후보", value: `${magokCount}개`, note: "업무지구·신축급 단지 중심" },
  { label: "우장산·가양권 후보", value: `${westCount}개`, note: "실거주·9호선 생활권 중심" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: GMAP_META.title,
      description: GMAP_META.description,
      dateModified: GMAP_META.updatedAt,
      inLanguage: "ko-KR",
      mainEntityOfPage: reportUrl,
      author: { "@type": "Organization", name: "비교계산소" },
      about: ["강서 아파트", "마곡 아파트", "마곡 실거래가", "마곡엠밸리", "강서힐스테이트"],
    },
    {
      "@type": "FAQPage",
      mainEntity: GMAP_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
        { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
        { "@type": "ListItem", position: 3, name: GMAP_META.title, item: reportUrl },
      ],
    },
  ],
};
---

<BaseLayout title={GMAP_META.seoTitle} description={GMAP_META.description} jsonLd={jsonLd}>
  <SiteHeader />
  <main class="container page-shell report-page gmap-page" data-report="gangseo-magok-apartment-price-2026">
    <CalculatorHero
      eyebrow="강서·마곡 실거래가 리포트"
      title="강서·마곡 대장 아파트, 최저가일 때 샀다면 지금 얼마를 벌었을까?"
      description={GMAP_META.description}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        GMAP_META.notice,
        "이 리포트는 서울특별시 강서구 행정구역을 기준으로 하며, 생활권은 마곡·발산·우장산·가양·등촌 등으로 나눠 표시합니다.",
        "마곡 업무지구 접근성은 수요 요인 중 하나일 뿐이며, 현재 실거래가와 별도로 해석해야 합니다.",
        "후보 단지는 공식 단지명, 전용면적, 거래월, 취소 여부를 국토교통부 실거래가 공개시스템에서 다시 확인해야 합니다.",
        "최저가 대비 금액은 세금·중개보수·대출이자·보유비용을 반영하지 않은 평가차익(추정)입니다.",
        "이 리포트는 투자 권유가 아니며, 실제 거래 판단은 국토교통부 실거래가 공개시스템과 현장 확인을 기준으로 해야 합니다.",
      ]}
    />

    <section class="gmap-summary" aria-labelledby="gmap-summary-title">
      <div class="gmap-section-head">
        <p>요약</p>
        <h2 id="gmap-summary-title">강서·마곡 Top10 실거래 기준 한눈에 보기</h2>
      </div>
      <div class="gmap-summary-grid">
        {summaryCards.map((card) => (
          <article class="gmap-summary-card">
            <span>{card.label}</span>
            <strong>{card.value}</strong>
            <p>{card.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="gmap-picker" aria-labelledby="gmap-picker-title">
      <div class="gmap-section-head">
        <p>단지별 카드</p>
        <h2 id="gmap-picker-title">최저가일 때 샀다면 지금 평가차익은?</h2>
      </div>
      <div class="gmap-tabs" role="tablist" aria-label="강서·마곡 아파트 단지 선택">
        {GMAP_APARTMENTS.map((row, index) => (
          <button
            class={`gmap-tab${index === 0 ? " is-active" : ""}`}
            type="button"
            data-complex={row.id}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            {row.rank}. {row.complexName}
          </button>
        ))}
      </div>

      <article class="gmap-profit-card" aria-live="polite">
        <div class="gmap-profit-card__main">
          <span class="gmap-badge" data-gmap-field="badge">{defaultApartment.badge}</span>
          <p class="gmap-kicker" data-gmap-field="areaGroup">{defaultApartment.areaGroup} · {defaultApartment.legalDongLabel}</p>
          <h3 data-gmap-field="complexName">{defaultApartment.complexName}</h3>
          <p data-gmap-field="profitSentence">
            {defaultApartment.fiveYearLowDate} {formatEok(defaultApartment.fiveYearLowPriceManwon)}에 거래됐고, 현재 기준가는 {formatEok(defaultApartment.latestTradePriceManwon)}입니다.
          </p>
          <div class="gmap-profit-card__numbers">
            <div>
              <span>평가차익(추정)</span>
              <strong data-gmap-field="gain">{formatEok(defaultApartment.estimatedGainManwon)}</strong>
            </div>
            <div>
              <span>상승률(추정)</span>
              <strong data-gmap-field="gainRate">{defaultApartment.estimatedGainRate}%</strong>
            </div>
          </div>
        </div>
        <dl class="gmap-profit-card__meta">
          <div><dt>최근 기준가</dt><dd data-gmap-field="latest">{formatEok(defaultApartment.latestTradePriceManwon)}</dd></div>
          <div><dt>거래월·면적</dt><dd data-gmap-field="latestMeta">{defaultApartment.latestTradeDate} · {defaultApartment.latestTradeArea}</dd></div>
          <div><dt>5년 저점 참고</dt><dd data-gmap-field="low">{formatEok(defaultApartment.fiveYearLowPriceManwon)}</dd></div>
          <div><dt>업무지구·교통 메모</dt><dd data-gmap-field="workplace">{defaultApartment.workplaceNote}</dd></div>
          <div><dt>공항·한강 메모</dt><dd data-gmap-field="access">{defaultApartment.airportNote ?? defaultApartment.riverNote}</dd></div>
          <div><dt>주의</dt><dd data-gmap-field="note">{defaultApartment.note}</dd></div>
        </dl>
      </article>
      <p class="gmap-plain-note">
        이 금액은 취득세, 중개보수, 보유세, 대출이자, 양도소득세를 반영하지 않은 단순 시세 차이입니다. 같은 단지라도 동·층·향·면적·거래 시점에 따라 실제 가격은 크게 달라질 수 있습니다.
      </p>
    </section>

    <section class="gmap-table-section" aria-labelledby="gmap-table-title">
      <div class="gmap-section-head gmap-section-head--row">
        <div>
          <p>비교표</p>
          <h2 id="gmap-table-title">강서·마곡 대장 아파트 Top10 실거래가</h2>
        </div>
        <div class="gmap-sort-controls" aria-label="정렬 기준">
          <button class="is-active" type="button" data-sort="rank">순위</button>
          <button type="button" data-sort="gain">평가차익</button>
          <button type="button" data-sort="gainRate">상승률</button>
          <button type="button" data-sort="latestPrice">최근가</button>
          <button type="button" data-sort="area">생활권</button>
        </div>
      </div>
      <div class="gmap-table-wrap">
        <table class="gmap-table">
          <caption>강서·마곡 아파트 Top10 최근 기준가와 5년 저점 대비 평가차익 비교</caption>
          <thead>
            <tr>
              <th scope="col">순위</th>
              <th scope="col">단지명</th>
              <th scope="col">법정동</th>
              <th scope="col">생활권</th>
              <th scope="col">최근 기준가</th>
              <th scope="col">거래월</th>
              <th scope="col">2025 대비</th>
              <th scope="col">5년 저점</th>
              <th scope="col">평가차익(추정)</th>
              <th scope="col">전세가율</th>
              <th scope="col">주의</th>
            </tr>
          </thead>
          <tbody data-gmap-table-body>
            {GMAP_APARTMENTS.map((row) => (
              <tr data-row-id={row.id}>
                <td>{row.rank}</td>
                <th scope="row">
                  <strong>{row.complexName}</strong>
                  <span>{row.mainAreaLabel}</span>
                </th>
                <td>{row.legalDongLabel}</td>
                <td>{row.areaGroup}</td>
                <td>{formatEok(row.latestTradePriceManwon)}</td>
                <td>{row.latestTradeDate}</td>
                <td>{row.previousYearPriceManwon ? `${formatEok(row.latestTradePriceManwon - row.previousYearPriceManwon)} 상승 참고` : "확인 필요"}</td>
                <td>{formatEok(row.fiveYearLowPriceManwon)}</td>
                <td>{formatEok(row.estimatedGainManwon)} · {row.estimatedGainRate}%</td>
                <td>{row.jeonseRatio ? `${row.jeonseRatio}% 참고` : "확인 필요"}</td>
                <td>{row.tradeCountNote}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="gmap-area-map" aria-labelledby="gmap-area-title">
      <div class="gmap-section-head">
        <p>생활권</p>
        <h2 id="gmap-area-title">마곡·발산·우장산·가양 생활권 가격 차이</h2>
      </div>
      <div class="gmap-area-grid">
        {GMAP_AREA_CARDS.map((card) => (
          <article class="gmap-area-card">
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <strong>{card.priceInterpretation}</strong>
            <p>{card.description}</p>
            <small>{card.caution}</small>
          </article>
        ))}
      </div>
      <p class="gmap-plain-note">
        강서구는 마곡 업무지구 인접 신축축과 우장산·화곡 실거주축, 가양·등촌 9호선·한강 인접축의 가격 논리가 다릅니다. 같은 강서구 안에서도 업무지구 접근성, 입주연식, 단지 규모, 역 접근성, 거래 시점에 따라 가격 차이가 크게 나타날 수 있습니다.
      </p>
    </section>

    <section class="gmap-chart" aria-labelledby="gmap-chart-title">
      <div class="gmap-section-head">
        <p>막대 비교</p>
        <h2 id="gmap-chart-title">현재 기준가 vs 5년 저점 참고가</h2>
      </div>
      <div class="gmap-bar-list" data-gmap-bars>
        {GMAP_APARTMENTS.map((row) => (
          <article class="gmap-bar-row" data-row-id={row.id}>
            <div class="gmap-bar-row__label">
              <strong>{row.complexName}</strong>
              <span>{row.areaGroup}</span>
            </div>
            <div class="gmap-bar-row__bars">
              <span class="gmap-bar gmap-bar--latest" style={`width: ${Math.max(12, (row.latestTradePriceManwon / maxLatest) * 100)}%`}>{formatEok(row.latestTradePriceManwon)}</span>
              <span class="gmap-bar gmap-bar--low" style={`width: ${Math.max(12, (row.fiveYearLowPriceManwon / maxLatest) * 100)}%`}>{formatEok(row.fiveYearLowPriceManwon)}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="gmap-context" aria-labelledby="gmap-context-title">
      <div class="gmap-section-head">
        <p>가격 맥락</p>
        <h2 id="gmap-context-title">마곡 아파트가 주목받는 이유</h2>
      </div>
      <div class="gmap-context-grid">
        {GMAP_CONTEXT.map((card) => (
          <article class="gmap-context-card">
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="gmap-data-method" aria-labelledby="gmap-method-title">
      <div class="gmap-section-head">
        <p>데이터 기준</p>
        <h2 id="gmap-method-title">강서구 실거래가 데이터 기준</h2>
      </div>
      <ul class="gmap-risk-list">
        {GMAP_METHOD.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="gmap-risk" aria-labelledby="gmap-risk-title">
      <div class="gmap-section-head">
        <p>리스크</p>
        <h2 id="gmap-risk-title">평가차익보다 먼저 봐야 하는 변수</h2>
      </div>
      <ul class="gmap-risk-list">
        {GMAP_RISKS.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="gmap-related" aria-labelledby="gmap-related-title">
      <div class="gmap-section-head">
        <p>다음 단계</p>
        <h2 id="gmap-related-title">가격 확인 뒤 이어서 볼 리포트와 계산기</h2>
      </div>
      <div class="gmap-related-grid">
        {GMAP_RELATED_LINKS.map((link) => (
          <a class="gmap-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="강서·마곡 아파트 실거래가를 볼 때 먼저 확인할 것"
      intro={GMAP_SEO_INTRO}
      criteria={GMAP_SEO_CRITERIA}
      faq={GMAP_FAQ}
      related={GMAP_RELATED_LINKS}
    />

    <script type="application/json" id="gmap-data" set:html={JSON.stringify(GMAP_APARTMENTS)}></script>
    <script src={withBase("/scripts/gangseo-magok-apartment-price-2026.js")} defer></script>
  </main>
</BaseLayout>
