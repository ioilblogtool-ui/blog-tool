---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  BSR_APPLICATION_STEPS,
  BSR_CHECKLIST,
  BSR_FAILURE_CASES,
  BSR_FAQ,
  BSR_INSIGHTS,
  BSR_META,
  BSR_METRO_BENEFITS,
  BSR_NATIONAL_BENEFITS,
  BSR_REGIONS,
  BSR_RELATED_LINKS,
  BSR_SCENARIOS,
  BSR_SOURCE_LINKS,
} from "../../data/birthSupportByRegion2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const fmt = (value: number | null) => value === null ? "확인 필요" : `${Math.round(value / 10000).toLocaleString("ko-KR")}만원`;
const byProvince = (province: string) => BSR_REGIONS.filter((row) => row.province === province);
const badgeClass = (badge: string) => badge.replace(/\s+/g, "-");
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: BSR_META.title,
  description: BSR_META.description,
  inLanguage: "ko-KR",
  dateModified: BSR_META.updatedAt,
  mainEntityOfPage: `https://bigyocalc.com/reports/${BSR_META.slug}/`,
};
---

<BaseLayout title="2026 지역별 출산지원금 비교 | 서울·경기·지방 출산장려금 총정리" description={BSR_META.description} jsonLd={jsonLd}>
  <SiteHeader />
  <main class="container page-shell report-page bsr-page">
    <CalculatorHero
      eyebrow="출산·육아 지원금 리포트"
      title={BSR_META.title}
      description="국가 공통 지원금, 광역 지원, 시군구 자체 출산장려금을 분리해 서울·경기·지방 지역별 차이를 비교합니다."
    />
    <InfoNotice
      title="공식 확인 안내"
      lines={[
        "지자체 출산지원금은 조례, 예산, 거주요건에 따라 변경될 수 있어 신청 전 공식 페이지와 주민센터 확인이 필요합니다.",
        "표의 시군구 금액은 지자체 자체 현금 지원 중심입니다. 첫만남이용권·부모급여·아동수당은 국가 공통 지원 섹션에서 따로 봐야 합니다.",
        `업데이트 기준: ${BSR_META.updatedAt}`,
      ]}
    />
    <DesignTrustPanel
      title="지역별 출산지원금 비교 기준"
      updatedAt={BSR_META.updatedAt}
      notes={[
        "국가 공통 지원, 시도 광역 지원, 시군구 자체 지원을 분리했습니다.",
        "확인 필요 배지는 공식 금액으로 확정 입력하지 않은 항목입니다.",
        "총액이 큰 지역은 장기 분할 지급과 전출 중단 조건이 있을 수 있습니다.",
      ]}
    />

    <section class="content-section bsr-summary-section">
      <div class="bsr-summary-grid">
        <article><p>국가 공통 지원</p><strong>첫만남·부모급여·아동수당</strong><span>대부분 출생아 공통</span></article>
        <article><p>광역 지원</p><strong>서울형·경기도형 산후조리비</strong><span>시도별 별도 신청</span></article>
        <article><p>지역별 추가 지원</p><strong>출산장려금·축하금</strong><span>시·군·구별 편차 큼</span></article>
        <article><p>필수 확인</p><strong>거주요건·분할지급</strong><span>전입일과 전출 조건 주의</span></article>
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">국가 공통 지원</p>
        <h2>출산지원금은 국가 공통과 지자체 지원을 나눠 봐야 합니다</h2>
      </div>
      <div class="bsr-card-grid">
        {BSR_NATIONAL_BENEFITS.map((item) => (
          <article class="bsr-info-card">
            <span>{item.badge}</span>
            <strong>{item.name}</strong>
            <p class="bsr-info-card__amount">{item.amount}</p>
            <p>{item.desc}</p>
            <small>{item.apply}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">광역 지원</p>
        <h2>서울·경기처럼 시도 단위 지원은 시군구 장려금과 별도로 더합니다</h2>
      </div>
      <div class="bsr-card-grid">
        {BSR_METRO_BENEFITS.map((item) => (
          <article class="bsr-info-card">
            <span>{item.badge}</span>
            <strong>{item.name}</strong>
            <p class="bsr-info-card__amount">{item.amount}</p>
            <p>{item.desc}</p>
            <small>{item.apply}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 해석</p>
        <h2>지역별 금액표를 볼 때 놓치기 쉬운 차이</h2>
      </div>
      <div class="bsr-insight-grid">
        {BSR_INSIGHTS.map((item) => (
          <article class="bsr-insight-card">
            {item.value && <span>{item.value}</span>}
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    {["서울", "경기", "지방"].map((province) => (
      <section class="content-section">
        <div class="section-header section-header--compact">
          <p class="section-header__eyebrow">{province} 비교</p>
          <h2>{province} 지역 시군구 자체 지원금 확인표</h2>
          <p>아래 금액은 국가 공통 첫만남이용권·부모급여·아동수당을 제외한 지역 자체 지원 중심입니다.</p>
        </div>
        <div class="table-wrap">
          <table class="bsr-table">
            <thead><tr><th>지역</th><th>첫째</th><th>둘째</th><th>셋째 이상</th><th>별도 지원</th><th>거주요건</th><th>신청기한</th><th>상태</th></tr></thead>
            <tbody>
              {byProvince(province).map((row) => (
                <tr>
                  <td>
                    <strong>{row.region}</strong>
                    <small><a href={row.sourceUrl} target="_blank" rel="noopener noreferrer">{row.source}</a> · {row.lastCheckedAt}</small>
                    {row.note && <em>{row.note}</em>}
                  </td>
                  <td>{fmt(row.first)}</td>
                  <td>{fmt(row.second)}</td>
                  <td>{fmt(row.thirdOrMore)}</td>
                  <td>{row.extra}</td>
                  <td>{row.residence}</td>
                  <td>{row.deadline}</td>
                  <td><span class={`bsr-badge bsr-badge--${badgeClass(row.badge)}`}>{row.badge}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))}

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">사례별 보기</p>
        <h2>같은 출산지원금이라도 첫해 현금흐름은 다르게 보입니다</h2>
      </div>
      <div class="bsr-scenario-grid">
        {BSR_SCENARIOS.map((item) => (
          <article class="bsr-scenario-card">
            <span>{item.area}</span>
            <h3>{item.title}</h3>
            <p>{item.firstYear}</p>
            <small>{item.watch}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">신청 순서</p>
        <h2>출생신고 후에는 공통 지원부터 지역 지원까지 순서대로 확인하세요</h2>
      </div>
      <div class="bsr-step-list">
        {BSR_APPLICATION_STEPS.map((item) => (
          <article>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section bsr-check-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">신청 전 체크</p>
        <h2>주민센터에 문의하기 전 준비할 질문</h2>
      </div>
      <ul class="bsr-check-list">
        {BSR_CHECKLIST.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact"><p class="section-header__eyebrow">신청 실패 예방</p><h2>지원금은 금액보다 조건을 먼저 확인해야 합니다</h2></div>
      <div class="bsr-card-grid">{BSR_FAILURE_CASES.map((item) => <article class="bsr-warning-card">{item}</article>)}</div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">공식 출처</p>
        <h2>최종 신청 전 확인할 공식 페이지</h2>
      </div>
      <div class="bsr-source-grid">
        {BSR_SOURCE_LINKS.map((item) => (
          <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
        ))}
      </div>
    </section>

    <section class="content-section bsr-cta-section">
      <div><p class="section-header__eyebrow">계산기로 이어보기</p><h2>우리 집 기준 총수령액은 계산기로 확인하세요</h2><p>지역별 지원금은 변동 가능성이 있어 최종 신청 전 주민센터 확인이 필요합니다.</p></div>
      <a href={withBase("/tools/birth-support-money/")}>출산지원금 총수령액 계산기 열기</a>
    </section>

    <SeoContent
      introTitle="지역별 출산지원금 비교표 읽는 법"
      intro={[
        "출산을 앞두고 거주 지역에 따라 지원금이 얼마나 다른지 찾아보면 같은 나라인데도 지역별 격차가 생각보다 크다는 걸 알게 됩니다. 출산지원금은 첫만남이용권처럼 전국 공통으로 받는 항목, 서울형·경기도형처럼 광역자치단체가 운영하는 항목, 시군구 자체 출산장려금이 함께 적용되는 구조입니다.",
        "이 페이지는 세 항목을 섞지 않고 분리해서 보여줍니다. 그래서 지역별 표의 금액만 보고 총수령액으로 이해하지 말고, 국가 공통 지원과 광역 지원을 별도로 더해야 실제 받을 수 있는 총액을 정확히 파악할 수 있습니다.",
        "특히 고액 지원 지역은 총액보다 지급 기간과 전출 조건이 중요합니다. 몇 년에 걸쳐 나눠 받는 돈인지, 회차별 신청이 필요한지, 이사하면 남은 지급이 중단되는지를 먼저 확인해야 실제로 받을 수 있는 금액을 정확히 가늠할 수 있습니다.",
        "이 리포트의 지원금 정보는 각 지자체의 공개 자료를 기준으로 정리한 것이며, 지자체별 조례 개정에 따라 금액과 조건이 자주 바뀔 수 있습니다. 정확한 신청 자격과 금액은 거주지 관할 주민센터나 해당 지자체 홈페이지에서 다시 확인하는 것을 권장합니다.",
      ]}
      criteria={[
        "공식 페이지에서 금액과 조건을 확인한 항목은 공식 배지를 표시했습니다.",
        "확정 데이터가 없거나 조건 변동 가능성이 큰 지역은 확인 필요 또는 참고로 표시했습니다.",
        "거주요건, 신청기한, 지급수단, 분할 지급 조건은 실제 수령 가능 여부를 좌우합니다.",
        "첫만남이용권·부모급여·아동수당은 지역별 표에 중복 반영하지 않았습니다.",
      ]}
      faq={BSR_FAQ}
      related={BSR_RELATED_LINKS}
    />
  </main>
</BaseLayout>



