---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  GDAP_APARTMENTS,
  GDAP_AREA_CARDS,
  GDAP_CONTEXT,
  GDAP_FAQ,
  GDAP_META,
  GDAP_METHOD,
  GDAP_RELATED_LINKS,
  GDAP_RISKS,
  GDAP_SEO_CRITERIA,
  GDAP_SEO_INTRO,
  formatEok,
} from "../../data/gangdongApartmentPrice2026";
import { withBase } from "../../utils/base";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${GDAP_META.slug}/`;
const defaultApartment = GDAP_APARTMENTS[0];
const maxLatest = Math.max(...GDAP_APARTMENTS.map((row) => row.latestTradePriceManwon));
const maxGain = GDAP_APARTMENTS.reduce((max, row) => (row.estimatedGainManwon > max.estimatedGainManwon ? row : max), defaultApartment);
const godeokCount = GDAP_APARTMENTS.filter((row) => row.areaGroup === "고덕·상일권").length;
const dunchonCount = GDAP_APARTMENTS.filter((row) => row.areaGroup === "둔촌·성내권").length;

const summaryCards = [
  { label: "데이터 기준", value: GDAP_META.updatedAt, note: GDAP_META.dataAsOf },
  { label: "최고 기준가", value: formatEok(maxLatest), note: "국토교통부 원문 재검증 필요" },
  { label: "최대 평가차익(추정)", value: formatEok(maxGain.estimatedGainManwon), note: `${maxGain.complexName} 참고` },
  { label: "고덕·상일권 후보", value: `${godeokCount}개`, note: "신축 대단지 중심" },
  { label: "둔촌·성내권 후보", value: `${dunchonCount}개`, note: "입주 물량·재건축 맥락 분리" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: GDAP_META.title,
      description: GDAP_META.description,
      dateModified: GDAP_META.updatedAt,
      inLanguage: "ko-KR",
      mainEntityOfPage: reportUrl,
      author: { "@type": "Organization", name: "비교계산소" },
      about: ["강동 아파트", "강동 실거래가", "고덕그라시움", "고덕아르테온", "올림픽파크포레온"],
    },
    {
      "@type": "FAQPage",
      mainEntity: GDAP_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
        { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
        { "@type": "ListItem", position: 3, name: GDAP_META.title, item: reportUrl },
      ],
    },
  ],
};
---

<BaseLayout title={GDAP_META.seoTitle} description={GDAP_META.description} jsonLd={jsonLd}>
  <SiteHeader />
  <main class="container page-shell report-page gdap-page" data-report="gangdong-apartment-price-2026">
    <CalculatorHero
      eyebrow="강동 실거래가 리포트"
      title="강동 대장 아파트, 최저가일 때 샀다면 지금 얼마를 벌었을까?"
      description={GDAP_META.description}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        GDAP_META.notice,
        "이 리포트는 서울특별시 강동구 행정구역을 기준으로 하며, 생활권은 고덕·상일, 둔촌·성내, 명일·암사, 천호·강동역권으로 나눠 표시합니다.",
        "둔촌 재건축·입주 물량 기대감은 현재 실거래가와 분리해서 해석해야 합니다.",
        "후보 단지는 공식 단지명, 전용면적, 거래월, 취소 여부를 국토교통부 실거래가 공개시스템에서 다시 확인해야 합니다.",
        "최저가 대비 금액은 세금·중개보수·대출이자·보유비용을 반영하지 않은 평가차익(추정)입니다.",
        "이 리포트는 투자 권유가 아니며, 실제 거래 판단은 원문 실거래와 현장 확인을 기준으로 해야 합니다.",
      ]}
    />

    <section class="gdap-summary" aria-labelledby="gdap-summary-title">
      <div class="gdap-section-head">
        <p>요약</p>
        <h2 id="gdap-summary-title">강동 Top10 실거래 기준 한눈에 보기</h2>
      </div>
      <div class="gdap-summary-grid">
        {summaryCards.map((card) => (
          <article class="gdap-summary-card">
            <span>{card.label}</span>
            <strong>{card.value}</strong>
            <p>{card.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="gdap-picker" aria-labelledby="gdap-picker-title">
      <div class="gdap-section-head">
        <p>단지별 카드</p>
        <h2 id="gdap-picker-title">최저가일 때 샀다면 지금 평가차익은?</h2>
      </div>
      <div class="gdap-tabs" role="tablist" aria-label="강동 아파트 단지 선택">
        {GDAP_APARTMENTS.map((row, index) => (
          <button
            class={`gdap-tab${index === 0 ? " is-active" : ""}`}
            type="button"
            data-complex={row.id}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            {row.rank}. {row.complexName}
          </button>
        ))}
      </div>

      <article class="gdap-profit-card" aria-live="polite">
        <div class="gdap-profit-card__main">
          <span class="gdap-badge" data-gdap-field="badge">{defaultApartment.badge}</span>
          <p class="gdap-kicker" data-gdap-field="areaGroup">{defaultApartment.areaGroup} · {defaultApartment.legalDongLabel}</p>
          <h3 data-gdap-field="complexName">{defaultApartment.complexName}</h3>
          <p data-gdap-field="profitSentence">
            {defaultApartment.fiveYearLowDate} {formatEok(defaultApartment.fiveYearLowPriceManwon)}에 거래됐고, 현재 기준가는 {formatEok(defaultApartment.latestTradePriceManwon)}입니다.
          </p>
          <div class="gdap-profit-card__numbers">
            <div>
              <span>평가차익(추정)</span>
              <strong data-gdap-field="gain">{formatEok(defaultApartment.estimatedGainManwon)}</strong>
            </div>
            <div>
              <span>상승률(추정)</span>
              <strong data-gdap-field="gainRate">{defaultApartment.estimatedGainRate}%</strong>
            </div>
          </div>
        </div>
        <dl class="gdap-profit-card__meta">
          <div><dt>최근 기준가</dt><dd data-gdap-field="latest">{formatEok(defaultApartment.latestTradePriceManwon)}</dd></div>
          <div><dt>거래월·면적</dt><dd data-gdap-field="latestMeta">{defaultApartment.latestTradeDate} · {defaultApartment.latestTradeArea}</dd></div>
          <div><dt>5년 저점 참고</dt><dd data-gdap-field="low">{formatEok(defaultApartment.fiveYearLowPriceManwon)}</dd></div>
          <div><dt>입주·공급 메모</dt><dd data-gdap-field="supply">{defaultApartment.supplyNote}</dd></div>
          <div><dt>생활권 메모</dt><dd data-gdap-field="redevelopment">{defaultApartment.redevelopmentNote}</dd></div>
          <div><dt>주의</dt><dd data-gdap-field="note">{defaultApartment.note}</dd></div>
        </dl>
      </article>
      <p class="gdap-plain-note">
        이 금액은 취득세, 중개보수, 보유세, 대출이자, 양도소득세를 반영하지 않은 단순 시세 차이입니다. 둔촌 재건축·입주 물량 기대감은 현재 실거래가와 분리해서 확인해야 합니다.
      </p>
    </section>

    <section class="gdap-table-section" aria-labelledby="gdap-table-title">
      <div class="gdap-section-head gdap-section-head--row">
        <div>
          <p>비교표</p>
          <h2 id="gdap-table-title">강동 대장 아파트 Top10 실거래가</h2>
        </div>
        <div class="gdap-sort-controls" aria-label="정렬 기준">
          <button class="is-active" type="button" data-sort="rank">순위</button>
          <button type="button" data-sort="gain">평가차익</button>
          <button type="button" data-sort="gainRate">상승률</button>
          <button type="button" data-sort="latestPrice">최근가</button>
          <button type="button" data-sort="area">생활권</button>
        </div>
      </div>
      <div class="gdap-table-wrap">
        <table class="gdap-table">
          <caption>강동 아파트 Top10 최근 기준가와 5년 저점 대비 평가차익 비교</caption>
          <thead>
            <tr>
              <th scope="col">순위</th>
              <th scope="col">단지명</th>
              <th scope="col">법정동</th>
              <th scope="col">생활권</th>
              <th scope="col">최근 기준가</th>
              <th scope="col">거래월</th>
              <th scope="col">2025 대비</th>
              <th scope="col">5년 저점</th>
              <th scope="col">평가차익(추정)</th>
              <th scope="col">전세가율</th>
              <th scope="col">주의</th>
            </tr>
          </thead>
          <tbody data-gdap-table-body>
            {GDAP_APARTMENTS.map((row) => (
              <tr data-row-id={row.id}>
                <td>{row.rank}</td>
                <th scope="row">
                  <strong>{row.complexName}</strong>
                  <span>{row.mainAreaLabel}</span>
                </th>
                <td>{row.legalDongLabel}</td>
                <td>{row.areaGroup}</td>
                <td>{formatEok(row.latestTradePriceManwon)}</td>
                <td>{row.latestTradeDate}</td>
                <td>{row.previousYearPriceManwon ? `${formatEok(row.latestTradePriceManwon - row.previousYearPriceManwon)} 상승 참고` : "확인 필요"}</td>
                <td>{formatEok(row.fiveYearLowPriceManwon)}</td>
                <td>{formatEok(row.estimatedGainManwon)} · {row.estimatedGainRate}%</td>
                <td>{row.jeonseRatio ? `${row.jeonseRatio}% 참고` : "확인 필요"}</td>
                <td>{row.tradeCountNote}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="gdap-area-map" aria-labelledby="gdap-area-title">
      <div class="gdap-section-head">
        <p>생활권</p>
        <h2 id="gdap-area-title">고덕·상일·둔촌·명일·암사 생활권 차이</h2>
      </div>
      <div class="gdap-area-grid">
        {GDAP_AREA_CARDS.map((card) => (
          <article class="gdap-area-card">
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <strong>{card.priceInterpretation}</strong>
            <p>{card.description}</p>
            <small>{card.caution}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="gdap-chart" aria-labelledby="gdap-chart-title">
      <div class="gdap-section-head">
        <p>막대 비교</p>
        <h2 id="gdap-chart-title">현재 기준가 vs 5년 저점 참고가</h2>
      </div>
      <div class="gdap-bar-list" data-gdap-bars>
        {GDAP_APARTMENTS.map((row) => (
          <article class="gdap-bar-row" data-row-id={row.id}>
            <div class="gdap-bar-row__label">
              <strong>{row.complexName}</strong>
              <span>{row.areaGroup}</span>
            </div>
            <div class="gdap-bar-row__bars">
              <span class="gdap-bar gdap-bar--latest" style={`width: ${Math.max(12, (row.latestTradePriceManwon / maxLatest) * 100)}%`}>{formatEok(row.latestTradePriceManwon)}</span>
              <span class="gdap-bar gdap-bar--low" style={`width: ${Math.max(12, (row.fiveYearLowPriceManwon / maxLatest) * 100)}%`}>{formatEok(row.fiveYearLowPriceManwon)}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="gdap-context" aria-labelledby="gdap-context-title">
      <div class="gdap-section-head">
        <p>가격 맥락</p>
        <h2 id="gdap-context-title">강동 아파트 가격을 움직이는 변수</h2>
      </div>
      <div class="gdap-context-grid">
        {GDAP_CONTEXT.map((card) => (
          <article class="gdap-context-card">
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="gdap-data-method" aria-labelledby="gdap-method-title">
      <div class="gdap-section-head">
        <p>데이터 기준</p>
        <h2 id="gdap-method-title">강동 실거래가 데이터 기준</h2>
      </div>
      <ul class="gdap-risk-list">
        {GDAP_METHOD.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="gdap-risk" aria-labelledby="gdap-risk-title">
      <div class="gdap-section-head">
        <p>리스크</p>
        <h2 id="gdap-risk-title">평가차익보다 먼저 봐야 하는 변수</h2>
      </div>
      <ul class="gdap-risk-list">
        {GDAP_RISKS.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="gdap-related" aria-labelledby="gdap-related-title">
      <div class="gdap-section-head">
        <p>다음 단계</p>
        <h2 id="gdap-related-title">가격 확인 뒤 이어서 볼 리포트와 계산기</h2>
      </div>
      <div class="gdap-related-grid">
        {GDAP_RELATED_LINKS.map((link) => (
          <a class="gdap-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="강동 아파트 실거래가를 볼 때 먼저 확인할 것"
      intro={GDAP_SEO_INTRO}
      criteria={GDAP_SEO_CRITERIA}
      faq={GDAP_FAQ}
      related={GDAP_RELATED_LINKS}
    />

    <script type="application/json" id="gdap-data" set:html={JSON.stringify(GDAP_APARTMENTS)}></script>
    <script src={withBase("/scripts/gangdong-apartment-price-2026.js")} defer></script>
  </main>
</BaseLayout>
