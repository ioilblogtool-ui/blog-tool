---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  SIC_COMMITTEE_MEMBERS,
  SIC_FAQ,
  SIC_LAUNCH_INFO,
  SIC_META,
  SIC_REFORM_TASKS,
  SIC_RELATED_LINKS,
  SIC_SEO_CRITERIA,
  SIC_SEO_INTRO,
  SIC_STAKEHOLDER_IMPACTS,
  SIC_VERIFICATION_ITEMS,
  type EvidenceBadge,
} from "../../data/soccerInnovationCommittee2026";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${SIC_META.slug}/`;
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const totalScore = (task: typeof SIC_REFORM_TASKS[number]) =>
  task.disclosureScore + task.feasibilityScore + task.fanImpactScore + task.longTermScore + task.kleagueLinkScore;

const evidenceTone: Record<EvidenceBadge, string> = {
  "공식": "official",
  "보도 기준": "reported",
  "분석": "analysis",
  "확인 필요": "check",
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: SIC_META.h1,
    description: SIC_META.seoDescription,
    dateModified: SIC_META.updatedAt,
    mainEntityOfPage: reportUrl,
    inLanguage: "ko-KR",
    author: { "@type": "Organization", name: "비교계산소" },
    publisher: { "@type": "Organization", name: "비교계산소", url: siteBase },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: SIC_FAQ.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
      { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
      { "@type": "ListItem", position: 3, name: SIC_META.title, item: reportUrl },
    ],
  },
];
---

<BaseLayout title={SIC_META.seoTitle} description={SIC_META.seoDescription} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page sic-page" data-report={SIC_META.slug}>
    <CalculatorHero
      eyebrow="한국 축구 개혁 리포트"
      title={SIC_META.h1}
      description={SIC_META.description}
    />

    <div class="sic-meta-row" aria-label="문서 기준">
      <span>업데이트 기준: {SIC_META.updatedAt}</span>
      <span class="sic-badge">{SIC_META.dataStatusLabel}</span>
    </div>

    <section class="sic-quick-answer" aria-label="축구혁신위원회 빠른 답변">
      <p>빠른 답변</p>
      <strong>K축구 혁신위원회는 2026년 7월 6일 서울 올림픽파크텔에서 공식 출범했으며, 문체부 장관 최휘영과 박지성이 공동위원장을 맡았습니다. 이영표·박주호 등이 위원으로 참여해 감독 선임, 협회 운영, 예산 공개, 유소년 육성, K리그 연계, 심판 신뢰, 팬 소통을 점검합니다.</strong>
      <span>위원 명단·출범일은 다수 언론 보도 기준이며, 세부 권한 범위와 예산은 공식 발표가 나오는 대로 업데이트합니다.</span>
    </section>

    <section class="content-section sic-section" aria-labelledby="sic-members-title">
      <div class="sic-section__head">
        <p>위원 명단</p>
        <h2 id="sic-members-title">K축구 혁신위원회 위원 명단</h2>
        <span>{SIC_LAUNCH_INFO.date} {SIC_LAUNCH_INFO.location}에서 출범. {SIC_LAUNCH_INFO.purpose}</span>
      </div>
      <div class="sic-member-grid">
        {SIC_COMMITTEE_MEMBERS.map((member) => (
          <article class={`sic-member-card ${member.isChair ? "sic-member-card--chair" : ""}`}>
            {member.isChair && <span class="sic-badge">공동위원장</span>}
            <strong>{member.name}</strong>
            <span>{member.affiliation}</span>
          </article>
        ))}
      </div>
      <div class="sic-chip-row" aria-label="위원회 주요 안건">
        {SIC_LAUNCH_INFO.agenda.map((item) => <span>{item}</span>)}
      </div>

      <div class="sic-criteria-box">
        <strong>위원 선정 기준</strong>
        <ul>
          {SIC_LAUNCH_INFO.selectionCriteria.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <blockquote class="sic-chair-quote">{SIC_LAUNCH_INFO.chairStatement}</blockquote>
    </section>

    <section class="sic-cta-grid" aria-label="관련 스포츠 콘텐츠 바로가기">
      <a href={withBase("/reports/worldcup-manager-salary-comparison-2026/")} class="sic-cta-card">
        <span>대표팀 운영비</span>
        <strong>월드컵 감독 연봉 비교</strong>
        <small>감독 연봉 기준으로 대표팀 운영 비용을 봅니다.</small>
      </a>
      <a href={withBase("/reports/kleague-salary-comparison-2026/")} class="sic-cta-card">
        <span>K리그 구조</span>
        <strong>K리그 구단 연봉 순위</strong>
        <small>리그 투자와 대표팀 경쟁력 연결을 봅니다.</small>
      </a>
      <a href={withBase("/tools/worldcup-prize-money-calculator/")} class="sic-cta-card">
        <span>상금·포상금</span>
        <strong>월드컵 포상금 계산기</strong>
        <small>성적별 협회 상금과 선수단 포상금을 계산합니다.</small>
      </a>
    </section>

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        SIC_META.dataNote,
        "이 페이지의 개혁 점수표는 공식 평가가 아니라 공개성·실행 가능성·팬 체감·장기 효과·K리그 연계를 보는 분석용 체크리스트입니다.",
        "공식 확인 전 위원 명단, 권한, 예산 금액은 임의로 추정하지 않고 확인 필요 항목으로 분리합니다.",
      ]}
    />

    <section class="content-section sic-kpi-grid" aria-label="한국 축구 개혁 핵심 지표">
      <article class="sic-kpi-card sic-kpi-card--primary">
        <span>개혁 축</span>
        <strong>7개</strong>
        <small>감독 선임부터 팬 소통까지</small>
      </article>
      <article class="sic-kpi-card">
        <span>이해관계자</span>
        <strong>5그룹</strong>
        <small>대표팀·K리그·유소년·지도자·팬</small>
      </article>
      <article class="sic-kpi-card">
        <span>핵심 지표</span>
        <strong>공개성</strong>
        <small>기준과 예산이 보이는지</small>
      </article>
      <article class="sic-kpi-card">
        <span>장기 과제</span>
        <strong>4~8년</strong>
        <small>월드컵 1~2회 사이클 관점</small>
      </article>
    </section>

    <section class="content-section sic-section" aria-labelledby="sic-why-title">
      <div class="sic-section__head">
        <p>왜 지금 필요한가</p>
        <h2 id="sic-why-title">한국 축구 개혁은 감독 한 명보다 넓은 문제입니다</h2>
        <span>대표팀 감독 선임 논란은 눈에 잘 보이는 사례지만, 실제 개혁은 협회 의사결정, 예산 공개, 유소년 육성, K리그 연계, 심판 신뢰, 팬 소통까지 함께 봐야 합니다.</span>
      </div>
      <div class="sic-reason-grid">
        <article>
          <strong>대표팀 운영</strong>
          <p>월드컵 사이클마다 목표, 권한, 책임자가 달라지면 결과 이후 논란만 반복됩니다.</p>
        </article>
        <article>
          <strong>감독 선임 불신</strong>
          <p>후보 기준과 회의 과정이 보이지 않으면 선임 결과와 별개로 신뢰가 약해집니다.</p>
        </article>
        <article>
          <strong>K리그 연결</strong>
          <p>대표팀 경쟁력은 국내 리그 투자, 일정, 유소년 운영과 분리해서 볼 수 없습니다.</p>
        </article>
        <article>
          <strong>팬 신뢰 회복</strong>
          <p>발표문보다 중요한 것은 기준, 일정, 예산, 책임 소재를 확인할 수 있는 구조입니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section sic-section" aria-labelledby="sic-task-title">
      <div class="sic-section__head">
        <p>개혁 과제</p>
        <h2 id="sic-task-title">한국 축구 개혁 과제 7가지</h2>
        <span>각 항목은 공식 안건이 아니라 공개 자료와 팬 체감도를 바탕으로 정리한 분석용 체크리스트입니다.</span>
      </div>
      <div class="sic-task-grid">
        {SIC_REFORM_TASKS.map((task, index) => (
          <article class="sic-task-card">
            <div class="sic-task-card__top">
              <span class="sic-task-card__no">{String(index + 1).padStart(2, "0")}</span>
              <span class={`sic-badge sic-badge--${evidenceTone[task.evidenceBadge]}`}>{task.evidenceBadge}</span>
            </div>
            <h3>{task.title}</h3>
            <p>{task.summary}</p>
            <div class="sic-task-card__problem">
              <strong>현재 문제</strong>
              <span>{task.currentProblem}</span>
            </div>
            <div class="sic-chip-row" aria-label={`${task.title} 확인 지표`}>
              {task.whatToCheck.map((item) => <span>{item}</span>)}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section sic-section" aria-labelledby="sic-impact-title">
      <div class="sic-section__head">
        <p>이해관계자별 영향</p>
        <h2 id="sic-impact-title">대표팀·K리그·유소년에게 뭐가 달라지나</h2>
        <span>축구혁신위원회 논의는 대표팀만의 문제가 아니라 리그, 육성, 지도자, 팬 신뢰까지 이어집니다.</span>
      </div>
      <div class="sic-stakeholder-grid">
        {SIC_STAKEHOLDER_IMPACTS.map((item) => (
          <article class="sic-stakeholder-card">
            <strong>{item.group}</strong>
            <p>{item.concern}</p>
            <span>{item.expectedChange}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section sic-section" aria-labelledby="sic-score-title">
      <div class="sic-section__head">
        <p>개혁 점수표</p>
        <h2 id="sic-score-title">공개성·실행 가능성으로 보는 우선순위</h2>
        <span>점수는 공식 평가가 아니라 어떤 항목을 먼저 확인해야 하는지 보여주는 분석용 기준입니다.</span>
      </div>
      <div class="sic-score-table-wrap">
        <table class="sic-score-table">
          <caption>한국 축구 개혁 과제별 분석용 점수표</caption>
          <thead>
            <tr>
              <th>개혁 과제</th>
              <th>공개성</th>
              <th>실행</th>
              <th>팬 체감</th>
              <th>장기 효과</th>
              <th>K리그 연계</th>
              <th>합계</th>
              <th>상태</th>
            </tr>
          </thead>
          <tbody>
            {SIC_REFORM_TASKS.map((task) => (
              <tr>
                <td>
                  <strong>{task.shortLabel}</strong>
                  <small>{task.title}</small>
                </td>
                <td>{task.disclosureScore}</td>
                <td>{task.feasibilityScore}</td>
                <td>{task.fanImpactScore}</td>
                <td>{task.longTermScore}</td>
                <td>{task.kleagueLinkScore}</td>
                <td><strong>{totalScore(task)}</strong></td>
                <td><span class="sic-score-pill">{task.statusLabel}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="sic-note">점수표는 공식 평가가 아니라 공개 자료와 팬 체감도를 바탕으로 한 분석용 체크리스트입니다. 실제 제도 변화 여부는 공식 발표와 후속 실행 결과를 기준으로 봐야 합니다.</p>
    </section>

    <section class="content-section sic-section" aria-labelledby="sic-money-title">
      <div class="sic-section__head">
        <p>돈으로 보는 축구 개혁</p>
        <h2 id="sic-money-title">예산 공개가 있어야 개혁 실행력을 판단할 수 있습니다</h2>
        <span>확인되지 않은 금액은 쓰지 않고, 공개가 필요한 항목을 먼저 나눠 보여줍니다.</span>
      </div>
      <div class="sic-money-grid">
        {["대표팀 운영", "국제대회 준비", "유소년 육성", "지도자 교육", "심판·경기 운영", "행정비"].map((label) => (
          <article class="sic-money-card">
            <span>공개 필요</span>
            <strong>{label}</strong>
            <p>공식 예산 항목이 확인되면 금액과 기준을 분리해 업데이트합니다.</p>
          </article>
        ))}
      </div>
      <div class="sic-inline-cta">
        <div>
          <strong>대표팀 운영 비용을 숫자로 먼저 보고 싶다면</strong>
          <p>월드컵 감독 연봉 비교와 월드컵 포상금 계산기를 함께 확인하세요.</p>
        </div>
        <a href={withBase("/reports/worldcup-manager-salary-comparison-2026/")}>월드컵 감독 연봉 비교</a>
        <a href={withBase("/tools/worldcup-prize-money-calculator/")}>월드컵 포상금 계산기</a>
      </div>
    </section>

    <section class="content-section sic-section" aria-labelledby="sic-global-title">
      <div class="sic-section__head">
        <p>해외 사례 참고</p>
        <h2 id="sic-global-title">일본·독일·잉글랜드 사례는 방향만 참고해야 합니다</h2>
        <span>협회와 리그 구조가 다르기 때문에 단순 복제보다 어떤 지표를 공개하는지에 초점을 맞춥니다.</span>
      </div>
      <div class="sic-example-grid">
        <article>
          <strong>일본</strong>
          <p>장기 육성과 J리그 연계를 자주 참고하지만, 구체 예산과 제도는 공식 자료 확인 후 비교해야 합니다.</p>
        </article>
        <article>
          <strong>독일</strong>
          <p>유소년·지도자 교육 사례가 자주 언급됩니다. 2000년대 개혁을 과도하게 단순화하지 않아야 합니다.</p>
        </article>
        <article>
          <strong>잉글랜드</strong>
          <p>리그 상업성과 아카데미 구조를 참고하되, 협회·리그 수익 구조 차이를 함께 설명해야 합니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section sic-section" aria-labelledby="sic-verification-title">
      <div class="sic-section__head">
        <p>발행 전 확인</p>
        <h2 id="sic-verification-title">공식 확인이 필요한 항목</h2>
        <span>검색 노출보다 중요한 것은 사실 관계입니다. 확인되지 않은 항목은 확인 필요로 남깁니다.</span>
      </div>
      <div class="sic-verification-list">
        {SIC_VERIFICATION_ITEMS.map((item) => (
          <article>
            <span class={`sic-badge sic-badge--${evidenceTone[item.status]}`}>{item.status}</span>
            <strong>{item.label}</strong>
            <p>{item.note}</p>
            <small>{item.sourceLabel}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section sic-section" aria-labelledby="sic-related-title">
      <div class="sic-section__head">
        <p>다음으로 볼 콘텐츠</p>
        <h2 id="sic-related-title">축구 구조를 숫자로 이어서 보기</h2>
      </div>
      <div class="sic-related-grid">
        {SIC_RELATED_LINKS.map((item) => (
          <a href={withBase(item.href)} class="sic-related-card">
            <strong>{item.label}</strong>
            <span>{item.description}</span>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="축구혁신위원회와 한국 축구 개혁 과제를 함께 봐야 하는 이유"
      intro={SIC_SEO_INTRO}
      inputPoints={[
        "축구혁신위원회가 어떤 역할을 해야 하는지 한눈에 봅니다.",
        "한국 축구 개혁 과제를 대표팀·K리그·유소년·예산·팬 소통으로 나눠 봅니다.",
        "개혁 점수표로 공개성, 실행 가능성, 팬 체감, 장기 효과를 비교합니다.",
        "월드컵 감독 연봉, K리그 연봉, 월드컵 포상금 콘텐츠로 이어서 확인합니다.",
      ]}
      criteria={SIC_SEO_CRITERIA}
      faq={SIC_FAQ}
      related={SIC_RELATED_LINKS}
    />
  </main>
</BaseLayout>
