---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  GDAP_APARTMENTS,
  GDAP_AREA_CARDS,
  GDAP_CONTEXT,
  GDAP_FAQ,
  GDAP_META,
  GDAP_METHOD,
  GDAP_RELATED_LINKS,
  GDAP_RISKS,
  GDAP_SEO_CRITERIA,
  GDAP_SEO_INTRO,
} from "../../data/gwanggyoApartmentPrice2026";
import { withBase } from "../../utils/base";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${GDAP_META.slug}/`;
const defaultApartment = GDAP_APARTMENTS[0];
const maxPrice = GDAP_APARTMENTS.reduce((max, row) => (row.latestTradePriceManwon > max.latestTradePriceManwon ? row : max), defaultApartment);
const maxGain = GDAP_APARTMENTS.reduce((max, row) => (row.estimatedGainManwon > max.estimatedGainManwon ? row : max), defaultApartment);
const lakeParkCount = GDAP_APARTMENTS.filter((row) => row.areaGroup === "호수공원권").length;
const centralCount = GDAP_APARTMENTS.filter((row) => row.areaGroup === "광교중앙역권").length;
const sanghyeonCount = GDAP_APARTMENTS.filter((row) => row.areaGroup === "상현역권").length;

const formatEok = (manwon: number) => {
  const eok = manwon / 10000;
  const fixed = eok >= 10 ? eok.toFixed(1) : eok.toFixed(2);
  return `${fixed.replace(/\.0$/, "")}억원`;
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: GDAP_META.title,
      description: GDAP_META.description,
      dateModified: GDAP_META.updatedAt,
      inLanguage: "ko-KR",
      mainEntityOfPage: reportUrl,
      author: { "@type": "Organization", name: "비교계산소" },
      about: ["광교 아파트", "광교 실거래가", "광교자연앤힐스테이트", "광교중흥S클래스"],
    },
    {
      "@type": "FAQPage",
      mainEntity: GDAP_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
        { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
        { "@type": "ListItem", position: 3, name: GDAP_META.title, item: reportUrl },
      ],
    },
  ],
};
---

<BaseLayout title={GDAP_META.seoTitle} description={GDAP_META.description} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page gdap-page" data-report="gwanggyo-apartment-price-2026">
    <CalculatorHero
      eyebrow="광교 실거래가 리포트"
      title="광교 대장 아파트, 최저가일 때 샀다면 지금 얼마를 벌었을까?"
      description={GDAP_META.description}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        GDAP_META.notice,
        "광교 생활권은 수원시 영통구와 용인시 수지구 일부가 함께 검색되는 경우가 있어, 단지별 행정구역을 따로 표시합니다.",
        "자연앤힐스테이트·중흥S클래스는 아실 실거래 기반, 나머지 단지는 구현 전 추정값으로 국토교통부 원문 재확인이 필요합니다.",
        "최저가 대비 금액은 세금·중개보수·대출이자·보유비용을 반영하지 않은 평가차익(추정)입니다.",
        "이 리포트는 투자 권유가 아니며, 실제 거래 판단은 국토교통부 실거래가 공개시스템과 현장 확인을 기준으로 해야 합니다.",
      ]}
    />

    <section class="gdap-summary" aria-labelledby="gdap-summary-title">
      <div class="gdap-section-head">
        <p>요약</p>
        <h2 id="gdap-summary-title">광교 Top10 실거래 기준 한눈에 보기</h2>
      </div>
      <div class="gdap-summary-grid">
        <article class="gdap-summary-card">
          <span>데이터 기준</span>
          <strong>{GDAP_META.updatedAt}</strong>
          <p>{GDAP_META.dataAsOf}</p>
        </article>
        <article class="gdap-summary-card">
          <span>최고 기준가</span>
          <strong>{formatEok(maxPrice.latestTradePriceManwon)}</strong>
          <p>{maxPrice.complexName} 기준</p>
        </article>
        <article class="gdap-summary-card">
          <span>최대 평가차익(추정)</span>
          <strong>{formatEok(maxGain.estimatedGainManwon)}</strong>
          <p>{maxGain.complexName} 기준 단순 시세 차이</p>
        </article>
        <article class="gdap-summary-card">
          <span>생활권 구성</span>
          <strong>{lakeParkCount}/{centralCount}/{sanghyeonCount}</strong>
          <p>호수공원권 / 광교중앙역권 / 상현역권</p>
        </article>
      </div>
    </section>

    <section class="gdap-picker" aria-labelledby="gdap-picker-title">
      <div class="gdap-section-head">
        <p>단지별 카드</p>
        <h2 id="gdap-picker-title">최저가일 때 샀다면 지금 평가차익은?</h2>
      </div>

      <div class="gdap-tabs" role="tablist" aria-label="광교 아파트 단지 선택">
        {GDAP_APARTMENTS.map((row, index) => (
          <button
            class={`gdap-tab${index === 0 ? " is-active" : ""}`}
            type="button"
            data-complex={row.id}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            {row.rank}. {row.complexName}
          </button>
        ))}
      </div>

      <article class="gdap-profit-card" aria-live="polite">
        <div class="gdap-profit-card__main">
          <span class="gdap-badge" data-gdap-field="badge">{defaultApartment.badge}</span>
          <h3 data-gdap-field="complexName">{defaultApartment.complexName}</h3>
          <p data-gdap-field="areaMeta" class="gdap-profit-card__area-meta">
            {defaultApartment.cityLabel} · {defaultApartment.areaGroup}
            {defaultApartment.stationLabel && ` · ${defaultApartment.stationLabel}`}
          </p>
          <p data-gdap-field="profitSentence">
            {defaultApartment.fiveYearLowDate} {formatEok(defaultApartment.fiveYearLowPriceManwon)}에 거래된 뒤, 현재 기준가는 {formatEok(defaultApartment.latestTradePriceManwon)}입니다.
          </p>
          <div class="gdap-profit-card__numbers">
            <div>
              <span>평가차익(추정)</span>
              <strong data-gdap-field="gain">{formatEok(defaultApartment.estimatedGainManwon)}</strong>
            </div>
            <div>
              <span>상승률(추정)</span>
              <strong data-gdap-field="gainRate">{defaultApartment.estimatedGainRate}%</strong>
            </div>
          </div>
        </div>
        <dl class="gdap-profit-card__meta">
          <div><dt>최근 기준가</dt><dd data-gdap-field="latest">{formatEok(defaultApartment.latestTradePriceManwon)}</dd></div>
          <div><dt>거래월·면적</dt><dd data-gdap-field="latestMeta">{defaultApartment.latestTradeDate} · {defaultApartment.latestTradeArea}</dd></div>
          <div><dt>5년 저점 참고</dt><dd data-gdap-field="low">{formatEok(defaultApartment.fiveYearLowPriceManwon)}</dd></div>
          <div><dt>전세가율</dt><dd data-gdap-field="jeonse">{defaultApartment.jeonseRatio ? `${defaultApartment.jeonseRatio}% 참고` : "확인 필요"}</dd></div>
          <div><dt>면적 주의</dt><dd data-gdap-field="areaNote">{defaultApartment.mainAreaLabel}</dd></div>
          <div><dt>주의</dt><dd data-gdap-field="note">{defaultApartment.note}</dd></div>
        </dl>
      </article>
      <p class="gdap-plain-note">
        이 금액은 취득세, 중개보수, 보유세, 대출이자, 양도소득세를 반영하지 않은 단순 시세 차이입니다. 실제 투자 성과나 매수 추천으로 해석하면 안 됩니다.
      </p>
    </section>

    <section class="gdap-table-section" aria-labelledby="gdap-table-title">
      <div class="gdap-section-head gdap-section-head--row">
        <div>
          <p>비교표</p>
          <h2 id="gdap-table-title">광교 대장 아파트 Top10 실거래가</h2>
        </div>
        <div class="gdap-sort-controls" aria-label="정렬 기준">
          <button class="is-active" type="button" data-sort="rank">순위</button>
          <button type="button" data-sort="gain">평가차익</button>
          <button type="button" data-sort="gainRate">상승률</button>
          <button type="button" data-sort="latestPrice">최근가</button>
          <button type="button" data-sort="area">생활권</button>
        </div>
      </div>
      <div class="gdap-table-wrap">
        <table class="gdap-table">
          <caption>광교 아파트 Top10 후보의 최근 기준가와 5년 저점 대비 평가차익 비교</caption>
          <thead>
            <tr>
              <th scope="col">순위</th>
              <th scope="col">단지명</th>
              <th scope="col">행정구역</th>
              <th scope="col">생활권</th>
              <th scope="col">최근 실거래가</th>
              <th scope="col">거래월</th>
              <th scope="col">2025 대비</th>
              <th scope="col">5년 저점 참고</th>
              <th scope="col">평가차익(추정)</th>
              <th scope="col">전세가율</th>
              <th scope="col">주의</th>
            </tr>
          </thead>
          <tbody data-gdap-table-body>
            {GDAP_APARTMENTS.map((row) => (
              <tr data-row-id={row.id}>
                <td>{row.rank}</td>
                <th scope="row">
                  <strong>{row.complexName}</strong>
                  <span>{row.mainAreaLabel}</span>
                </th>
                <td>{row.cityLabel}</td>
                <td>{row.areaGroup}</td>
                <td>{formatEok(row.latestTradePriceManwon)}</td>
                <td>{row.latestTradeDate}</td>
                <td>{row.previousYearPriceManwon ? `${formatEok(row.latestTradePriceManwon - row.previousYearPriceManwon)} 상승 참고` : "확인 필요"}</td>
                <td>{formatEok(row.fiveYearLowPriceManwon)}</td>
                <td>{formatEok(row.estimatedGainManwon)} · {row.estimatedGainRate}%</td>
                <td>{row.jeonseRatio ? `${row.jeonseRatio}% 참고` : "확인 필요"}</td>
                <td>{row.tradeCountNote}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="gdap-area-map" aria-labelledby="gdap-area-title">
      <div class="gdap-section-head">
        <p>생활권 분해</p>
        <h2 id="gdap-area-title">호수공원권·광교중앙역권·상현역권 가격 차이</h2>
      </div>
      <div class="gdap-area-grid" data-gdap-area-cards>
        {GDAP_AREA_CARDS.map((card) => (
          <article
            class={`gdap-area-card${card.areaGroup === defaultApartment.areaGroup ? " is-selected" : ""}`}
            data-area-group={card.areaGroup}
          >
            <span class={`gdap-area-badge gdap-area-badge--${card.badge === "확인 필요" ? "check" : "estimate"}`}>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
            <strong>{card.priceInterpretation}</strong>
            <small>{card.caution}</small>
          </article>
        ))}
      </div>
      <p class="gdap-plain-note">
        광교 생활권은 수원시 영통구와 용인시 수지구 일부가 함께 검색되는 경우가 있습니다. 이 리포트는 행정구역 순위가 아니라 광교 생활권 대표 단지 비교입니다.
      </p>
    </section>

    <section class="gdap-chart" aria-labelledby="gdap-chart-title">
      <div class="gdap-section-head">
        <p>막대 비교</p>
        <h2 id="gdap-chart-title">현재 기준가 vs 5년 저점 참고가</h2>
      </div>
      <div class="gdap-bar-list" data-gdap-bars>
        {GDAP_APARTMENTS.map((row) => (
          <article class={`gdap-bar-row${row.id === defaultApartment.id ? " is-selected" : ""}`} data-row-id={row.id}>
            <div class="gdap-bar-row__label">
              <strong>{row.complexName}</strong>
              <span>{row.areaGroup} · {row.badge}</span>
            </div>
            <div class="gdap-bar-row__bars">
              <span class="gdap-bar gdap-bar--latest" style={`width: ${Math.max(12, (row.latestTradePriceManwon / maxPrice.latestTradePriceManwon) * 100)}%`}>{formatEok(row.latestTradePriceManwon)}</span>
              <span class="gdap-bar gdap-bar--low" style={`width: ${Math.max(12, (row.fiveYearLowPriceManwon / maxPrice.latestTradePriceManwon) * 100)}%`}>{formatEok(row.fiveYearLowPriceManwon)}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="gdap-context" aria-labelledby="gdap-context-title">
      <div class="gdap-section-head">
        <p>가격 맥락</p>
        <h2 id="gdap-context-title">광교 아파트가 비싼 이유와 해석 기준</h2>
      </div>
      <div class="gdap-context-grid">
        {GDAP_CONTEXT.map((card) => (
          <article class="gdap-context-card">
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="gdap-data-method" aria-labelledby="gdap-method-title">
      <div class="gdap-section-head">
        <p>데이터 기준</p>
        <h2 id="gdap-method-title">광교 실거래가 데이터 기준</h2>
      </div>
      <ul class="gdap-risk-list">
        {GDAP_METHOD.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="gdap-risk" aria-labelledby="gdap-risk-title">
      <div class="gdap-section-head">
        <p>리스크</p>
        <h2 id="gdap-risk-title">평가차익보다 먼저 봐야 하는 변수</h2>
      </div>
      <ul class="gdap-risk-list">
        {GDAP_RISKS.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="gdap-related" aria-labelledby="gdap-related-title">
      <div class="gdap-section-head">
        <p>다음 단계</p>
        <h2 id="gdap-related-title">광교 가격 확인 뒤 이어서 볼 리포트와 계산기</h2>
      </div>
      <div class="gdap-related-grid">
        {GDAP_RELATED_LINKS.map((link) => (
          <a class="gdap-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="광교 아파트 실거래가를 볼 때 먼저 확인할 것"
      intro={GDAP_SEO_INTRO}
      criteria={GDAP_SEO_CRITERIA}
      faq={GDAP_FAQ}
      related={GDAP_RELATED_LINKS}
    />

    <script type="application/json" id="gdap-data" set:html={JSON.stringify(GDAP_APARTMENTS)}></script>
    <script type="application/json" id="gdap-area-data" set:html={JSON.stringify(GDAP_AREA_CARDS)}></script>
    <script src={withBase("/scripts/gwanggyo-apartment-price-2026.js")} defer></script>
  </main>
</BaseLayout>
