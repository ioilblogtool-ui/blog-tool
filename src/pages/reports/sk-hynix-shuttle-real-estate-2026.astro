---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  APARTMENT_AREAS,
  SK_HYNIX_SHUTTLE_FAQ,
  SK_HYNIX_SHUTTLE_META,
  SK_HYNIX_SHUTTLE_RELATED,
  SK_HYNIX_SHUTTLE_ZONES,
} from "../../data/skHynixShuttleRealEstate2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const price = (value: number | null) => {
  if (value === null) return "확인 필요";
  const eok = value / 10000;
  return `${eok.toFixed(eok >= 10 || Number.isInteger(eok) ? 0 : 1).replace(".0", "")}억`;
};
const manwon = (value: number | null) => value === null ? "확인 필요" : `${value.toLocaleString("ko-KR")}만원`;
const zoneById = new Map(SK_HYNIX_SHUTTLE_ZONES.map((zone) => [zone.id, zone]));
const mainAreas = APARTMENT_AREAS.map((area) => ({ ...area, zone: zoneById.get(area.zoneId) }));
const summaryCards = [
  {
    label: "가장 짧은 통근",
    value: "이천 현지 5~15분",
    text: "출퇴근 시간은 가장 짧지만 생활 인프라와 교육 여건은 별도 확인이 필요합니다.",
  },
  {
    label: "중간 거점",
    value: "판교·분당 40~50분",
    text: "이천 본사와 판교 사무소를 모두 고려할 수 있어 발령 변동성이 있을 때 검토하기 좋습니다.",
  },
  {
    label: "시세 범위",
    value: "전세 1.5억~7.5억",
    text: "30평대 참고값 기준이며 실제 단지, 연식, 역세권 여부에 따라 크게 달라질 수 있습니다.",
  },
];
const livingCompare = [
  ["출퇴근 시간", "10~15분", "40~60분"],
  ["30평대 전세", "약 1.5억", "약 4.5억~6.2억"],
  ["생활 인프라", "제한적", "풍부"],
  ["자녀 교육", "수도권 핵심지 대비 부족", "상대적으로 유리"],
  ["서울 접근성", "불편", "우수"],
];
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: SK_HYNIX_SHUTTLE_META.title,
  description: SK_HYNIX_SHUTTLE_META.description,
  inLanguage: "ko-KR",
  dateModified: "2026-05-25",
  author: {
    "@type": "Organization",
    name: "비교계산소",
  },
};
---

<BaseLayout
  title="SK하이닉스 셔틀버스 아파트 시세 정리 2026 | 이천·판교·분당 직주근접 비교"
  description={SK_HYNIX_SHUTTLE_META.description}
  jsonLd={articleJsonLd}
>
  <SiteHeader />
  <main class="container page-shell report-page op-page skhre-page">
    <CalculatorHero
      eyebrow="SK하이닉스 직주근접 리포트"
      title={SK_HYNIX_SHUTTLE_META.title}
      description="이천 본사·청주·판교 캠퍼스별 주요 셔틀 권역 아파트 전세·매매 시세를 정리했습니다. 이천 발령 때 어디에 살지, PS 성과급으로 어느 가격대까지 가능한지 함께 확인하세요."
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        "셔틀 정류장 지역은 재직자 커뮤니티 기반 추정이며, 정확한 노선은 HAPPYROAD 앱 또는 사내 포털에서 확인하세요.",
        "아파트 시세는 국토부 실거래가 2026년 1분기 기준 30평대 참고값입니다.",
        "소요 시간은 카카오맵 기준 평상시 추정이며 교통 상황에 따라 20~30분 이상 차이가 날 수 있습니다.",
      ]}
    />

    <DesignTrustPanel
      title="SK하이닉스 셔틀권 부동산 리포트 기준"
      updatedAt={SK_HYNIX_SHUTTLE_META.updatedAt}
      notes={[
        SK_HYNIX_SHUTTLE_META.caution,
        "본 리포트는 거주지 검토를 위한 비교 자료이며 특정 지역, 단지, 매수를 권유하지 않습니다.",
      ]}
    />

    <section class="op-section">
      <div class="skhre-summary-grid">
        {summaryCards.map((card) => (
          <article class="skhre-summary-card">
            <p>{card.label}</p>
            <strong>{card.value}</strong>
            <span>{card.text}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="op-section">
      <h2>권역별 셔틀과 아파트 시세 비교</h2>
      <div class="op-table-wrap skhre-zone-table">
        <table>
          <thead>
            <tr>
              <th>권역</th>
              <th>주요 정류장·지역</th>
              <th>대상 캠퍼스</th>
              <th>소요 시간</th>
              <th>30평대 전세</th>
              <th>30평대 매매</th>
              <th>평당가</th>
              <th>구분</th>
            </tr>
          </thead>
          <tbody>
            {mainAreas.map((area) => (
              <tr>
                <td>{area.zone?.name}</td>
                <td>{area.district}</td>
                <td>{area.zone?.targetCampus.join(", ")}</td>
                <td>{area.zone?.commuteMin ? `약 ${area.zone.commuteMin}분+` : "확인 필요"}</td>
                <td>{price(area.priceJeonseManwon)}</td>
                <td>{price(area.priceMeomaeManwon)}</td>
                <td>{manwon(area.pricePerPyeong)}</td>
                <td><span class={`skhre-badge skhre-badge--${area.badge === "확인됨" ? "confirmed" : "estimate"}`}>{area.badge}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="op-message">표의 가격은 30평대 참고값입니다. 같은 권역이라도 역세권, 연식, 단지 규모, 층수, 대출 가능 여부에 따라 실제 매수·전세 조건이 달라집니다.</p>
    </section>

    <section class="op-section">
      <h2>캠퍼스별 주거 권역 상세</h2>
      <div class="skhre-zone-cards">
        {SK_HYNIX_SHUTTLE_ZONES.map((zone) => {
          const areas = APARTMENT_AREAS.filter((area) => area.zoneId === zone.id);
          return (
            <article class="skhre-zone-card">
              <div class="skhre-zone-card__head">
                <span class={`skhre-badge skhre-badge--${zone.badge === "확인됨" ? "confirmed" : "estimate"}`}>{zone.badge}</span>
                <h3>{zone.name}</h3>
              </div>
              <p>{zone.commuteNote}</p>
              <dl>
                <div><dt>정류장</dt><dd>{zone.areas.join(" · ")}</dd></div>
                <div><dt>캠퍼스</dt><dd>{zone.targetCampus.join(" · ")}</dd></div>
              </dl>
              {areas.map((area) => (
                <div class="skhre-price-strip">
                  <span>{area.district}</span>
                  <strong>전세 {price(area.priceJeonseManwon)} · 매매 {price(area.priceMeomaeManwon)}</strong>
                  <em>{area.note}</em>
                </div>
              ))}
            </article>
          );
        })}
      </div>
    </section>

    <section class="op-section">
      <h2>이천 현지 거주 vs 판교·분당 셔틀 비교</h2>
      <div class="op-table-wrap skhre-compare-table">
        <table>
          <thead><tr><th>항목</th><th>이천 현지 거주</th><th>판교·분당 + 셔틀</th></tr></thead>
          <tbody>
            {livingCompare.map(([label, local, pangyo]) => (
              <tr><td>{label}</td><td>{local}</td><td>{pangyo}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="op-message">이천 현지는 시간을 사고, 판교·분당은 생활권을 사는 선택에 가깝습니다. 교대근무, 자녀 교육, 배우자 직장 위치에 따라 최적지가 달라집니다.</p>
    </section>

    <section class="op-section skhre-cta-box">
      <div>
        <p>성과급과 주거 예산을 한 번에 맞춰보세요</p>
        <h2>SK하이닉스 PS로 이천·판교 아파트 예산이 가능한지 계산하기</h2>
        <span>성과급은 변동성이 크므로 현금흐름, 대출금리, 세금까지 함께 넣어 보는 편이 안전합니다.</span>
      </div>
      <div class="skhre-cta-box__actions">
        <a class="button button--secondary" href={withBase("/tools/sk-hynix-bonus/")}>성과급 계산기</a>
        <a class="button button--ghost" href={withBase("/tools/home-purchase-fund/")}>내집마련 자금 계산기</a>
      </div>
    </section>

    <section class="op-section skhre-cluster-notice">
      <h2>용인 반도체 클러스터는 어떻게 봐야 하나요?</h2>
      <p>용인 처인구 일대 반도체 클러스터는 장기적으로 근무지와 주거 수요를 바꿀 수 있는 변수입니다. 다만 실제 배치, 셔틀 노선, 입주 시점이 확정되기 전에는 투자 판단보다 근무지 이동 가능성과 생활 편의성을 먼저 보는 것이 안전합니다.</p>
      <ul>
        <li>이천 본사 발령자는 현재 셔틀권과 실제 통근 피로도를 우선 확인합니다.</li>
        <li>판교 사무소 가능성이 있으면 판교·분당권의 유연성이 커집니다.</li>
        <li>용인권은 클러스터 진행 상황과 회사 노선 확정 이후 재검토하는 편이 현실적입니다.</li>
      </ul>
    </section>

    <section class="op-section">
      <h2>같이 보면 좋은 계산기와 리포트</h2>
      <div class="skhre-related-grid">
        {SK_HYNIX_SHUTTLE_RELATED.map((item) => (
          <a href={withBase(item.href)}>
            <strong>{item.label}</strong>
            <span>바로 확인하기</span>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="SK하이닉스 셔틀권 부동산 리포트를 보는 방법"
      intro={[
        "SK하이닉스 이천 본사 발령을 받으면 가장 먼저 떠오르는 질문은 어디에 살아야 하느냐입니다. 이천은 서울에서 대중교통으로 접근하기 쉽지 않아 회사 셔틀버스가 현실적인 통근 수단이 됩니다. 강남권에서는 이천까지 80~100분, 판교에서는 약 40분 수준으로 보는 것이 현실적입니다.",
        "SK하이닉스 셔틀버스는 강남역, 역삼역, 양재역, 판교역, 정자역 등 주요 거점이 재직자 커뮤니티에서 반복적으로 확인됩니다. 다만 실제 운행 노선과 시간표는 HAPPYROAD 앱 또는 사내 포털에서 재직자가 직접 확인해야 합니다.",
        "셔틀 소요 시간과 아파트 시세를 함께 보면 직주근접 비용의 차이가 보입니다. 이천 현지는 30평대 전세가 약 1.5억원 수준으로 낮지만 생활 인프라가 제한적이고, 판교는 전세 부담이 크지만 이천과 판교 사무소 모두 대응할 수 있는 중간 거점입니다.",
        "이 리포트의 정류장과 시간은 추정값이며, 아파트 시세도 2026년 1분기 참고값입니다. 거주지를 최종 결정하기 전에는 최신 셔틀 노선, 실거래가, 대출 가능액, 세금, 가족 생활권을 함께 확인해야 합니다.",
      ]}
      inputPoints={[
        "권역별 셔틀 소요 시간과 30평대 전세·매매 시세를 한 표에서 비교합니다.",
        "이천 현지 거주와 판교·분당 셔틀 통근의 장단점을 비용·시간·생활 인프라 기준으로 비교합니다.",
        "SK하이닉스 성과급 계산기와 내집마련 자금 계산기로 실제 예산 범위를 이어서 확인할 수 있습니다.",
      ]}
      criteria={[
        "셔틀 권역은 재직자 커뮤니티와 공개 확인 정류장 기반 추정값입니다.",
        "아파트 시세는 국토부 실거래가 2026년 1분기 기준 30평대 참고값입니다.",
        "소요 시간은 평상시 기준 추정이며 실제 출퇴근 시간대와 교통 상황에 따라 달라질 수 있습니다.",
        "본 콘텐츠는 정보 제공용이며 특정 지역, 단지, 매수를 권유하지 않습니다.",
      ]}
      faq={SK_HYNIX_SHUTTLE_FAQ}
      related={SK_HYNIX_SHUTTLE_RELATED}
    />
  </main>
</BaseLayout>
