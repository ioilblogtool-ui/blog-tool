---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import { pensionByJobReport } from "../../data/pensionByJobComparison2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const report = pensionByJobReport;
const faqItems = report.faq.map((i) => ({ question: i.q, answer: i.a }));

// 20년 납입 기준 기본 표시 (SSR, JS 없이도 표시)
const defaultTerm = report.termSimulations.find((s) => s.termKey === "y20")!;
const maxReceive = Math.max(...defaultTerm.rows.map((r) => r.monthlyReceiveMan));

function fmtMan(v: number): string {
  return `${v.toLocaleString("ko-KR")}만 원`;
}
---

<BaseLayout title={report.meta.seoTitle} description={report.meta.seoDescription}>
  <SiteHeader />

  <main class="container page-shell report-page pbjc-page">
    <CalculatorHero
      eyebrow="직종별 연금 비교 리포트"
      title="직종별 연금 비교 2026 — 공무원·군인·사학·국민연금"
      description="같은 월급, 20년 납입 기준으로 직종마다 연금 수령액이 얼마나 다를까요? 납입 부담부터 손익분기점까지 한눈에 비교합니다."
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        `출처: ${report.meta.dataSourceLabel} (${report.meta.updatedAt} 기준)`,
        report.meta.caution,
      ]}
    />

    <!-- KPI 요약 카드 -->
    <section class="content-section pbjc-kpi-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 수치</p>
        <h2>먼저 봐야 할 숫자 4개</h2>
      </div>
      <div class="pbjc-kpi-grid">
        {report.kpis.map((kpi) => (
          <article class={`pbjc-kpi-card${kpi.tone ? ` is-${kpi.tone}` : ""}`}>
            <p class="pbjc-kpi-card__label">{kpi.label}</p>
            <strong class="pbjc-kpi-card__value">{kpi.value}</strong>
            <span class="pbjc-kpi-card__sub">{kpi.sub}</span>
          </article>
        ))}
      </div>
    </section>

    <!-- 4개 연금 제도 핵심 비교표 -->
    <section class="content-section pbjc-compare-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">제도 비교</p>
        <h2>4개 연금 제도 한눈에 비교</h2>
        <p>납입률·지급 개시 나이·소득대체율을 동일 기준으로 정리했습니다.</p>
      </div>
      <div class="table-wrap pbjc-table-wrap">
        <table class="pbjc-compare-table">
          <thead>
            <tr>
              <th class="col-item">항목</th>
              {report.pensions.map((p) => (
                <th class="col-pension" style={`border-top: 3px solid ${p.color}`}>
                  <span style={`color:${p.color}`}>{p.name}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="col-item">가입 대상</td>
              {report.pensions.map((p) => <td>{p.target}</td>)}
            </tr>
            <tr>
              <td class="col-item">본인 납입률</td>
              {report.pensions.map((p) => (
                <td><strong>{p.selfRatePct}%</strong></td>
              ))}
            </tr>
            <tr>
              <td class="col-item">고용주 납입률</td>
              {report.pensions.map((p) => <td>{p.employerRatePct}%</td>)}
            </tr>
            <tr>
              <td class="col-item">총 납입률</td>
              {report.pensions.map((p) => (
                <td><strong>{p.totalRatePct}%</strong></td>
              ))}
            </tr>
            <tr>
              <td class="col-item">지급 개시</td>
              {report.pensions.map((p) => (
                <td class={p.id === "military" ? "pbjc-military-note" : ""}>
                  {p.paymentStartAge}
                  {p.id === "military" && <span class="pbjc-badge pbjc-badge--special">특이</span>}
                </td>
              ))}
            </tr>
            <tr>
              <td class="col-item">20년 소득대체율</td>
              {report.pensions.map((p) => <td>{p.replacementRate20y}</td>)}
            </tr>
            <tr>
              <td class="col-item">현재 상태</td>
              {report.pensions.map((p) => (
                <td class="pbjc-status">{p.currentStatus}</td>
              ))}
            </tr>
          </tbody>
        </table>
      </div>
      <p class="pbjc-table-note">
        ※ 군인연금 지급 개시: 20년 이상 복무 충족 시 전역 즉시 수령 가능 (타 연금과 다름)<br/>
        ※ 소득대체율은 단순 추정 범위이며 납입 기간·개혁 시점에 따라 달라집니다.
      </p>
    </section>

    <!-- 납입 부담 비교 -->
    <section class="content-section pbjc-contrib-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">납입 부담 비교</p>
        <h2>월 기준소득 300만 원 기준 납입 부담</h2>
        <p>국민연금 본인 납입률(4.5%)은 직역연금(9%)의 절반입니다. 납입 부담이 낮은 만큼 수령액도 낮습니다.</p>
      </div>
      <div class="pbjc-contrib-grid">
        {report.contributions.map((row) => {
          const pension = report.pensions.find((p) => p.id === row.pensionId)!;
          return (
            <article class="pbjc-contrib-card" style={`--pension-color: ${pension.color}`}>
              <p class="pbjc-contrib-card__name" style={`color:${pension.color}`}>{pension.name}</p>
              <div class="pbjc-contrib-card__rows">
                <div class="pbjc-contrib-row">
                  <span>본인 월 납입</span>
                  <strong>{fmtMan(row.selfMonthlyMan)}</strong>
                </div>
                <div class="pbjc-contrib-row">
                  <span>고용주 월 납입</span>
                  <strong>{fmtMan(row.employerMonthlyMan)}</strong>
                </div>
                <div class="pbjc-contrib-row pbjc-contrib-row--total">
                  <span>합산 월 납입</span>
                  <strong>{fmtMan(row.totalMonthlyMan)}</strong>
                </div>
                <div class="pbjc-contrib-row">
                  <span>20년 본인 납입 총액</span>
                  <strong>{fmtMan(row.selfTotal20yMan)}</strong>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- 납입 기간 탭 + 수령액 bar row -->
    <section class="content-section pbjc-sim-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">수령액 비교</p>
        <h2>납입 기간별 예상 월 수령액</h2>
        <p>월 기준소득 300만 원 기준 단순 추정값입니다. 납입 기간을 선택해서 비교하세요.</p>
      </div>

      <div class="pbjc-term-tabs" id="pbjcTermTabs">
        {report.termSimulations.map((sim, i) => (
          <button
            type="button"
            class={`pbjc-tab-btn${i === 1 ? " is-active" : ""}`}
            data-term={sim.termKey}
          >
            {sim.termLabel}
          </button>
        ))}
      </div>

      <div class="pbjc-bar-list" id="pbjcBarList">
        {defaultTerm.rows.map((row) => {
          const pension = report.pensions.find((p) => p.id === row.pensionId)!;
          const pct = Math.max(4, Math.round((row.monthlyReceiveMan / maxReceive) * 100));
          return (
            <div class="pbjc-bar-row" data-pension={row.pensionId}>
              <span class="pbjc-bar-row__name" style={`color:${pension.color}`}>{pension.nameShort}</span>
              <div class="pbjc-bar-row__bar-wrap">
                <div
                  class="pbjc-bar-row__bar"
                  style={`width:${pct}%; background:${pension.color}`}
                  data-pct={pct}
                ></div>
              </div>
              <span class="pbjc-bar-row__val" data-val={row.monthlyReceiveMan}>
                {fmtMan(row.monthlyReceiveMan)}
                {row.isEstimate && <em class="pbjc-est">추정</em>}
              </span>
            </div>
          );
        })}
      </div>
      <p class="pbjc-sim-note">※ 단순 소득대체율 기반 추정값. 물가연동·개인 재직기간 미반영.</p>

      <!-- Chart.js 묶음 막대 -->
      <div class="section-header section-header--compact" style="margin-top:28px">
        <p class="section-header__eyebrow">기간별 격차</p>
        <h2>납입 기간별 수령액 격차 비교</h2>
      </div>
      <div class="pbjc-chart-wrap">
        <canvas id="pbjcTermChart"></canvas>
      </div>
    </section>

    <!-- 손익분기점 카드 -->
    <section class="content-section pbjc-breakeven-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">손익분기점</p>
        <h2>납입 총액을 회수하려면 몇 년이 걸릴까요?</h2>
        <p>20년 납입 기준 본인 부담 총액 ÷ 월 수령액 = 회수 기간. 모두 추정값입니다.</p>
      </div>
      <div class="pbjc-breakeven-grid">
        {report.breakevenCards.map((card) => {
          const pension = report.pensions.find((p) => p.id === card.pensionId)!;
          return (
            <article class="pbjc-breakeven-card" style={`--pension-color: ${pension.color}`}>
              <p class="pbjc-breakeven-card__name" style={`color:${pension.color}`}>{pension.name}</p>
              <div class="pbjc-breakeven-card__rows">
                <div class="pbjc-bk-row">
                  <span>20년 본인 납입 총액</span>
                  <strong>{fmtMan(card.totalContribMan)}</strong>
                </div>
                <div class="pbjc-bk-row">
                  <span>예상 월 수령액</span>
                  <strong>{fmtMan(card.monthlyReceiveMan)} <em class="pbjc-est">추정</em></strong>
                </div>
                <div class="pbjc-bk-row pbjc-bk-row--highlight">
                  <span>회수까지</span>
                  <strong>{card.breakevenYears}년</strong>
                </div>
              </div>
              <p class="pbjc-breakeven-card__age">{card.breakevenAgeNote}</p>
              {card.note && <p class="pbjc-breakeven-card__note">{card.note}</p>}
            </article>
          );
        })}
      </div>
    </section>

    <!-- 연금개혁 요약 카드 -->
    <section class="content-section pbjc-reform-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">연금개혁</p>
        <h2>2025~2026 연금개혁 주요 변화</h2>
      </div>
      <div class="pbjc-reform-grid">
        {report.reformCards.map((card) => (
          <article class="pbjc-reform-card">
            <strong class="pbjc-reform-card__title">{card.title}</strong>
            <p class="pbjc-reform-card__desc">{card.description}</p>
            <div class="pbjc-reform-card__tags">
              {card.affectedPensionIds.map((id) => {
                const p = report.pensions.find((pp) => pp.id === id)!;
                return <span class="pbjc-reform-tag" style={`background:${p.color}22; color:${p.color}`}>{p.nameShort}</span>;
              })}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="content-section pbjc-faq-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">자주 묻는 질문</p>
        <h2>FAQ</h2>
      </div>
      <div class="pbjc-faq-list">
        {report.faq.map((item) => (
          <article class="pbjc-faq-item">
            <p class="pbjc-faq-item__q">{item.q}</p>
            <p class="pbjc-faq-item__a">{item.a}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="content-section pbjc-cta-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">관련 콘텐츠</p>
        <h2>함께 보면 좋은 리포트</h2>
      </div>
      <div class="pbjc-cta-grid">
        {report.relatedLinks.map((link) => (
          <a class="pbjc-cta-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <span>{link.description}</span>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="직종별 연금 비교 리포트 읽는 법"
      intro={[
        "이 리포트는 공무원연금·군인연금·사학연금·국민연금을 월 기준소득 300만 원, 납입 기간 10·20·30년이라는 동일 조건으로 비교한 참고용 데이터 리포트입니다.",
        "직종별 납입률이 다르므로 수령액만 보는 것이 아니라 본인 납입 부담도 함께 고려해야 합니다. 납입 부담 비교 섹션을 함께 확인하면 단순 수령액보다 더 정확한 비교를 할 수 있습니다.",
        "같은 월 기준소득이라도 직종별 연금 구조가 달라 수령액 격차가 크게 벌어질 수 있습니다. 공무원연금과 군인연금은 국민연금보다 상대적으로 높은 소득대체율을 적용받는 것으로 알려져 있어, 직종 선택이 노후 연금 규모에도 영향을 줄 수 있습니다.",
        "수령액 수치는 단순 소득대체율 기반 추정값입니다. 개인 재직기간·물가연동·개혁 시점에 따라 실제와 다를 수 있으니 정확한 수령액은 각 연금 공단에서 확인하세요.",
      ]}
      criteria={[
        "수령액 시뮬레이션은 월 기준소득 300만 원, 단순 소득대체율 기반 추정값입니다.",
        "물가연동·재직기간 가산·연금 개혁 시점 등이 반영되지 않은 단순 참고값입니다.",
        "군인연금 지급 개시 나이는 20년 복무 충족 시 즉시로, 타 연금과 구조가 다릅니다.",
        "연금개혁 내용은 2026년 5월 기준입니다. 추가 개혁 시 수치가 달라질 수 있습니다.",
      ]}
      faq={faqItems}
      related={report.relatedLinks}
    />
  </main>

  <script id="pbjcReportData" type="application/json" set:html={JSON.stringify(report)}></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/pension-by-job-comparison-2026.js")}></script>
</BaseLayout>
