---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  bucketLabel,
  etfVsDirectStock10Year2026,
  formatPercent,
} from "../../data/etfVsDirectStock10Year2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const report = etfVsDirectStock10Year2026;
const tenYearRows = report.tenYearRows;
const bestReturn = [...tenYearRows].sort((a, b) => b.cumulativeReturn - a.cumulativeReturn)[0];
const lowestMdd = [...tenYearRows].sort((a, b) => Math.abs(a.mdd) - Math.abs(b.mdd))[0];
const highestMdd = [...tenYearRows].sort((a, b) => Math.abs(b.mdd) - Math.abs(a.mdd))[0];
const lowestVol = [...tenYearRows].sort((a, b) => a.volatility - b.volatility)[0];
const faqItems = report.faq.map((item) => ({ question: item.q, answer: item.a }));

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: report.meta.title,
      description: report.meta.subtitle,
      inLanguage: "ko-KR",
      dateModified: "2026-04-19",
      mainEntityOfPage: `https://bigyocalc.com/reports/${report.meta.slug}/`,
      publisher: {
        "@type": "Organization",
        name: "비교계산소",
        url: "https://bigyocalc.com",
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: report.faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.a,
        },
      })),
    },
  ],
};
---

<BaseLayout title={`${report.meta.title} | ETF vs 직접투자 수익률·MDD·세후 비교`} description={report.meta.subtitle} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page evds26-page">
    <CalculatorHero
      eyebrow="장기투자 비교 리포트"
      title={report.meta.title}
      description="수익률만이 아니라 변동성, 세금, 유지 가능성까지 같이 봅니다."
    />

    <InfoNotice
      title="비교 기준 안내"
      lines={[
        `기간은 ${report.meta.period} 고정 스냅샷입니다.`,
        "국내 상장 미국 ETF는 상장 이후 성과로 별도 비교합니다.",
        report.meta.caution,
      ]}
    />

    <section class="content-section evds26-brief-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">Editor&apos;s Brief</p>
        <h2>수익률 1등과 오래 버틸 수 있는 투자 대상은 다를 수 있습니다</h2>
        <p>{report.heroSummary}</p>
      </div>
      <div class="evds26-chip-row">
        <span>ETF</span>
        <span>개별주</span>
        <span>10년 비교</span>
        <span class="is-warn">세후 단순 추정</span>
      </div>
      <div class="evds26-brief-grid">
        {report.briefCards.map((item) => (
          <article class="evds26-brief-card">
            <strong>{item.title}</strong>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section evds26-kpi-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 요약</p>
        <h2>먼저 봐야 할 숫자 4개</h2>
      </div>
      <div class="evds26-kpi-grid">
        {report.kpis.map((item) => (
          <article class="evds26-kpi-card">
            <p>{item.label}</p>
            <strong>{item.value}</strong>
            <span>{item.sub}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section evds26-table-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">10년 전체 비교</p>
        <h2>국내 ETF와 국내 개별주를 같은 기간으로 비교</h2>
        <p>아래 표에는 2016~2026 전체 비교가 가능한 자산만 넣었습니다. 국내 상장 미국 ETF는 별도 섹션에서 봅니다.</p>
      </div>

      <div class="evds26-mode-tabs" id="evds26ModeTabs">
        <button type="button" class="is-active" data-mode="gross">배당 미포함</button>
        <button type="button" data-mode="dividend">배당 재투자</button>
        <button type="button" data-mode="afterTax">세후 단순 추정</button>
      </div>

      <div class="evds26-table-wrap">
        <table class="evds26-table">
          <thead>
            <tr>
              <th>자산</th>
              <th>유형</th>
              <th>누적수익률</th>
              <th>CAGR</th>
              <th>MDD</th>
              <th>변동성</th>
              <th>배당 재투자</th>
              <th>세후 순수익</th>
            </tr>
          </thead>
          <tbody id="evds26CompareBody">
            {tenYearRows.map((row) => (
              <tr data-asset-id={row.id}>
                <td><strong>{row.name}</strong><span>{row.ticker}</span></td>
                <td>{bucketLabel[row.bucket]}</td>
                <td data-value="gross">{formatPercent(row.cumulativeReturn)}</td>
                <td>{formatPercent(row.cagr)}</td>
                <td class="is-risk">{formatPercent(row.mdd)}</td>
                <td>{row.volatility.toFixed(1)}%</td>
                <td data-value="dividend">{formatPercent(row.dividendAdjustedReturn ?? row.cumulativeReturn)}</td>
                <td data-value="afterTax">{formatPercent(row.afterTaxReturn ?? row.cumulativeReturn)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="evds26-note">세후 수익은 설명용 단순화 추정치이며 실제 계좌, 보유 규모, 매매 방식에 따라 달라질 수 있습니다.</p>
    </section>

    <section class="content-section evds26-chart-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">성장 곡선</p>
        <h2>2016=100으로 지수화하면 경로 차이가 보입니다</h2>
      </div>
      <article class="evds26-chart-panel">
        <div class="evds26-chart-wrap">
          <canvas id="evds26GrowthChart"></canvas>
        </div>
      </article>
    </section>

    <section class="content-section evds26-risk-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">MDD와 변동성</p>
        <h2>가장 많이 오른 자산과 가장 버티기 쉬운 자산은 다릅니다</h2>
      </div>
      <div class="evds26-risk-grid">
        <article class="evds26-risk-card is-return"><p>누적수익률 1위</p><strong>{bestReturn.name}</strong><span>{formatPercent(bestReturn.cumulativeReturn)}</span></article>
        <article class="evds26-risk-card is-warn"><p>최대 낙폭 가장 큼</p><strong>{highestMdd.name}</strong><span>{formatPercent(highestMdd.mdd)}</span></article>
        <article class="evds26-risk-card"><p>최대 낙폭 가장 낮음</p><strong>{lowestMdd.name}</strong><span>{formatPercent(lowestMdd.mdd)}</span></article>
        <article class="evds26-risk-card"><p>변동성 가장 낮음</p><strong>{lowestVol.name}</strong><span>{lowestVol.volatility.toFixed(1)}%</span></article>
      </div>
    </section>

    <section class="content-section evds26-global-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">상장 이후 비교</p>
        <h2>국내 상장 미국 ETF는 상장 이후 성과가 어땠을까</h2>
        <p>이 섹션은 2016~2026 전체 10년 비교가 아닙니다. 각 ETF의 상장 이후 구간만 비교합니다.</p>
      </div>
      <div class="evds26-table-wrap">
        <table class="evds26-table evds26-global-table">
          <thead>
            <tr>
              <th>ETF</th>
              <th>상장일</th>
              <th>상장 이후 누적</th>
              <th>CAGR</th>
              <th>MDD</th>
              <th>보수/지수</th>
              <th>주의사항</th>
            </tr>
          </thead>
          <tbody>
            {report.globalEtfRows.map((row) => (
              <tr data-global-row={row.id}>
                <td><strong>{row.name}</strong><span>{row.ticker}</span></td>
                <td>{row.listedAt}</td>
                <td>{formatPercent(row.cumulativeReturn)}</td>
                <td>{formatPercent(row.cagr)}</td>
                <td class="is-risk">{formatPercent(row.mdd)}</td>
                <td>{row.feeNote}</td>
                <td>{row.summary}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section evds26-cost-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">세금·보수·거래비용</p>
        <h2>세후 순수익은 상품 구조에 따라 달라질 수 있습니다</h2>
      </div>
      <div class="evds26-cost-grid">
        {report.costTaxRows.map((row) => (
          <article class="evds26-cost-card">
            <h3>{row.assetType}</h3>
            <dl>
              <div><dt>매매차익</dt><dd>{row.capitalGainTax}</dd></div>
              <div><dt>거래세</dt><dd>{row.transactionTax}</dd></div>
              <div><dt>배당/분배금</dt><dd>{row.dividendTax}</dd></div>
              <div><dt>보수/수수료</dt><dd>{row.feeCost}</dd></div>
            </dl>
            <p>{row.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section evds26-strategy-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">혼합 전략</p>
        <h2>ETF 코어 + 직접투자 위성으로 현실적인 균형을 잡기</h2>
      </div>
      <div class="evds26-strategy-grid">
        {report.strategyCards.map((item) => (
          <article class={`evds26-strategy-card is-${item.id}`}>
            <span>{item.fit}</span>
            <strong>{item.title}</strong>
            <b>{item.composition}</b>
            <p>{item.summary}</p>
            <small>{item.caution}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section evds26-fit-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">투자 성향별 추천</p>
        <h2>수익률보다 내가 계속 유지할 수 있는 방식이 먼저입니다</h2>
      </div>
      <div class="evds26-fit-grid">
        {report.investorFits.map((item) => (
          <article class="evds26-fit-card">
            <p>{item.type}</p>
            <strong>{item.strategy}</strong>
            <span>{item.reason}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section evds26-source-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">출처와 다음 이동</p>
        <h2>원자료와 관련 계산기를 함께 확인하세요</h2>
      </div>
      <div class="evds26-source-grid">
        <article class="evds26-source-panel">
          <h3>참고 출처</h3>
          <div class="evds26-link-list">
            {report.sourceLinks.map((item) => (
              <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
            ))}
          </div>
        </article>
        <article class="evds26-source-panel">
          <h3>관련 계산기·리포트</h3>
          <div class="evds26-related-grid">
            {report.relatedLinks.map((item) => (
              <a href={withBase(item.href)}>
                <strong>{item.label}</strong>
                <span>{item.description}</span>
              </a>
            ))}
          </div>
        </article>
      </div>
    </section>

    <SeoContent
      introTitle="ETF와 직접투자 10년 비교를 어떻게 읽어야 하나"
      intro={[
        "ETF와 직접투자 비교는 단순 누적수익률 순위만 보면 결론이 왜곡될 수 있습니다. 10년 뒤 결과뿐 아니라 중간 하락폭, 변동성, 세금, 보유 지속 가능성을 함께 봐야 합니다.",
        "이 페이지는 2016~2026 전체 비교가 가능한 국내 ETF와 국내 개별주를 먼저 비교하고, 국내 상장 미국 ETF는 상장 이후 비교군으로 분리했습니다.",
      ]}
      inputPoints={[
        "10년 전체 비교군과 상장 이후 비교군은 기간이 다르므로 같은 표에 섞지 않았습니다.",
        "배당 재투자와 세후 단순 추정을 탭으로 전환해 수익률 해석 차이를 확인할 수 있습니다.",
        "개별주 수익률이 높아도 MDD와 변동성이 커지면 실제 보유 난이도는 크게 올라갑니다.",
      ]}
      criteria={[
        "세후 수익은 일반 투자자 기준 단순화 추정이며 세무 자문이 아닙니다.",
        "배당 재투자 수익은 설명용 비교 지표로 실제 지급일과 재투자 가격에 따라 달라질 수 있습니다.",
        "국내 상장 미국 ETF는 상장 시점이 늦어 2016~2026 10년 전체 비교표에서 제외했습니다.",
      ]}
      faq={faqItems}
      related={report.relatedLinks.map((item) => ({ href: item.href, label: item.label }))}
    />
  </main>

  <script id="etfVsDirectStock10Year2026Data" type="application/json" set:html={JSON.stringify(report)}></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/etf-vs-direct-stock-10year-2026.js")}></script>
</BaseLayout>

