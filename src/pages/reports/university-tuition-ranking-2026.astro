---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import { withBase } from "../../utils/base";
import {
  UTR_META,
  TUITION_PRESETS,
  TUITION_TREND_2022_2026,
  TUITION_TOP_SCHOOLS,
  UTR_OVERVIEW_STATS,
  UTR_MAX_TUITION,
  UTR_FAQ,
  UTR_SEO_INTRO,
  UTR_SEO_CRITERIA,
  UTR_RELATED_LINKS,
} from "../../data/universityTuitionRanking2026";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${UTR_META.slug}/`;
const man = (value: number) => `${Math.round(value / 10000).toLocaleString("ko-KR")}만원`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: UTR_META.title,
    description: UTR_META.seoDescription,
    dateModified: UTR_META.updatedAt,
    mainEntityOfPage: reportUrl,
    author: { "@type": "Organization", name: "비교계산소" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: UTR_FAQ.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
      { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
      { "@type": "ListItem", position: 3, name: UTR_META.title, item: reportUrl },
    ],
  },
];

const topSchoolMax = Math.max(...TUITION_TOP_SCHOOLS.map((s) => s.annualTuition));
---
<BaseLayout title={UTR_META.seoTitle} description={UTR_META.seoDescription} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page op-page utr-page" data-report={UTR_META.slug}>
    <CalculatorHero
      eyebrow="대학 등록금 비교"
      title={UTR_META.title}
      description={UTR_META.description}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        UTR_META.dataNote,
        "이 리포트는 명목 등록금 기준이며 국가장학금 등 지원금을 뺀 실질 등록금이 아닙니다.",
      ]}
    />

    <section class="op-section utr-overview-section">
      <h2>한눈에 보는 개요</h2>
      <div class="utr-overview-grid">
        {UTR_OVERVIEW_STATS.map((stat) => (
          <article class="utr-overview-card">
            <span>{stat.label}</span>
            <strong>{stat.value}</strong>
            {stat.note && <small>{stat.note}</small>}
          </article>
        ))}
      </div>
    </section>

    <section class="op-section">
      <h2>설립유형·계열별 등록금 비교</h2>
      <div class="utr-bar-list">
        {TUITION_PRESETS.map((preset) => (
          <div class="utr-bar-row">
            <span class="utr-bar-row__label">{preset.label}</span>
            <div class="utr-bar-row__track">
              <div class="utr-bar-row__fill" style={`width:${Math.max((preset.annualTuition / UTR_MAX_TUITION) * 100, 4)}%`}></div>
            </div>
            <span class="utr-bar-row__value">{man(preset.annualTuition)}</span>
          </div>
        ))}
      </div>
      <p class="op-message">막대 길이는 연간 등록금 기준이며, 설립유형별 평균과 계열별 평균은 서로 다른 집계 기준입니다.</p>
    </section>

    <section class="op-section">
      <h2>등록금 상위 대학 예시</h2>
      <div class="utr-table-wrap">
        <table class="utr-table">
          <thead><tr><th>대학</th><th>연간 등록금</th><th>비고</th></tr></thead>
          <tbody>
            {TUITION_TOP_SCHOOLS.map((school) => (
              <tr>
                <td><strong>{school.name}</strong></td>
                <td>{man(school.annualTuition)}</td>
                <td>{school.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="op-message">절대 순위가 아닌 참고 사례입니다. 계열 구성이 다른 학교 간 단순 비교는 주의가 필요합니다(최고 {man(topSchoolMax)}).</p>
    </section>

    <section class="op-section">
      <h2>최근 5년 등록금 인상·동결 현황</h2>
      <div class="utr-table-wrap">
        <table class="utr-table">
          <thead><tr><th>학년도</th><th>법정 인상 상한</th><th>실제 인상 대학 수</th></tr></thead>
          <tbody>
            {TUITION_TREND_2022_2026.map((row) => (
              <tr><td>{row.year}</td><td>{row.legalCapRate}%</td><td>{row.raisedSchools}개교</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="op-section">
      <h2>같이 보면 좋은 계산기와 리포트</h2>
      <div class="utr-related-grid">
        {UTR_RELATED_LINKS.map((link) => (
          <a class="utr-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="대학 등록금 순위, 이렇게 읽으면 됩니다"
      intro={UTR_SEO_INTRO}
      criteria={UTR_SEO_CRITERIA}
      faq={UTR_FAQ}
      related={UTR_RELATED_LINKS.map((l) => ({ href: l.href, label: l.label }))}
    />
  </main>
</BaseLayout>
