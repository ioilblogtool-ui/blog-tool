---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  GNAP_APARTMENTS,
  GNAP_AREA_CARDS,
  GNAP_CONTEXT,
  GNAP_FAQ,
  GNAP_META,
  GNAP_METHOD,
  GNAP_RELATED_LINKS,
  GNAP_RISKS,
  GNAP_SEO_CRITERIA,
  GNAP_SEO_INTRO,
} from "../../data/gangnamApartmentPrice2026";
import { withBase } from "../../utils/base";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${GNAP_META.slug}/`;
const defaultApartment = GNAP_APARTMENTS[0];
const maxPrice = GNAP_APARTMENTS.reduce((max, row) => (row.latestTradePriceManwon > max.latestTradePriceManwon ? row : max), defaultApartment);
const maxGain = GNAP_APARTMENTS.reduce((max, row) => (row.estimatedGainManwon > max.estimatedGainManwon ? row : max), defaultApartment);
const redevelopmentCount = GNAP_APARTMENTS.filter((row) => row.areaGroup === "재건축 기대권").length;
const newTownCount = GNAP_APARTMENTS.filter((row) => row.areaGroup === "개포·일원권").length;
const primeAreaCount = GNAP_APARTMENTS.filter((row) => row.areaGroup === "압구정·청담권" || row.areaGroup === "대치·도곡권").length;

const formatEok = (manwon: number) => {
  const eok = manwon / 10000;
  const fixed = eok >= 10 ? eok.toFixed(1) : eok.toFixed(2);
  return `${fixed.replace(/\.0$/, "")}억원`;
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: GNAP_META.title,
      description: GNAP_META.description,
      dateModified: GNAP_META.updatedAt,
      inLanguage: "ko-KR",
      mainEntityOfPage: reportUrl,
      author: { "@type": "Organization", name: "비교계산소" },
      about: ["강남 아파트", "압구정 현대", "대치 아파트", "개포 아파트", "강남 실거래가"],
    },
    {
      "@type": "FAQPage",
      mainEntity: GNAP_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
        { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
        { "@type": "ListItem", position: 3, name: GNAP_META.title, item: reportUrl },
      ],
    },
  ],
};
---

<BaseLayout title={GNAP_META.seoTitle} description={GNAP_META.description} canonicalUrl={reportUrl} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page gnap-page" data-report="gangnam-apartment-price-2026">
    <CalculatorHero
      eyebrow="강남 실거래가 리포트"
      title="강남 대장 아파트, 최저가일 때 샀다면 지금 얼마를 벌었을까?"
      description={GNAP_META.description}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        GNAP_META.notice,
        "이 리포트는 서울특별시 강남구 행정구역을 기준으로 하며, 생활권은 압구정·청담권, 대치·도곡권, 개포·일원권, 삼성·역삼권, 재건축 기대권으로 나눠 표시합니다.",
        "재건축 기대감은 현재 실거래가와 분리해서 해석해야 하며, 사업 속도·부담금·입주 시점은 확정값처럼 표시하지 않습니다.",
        "초고가·재건축 단지는 84㎡ 일반 아파트와 직접 비교가 어려울 수 있어 면적 정보를 별도로 표시합니다.",
        "최저가 대비 금액은 세금·중개보수·대출이자·보유비용을 반영하지 않은 평가차익(추정)입니다.",
        "이 리포트는 투자 권유가 아니며 실제 거래 판단은 국토교통부 실거래가 공개시스템과 현장 확인을 기준으로 해야 합니다.",
      ]}
    />

    <section class="gnap-summary" aria-labelledby="gnap-summary-title">
      <div class="gnap-section-head">
        <p>요약</p>
        <h2 id="gnap-summary-title">강남 Top10 후보 기준 한눈에 보기</h2>
      </div>
      <div class="gnap-summary-grid">
        <article class="gnap-summary-card">
          <span>데이터 기준</span>
          <strong>{GNAP_META.updatedAt}</strong>
          <p>{GNAP_META.dataAsOf}</p>
        </article>
        <article class="gnap-summary-card">
          <span>최고 기준가</span>
          <strong>{formatEok(maxPrice.latestTradePriceManwon)}</strong>
          <p>{maxPrice.complexName} 후보값</p>
        </article>
        <article class="gnap-summary-card">
          <span>최대 평가차익(추정)</span>
          <strong>{formatEok(maxGain.estimatedGainManwon)}</strong>
          <p>{maxGain.complexName} 기준 단순 시세 차이</p>
        </article>
        <article class="gnap-summary-card">
          <span>생활권 구성</span>
          <strong>{primeAreaCount}/{newTownCount}/{redevelopmentCount}</strong>
          <p>핵심 고가권 / 개포 신축권 / 재건축 기대권</p>
        </article>
      </div>
    </section>

    <section class="gnap-picker" aria-labelledby="gnap-picker-title">
      <div class="gnap-section-head">
        <p>단지별 카드</p>
        <h2 id="gnap-picker-title">최저가일 때 샀다면 지금 평가차익은?</h2>
      </div>

      <div class="gnap-tabs" role="tablist" aria-label="강남 아파트 단지 선택">
        {GNAP_APARTMENTS.map((row, index) => (
          <button
            class={`gnap-tab${index === 0 ? " is-active" : ""}`}
            type="button"
            data-complex={row.id}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            {row.rank}. {row.complexName}
          </button>
        ))}
      </div>

      <article class="gnap-profit-card" aria-live="polite">
        <div class="gnap-profit-card__main">
          <span class="gnap-badge" data-gnap-field="badge">{defaultApartment.badge}</span>
          <h3 data-gnap-field="complexName">{defaultApartment.complexName}</h3>
          <p class="gnap-area-line" data-gnap-field="areaLine">
            {defaultApartment.legalDongLabel} · {defaultApartment.areaGroup} · {defaultApartment.stationLabel}
          </p>
          <p data-gnap-field="profitSentence">
            {defaultApartment.fiveYearLowDate} {formatEok(defaultApartment.fiveYearLowPriceManwon)}에 거래됐고, 현재 기준가는 {formatEok(defaultApartment.latestTradePriceManwon)}입니다.
          </p>
          <div class="gnap-profit-card__numbers">
            <div>
              <span>평가차익(추정)</span>
              <strong data-gnap-field="gain">{formatEok(defaultApartment.estimatedGainManwon)}</strong>
            </div>
            <div>
              <span>상승률(추정)</span>
              <strong data-gnap-field="gainRate">{defaultApartment.estimatedGainRate}%</strong>
            </div>
          </div>
        </div>
        <dl class="gnap-profit-card__meta">
          <div><dt>최근 기준가</dt><dd data-gnap-field="latest">{formatEok(defaultApartment.latestTradePriceManwon)}</dd></div>
          <div><dt>거래일·면적</dt><dd data-gnap-field="latestMeta">{defaultApartment.latestTradeDate} · {defaultApartment.latestTradeArea}</dd></div>
          <div><dt>5년 저점권 참고</dt><dd data-gnap-field="low">{formatEok(defaultApartment.fiveYearLowPriceManwon)}</dd></div>
          <div><dt>생활권 메모</dt><dd data-gnap-field="schoolNote">{defaultApartment.schoolNote ?? defaultApartment.stationLabel}</dd></div>
          <div><dt>재건축 메모</dt><dd data-gnap-field="redevelopmentNote">{defaultApartment.redevelopmentNote ?? "재건축 기대 단지로 분류하지 않았습니다."}</dd></div>
          <div><dt>주의</dt><dd data-gnap-field="note">{defaultApartment.note}</dd></div>
        </dl>
      </article>
      <p class="gnap-plain-note">
        금액은 취득세, 중개보수, 보유세, 대출이자, 양도세를 반영하지 않은 단순 시세 차이입니다. 같은 단지라도 동·층·조망·면적·거래 시점에 따라 실제 가격은 크게 달라질 수 있습니다.
      </p>
    </section>

    <section class="gnap-table-section" aria-labelledby="gnap-table-title">
      <div class="gnap-section-head gnap-section-head--row">
        <div>
          <p>비교표</p>
          <h2 id="gnap-table-title">강남 대장 아파트 Top10 실거래가</h2>
        </div>
        <div class="gnap-sort-controls" aria-label="정렬 기준">
          <button class="is-active" type="button" data-sort="rank">순위</button>
          <button type="button" data-sort="gain">평가차익</button>
          <button type="button" data-sort="gainRate">상승률</button>
          <button type="button" data-sort="latestPrice">최근가</button>
          <button type="button" data-sort="area">생활권</button>
        </div>
      </div>
      <div class="gnap-table-wrap">
        <table class="gnap-table">
          <caption>강남 아파트 Top10 후보의 최근 기준가와 5년 저점권 대비 평가차익 비교</caption>
          <thead>
            <tr>
              <th scope="col">순위</th>
              <th scope="col">단지명</th>
              <th scope="col">법정동</th>
              <th scope="col">생활권</th>
              <th scope="col">최근 기준가</th>
              <th scope="col">거래일</th>
              <th scope="col">2025 대비</th>
              <th scope="col">5년 저점권</th>
              <th scope="col">평가차익(추정)</th>
              <th scope="col">전세가율</th>
              <th scope="col">주의</th>
            </tr>
          </thead>
          <tbody data-gnap-table-body>
            {GNAP_APARTMENTS.map((row) => (
              <tr data-row-id={row.id}>
                <td>{row.rank}</td>
                <th scope="row">
                  <strong>{row.complexName}</strong>
                  <span>{row.mainAreaLabel}</span>
                </th>
                <td>{row.legalDongLabel}</td>
                <td>{row.areaGroup}</td>
                <td>{formatEok(row.latestTradePriceManwon)}</td>
                <td>{row.latestTradeDate}</td>
                <td>{row.previousYearPriceManwon ? `${formatEok(row.latestTradePriceManwon - row.previousYearPriceManwon)} 상승 참고` : "확인 필요"}</td>
                <td>{formatEok(row.fiveYearLowPriceManwon)}</td>
                <td>{formatEok(row.estimatedGainManwon)} · {row.estimatedGainRate}%</td>
                <td>{row.jeonseRatio ? `${row.jeonseRatio}% 참고` : "확인 필요"}</td>
                <td>{row.tradeCountNote}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="gnap-area-map" aria-labelledby="gnap-area-title">
      <div class="gnap-section-head">
        <p>생활권 분해</p>
        <h2 id="gnap-area-title">압구정·청담·대치·개포 생활권 가격 차이</h2>
      </div>
      <div class="gnap-area-grid" data-gnap-area-cards>
        {GNAP_AREA_CARDS.map((card) => (
          <article class={`gnap-area-card${card.areaGroup === defaultApartment.areaGroup ? " is-selected" : ""}`} data-area-group={card.areaGroup}>
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
            <strong>{card.priceInterpretation}</strong>
            <small>{card.caution}</small>
          </article>
        ))}
      </div>
      <p class="gnap-plain-note">
        강남구는 같은 구 안에서도 압구정·청담 초고가권, 대치 학군권, 개포 신축권, 삼성·역삼 직주근접권의 가격 논리가 다릅니다. 재건축 기대감, 입주 연식, 면적, 거래 시점에 따라 가격 차이가 크게 날 수 있습니다.
      </p>
    </section>

    <section class="gnap-chart" aria-labelledby="gnap-chart-title">
      <div class="gnap-section-head">
        <p>막대 비교</p>
        <h2 id="gnap-chart-title">현재 기준가 vs 5년 저점권 참고가</h2>
      </div>
      <div class="gnap-bar-list" data-gnap-bars>
        {GNAP_APARTMENTS.map((row) => (
          <article class="gnap-bar-row" data-row-id={row.id}>
            <div class="gnap-bar-row__label">
              <strong>{row.complexName}</strong>
              <span>{row.areaGroup} · {row.badge}</span>
            </div>
            <div class="gnap-bar-row__bars">
              <span class="gnap-bar gnap-bar--latest" style={`width: ${(row.latestTradePriceManwon / maxPrice.latestTradePriceManwon) * 100}%`}>{formatEok(row.latestTradePriceManwon)}</span>
              <span class="gnap-bar gnap-bar--low" style={`width: ${(row.fiveYearLowPriceManwon / maxPrice.latestTradePriceManwon) * 100}%`}>{formatEok(row.fiveYearLowPriceManwon)}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="gnap-context" aria-labelledby="gnap-context-title">
      <div class="gnap-section-head">
        <p>가격 맥락</p>
        <h2 id="gnap-context-title">강남 아파트 가격을 읽는 핵심 변수</h2>
      </div>
      <div class="gnap-context-grid">
        {GNAP_CONTEXT.map((card) => (
          <article class="gnap-context-card">
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="gnap-data-method" aria-labelledby="gnap-method-title">
      <div class="gnap-section-head">
        <p>데이터 기준</p>
        <h2 id="gnap-method-title">강남 실거래가 데이터 기준</h2>
      </div>
      <ul class="gnap-risk-list">
        {GNAP_METHOD.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="gnap-risk" aria-labelledby="gnap-risk-title">
      <div class="gnap-section-head">
        <p>리스크</p>
        <h2 id="gnap-risk-title">평가차익보다 먼저 봐야 하는 변수</h2>
      </div>
      <ul class="gnap-risk-list">
        {GNAP_RISKS.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="gnap-related" aria-labelledby="gnap-related-title">
      <div class="gnap-section-head">
        <p>다음 단계</p>
        <h2 id="gnap-related-title">강남 가격 확인 후 이어서 볼 리포트와 계산기</h2>
      </div>
      <div class="gnap-related-grid">
        {GNAP_RELATED_LINKS.map((link) => (
          <a class="gnap-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="강남 아파트 실거래가를 볼 때 먼저 확인할 것"
      intro={GNAP_SEO_INTRO}
      criteria={GNAP_SEO_CRITERIA}
      faq={GNAP_FAQ}
      related={GNAP_RELATED_LINKS}
    />

    <script type="application/json" id="gnap-data" set:html={JSON.stringify(GNAP_APARTMENTS)}></script>
    <script type="application/json" id="gnap-area-data" set:html={JSON.stringify(GNAP_AREA_CARDS)}></script>
    <script src={withBase("/scripts/gangnam-apartment-price-2026.js")} defer></script>
  </main>
</BaseLayout>
