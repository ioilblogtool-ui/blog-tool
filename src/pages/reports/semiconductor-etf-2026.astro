---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  DATA_UPDATED_AT,
  ETF_ROWS,
  FAQ_ITEMS,
  FX_RATE_KRW_PER_USD,
  MATCHING_ROWS,
  REFERENCES,
  RELATED_LINKS,
  REPORT_META,
  SEMICONDUCTOR_COMPANIES,
  SUMMARY_CARDS,
  TAKEAWAYS,
} from "../../data/semiconductorEtf2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const faqItems = FAQ_ITEMS.map((item) => ({ question: item.q, answer: item.a }));
const relatedLinks = RELATED_LINKS.map((item) => ({ label: item.label, href: item.href }));
const chartSeed = {
  etfs: ETF_ROWS.map((item) => ({
    ticker: item.ticker,
    market: item.market,
    aumKrwBillion: item.aumKrwBillion,
  })),
  companies: SEMICONDUCTOR_COMPANIES.map((item) => ({
    name: item.name,
    marketCapKrwTrillion: item.marketCapKrwTrillion,
  })),
};

const formatAum = (value: number) => {
  if (value >= 1000) return `${(value / 1000).toFixed(2)}조원`;
  return `${value.toFixed(0)}억원`;
};

const formatCompanyCap = (value: number) => `${value.toLocaleString("ko-KR", { maximumFractionDigits: 1 })}조원`;
---

<BaseLayout title={REPORT_META.title} description={REPORT_META.description}>
  <SiteHeader />

  <main class="container page-shell report-page se26-page">
    <CalculatorHero
      eyebrow="반도체 ETF 리포트"
      title="미국·한국 반도체 ETF 비교 2026"
      description="SOXX, SMH, TIGER, RISE, ACE를 원화 기준 운용 규모와 최신 반도체 시총 흐름까지 묶어서 비교합니다."
    />

    <InfoNotice
      title="비교 기준 안내"
      lines={[REPORT_META.methodology, REPORT_META.caution, REPORT_META.updatedAt]}
    />

    <section class="content-section se26-summary-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">Overview</p>
        <h2>이 페이지에서 먼저 봐야 할 숫자</h2>
      </div>
      <div class="se26-summary-grid">
        {SUMMARY_CARDS.map((card) => (
          <article class="se26-summary-card">
            <p>{card.label}</p>
            <strong>{card.value}</strong>
            <span>{card.sub}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section se26-chart-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">ETF 규모</p>
        <h2>원화 기준 ETF 규모를 한눈에 보면 미국 원ETF와 국내 상장 ETF의 체급 차이가 보입니다</h2>
        <p>미국 ETF 순자산도 같은 기준환율로 원화 환산해 나란히 비교했습니다. 국내 상장 ETF는 실제 원화 순자산을 그대로 사용했습니다.</p>
      </div>
      <article class="se26-chart-panel">
        <div class="se26-chart-wrap">
          <canvas id="se26AumChart" aria-label="반도체 ETF 원화 기준 규모 차트"></canvas>
        </div>
        <p class="se26-chart-note">환산 기준: 1달러 = {FX_RATE_KRW_PER_USD.toLocaleString("ko-KR")}원. ETF별 기준일이 다르므로 절대 순위보다 체급 비교용으로 보는 편이 좋습니다.</p>
      </article>
    </section>

    <section class="content-section se26-etf-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">ETF 비교</p>
        <h2>국내형과 미국형은 상장 시장, 환노출, 집중도가 모두 다릅니다</h2>
        <p>버튼으로 시장을 좁혀 보고, 표에서는 규모, 총보수, 환헤지 여부, 상위 보유 종목을 함께 읽어보세요.</p>
      </div>

      <div class="se26-tab-row" id="se26MarketTabs">
        <button type="button" class="se26-tab-btn is-active" data-market-tab="all">전체</button>
        <button type="button" class="se26-tab-btn" data-market-tab="US">미국 상장</button>
        <button type="button" class="se26-tab-btn" data-market-tab="KR">한국 상장</button>
      </div>

      <div class="table-wrap">
        <table class="se26-table">
          <thead>
            <tr>
              <th>ETF</th>
              <th>시장</th>
              <th>성격</th>
              <th>총보수</th>
              <th>원화 기준 규모</th>
              <th>환 구조</th>
              <th>상위 보유 종목</th>
              <th>잘 맞는 경우</th>
            </tr>
          </thead>
          <tbody>
            {ETF_ROWS.map((etf) => (
              <tr data-market-row={etf.market}>
                <td>
                  <div class="se26-row-title">
                    <span class={`se26-ticker ${etf.market === "US" ? "se26-ticker--us" : "se26-ticker--kr"}`}>{etf.ticker}</span>
                    <strong>{etf.name}</strong>
                    <span>{etf.manager}</span>
                  </div>
                </td>
                <td>{etf.market === "US" ? "미국" : "한국"}</td>
                <td>
                  <span class="se26-badge">{etf.category}</span>
                  <p class="se26-inline-note">{etf.focus}</p>
                </td>
                <td>{etf.expenseRatio.toFixed(2)}%</td>
                <td>
                  <strong class="is-current">{formatAum(etf.aumKrwBillion)}</strong>
                  <span class="se26-inline-note">{etf.aumOriginal} · {etf.sourceDate}</span>
                </td>
                <td>{etf.hedged}</td>
                <td>
                  <div class="se26-holding-chips">
                    {etf.topHoldings.length > 0 ? etf.topHoldings.map((holding) => (
                      <span class="se26-holding-chip">{holding.name} <em>{holding.weight}%</em></span>
                    )) : <span class="se26-inline-note">핵심 보유 종목은 출처 링크 참고</span>}
                  </div>
                </td>
                <td>{etf.fit}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section se26-mktcap-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">반도체 시총</p>
        <h2>최신 시총을 원화로 환산하면 어떤 ETF가 어떤 체급의 기업을 담는지 감이 빨라집니다</h2>
        <p>{DATA_UPDATED_AT} 현재 공개된 최신 시총 기준을 원화 환산한 비교용 값입니다. 삼성전자와 SK하이닉스도 같은 축에서 읽을 수 있게 맞췄습니다.</p>
      </div>
      <article class="se26-chart-panel">
        <div class="se26-chart-wrap">
          <canvas id="se26MarketCapChart" aria-label="반도체 시가총액 원화 환산 차트"></canvas>
        </div>
      </article>
      <div class="se26-bar-list">
        {SEMICONDUCTOR_COMPANIES.map((company) => (
          <div class="se26-bar-row">
            <div class="se26-bar-meta">
              <span class="se26-bar-rank">{company.rank}</span>
              <div class="se26-bar-info">
                <strong>{company.name}</strong>
                <span>{company.country} · {company.segment}</span>
              </div>
              <span class="se26-bar-cap">{formatCompanyCap(company.marketCapKrwTrillion)}</span>
            </div>
            <div class="se26-bar-etfs">
              {company.includedEtfs.map((etf) => <span class="se26-etf-badge">{etf}</span>)}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="content-section se26-matching-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">선택 가이드</p>
        <h2>무엇을 원하느냐에 따라 고르는 ETF가 달라집니다</h2>
      </div>
      <div class="table-wrap">
        <table class="se26-table se26-table--matching">
          <thead>
            <tr>
              <th>내가 원하는 것</th>
              <th>우선 볼 ETF</th>
            </tr>
          </thead>
          <tbody>
            {MATCHING_ROWS.map((row) => (
              <tr>
                <td>{row.need}</td>
                <td><span class="se26-match-etf">{row.etf}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section se26-takeaway-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">추가로 볼 것</p>
        <h2>이 페이지에 더해 같이 체크하면 좋은 포인트</h2>
      </div>
      <div class="se26-pros-grid">
        {TAKEAWAYS.map((item) => (
          <article class="se26-pros-card">
            <strong class="se26-pros-card__name">{item.title}</strong>
            <p class="se26-pros-card__body">{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section se26-reference-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">출처와 연결</p>
        <h2>공식 페이지와 같이 보면 해석이 더 정확합니다</h2>
      </div>
      <div class="se26-reference-grid">
        <article class="se26-reference-card">
          <h3>공식 운용사 페이지</h3>
          <div class="se26-reference-links">
            {REFERENCES.official.map((item) => <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>)}
          </div>
        </article>
        <article class="se26-reference-card">
          <h3>시장 규모 참고</h3>
          <div class="se26-reference-links">
            {REFERENCES.market.map((item) => <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>)}
          </div>
        </article>
        <article class="se26-reference-card">
          <h3>같이 볼 콘텐츠</h3>
          <div class="se26-reference-links">
            {REFERENCES.supporting.map((item) => (
              item.href.startsWith("/")
                ? <a href={withBase(item.href)}>{item.label}</a>
                : <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
            ))}
          </div>
        </article>
      </div>
    </section>

    <section class="content-section se26-cta-section">
      <div class="se26-cta-card">
        <div>
          <p class="se26-cta-card__eyebrow">다음 액션</p>
          <h2>ETF 비교를 본 뒤에는 실제 수익 곡선과 산업 구조를 같이 보면 판단이 훨씬 쉬워집니다</h2>
          <p>적립식 투자 계산기와 반도체 밸류체인 리포트로 이어서 보면, 어떤 ETF가 어떤 기업 체급과 산업 구간을 담는지 연결해서 볼 수 있습니다.</p>
        </div>
        <div class="button-group">
          {RELATED_LINKS.map((item) => <a class="button button--secondary" href={withBase(item.href)}>{item.label}</a>)}
        </div>
      </div>
    </section>

    <SeoContent
      introTitle="반도체 ETF 2026 리포트를 읽는 방법"
      intro={[
        "이 페이지는 미국 상장 반도체 ETF와 한국 상장 반도체 ETF를 같은 화면에서 비교하기 위해 만들었습니다. 단순 수익률보다 먼저 운용 규모, 상위 보유 종목, 환노출 구조, 어떤 시총 체급의 기업을 담고 있는지를 같이 읽게 하는 데 목적이 있습니다.",
        "특히 원화 기준 비교를 넣은 이유는 한국 투자자 입장에서 미국 원ETF와 국내 상장 ETF의 체급 차이와 접근성을 한 번에 읽기 쉽게 만들기 위해서입니다. 원화 환산은 비교용 기준이고, 실제 투자 판단 전에는 운용사 공식 페이지의 최신 AUM과 구성 종목을 다시 확인하는 것이 안전합니다.",
      ]}
      criteria={[
        `미국 ETF 순자산은 달러 기준 값을 1달러=${FX_RATE_KRW_PER_USD.toLocaleString("ko-KR")}원으로 환산한 비교용 수치입니다.`,
        "국내 ETF 순자산은 운용사 페이지 또는 최근 공개 기사 내 KRX 인용 수치를 그대로 사용했습니다.",
        "반도체 기업 시총은 2026년 4월 9일 시점의 최신 공개 랭킹을 기준으로 원화 환산했습니다.",
        "한국 상장 ETF는 미국 원ETF 대비 총보수가 높아도 원화 매수 편의, 연금 계좌 활용, 세금 체감 측면에서 장점이 있을 수 있습니다.",
      ]}
      faq={faqItems}
      related={relatedLinks}
    />
  </main>

  <script id="se26ChartSeed" type="application/json" set:html={JSON.stringify(chartSeed)}></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/semiconductor-etf-2026.js")}></script>
</BaseLayout>
