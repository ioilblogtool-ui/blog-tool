      </div>

      <div class="otc-faq-list">
        {FAQ_ITEMS.map((item, index) => (
          <details class="otc-faq-item" open={index === 0}>
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="content-section otc-cta-section">
      <div class="otc-cta-card">
        <div>
          <p class="otc-cta-card__eyebrow">다음 단계</p>
