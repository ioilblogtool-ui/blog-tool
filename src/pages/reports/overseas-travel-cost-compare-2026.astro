---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  BUDGET_MATRIX,
  CITIES,
  FAQ_ITEMS,
  FX_STRATEGY_CARDS,
  REGION_SUMMARY,
  RELATED_LINKS,
  SAVING_TIPS,
  TRAVEL_REPORT_META,
} from "../../data/overseasTravelCostCompare2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const styleOrder = ["budget", "standard", "premium"] as const;
const durationOrder = ["2n3d", "4n5d", "7n8d"] as const;
const regionOrder = ["japan", "southeast-asia", "europe"] as const;

const styleLabels = {
  budget: "배낭형",
  standard: "스탠다드",
  premium: "프리미엄",
} as const;

const durationLabels = {
  "2n3d": "2박 3일",
  "4n5d": "4박 5일",
  "7n8d": "7박 8일",
} as const;

const regionLabels = {
  japan: "일본",
  "southeast-asia": "동남아",
  europe: "유럽",
} as const;

const cityById = Object.fromEntries(CITIES.map((city) => [city.id, city]));
const defaultStyle = "standard";
const defaultDuration = "4n5d";
const defaultRows = [...BUDGET_MATRIX[defaultStyle][defaultDuration]].sort((a, b) => a.total - b.total);
const cheapestRow = defaultRows[0];
const priciestRow = defaultRows[defaultRows.length - 1];
const averageTotal = Math.round(defaultRows.reduce((sum, row) => sum + row.total, 0) / defaultRows.length);
const gapTotal = priciestRow.total - cheapestRow.total;

const regionStats = regionOrder.map((regionId) => {
  const rows = defaultRows.filter((row) => cityById[row.cityId]?.region === regionId);
  const average = Math.round(rows.reduce((sum, row) => sum + row.total, 0) / rows.length);
  return {
    regionId,
    average,
    ...REGION_SUMMARY[regionId],
  };
});

const cheapestRegion = [...regionStats].sort((a, b) => a.average - b.average)[0];

const overviewStats = [
  { label: "비교 도시", value: `${CITIES.length}개 도시`, note: "일본 2 · 동남아 3 · 유럽 3" },
  { label: "기준 인원", value: `${TRAVEL_REPORT_META.persons}인`, note: "성인 2인 기준" },
  { label: "기준 시나리오", value: `${styleLabels[defaultStyle]} · ${durationLabels[defaultDuration]}`, note: "기본 비교값" },
  { label: "조사 시점", value: `${TRAVEL_REPORT_META.updatedAt} 기준`, note: TRAVEL_REPORT_META.rateNote },
];

const formatWon = (value: number) => `${Math.round(value).toLocaleString("ko-KR")}원`;
const formatRange = (min: number, max: number) => `${formatWon(min)} ~ ${formatWon(max)}`;

const flightRows = CITIES.map((city) => ({
  city,
  offseason: formatRange(city.flight.offseason.min, city.flight.offseason.max),
  regular: formatRange(city.flight.regular.min, city.flight.regular.max),
  peak: formatRange(city.flight.peak.min, city.flight.peak.max),
  luggage: city.flight.luggageExtra ? `추가 수하물 2인 ${formatWon(city.flight.luggageExtra)}` : "기본 수하물 포함",
}));

const stayRows = CITIES.map((city) => ({
  city,
  hostel: formatWon(city.accommodation.hostel),
  standard: formatWon(city.accommodation.standard),
  premium: formatWon(city.accommodation.premium),
  tax: city.accommodation.taxPerNightPer > 0
    ? `1인 1박 ${formatWon(city.accommodation.taxPerNightPer)} + ${city.accommodation.taxNote}`
    : city.accommodation.taxNote,
}));

const foodRows = CITIES.map((city) => ({
  city,
  cheapMeal: formatWon(city.food.cheapMealPer),
  midMeal: formatWon(city.food.midMeal2p),
  coffee: formatWon(city.food.coffeePer),
  attractions: city.attractions.slice(0, 3).map((item) => `${item.name} ${formatWon(item.pricePer)}`).join(" · "),
}));

const miscRows = CITIES.map((city) => ({
  city,
  transport: `${formatWon(city.transport.dailyPerPerson)} / 1인 1일`,
  airportTransfer: `${formatWon(city.transport.airportTransferPer)} / 1인 편도`,
  esim: `${formatWon(city.sim.fiveDayPer)} / 1인 5일`,
  insurance: `${formatWon(city.insuranceAvg2p)} / 2인`,
}));

const seed = {
  meta: TRAVEL_REPORT_META,
  cities: CITIES.map((city) => ({
    id: city.id,
    label: city.label,
    region: city.region,
    country: city.country,
  })),
  matrix: BUDGET_MATRIX,
  regionSummary: REGION_SUMMARY,
};

const faqItems = FAQ_ITEMS.map((item) => ({ question: item.q, answer: item.a }));
---

<BaseLayout
  title={TRAVEL_REPORT_META.title}
  description="일본, 동남아, 유럽 8개 도시의 2026년 해외여행 총비용을 항공권, 숙소, 식비, 교통, 관광, 통신, 보험까지 묶어서 비교하는 리포트입니다."
>
  <SiteHeader />

  <main class="container page-shell report-page otc-compare-report-page">
    <CalculatorHero
      eyebrow="여행 비용 리포트"
      title={TRAVEL_REPORT_META.title}
      description="도쿄, 오사카, 방콕, 하노이, 마닐라, 파리, 로마, 바르셀로나를 기준으로 2인 여행 총비용 구조를 비교합니다."
      badges={["해외여행", "예산비교", "2인 기준", "2026"]}
    />

    <InfoNotice
      title="비교 기준"
      lines={[
        "모든 금액은 2026년 4월 기준 공개 시세와 예약 페이지를 바탕으로 정리한 추정값입니다.",
        TRAVEL_REPORT_META.rateNote,
        "기본 비교값은 성인 2인, 스탠다드, 4박 5일 시나리오이며 실제 예약 시점의 항공권·환율·세금에 따라 달라질 수 있습니다.",
      ]}
    />

    <section class="content-section otc-overview-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">조사 개요</p>
        <h2>같은 2인 여행이어도 권역과 스타일에 따라 총예산 구조가 크게 달라집니다</h2>
        <p>먼저 기본 조사 조건과 현재 기준에서 가장 저렴한 도시, 가장 비싼 도시를 빠르게 확인할 수 있게 구성했습니다.</p>
      </div>

      <div class="otc-overview-grid">
        {overviewStats.map((stat) => (
          <article class="otc-overview-card">
            <p>{stat.label}</p>
            <strong>{stat.value}</strong>
            <span>{stat.note}</span>
          </article>
        ))}
      </div>

      <div class="otc-headline-grid">
        <article class="otc-headline-card is-low">
          <p>기본 시나리오 최저 도시</p>
          <strong>{cityById[cheapestRow.cityId].label}</strong>
          <span>{formatWon(cheapestRow.total)}</span>
        </article>
        <article class="otc-headline-card is-high">
          <p>기본 시나리오 최고 도시</p>
          <strong>{cityById[priciestRow.cityId].label}</strong>
          <span>{formatWon(priciestRow.total)}</span>
        </article>
        <article class="otc-headline-card is-gap">
          <p>최저-최고 격차</p>
          <strong>{formatWon(gapTotal)}</strong>
          <span>{cityById[cheapestRow.cityId].label} vs {cityById[priciestRow.cityId].label}</span>
        </article>
      </div>
    </section>

    <section class="content-section otc-static-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">항공권 · 수하물</p>
        <h2>동남아는 현지 물가보다 항공권이, 유럽은 항공권과 수하물이 동시에 총액을 끌어올립니다</h2>
        <p>서울 출발 2인 왕복 기준 범위형 가격으로 정리했습니다. 저가항공 이용 시 수하물 비용을 반드시 함께 봐야 합니다.</p>
      </div>

      <div class="table-wrap">
        <table class="otc-table otc-table--dense">
          <thead>
            <tr>
              <th>도시</th>
              <th>비수기</th>
              <th>일반</th>
              <th>성수기</th>
              <th>수하물 메모</th>
            </tr>
          </thead>
          <tbody>
            {flightRows.map((row) => (
              <tr>
                <td>
                  <strong>{row.city.label}</strong>
                  <span>{regionLabels[row.city.region]} · {row.city.country}</span>
                </td>
                <td>{row.offseason}</td>
                <td>{row.regular}</td>
                <td>{row.peak}</td>
                <td>{row.luggage}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section otc-static-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">숙박</p>
        <h2>숙소 등급 차이가 가장 크게 벌어지는 구간은 유럽이고, 동남아는 상향 선택에도 부담이 낮은 편입니다</h2>
        <p>1박 2인 1실 기준입니다. 유럽 도시는 관광세와 숙박세가 별도로 붙는 경우가 많아 총액 계산에 포함했습니다.</p>
      </div>

      <div class="table-wrap">
        <table class="otc-table otc-table--dense">
          <thead>
            <tr>
              <th>도시</th>
              <th>호스텔/가성비</th>
              <th>2~3성급</th>
              <th>4성급 이상</th>
              <th>도시세/관광세</th>
            </tr>
          </thead>
          <tbody>
            {stayRows.map((row) => (
              <tr>
                <td>
                  <strong>{row.city.label}</strong>
                  <span>{regionLabels[row.city.region]}</span>
                </td>
                <td>{row.hostel}</td>
                <td>{row.standard}</td>
                <td>{row.premium}</td>
                <td>{row.tax}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section otc-static-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">식비 · 관광</p>
        <h2>현지 체감 물가는 식비와 입장료에서 갈리고, 같은 도시 안에서도 선택지에 따라 편차가 큽니다</h2>
        <p>가벼운 식사, 중간급 2인 식사, 커피, 대표 유료 관광지 3개 기준으로 도시별 체감 구조를 요약했습니다.</p>
      </div>

      <div class="table-wrap">
        <table class="otc-table otc-table--dense">
          <thead>
            <tr>
              <th>도시</th>
              <th>가벼운 식사</th>
              <th>중간급 2인 식사</th>
              <th>커피/간식</th>
              <th>대표 관광지</th>
            </tr>
          </thead>
          <tbody>
            {foodRows.map((row) => (
              <tr>
                <td>
                  <strong>{row.city.label}</strong>
                  <span>{regionLabels[row.city.region]}</span>
                </td>
                <td>{row.cheapMeal}</td>
                <td>{row.midMeal}</td>
                <td>{row.coffee}</td>
                <td>{row.attractions}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section otc-static-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">교통 · 통신 · 보험</p>
        <h2>작아 보이는 부대비용이 여행 기간이 길어질수록 총예산을 꾸준히 밀어 올립니다</h2>
        <p>시내 교통, 공항 이동, 5일 eSIM, 2인 여행자보험 기준이며, 장기 일정일수록 체감 차이가 커집니다.</p>
      </div>

      <div class="table-wrap">
        <table class="otc-table otc-table--dense">
          <thead>
            <tr>
              <th>도시</th>
              <th>시내 교통</th>
              <th>공항 이동</th>
              <th>eSIM</th>
              <th>여행자보험</th>
            </tr>
          </thead>
          <tbody>
            {miscRows.map((row) => (
              <tr>
                <td>
                  <strong>{row.city.label}</strong>
                  <span>{regionLabels[row.city.region]}</span>
                </td>
                <td>{row.transport}</td>
                <td>{row.airportTransfer}</td>
                <td>{row.esim}</td>
                <td>{row.insurance}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section otc-strategy-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">환전 · 결제</p>
        <h2>환율과 결제 수단은 총예산보다 체감 스트레스에 더 직접적으로 작용합니다</h2>
        <p>현금, 여행 특화 카드, 현지 ATM 인출을 같이 비교해 두면 현지에서 불필요한 수수료를 줄일 수 있습니다.</p>
      </div>

      <div class="otc-strategy-grid">
        {FX_STRATEGY_CARDS.map((card) => (
          <article class="otc-strategy-card">
            <p class="otc-strategy-card__eyebrow">{card.icon} {card.title}</p>
            <strong>{card.tip}</strong>
            <ul>
              {card.pros.map((item) => <li>{item}</li>)}
            </ul>
            <p class="otc-strategy-card__cons">{card.cons.join(" / ")}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section otc-sim-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">예산 시뮬레이터</p>
        <h2>여행 스타일과 기간을 바꾸면 8개 도시 총예산이 바로 다시 정렬됩니다</h2>
        <p>가장 저렴한 도시와 가장 비싼 도시, 평균 총액, 권역 평균까지 한 번에 비교할 수 있게 구성했습니다.</p>
      </div>

      <div class="otc-control-block">
        <p class="otc-control-label">여행 스타일</p>
        <div class="otc-pill-row">
          {styleOrder.map((style) => (
            <button
              type="button"
              class={`otc-pill${style === defaultStyle ? " is-active" : ""}`}
              data-otc-style={style}
            >
              {styleLabels[style]}
            </button>
          ))}
        </div>
      </div>

      <div class="otc-control-block">
        <p class="otc-control-label">여행 기간</p>
        <div class="otc-pill-row">
          {durationOrder.map((duration) => (
            <button
              type="button"
              class={`otc-pill${duration === defaultDuration ? " is-active" : ""}`}
              data-otc-duration={duration}
            >
              {durationLabels[duration]}
            </button>
          ))}
        </div>
      </div>

      <p class="otc-scenario-line" id="otcScenarioLine">
        현재 기준은 <strong>{styleLabels[defaultStyle]}</strong> · <strong>{durationLabels[defaultDuration]}</strong>, 성인 <strong>{TRAVEL_REPORT_META.persons}인</strong>입니다.
      </p>

      <div class="otc-chart-wrap">
        <canvas id="otcCompareChart"></canvas>
      </div>

      <div class="otc-summary-grid">
        <article class="otc-summary-card">
          <p>최저 도시</p>
          <strong id="otcSummaryLowCity">{cityById[cheapestRow.cityId].label}</strong>
          <span id="otcSummaryLowValue">{formatWon(cheapestRow.total)}</span>
        </article>
        <article class="otc-summary-card">
          <p>최고 도시</p>
          <strong id="otcSummaryHighCity">{cityById[priciestRow.cityId].label}</strong>
          <span id="otcSummaryHighValue">{formatWon(priciestRow.total)}</span>
        </article>
        <article class="otc-summary-card">
          <p>평균 총액</p>
          <strong id="otcSummaryAvgValue">{formatWon(averageTotal)}</strong>
          <span>{styleLabels[defaultStyle]} · {durationLabels[defaultDuration]}</span>
        </article>
        <article class="otc-summary-card">
          <p>권역 최저 평균</p>
          <strong id="otcSummaryRegion">{cheapestRegion.title}</strong>
          <span id="otcSummaryRegionValue">평균 {formatWon(cheapestRegion.average)}</span>
        </article>
      </div>

      <div class="otc-highlight-grid">
        <article class="otc-highlight-card">
          <p>최소-최대 격차</p>
          <strong id="otcSummaryGapValue">{formatWon(gapTotal)}</strong>
          <span id="otcSummaryGapText">{cityById[cheapestRow.cityId].label} 대비 {cityById[priciestRow.cityId].label}</span>
        </article>
        <article class="otc-highlight-card">
          <p>항공권 비중이 큰 도시</p>
          <strong id="otcSummaryFlightText">장거리 도시에서 항공 비중이 큽니다</strong>
          <span id="otcSummaryFlightValue">유럽은 총액의 절반 이상이 항공권인 경우가 많습니다.</span>
        </article>
      </div>

      <div class="table-wrap">
        <table class="otc-table">
          <thead>
            <tr>
              <th>도시</th>
              <th>항공 + 수하물</th>
              <th>숙박</th>
              <th>식비</th>
              <th>교통 + 관광</th>
              <th>통신 + 보험 + 기타세</th>
              <th>총액</th>
            </tr>
          </thead>
          <tbody id="otcCompareTableBody">
            {defaultRows.map((row) => (
              <tr>
                <td>
                  <strong>{cityById[row.cityId].label}</strong>
                  <span>{regionLabels[cityById[row.cityId].region]} · {cityById[row.cityId].country}</span>
                </td>
                <td>{formatWon(row.flight + row.luggage)}</td>
                <td>{formatWon(row.accommodation)}</td>
                <td>{formatWon(row.food)}</td>
                <td>{formatWon(row.transport + row.attractions)}</td>
                <td>{formatWon(row.sim + row.insurance + row.misc)}</td>
                <td class="is-total">{formatWon(row.total)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section otc-internal-link-section">
      <div class="otc-cta-card">
        <div>
          <p class="otc-cta-card__eyebrow">내부 링크</p>
          <h2>도시별 평균 비교 다음에는 해외 여행 계산기로 내 일정 기준 예산을 바로 계산해보세요</h2>
          <p>이 리포트가 도시별 평균 구조를 보여준다면, 해외 여행 계산기는 항공권, 숙소, 식비, 환율, 인원 수를 직접 넣어 내 여행 조건에 맞는 총예산을 계산하는 페이지입니다.</p>
        </div>
        <div class="otc-cta-links">
          <a class="button button--primary" href={withBase("/tools/overseas-travel-cost/")}>해외 여행 계산기 열기</a>
        </div>
      </div>
    </section>

    <section class="content-section otc-region-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">권역 요약</p>
        <h2>일본, 동남아, 유럽은 같은 여행비가 아니라 다른 구조의 비용 묶음입니다</h2>
      </div>

      <div class="otc-region-grid">
        {regionStats.map((region) => (
          <article class="otc-region-card">
            <p class="otc-region-card__eyebrow">{region.emoji} {region.title}</p>
            <strong>{region.recommend}</strong>
            <p>{region.pros}</p>
            <div class="otc-region-card__subgrid">
              <div>
                <span>주의 포인트</span>
                <b>{region.cons}</b>
              </div>
              <div>
                <span>평균 총액</span>
                <b>{formatWon(region.average)}</b>
              </div>
            </div>
          </article>
        ))}
