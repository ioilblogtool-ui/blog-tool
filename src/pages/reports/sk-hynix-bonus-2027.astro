---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import CompareCta from "../../components/CompareCta.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  SK_HYNIX_BONUS_2027_CRITERIA,
  SK_HYNIX_BONUS_2027_FAQ,
  SK_HYNIX_BONUS_2027_INVESTMENT_NOTES,
  SK_HYNIX_BONUS_2027_KPIS,
  SK_HYNIX_BONUS_2027_META,
  SK_HYNIX_BONUS_2027_RANK_ROWS,
  SK_HYNIX_BONUS_2027_REASON_CARDS,
  SK_HYNIX_BONUS_2027_RELATED,
  SK_HYNIX_BONUS_2027_SCENARIOS,
  SK_HYNIX_BONUS_2027_SEO_INTRO,
  SK_HYNIX_BONUS_2027_TAX_NOTES,
  SK_HYNIX_BONUS_STRUCTURE,
  formatWon,
} from "../../data/skHynixBonus2027";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteUrl = "https://bigyocalc.com";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: SK_HYNIX_BONUS_2027_META.title,
      description: SK_HYNIX_BONUS_2027_META.description,
      inLanguage: "ko-KR",
      dateModified: SK_HYNIX_BONUS_2027_META.dateModified,
      mainEntityOfPage: `${siteUrl}/reports/${SK_HYNIX_BONUS_2027_META.slug}/`,
      author: { "@type": "Organization", name: "비교계산소" },
      publisher: { "@type": "Organization", name: "비교계산소" },
    },
    {
      "@type": "FAQPage",
      mainEntity: SK_HYNIX_BONUS_2027_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<BaseLayout
  title={`${SK_HYNIX_BONUS_2027_META.title} | SK하이닉스 PS·PI 시나리오`}
  description={SK_HYNIX_BONUS_2027_META.description}
  jsonLd={jsonLd}
>
  <SiteHeader />

  <main class="container page-shell report-page skb27-page" data-report="sk-hynix-bonus-2027">
    <CalculatorHero
      eyebrow="SK하이닉스 성과급 전망"
      title={SK_HYNIX_BONUS_2027_META.title}
      description="2027년 SK하이닉스 PS·PI를 보수·기준·낙관 시나리오로 나누고, 직급별 세전 예상 성과급과 다음 계산 흐름까지 정리했습니다."
    />

    <InfoNotice
      title="성과급 전망 수치 안내"
      lines={[
        "이 페이지의 금액은 공식 확정 지급액이 아니라 기준급과 PS·PI 가정을 적용한 추정 시나리오입니다.",
        "실제 지급액은 회사 확정안, 개인 기준급, 직급, 재직 조건, 세금·공제 조건에 따라 달라질 수 있습니다.",
        "세후 실수령액과 투자 가능 금액은 계산기에서 본인 연봉과 성과급을 다시 넣어 확인하는 것을 권장합니다.",
      ]}
    />

    <section class="skb27-hero-board" aria-label="하이닉스 2027 성과급 핵심 요약">
      <div class="skb27-hero-copy">
        <span class="skb27-pill">추정 시나리오</span>
        <h2>노출이 이미 잡힌 하이닉스 성과급 검색 수요를 바로 받을 페이지</h2>
        <p>
          핵심은 단일 예상액이 아니라 PS 기준급 범위, PI 포함 여부, 직급별 체감액입니다. 결과를 본 뒤 바로
          하이닉스 계산기와 세후 계산기로 이어지도록 CTA를 상단에 배치했습니다.
        </p>
        <div class="skb27-hero-actions">
          <a class="button button--primary" href={withBase("/tools/sk-hynix-bonus/")}>내 연봉으로 계산하기</a>
          <a class="button button--secondary" href={withBase("/tools/bonus-after-tax-calculator/?company=sk-hynix")}>
            세후 실수령액 보기
          </a>
        </div>
      </div>
      <div class="skb27-kpi-grid">
        {SK_HYNIX_BONUS_2027_KPIS.map((item) => (
          <article class="skb27-kpi-card">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section skb27-section" id="structure">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">지급 구조</p>
        <h2>2027 전망 전에 PS·PI·기준급을 먼저 분리해서 봅니다</h2>
        <p>성과급 headline이 커질수록 PS와 PI가 섞여 보이기 쉽습니다. 이 리포트는 두 항목을 합산하되 기준은 분리해서 설명합니다.</p>
      </div>
      <div class="skb27-structure-grid">
        {SK_HYNIX_BONUS_STRUCTURE.map((item) => (
          <article class="skb27-structure-card">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section skb27-section" id="why-2027">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">왜 2027인가</p>
        <h2>하이닉스 2027 성과급은 업황과 이익률 변화에 민감합니다</h2>
      </div>
      <div class="skb27-reason-grid">
        {SK_HYNIX_BONUS_2027_REASON_CARDS.map((item) => (
          <article>
            <strong>{item.title}</strong>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section skb27-section" id="scenarios">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">영업이익별 시나리오</p>
        <h2>PS 기준급 5,400~6,600% 범위로 보면 과도한 확정 표현을 피할 수 있습니다</h2>
        <p>아래 표는 2027년 PS와 PI를 이해하기 위한 추정 범위입니다. 실제 확정안 발표 전까지는 범위로 해석하는 편이 안전합니다.</p>
      </div>
      <div class="skb27-scenario-grid">
        {SK_HYNIX_BONUS_2027_SCENARIOS.map((scenario) => (
          <article class={`skb27-scenario-card skb27-scenario-card--${scenario.id}`}>
            <div class="skb27-scenario-card__head">
              <span>{scenario.subtitle}</span>
              <h3>{scenario.label}</h3>
            </div>
            <strong>{scenario.summary}</strong>
            <p>{scenario.operatingProfitLabel}</p>
            <small>{scenario.interpretation}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section skb27-section" id="rank-table">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">직급별 예상표</p>
        <h2>직급별 연봉 가정으로 본 2027 하이닉스 성과급 예상액</h2>
        <p>표의 금액은 PS와 PI를 합친 세전 기준입니다. 내 연봉과 기준급이 다르면 계산기에서 직접 조정하세요.</p>
      </div>
      <div class="skb27-table-wrap">
        <table class="skb27-rank-table">
          <thead>
            <tr>
              <th>직급 가정</th>
              <th>연봉 가정</th>
              <th>보수적</th>
              <th>기준</th>
              <th>낙관</th>
              <th>월 환산 체감</th>
            </tr>
          </thead>
          <tbody>
            {SK_HYNIX_BONUS_2027_RANK_ROWS.map((row) => (
              <tr>
                <th>
                  <span>{row.rankLabel}</span>
                  <small>{row.note}</small>
                </th>
                <td>{formatWon(row.annualSalary)}</td>
                <td>{formatWon(row.conservativeBonus)}</td>
                <td><strong>{formatWon(row.baseBonus)}</strong></td>
                <td>{formatWon(row.aggressiveBonus)}</td>
                <td>{formatWon(row.baseMonthlyImpact)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="skb27-inline-cta">
        <div>
          <strong>내 기준급으로 다시 보면 차이가 큽니다</strong>
          <p>연봉, 기준급, PS·PI를 직접 바꿔서 본인 조건에 가까운 금액을 확인해보세요.</p>
        </div>
        <a class="button button--primary" href={withBase("/tools/sk-hynix-bonus/")}>하이닉스 계산기 열기</a>
      </div>
    </section>

    <section class="content-section skb27-section" id="tax">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">세후 실수령</p>
        <h2>성과급은 세전 금액보다 세후 체감액으로 계획해야 합니다</h2>
      </div>
      <div class="skb27-note-grid">
        {SK_HYNIX_BONUS_2027_TAX_NOTES.map((item) => (
          <article>{item}</article>
        ))}
      </div>
      <div class="skb27-inline-cta skb27-inline-cta--soft">
        <div>
          <strong>성과급 세후 금액을 바로 확인하세요</strong>
          <p>세전 성과급을 넣고 원천징수 이후 체감액을 다시 계산하면 지출·투자 계획이 더 현실적입니다.</p>
        </div>
        <a class="button button--secondary" href={withBase("/tools/bonus-after-tax-calculator/?company=sk-hynix")}>
          세후 실수령 계산하기
        </a>
      </div>
    </section>

    <section class="content-section skb27-section" id="next-action">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">다음 행동</p>
        <h2>성과급을 받았다면 세후·투자·비교 흐름으로 이어가세요</h2>
      </div>
      <div class="skb27-next-grid">
        <article>
          <span>1</span>
          <strong>내 연봉 기준 성과급</strong>
          <p>하이닉스 계산기에서 기준급과 PS·PI를 조정합니다.</p>
          <a href={withBase("/tools/sk-hynix-bonus/")}>계산하기</a>
        </article>
        <article>
          <span>2</span>
          <strong>세후 실수령액</strong>
          <p>성과급이 통장에 들어온 뒤 실제 남는 금액을 확인합니다.</p>
          <a href={withBase("/tools/bonus-after-tax-calculator/?company=sk-hynix")}>세후 보기</a>
        </article>
        <article>
          <span>3</span>
          <strong>나눠 투자했을 때</strong>
          <p>성과급 일부를 매달 나눠 넣는 경우의 장기 결과를 비교합니다.</p>
          <a href={withBase("/tools/dca-investment-calculator/")}>투자 시뮬레이션</a>
        </article>
      </div>
      <div class="skb27-investment-list">
        {SK_HYNIX_BONUS_2027_INVESTMENT_NOTES.map((item) => <p>{item}</p>)}
      </div>
    </section>

    <CompareCta
      variant="bonus"
      title="하이닉스 성과급을 삼성전자·반도체 업종과 비교해보세요"
      description="2027년 하이닉스 성과급 전망을 본 뒤 삼성전자, DB하이텍 등 반도체 성과급 구조와 세후 체감액까지 이어서 확인할 수 있습니다."
      links={[
        { href: "/compare/bonus/", label: "성과급 비교표 보기" },
        { href: "/tools/semiconductor-bonus-comparison/", label: "반도체 성과급 계산" },
      ]}
    />

    <SeoContent
      introTitle="하이닉스 2027 성과급 전망을 볼 때 중요한 기준"
      intro={SK_HYNIX_BONUS_2027_SEO_INTRO}
      criteria={SK_HYNIX_BONUS_2027_CRITERIA}
      faq={SK_HYNIX_BONUS_2027_FAQ}
      related={SK_HYNIX_BONUS_2027_RELATED}
    />
  </main>
</BaseLayout>
