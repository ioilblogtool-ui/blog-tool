<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script define:vars={{ barChartData, regionalChartData }}>
  window.addEventListener("load", () => {
    if (typeof window.Chart === "undefined") return;

    const barCtx = document.getElementById("ekcBarChart");
    if (barCtx) {
      new window.Chart(barCtx, {
        type: "bar",
        data: {
          labels: barChartData.labels,
          datasets: [{
            label: "3년 누적 비용 (추정)",
            data: barChartData.data,
            backgroundColor: barChartData.colors,
            borderRadius: 4,
          }],
        },
        options: {
          indexAxis: "y",
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx) => ` 약 ${Math.round(Number(ctx.parsed.x) / 10000).toLocaleString("ko-KR")}만 원`,
              },
            },
          },
          scales: {
            x: { ticks: { callback: (v) => Math.round(Number(v) / 10000) + "만" } },
            y: { grid: { display: false } },
          },
        },
      });
    }

    const regionalCtx = document.getElementById("ekcRegionalChart");
    if (regionalCtx) {
      new window.Chart(regionalCtx, {
        type: "bar",
        data: {
          labels: regionalChartData.labels,
          datasets: [
            { label: "영어유치원", data: regionalChartData.english, backgroundColor: "#F59E0B", borderRadius: 4 },
            { label: "일반유치원(민간)", data: regionalChartData.regular, backgroundColor: "#0F6E56", borderRadius: 4 },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: "top" },
            tooltip: {
              callbacks: {
                label: (ctx) => ` ${ctx.dataset.label}: 약 ${Math.round(Number(ctx.parsed.y) / 10000).toLocaleString("ko-KR")}만 원`,
              },
            },
          },
          scales: {
            x: { grid: { display: false } },
            y: { ticks: { callback: (v) => Math.round(Number(v) / 10000) + "만" } },
          },
        },
      });
    }
  });
</script>
