---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  DTAP_APARTMENTS,
  DTAP_CONTEXT,
  DTAP_FAQ,
  DTAP_META,
  DTAP_METHOD,
  DTAP_RELATED_LINKS,
  DTAP_RISKS,
  DTAP_SEO_CRITERIA,
  DTAP_SEO_INTRO,
} from "../../data/dongtanApartmentPrice2026";
import { withBase } from "../../utils/base";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${DTAP_META.slug}/`;
const defaultApartment = DTAP_APARTMENTS[0];
const averageGainRate = Math.round(DTAP_APARTMENTS.reduce((sum, row) => sum + row.estimatedGainRate, 0) / DTAP_APARTMENTS.length);
const maxGain = DTAP_APARTMENTS.reduce((max, row) => (row.estimatedGainManwon > max.estimatedGainManwon ? row : max), defaultApartment);
const confirmedCount = DTAP_APARTMENTS.filter((row) => row.badge !== "확인 필요").length;

const formatEok = (manwon: number) => {
  const eok = manwon / 10000;
  const fixed = eok >= 10 ? eok.toFixed(1) : eok.toFixed(2);
  return `${fixed.replace(/\.0$/, "")}억원`;
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: DTAP_META.title,
      description: DTAP_META.description,
      dateModified: DTAP_META.updatedAt,
      inLanguage: "ko-KR",
      mainEntityOfPage: reportUrl,
      author: { "@type": "Organization", name: "비교계산소" },
      about: ["동탄 아파트", "동탄 실거래가", "동탄 대장 아파트", "동탄역 롯데캐슬"],
    },
    {
      "@type": "FAQPage",
      mainEntity: DTAP_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
        { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
        { "@type": "ListItem", position: 3, name: DTAP_META.title, item: reportUrl },
      ],
    },
  ],
};
---

<BaseLayout title={DTAP_META.seoTitle} description={DTAP_META.description} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page dtap-page" data-report="dongtan-apartment-price-2026">
    <CalculatorHero
      eyebrow="동탄 실거래가 리포트"
      title="동탄 대장 아파트, 최저가일 때 샀다면 지금 얼마를 벌었을까?"
      description={DTAP_META.description}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        DTAP_META.notice,
        "최저가 대비 금액은 세금·중개보수·대출이자·보유비용을 반영하지 않은 평가차익(추정)입니다.",
        "이 리포트는 투자 권유가 아니며, 실제 거래 판단은 국토교통부 실거래가 공개시스템과 현장 확인을 기준으로 해야 합니다.",
      ]}
    />

    <section class="dtap-summary" aria-labelledby="dtap-summary-title">
      <div class="dtap-section-head">
        <p>요약</p>
        <h2 id="dtap-summary-title">동탄 Top10 실거래 기준 한눈에 보기</h2>
      </div>
      <div class="dtap-summary-grid">
        <article class="dtap-summary-card">
          <span>데이터 기준</span>
          <strong>{DTAP_META.updatedAt}</strong>
          <p>{DTAP_META.dataAsOf}</p>
        </article>
        <article class="dtap-summary-card">
          <span>비교 단지</span>
          <strong>{DTAP_APARTMENTS.length}개</strong>
          <p>확인값 {confirmedCount}개, 재확인 후보 {DTAP_APARTMENTS.length - confirmedCount}개</p>
        </article>
        <article class="dtap-summary-card">
          <span>평균 상승률</span>
          <strong>{averageGainRate}%</strong>
          <p>최근 기준가와 5년 저점 참고가의 단순 비교</p>
        </article>
        <article class="dtap-summary-card">
          <span>최대 평가차익(추정)</span>
          <strong>{formatEok(maxGain.estimatedGainManwon)}</strong>
          <p>{maxGain.complexName} 기준</p>
        </article>
      </div>
    </section>

    <section class="dtap-picker" aria-labelledby="dtap-picker-title">
      <div class="dtap-section-head">
        <p>단지별 카드</p>
        <h2 id="dtap-picker-title">최저가일 때 샀다면 지금 평가차익은?</h2>
      </div>

      <div class="dtap-tabs" role="tablist" aria-label="동탄 아파트 단지 선택">
        {DTAP_APARTMENTS.map((row, index) => (
          <button
            class={`dtap-tab${index === 0 ? " is-active" : ""}`}
            type="button"
            data-complex={row.id}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            {row.rank}. {row.complexName}
          </button>
        ))}
      </div>

      <article class="dtap-profit-card" aria-live="polite">
        <div class="dtap-profit-card__main">
          <span class="dtap-badge" data-dtap-field="badge">{defaultApartment.badge}</span>
          <h3 data-dtap-field="complexName">{defaultApartment.complexName}</h3>
          <p data-dtap-field="profitSentence">
            {defaultApartment.fiveYearLowDate} {formatEok(defaultApartment.fiveYearLowPriceManwon)}에 거래된 뒤, 현재 기준가는 {formatEok(defaultApartment.latestTradePriceManwon)}입니다.
          </p>
          <div class="dtap-profit-card__numbers">
            <div>
              <span>평가차익(추정)</span>
              <strong data-dtap-field="gain">{formatEok(defaultApartment.estimatedGainManwon)}</strong>
            </div>
            <div>
              <span>상승률(추정)</span>
              <strong data-dtap-field="gainRate">{defaultApartment.estimatedGainRate}%</strong>
            </div>
          </div>
        </div>
        <dl class="dtap-profit-card__meta">
          <div><dt>최근 기준가</dt><dd data-dtap-field="latest">{formatEok(defaultApartment.latestTradePriceManwon)}</dd></div>
          <div><dt>거래일·면적</dt><dd data-dtap-field="latestMeta">{defaultApartment.latestTradeDate} · {defaultApartment.latestTradeArea}</dd></div>
          <div><dt>5년 저점 참고</dt><dd data-dtap-field="low">{formatEok(defaultApartment.fiveYearLowPriceManwon)}</dd></div>
          <div><dt>주의</dt><dd data-dtap-field="note">{defaultApartment.note}</dd></div>
        </dl>
      </article>
      <p class="dtap-plain-note">
        이 금액은 취득세, 중개보수, 보유세, 대출이자, 양도소득세를 반영하지 않은 단순 시세 차이입니다. 실제 투자 성과나 매수 추천으로 해석하면 안 됩니다.
      </p>
    </section>

    <section class="dtap-table-section" aria-labelledby="dtap-table-title">
      <div class="dtap-section-head dtap-section-head--row">
        <div>
          <p>비교표</p>
          <h2 id="dtap-table-title">동탄 대장 아파트 Top10 실거래가</h2>
        </div>
        <div class="dtap-sort-controls" aria-label="정렬 기준">
          <button class="is-active" type="button" data-sort="rank">순위</button>
          <button type="button" data-sort="gain">평가차익</button>
          <button type="button" data-sort="gainRate">상승률</button>
          <button type="button" data-sort="latestPrice">최근가</button>
        </div>
      </div>
      <div class="dtap-table-wrap">
        <table class="dtap-table">
          <caption>동탄 아파트 Top10 최근 기준가와 5년 저점 대비 평가차익 비교</caption>
          <thead>
            <tr>
              <th scope="col">순위</th>
              <th scope="col">단지명</th>
              <th scope="col">권역</th>
              <th scope="col">최근 실거래가</th>
              <th scope="col">거래일</th>
              <th scope="col">2025 대비</th>
              <th scope="col">5년 저점 참고</th>
              <th scope="col">평가차익(추정)</th>
              <th scope="col">전세가율</th>
              <th scope="col">주의</th>
            </tr>
          </thead>
          <tbody data-dtap-table-body>
            {DTAP_APARTMENTS.map((row) => (
              <tr data-row-id={row.id}>
                <td>{row.rank}</td>
                <th scope="row">
                  <strong>{row.complexName}</strong>
                  <span>{row.mainAreaLabel}</span>
                </th>
                <td>{row.areaGroup}</td>
                <td>{formatEok(row.latestTradePriceManwon)}</td>
                <td>{row.latestTradeDate}</td>
                <td>{row.previousYearPriceManwon ? `${formatEok(row.latestTradePriceManwon - row.previousYearPriceManwon)} 상승 참고` : "확인 필요"}</td>
                <td>{formatEok(row.fiveYearLowPriceManwon)}</td>
                <td>{formatEok(row.estimatedGainManwon)} · {row.estimatedGainRate}%</td>
                <td>{row.jeonseRatio ? `${row.jeonseRatio}% 참고` : "확인 필요"}</td>
                <td>{row.tradeCountNote}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="dtap-chart" aria-labelledby="dtap-chart-title">
      <div class="dtap-section-head">
        <p>막대 비교</p>
        <h2 id="dtap-chart-title">현재 기준가 vs 5년 저점 참고가</h2>
      </div>
      <div class="dtap-bar-list" data-dtap-bars>
        {DTAP_APARTMENTS.map((row) => (
          <article class="dtap-bar-row" data-row-id={row.id}>
            <div class="dtap-bar-row__label">
              <strong>{row.complexName}</strong>
              <span>{row.badge}</span>
            </div>
            <div class="dtap-bar-row__bars">
              <span class="dtap-bar dtap-bar--latest" style={`width: ${(row.latestTradePriceManwon / maxGain.latestTradePriceManwon) * 100}%`}>{formatEok(row.latestTradePriceManwon)}</span>
              <span class="dtap-bar dtap-bar--low" style={`width: ${(row.fiveYearLowPriceManwon / maxGain.latestTradePriceManwon) * 100}%`}>{formatEok(row.fiveYearLowPriceManwon)}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="dtap-context" aria-labelledby="dtap-context-title">
      <div class="dtap-section-head">
        <p>가격 맥락</p>
        <h2 id="dtap-context-title">동탄역권·시범단지·호수공원권 가격 차이</h2>
      </div>
      <div class="dtap-context-grid">
        {DTAP_CONTEXT.map((card) => (
          <article class="dtap-context-card">
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="dtap-data-method" aria-labelledby="dtap-method-title">
      <div class="dtap-section-head">
        <p>데이터 기준</p>
        <h2 id="dtap-method-title">실거래가를 볼 때 반드시 확인할 점</h2>
      </div>
      <ul class="dtap-risk-list">
        {DTAP_METHOD.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="dtap-risk" aria-labelledby="dtap-risk-title">
      <div class="dtap-section-head">
        <p>리스크</p>
        <h2 id="dtap-risk-title">평가차익보다 먼저 봐야 하는 변수</h2>
      </div>
      <ul class="dtap-risk-list">
        {DTAP_RISKS.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="dtap-related" aria-labelledby="dtap-related-title">
      <div class="dtap-section-head">
        <p>다음 단계</p>
        <h2 id="dtap-related-title">가격 확인 뒤 이어서 볼 리포트와 계산기</h2>
      </div>
      <div class="dtap-related-grid">
        {DTAP_RELATED_LINKS.map((link) => (
          <a class="dtap-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="동탄 아파트 실거래가를 볼 때 먼저 확인할 것"
      intro={DTAP_SEO_INTRO}
      criteria={DTAP_SEO_CRITERIA}
      faq={DTAP_FAQ}
      related={DTAP_RELATED_LINKS}
    />

    <script type="application/json" id="dtap-data" set:html={JSON.stringify(DTAP_APARTMENTS)}></script>
    <script src={withBase("/scripts/dongtan-apartment-price-2026.js")} defer></script>
  </main>
</BaseLayout>
