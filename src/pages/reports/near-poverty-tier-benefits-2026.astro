---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  NPT_APPLICATION_STEPS,
  NPT_AUDIENCE_RECOMMENDATIONS,
  NPT_BENEFIT_ITEMS,
  NPT_COMPARISON_ROWS,
  NPT_FAQ,
  NPT_MEDIAN_INCOME_ROWS,
  NPT_META,
  NPT_RELATED_LINKS,
  NPT_SEO_CONTENT,
} from "../../data/nearPovertyTierBenefits2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const won = (value: number) => `${value.toLocaleString("ko-KR")}원`;
const sourceClass = (label: string) =>
  ({
    공식: "official",
    "확인 필요": "check",
    추정: "estimate",
  }[label] ?? "check");
const filterGroup = (group: string) => {
  if (group === "medical" || group === "jobs" || group === "disability") return "medical";
  if (group === "discount") return "discount";
  if (group === "voucher" || group === "education") return "voucher";
  if (group === "family" || group === "childcare") return "family";
  return "verify";
};
const filterLabels: Record<string, string> = {
  all: "전체",
  medical: "의료·자활",
  discount: "감면",
  voucher: "바우처",
  family: "가족·돌봄",
};
const fourPerson = NPT_MEDIAN_INCOME_ROWS.find((row) => row.householdSize === 4)!;
const faqSchema = NPT_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: { "@type": "Answer", text: item.answer },
}));
const chartSeed = {
  thresholdRow: fourPerson,
};
---

<BaseLayout
  title={NPT_META.seoTitle}
  description={NPT_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Article",
        headline: NPT_META.seoTitle,
        description: NPT_META.seoDescription,
        inLanguage: "ko-KR",
        dateModified: NPT_META.updatedAt,
        mainEntityOfPage: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/reports/near-poverty-tier-benefits-2026/`,
        author: { "@type": "Organization", name: "비교계산소" },
        publisher: { "@type": "Organization", name: "비교계산소" },
      },
      { "@type": "FAQPage", mainEntity: faqSchema },
    ],
  }}
>
  <SiteHeader />

  <main class="container page-shell report-page npt-page">
    <CalculatorHero
      eyebrow="복지/지원금 리포트"
      title={NPT_META.title}
      description="기초생활수급자는 아니지만 소득이 낮은 가구가 확인할 수 있는 혜택을 한 번에 정리합니다."
      badges={["2026", "차상위계층", "기준 중위소득", "확인서 발급"]}
    />

    <InfoNotice
      title="읽기 전 확인"
      lines={[
        NPT_META.dataNote,
        "차상위계층 확인서는 개별 혜택 신청의 전제 조건일 뿐이며, 확인서만으로 모든 혜택이 자동 적용되지 않습니다.",
        "실제 혜택 여부는 신청 시점, 사업 예산, 가구 특성에 따라 달라질 수 있습니다.",
      ]}
    />

    <DesignTrustPanel
      title="차상위계층 혜택 비교 기준"
      updatedAt={NPT_META.updatedAt}
      items={[
        { label: "공식", title: "기준 중위소득·차상위 확인 기준", description: "보건복지부 2026년 기준값을 표와 차트에 반영했습니다." },
        { label: "확인 필요", title: "세부 혜택 11종 소득기준·금액", description: "사업마다 공고 시점과 기준이 달라 확인 필요 배지로 분리했습니다." },
      ]}
      notes={[
        "이 리포트는 수급 확정이 아니라 신청 전 점검과 비교를 위한 자료입니다.",
        "정확한 신청 가능 여부는 복지로, 정부24, 주민센터에서 확인하세요.",
      ]}
    />

    <section class="content-section npt-summary">
      <div class="npt-summary-grid">
        <article class="npt-summary-card npt-summary-card--primary">
          <span>공식</span>
          <p>4인 가구 차상위계층 확인 기준</p>
          <strong>{won(fourPerson.education)}</strong>
          <small>기준 중위소득 50%</small>
        </article>
        <article class="npt-summary-card">
          <span>공식</span>
          <p>기초수급과의 차이</p>
          <strong>현금 급여 vs 감면·바우처</strong>
          <small>지원 형태가 다름</small>
        </article>
        <article class="npt-summary-card">
          <span>확인 필요 포함</span>
          <p>세부 혜택</p>
          <strong>{NPT_BENEFIT_ITEMS.length}종</strong>
          <small>의료·자활·통신·전기·바우처 등</small>
        </article>
        <article class="npt-summary-card">
          <span>공식</span>
          <p>확인서 발급처</p>
          <strong>복지로 · 주민센터</strong>
          <small>온라인·방문 모두 가능</small>
        </article>
      </div>
    </section>

    <section class="content-section npt-section" id="what-is-near-poverty">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">기초 개념</p>
        <h2>차상위계층은 기초수급자와 무엇이 다른가</h2>
        <p>차상위계층은 기초생활수급자 기준(중위 32~50%)은 넘지만, 소득이 낮아 감면·바우처 혜택을 받을 수 있는 계층입니다.</p>
      </div>

      <div class="npt-table-wrap">
        <table class="npt-comparison-table">
          <thead>
            <tr>
              <th>구분</th>
              <th>기초생활수급자</th>
              <th>차상위계층</th>
            </tr>
          </thead>
          <tbody>
            {NPT_COMPARISON_ROWS.map((row) => (
              <tr>
                <td>{row.label}</td>
                <td>{row.basicLivelihood}</td>
                <td class="is-highlight">{row.nearPoverty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="npt-chart-wrap npt-chart-wrap--short">
        <canvas id="nptThresholdChart" aria-label="4인 가구 기초수급 급여별 기준과 차상위계층 확인 기준 비교 차트"></canvas>
      </div>

      <div class="npt-table-wrap">
        <table class="npt-table">
          <thead>
            <tr>
              <th>가구원 수</th>
              <th>기준 중위소득</th>
              <th>차상위계층 확인 기준(중위 50%)</th>
            </tr>
          </thead>
          <tbody>
            {NPT_MEDIAN_INCOME_ROWS.map((row) => (
              <tr>
                <td>{row.householdSize}인</td>
                <td>{won(row.median2026)}</td>
                <td class="is-highlight">{won(row.education)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section npt-section" id="how-to-apply">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">발급 절차</p>
        <h2>차상위계층 확인서, 어떻게 받나요</h2>
      </div>
      <ol class="npt-step-list">
        {NPT_APPLICATION_STEPS.map((step) => (
          <li class="npt-step-card">
            <span class="npt-step-number">{step.step}</span>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="npt-calculator-cta" aria-labelledby="npt-calc-cta-title">
      <p class="npt-cta-eyebrow">직접 확인하기</p>
      <h2 id="npt-calc-cta-title">우리 집 소득인정액으로 수급·차상위 가능성을 계산해보세요</h2>
      <p>가구원 수, 소득, 재산 정보를 입력하면 기초수급과 차상위 중 어디에 해당할 가능성이 높은지 확인할 수 있습니다.</p>
      <a href={withBase("/tools/welfare-benefit-eligibility/")} class="npt-cta-button">복지급여 수급자격 계산기 열기</a>
    </section>

    <section class="content-section npt-section" id="benefit-list">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">세부 혜택 11종</p>
        <h2>차상위계층 혜택 한눈에 보기</h2>
        <p>분류 버튼을 누르면 관심 있는 혜택만 좁혀 볼 수 있습니다. 확인 필요 배지는 소득기준·금액을 공식 공고에서 다시 봐야 한다는 뜻입니다.</p>
      </div>
      <div class="npt-filter-row" role="tablist" aria-label="차상위 혜택 분류">
        {Object.entries(filterLabels).map(([group, label], index) => (
          <button
            class={`npt-filter-btn${index === 0 ? " is-active" : ""}`}
            type="button"
            data-npt-filter={group}
            aria-selected={index === 0 ? "true" : "false"}
          >
            {label}
          </button>
        ))}
      </div>
      <div class="npt-benefit-grid">
        {NPT_BENEFIT_ITEMS.map((item) => (
          <article class="npt-benefit-card" data-npt-group={filterGroup(item.group)}>
            <div class="npt-benefit-card__top">
              <span class={`npt-source-badge npt-source-badge--${sourceClass(item.sourceLabel)}`}>{item.sourceLabel}</span>
            </div>
            <h3>{item.name}</h3>
            <p>{item.supportSummary}</p>
            <dl>
              <div><dt>대상</dt><dd>{item.target}</dd></div>
              <div><dt>소득기준</dt><dd>{item.incomeCriteria}</dd></div>
              <div><dt>신청처</dt><dd>{item.applicationChannel}</dd></div>
            </dl>
            <small>{item.updatedAt}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section npt-section" id="audience-guide">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">대상자별 추천</p>
        <h2>내 상황이라면 무엇부터 확인할까</h2>
      </div>
      <div class="npt-recommendation-grid">
        {NPT_AUDIENCE_RECOMMENDATIONS.map((item) => (
          <article class="npt-recommendation-card">
            <span>추천</span>
            <h3>{item.audience}</h3>
            <ul>{item.firstCheck.map((benefit) => <li>{benefit}</li>)}</ul>
            <p>{item.reason}</p>
            <a href={item.ctaHref.startsWith("/") ? withBase(item.ctaHref) : item.ctaHref}>{item.ctaLabel}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section npt-section" id="fallback-flow">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">탈락 시 대안</p>
        <h2>기초수급 탈락 후 차상위로 넘어가는 절차</h2>
      </div>
      <div class="npt-fallback-grid">
        <article class="npt-fallback-card">
          <span>기초생활보장 탈락 통보</span>
          <strong>차상위계층 확인 신청</strong>
          <p>자동 전환되지 않으므로 주민센터·복지로에서 별도로 신청해야 합니다.</p>
        </article>
        <article class="npt-fallback-card">
          <span>차상위 기준에서도 탈락</span>
          <strong>긴급복지지원·지자체 개별 지원</strong>
          <p>위기 사유가 있다면 긴급복지지원을 우선 확인하세요.</p>
        </article>
      </div>
    </section>

    <section class="npt-public-cta">
      <p class="npt-cta-eyebrow">공식 경로</p>
      <h2>신청 전에는 복지로·정부24·주민센터에서 최종 확인하세요</h2>
      <p>차상위 세부 혜택은 예산과 공고 기간에 따라 달라질 수 있습니다. 신청 전 공식 안내를 확인하는 것이 안전합니다.</p>
      <div class="npt-source-grid">
        <a href="https://www.bokjiro.go.kr" target="_blank" rel="noopener noreferrer">
          <span>복지로</span>
          <strong>복지서비스 통합 조회</strong>
          <small>차상위계층 확인·신청·모의계산</small>
        </a>
        <a href="https://www.energyv.or.kr" target="_blank" rel="noopener noreferrer">
          <span>에너지바우처</span>
          <strong>에너지바우처 공식 안내</strong>
          <small>냉난방비 바우처 신청 기준</small>
        </a>
        <a href="https://www.mnuri.kr" target="_blank" rel="noopener noreferrer">
          <span>문화누리카드</span>
          <strong>문화누리카드 공식 안내</strong>
          <small>문화·여행·체육 바우처 사용처</small>
        </a>
      </div>
    </section>

    <SeoContent
      introTitle={NPT_SEO_CONTENT.introTitle}
      intro={NPT_SEO_CONTENT.intro}
      inputPoints={NPT_SEO_CONTENT.inputPoints}
      criteria={NPT_SEO_CONTENT.criteria}
      faq={NPT_FAQ}
      related={NPT_RELATED_LINKS}
    />
  </main>

  <script id="npt-data" type="application/json" set:html={JSON.stringify(chartSeed)} />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/near-poverty-tier-benefits-2026.js")}></script>
</BaseLayout>
