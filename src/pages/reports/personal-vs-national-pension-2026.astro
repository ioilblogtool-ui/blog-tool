---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  PVNP_FAQ,
  PVNP_GAP_ROWS,
  PVNP_GENERATION_ROWS,
  PVNP_INCOME_MIX_ROWS,
  PVNP_META,
  PVNP_NATIONAL_PENSION_2026,
  PVNP_PAYOUT_ROWS,
  PVNP_PENSION_TAX_ROWS,
  PVNP_RELATED_LINKS,
  PVNP_RISK_ROWS,
  PVNP_SIM_ROWS,
  PVNP_TAX_CREDIT_2026,
  PVNP_TAX_CREDIT_ROWS,
  PVNP_WITHDRAWAL_ROWS,
} from "../../data/personalVsNationalPension2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const formatWon = (value: number) => `${Math.round(value / 10000).toLocaleString("ko-KR")}만 원`;
const formatMonthly = (value: number) => `월 ${formatWon(value)}`;
const formatRate = (value: number) => `${value.toFixed(1)}%`;

const faqItems = PVNP_FAQ.map((item) => ({
  question: item.q,
  answer: item.a,
}));

const faqSchema = PVNP_FAQ.map((item) => ({
  "@type": "Question",
  name: item.q,
  acceptedAnswer: {
    "@type": "Answer",
    text: item.a,
  },
}));

const heroStats = [
  {
    label: "2026 국민연금 평균 수령액",
    value: "월 약 70만 원대",
    badge: "추정",
  },
  {
    label: "세액공제 최대",
    value: "연 148만 5천 원",
    badge: "참고",
  },
  {
    label: "국민연금 고갈 시점 조정",
    value: "2071년 전후",
    badge: "추정",
  },
];

const pensionLayers = [
  { layer: "1층", title: "국민연금", role: "기본 생활비", tone: "national" },
  { layer: "2층", title: "퇴직연금 DB/DC/IRP", role: "은퇴 전후 핵심 자산", tone: "retirement" },
  { layer: "3층", title: "연금저축·IRP·ISA·ETF", role: "부족분 보완, 생활 수준 유지", tone: "personal" },
];

const generationNotes = [
  { title: "30대", text: "시간이 가장 큰 자산입니다. 소액 시작과 복리 효과를 함께 보는 편이 좋습니다." },
  { title: "40대", text: "납입기간이 줄어드는 구간입니다. 월 납입액을 높이거나 IRP·DC를 병행해 부족분을 줄여야 합니다." },
  { title: "50대", text: "수익률보다 안정성·현금흐름 설계가 우선입니다. 수령 시점과 분할 기간 전략이 핵심입니다." },
];
---

<BaseLayout
  title={PVNP_META.title}
  description={PVNP_META.description}
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    headline: PVNP_META.heroTitle,
    description: PVNP_META.description,
    inLanguage: "ko-KR",
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  }}
>
  <SiteHeader />

  <main class="container page-shell report-page pvnp-page">
    <CalculatorHero
      eyebrow={PVNP_META.eyebrow}
      title={PVNP_META.heroTitle}
      description={PVNP_META.heroDescription}
      badges={["국민연금", "개인연금", "IRP", "노후 소득 갭", "2026"]}
    />

    <InfoNotice
      title="읽기 전 기준"
      lines={[
        "이 리포트는 국민연금과 개인연금을 대립해서 고르는 페이지가 아니라, 기본 안전망과 보완 장치를 함께 설계하기 위한 참고 자료입니다.",
        "수령액·적립액·고갈 시점 예시는 추정 또는 시뮬레이션이며 실제 결과는 가입기간, 소득, 운용성과, 제도 변화에 따라 달라질 수 있습니다.",
        "세액공제 안내는 일반 정보입니다. 실제 신고 전에는 국세청과 금융회사 안내를 확인하세요.",
      ]}
    />

    <nav class="pvnp-anchor-nav" aria-label="개인연금 국민연금 비교 빠른 이동">
      <a href="#summary">30초 결론</a>
      <a href="#national-pension-2026">국민연금 현황</a>
      <a href="#income-gap">소득 갭</a>
      <a href="#simulation">개인연금 시뮬레이션</a>
      <a href="#pension-tax">세금</a>
      <a href="#related">계산기 연결</a>
    </nav>

    <section class="content-section pvnp-hero-stats" id="summary">
      <div class="pvnp-stat-grid">
        {heroStats.map((item) => (
          <article class="pvnp-stat-card">
            <span class="pvnp-badge">{item.badge}</span>
            <p>{item.label}</p>
            <strong>{item.value}</strong>
          </article>
        ))}
      </div>
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">30초 결론</p>
        <h2>국민연금은 기본 안전망, 개인연금은 부족분을 메우는 보완 장치입니다</h2>
        <p>
          월 생활비 300만 원을 기준으로 보면 국민연금 평균 수령액만으로는 부족액이 크게 남을 수 있습니다.
          연금저축 600만 원, IRP 포함 900만 원 세액공제 한도를 먼저 이해하고 장기 현금흐름을 설계하는 것이 출발점입니다.
        </p>
      </div>
      <div class="pvnp-brief-grid">
        <article class="pvnp-brief-card is-national">
          <p>국민연금</p>
          <strong>기본 생활비 안전망</strong>
          <span>단독으로 월 300만 원 생활비를 충당하기는 어려울 수 있습니다.</span>
        </article>
        <article class="pvnp-brief-card is-personal">
          <p>개인연금</p>
          <strong>노후 소득 갭 보완</strong>
          <span>연금저축·IRP는 부족분 보완과 세액공제 구조를 함께 봐야 합니다.</span>
        </article>
        <article class="pvnp-brief-card is-tax">
          <p>수령 전략</p>
          <strong>늦게 받을수록 낮아지는 연금소득세율</strong>
          <span>55~69세 5.5%, 70~79세 4.4%, 80세 이상 3.3% 기준을 참고합니다.</span>
        </article>
      </div>
    </section>

    <section class="content-section" id="national-pension-2026">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">2026 국민연금 현황</p>
        <h2>평균 수령액과 보험료율은 추정·제도 변화 맥락으로 봐야 합니다</h2>
      </div>
      <div class="pvnp-kpi-grid">
        <article class="pvnp-kpi-card is-national">
          <p>평균 수령액 추정</p>
          <strong>{formatMonthly(PVNP_NATIONAL_PENSION_2026.estimatedAverageMonthlyPayout)}</strong>
          <span>물가변동률 {PVNP_NATIONAL_PENSION_2026.increaseRate}% 반영 추정</span>
        </article>
        <article class="pvnp-kpi-card">
          <p>보험료율</p>
          <strong>{formatRate(PVNP_NATIONAL_PENSION_2026.contributionRate2026)}</strong>
          <span>매년 0.5%p씩 단계 인상, 최종 {PVNP_NATIONAL_PENSION_2026.futureContributionRateTarget}% 방향</span>
        </article>
        <article class="pvnp-kpi-card">
          <p>최소 가입기간</p>
          <strong>{PVNP_NATIONAL_PENSION_2026.minContributionYears}년</strong>
          <span>노령연금 수급 조건의 기본선</span>
        </article>
        <article class="pvnp-kpi-card">
          <p>소득대체율</p>
          <strong>{PVNP_NATIONAL_PENSION_2026.incomeReplacementRate2026}%</strong>
          <span>평균소득 40년 가입 기준 방향</span>
        </article>
      </div>
      <div class="pvnp-callout">
        <span class="pvnp-badge pvnp-badge--estimate">추정</span>
        <strong>실제 수령액은 가입기간·생애 평균소득·수령개시연령에 따라 달라집니다.</strong>
        <p>{PVNP_NATIONAL_PENSION_2026.note}</p>
      </div>
    </section>

    <section class="content-section" id="personal-pension-structure">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">개인연금 구조</p>
        <h2>노후 소득은 1층 국민연금, 2층 퇴직연금, 3층 개인연금으로 나눠 봅니다</h2>
      </div>
      <div class="pvnp-layer-grid">
        {pensionLayers.map((item) => (
          <article class={`pvnp-layer-card is-${item.tone}`}>
            <span>{item.layer}</span>
            <strong>{item.title}</strong>
            <p>{item.role}</p>
          </article>
        ))}
      </div>
      <div class="pvnp-tax-box">
        <div>
          <p class="pvnp-mini-label">세액공제 일반 안내</p>
          <h3>연금저축 600만 원, IRP 포함 900만 원은 납입 한도입니다</h3>
          <p>900만 원을 전액 돌려받는 구조가 아니라, 한도 내 납입액의 16.5% 또는 13.2%를 세금에서 공제하는 방식입니다.</p>
        </div>
        <dl>
          <div><dt>연금저축 한도</dt><dd>{formatWon(PVNP_TAX_CREDIT_2026.pensionSavingsLimit)}</dd></div>
          <div><dt>IRP 포함 합산</dt><dd>{formatWon(PVNP_TAX_CREDIT_2026.combinedIrpLimit)}</dd></div>
          <div><dt>총급여 5,500만 원 이하</dt><dd>{formatRate(PVNP_TAX_CREDIT_2026.taxCreditRateLowIncome)}</dd></div>
          <div><dt>총급여 5,500만 원 초과</dt><dd>{formatRate(PVNP_TAX_CREDIT_2026.taxCreditRateHighIncome)}</dd></div>
        </dl>
      </div>
    </section>

    <section class="content-section" id="income-gap">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">국민연금 단독 vs 국민+개인연금</p>
        <h2>월 생활비 300만 원 기준 노후 소득 갭</h2>
        <p>월 생활비 300만 원은 비교를 위한 참고 예시입니다. 실제 필요 생활비는 주거비, 의료비, 부양가족, 지역에 따라 달라집니다.</p>
      </div>
      <div class="table-wrap pvnp-table-wrap">
        <table class="pvnp-table pvnp-gap-table">
          <thead>
            <tr>
              <th>구분</th>
              <th>월 연금수령액</th>
              <th>월 부족액</th>
              <th>연간 부족액</th>
              <th>20년 합산 부족액</th>
            </tr>
          </thead>
          <tbody>
            {PVNP_GAP_ROWS.map((row) => (
              <tr class={row.monthlyGap === 0 ? "is-ok" : ""}>
                <th>{row.label}</th>
                <td>{formatWon(row.monthlyPension)}</td>
                <td>{row.monthlyGap === 0 ? "부족 없음" : formatWon(row.monthlyGap)}</td>
                <td>{row.annualGap === 0 ? "-" : formatWon(row.annualGap)}</td>
                <td>{row.gap20Years === 0 ? "-" : formatWon(row.gap20Years)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section" id="simulation">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">개인연금 시뮬레이션</p>
        <h2>월 납입액과 수익률에 따라 은퇴 시 적립액이 크게 달라집니다</h2>
        <p>35세에서 60세까지 25년 납입 가정입니다. 수익률은 단순 추정이며 실제 운용 성과를 보장하지 않습니다.</p>
      </div>
      <div class="table-wrap pvnp-table-wrap">
        <table class="pvnp-table">
          <thead>
            <tr>
              <th>월 납입액</th>
              <th>연 4% 적립 추정</th>
              <th>연 6% 적립 추정</th>
              <th>연 8% 적립 추정</th>
            </tr>
          </thead>
          <tbody>
            {PVNP_SIM_ROWS.map((row) => (
              <tr>
                <th>{formatWon(row.monthlyContribution)}</th>
                <td>{formatWon(row.rate4)}</td>
                <td>{formatWon(row.rate6)}</td>
                <td>{formatWon(row.rate8)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="pvnp-subsection-head">
        <span class="pvnp-badge pvnp-badge--sim">시뮬레이션</span>
        <h3>20년 분할 수령 기준 월 수령액</h3>
        <p>연금소득세 5.5% 가정의 참고 시뮬레이션입니다.</p>
      </div>
      <div class="table-wrap pvnp-table-wrap">
        <table class="pvnp-table">
          <thead>
            <tr>
              <th>은퇴 시 적립액</th>
              <th>세전 월 수령액</th>
              <th>세후 월 수령액</th>
            </tr>
          </thead>
          <tbody>
            {PVNP_PAYOUT_ROWS.map((row) => (
              <tr>
                <th>{formatWon(row.totalAsset)}</th>
                <td>{formatWon(row.monthlyGross)}</td>
                <td>{formatWon(row.monthlyNet)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <a class="pvnp-inline-cta" href={withBase("/tools/retirement-fund-depletion/")}>내 노후자금 고갈 시점 계산하기</a>
    </section>

    <section class="content-section" id="generation-comparison">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">세대별 예상 수령액</p>
        <h2>30대·40대·50대는 같은 개인연금이라도 전략이 다릅니다</h2>
      </div>
      <div class="table-wrap pvnp-table-wrap">
        <table class="pvnp-table">
          <thead>
            <tr>
              <th>세대</th>
              <th>국민연금 예상 월수령액</th>
              <th>개인연금 예상 월수령액</th>
              <th>합산 월수령액</th>
              <th>월 300만 원 대비 평가</th>
            </tr>
          </thead>
          <tbody>
            {PVNP_GENERATION_ROWS.map((row) => (
              <tr>
                <th>{row.ageGroup}</th>
                <td>{row.nationalPensionRangeLabel}</td>
                <td>{row.personalPensionRangeLabel}</td>
                <td>{row.combinedRangeLabel}</td>
                <td>{row.gapNote}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="pvnp-generation-grid">
        {generationNotes.map((item) => (
          <article class="pvnp-generation-card">
            <p>{item.title}</p>
            <strong>{item.text}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" id="pension-tax">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">연금 수령 시 세금</p>
        <h2>납입 시 세액공제, 수령 시 연금소득세 구조로 이해해야 합니다</h2>
      </div>
      <div class="pvnp-tax-layout">
        <div class="table-wrap pvnp-table-wrap">
          <table class="pvnp-table pvnp-table--compact">
            <thead>
              <tr>
                <th>수령 나이</th>
                <th>연금소득세율</th>
              </tr>
            </thead>
            <tbody>
              {PVNP_PENSION_TAX_ROWS.map((row) => (
                <tr>
                  <th>{row.ageRange}</th>
                  <td>{formatRate(row.taxRate)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="pvnp-warning-box">
          <strong>중도해지·일시금 수령은 세부담이 커질 수 있습니다.</strong>
          <p>국민연금은 공적연금소득으로 종합소득세 과세 대상이 될 수 있고, 개인연금은 세액공제를 받은 납입액과 운용수익에 대해 수령 시 연금소득세가 적용됩니다.</p>
        </div>
      </div>
      <div class="pvnp-subsection-head">
        <span class="pvnp-badge pvnp-badge--reference">참고</span>
        <h3>세액공제 예시</h3>
        <p>납입 한도와 공제액을 구분해서 봐야 합니다.</p>
      </div>
      <div class="table-wrap pvnp-table-wrap">
        <table class="pvnp-table">
          <thead>
            <tr>
              <th>연 납입액</th>
              <th>총급여 5,500만 원 이하</th>
              <th>총급여 5,500만 원 초과</th>
            </tr>
          </thead>
          <tbody>
            {PVNP_TAX_CREDIT_ROWS.map((row) => (
              <tr>
                <th>{formatWon(row.annualContribution)}</th>
                <td>{formatWon(row.creditLowIncome)}</td>
                <td>{formatWon(row.creditHighIncome)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="pvnp-note">세액공제는 납입 900만 원 전액을 돌려받는 것이 아닙니다. 한도 내 납입액의 16.5% 또는 13.2%를 세금에서 공제합니다.</p>
    </section>

    <section class="content-section" id="withdrawal-strategy">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">수령 전략</p>
        <h2>노후 생활비 목적이라면 분할 수령과 비상자금 분리가 기본입니다</h2>
      </div>
      <div class="table-wrap pvnp-table-wrap">
        <table class="pvnp-table">
          <thead>
            <tr>
              <th>수령 방식</th>
              <th>장점</th>
              <th>단점</th>
              <th>추천 대상</th>
            </tr>
          </thead>
          <tbody>
            {PVNP_WITHDRAWAL_ROWS.map((row) => (
              <tr>
                <th>{row.method}</th>
                <td>{row.pros}</td>
                <td>{row.cons}</td>
                <td>{row.bestFor}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="pvnp-callout">
        <strong>기본 생활비는 국민연금과 분할 수령 연금으로 만들고, 비상자금은 별도 계좌로 분리하는 방식이 안정적입니다.</strong>
      </div>
    </section>

    <section class="content-section" id="depletion-risk">
