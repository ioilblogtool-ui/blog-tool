---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  ML_META,
  ML_HERO_STATS,
  SOLDIER_PAY,
  NCO_STEPS,
  OFFICER_STEPS,
  MILITARY_ALLOWANCES,
  CIVILIAN_COMP,
  MILITARY_FAQ,
} from "../../data/militarySalary2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const fmt    = (n: number) => Math.round(n / 10_000).toLocaleString("ko-KR");
const fmtWon = (n: number) => n.toLocaleString("ko-KR");

const ncoHasa  = NCO_STEPS.filter((s) => s.rank === "하사");
const ncoJungsa = NCO_STEPS.filter((s) => s.rank === "중사");
const ncoSangsa = NCO_STEPS.filter((s) => s.rank === "상사");
const ncoWonsa  = NCO_STEPS.filter((s) => s.rank === "원사");

const officerWigwan  = OFFICER_STEPS.filter((s) => s.rankGroup === "위관");
const officerYeongwan = OFFICER_STEPS.filter((s) => s.rankGroup === "영관");
const officerJangseong = OFFICER_STEPS.filter((s) => s.rankGroup === "장성");

const allowanceFixed   = MILITARY_ALLOWANCES.filter((a) => a.type === "fixed");
const allowanceSpecial = MILITARY_ALLOWANCES.filter((a) => a.type === "special");
const allowanceAnnual  = MILITARY_ALLOWANCES.filter((a) => a.type === "annual");

const faqItems = MILITARY_FAQ.map((f) => ({ question: f.q, answer: f.a }));

const soldierChartLabels = SOLDIER_PAY.map((s) => s.rank);
const soldierChartData   = SOLDIER_PAY.map((s) => Math.round(s.monthlyBase / 10_000));
---

<BaseLayout title={ML_META.title} description={ML_META.description}>
  <SiteHeader />

  <main class="container page-shell report-page ml-page">

    <!-- A. Hero -->
    <CalculatorHero
      eyebrow="직업·연봉 리포트"
      title="군인 월급·연봉 계급별 완전 정리 2026"
      description="이병부터 대장까지 계급별 봉급 · 2026년 병장 월급 인상 반영 · 부사관·장교 연봉 및 수당 구조"
    />

    <!-- B. InfoNotice -->
    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        "기본급은 국방부 군인보수법 및 2026년 군인 봉급표 기준입니다.",
        "병사 봉급은 2026년 1월 1일 기준 인상분이 반영된 수치입니다.",
        "세후 실수령은 미혼·부양가족 없음 기준 추정치이며 공제 조건에 따라 달라집니다.",
        "부사관·장교 봉급표는 대표 호봉만 표시했습니다. 동일 계급 내 호봉 편차가 있습니다.",
      ]}
    />

    <!-- C. Hero KPI -->
    <section class="content-section ml-kpi-section" aria-label="핵심 지표">
      <div class="ml-kpi-grid">
        <div class="ml-kpi-card">
          <p class="ml-kpi-card__label">2026 이병 월급</p>
          <p class="ml-kpi-card__value">{fmtWon(ML_HERO_STATS.privateMonthly)}원</p>
          <span class="ts-badge ts-badge--official">공식</span>
        </div>
        <div class="ml-kpi-card">
          <p class="ml-kpi-card__label">2026 병장 월급</p>
          <p class="ml-kpi-card__value">{fmtWon(ML_HERO_STATS.sergeantMonthly)}원</p>
          <span class="ts-badge ts-badge--official">공식</span>
          <p class="ml-kpi-card__sub">2027년 목표 인상 진행 중</p>
        </div>
        <div class="ml-kpi-card">
          <p class="ml-kpi-card__label">소위 임관 연봉</p>
          <p class="ml-kpi-card__value">약 {fmt(ML_HERO_STATS.secondLtAnnual)}만 원</p>
          <span class="ts-badge ts-badge--estimate">추정</span>
          <p class="ml-kpi-card__sub">수당 포함</p>
        </div>
        <div class="ml-kpi-card">
          <p class="ml-kpi-card__label">대장 연봉</p>
          <p class="ml-kpi-card__value">약 {fmt(ML_HERO_STATS.generalAnnual)}만 원</p>
          <span class="ts-badge ts-badge--estimate">추정</span>
          <p class="ml-kpi-card__sub">기본급 기준</p>
        </div>
      </div>
      <p class="ml-source-note">출처: 국방부 군인보수법 별표 (2026.1.1 기준)</p>
    </section>

    <!-- D. 병사 봉급표 -->
    <section class="content-section" aria-labelledby="ml-soldier-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">병사 봉급</p>
        <h2 id="ml-soldier-title">2026 병사 계급별 월급 <span class="ts-badge ts-badge--official">공식</span></h2>
        <p>이병~병장 기본급 및 세후 실수령 추정치. 급식·피복 등 현물 지원은 별도입니다.</p>
      </div>

      <div class="ml-soldier-grid">
        {SOLDIER_PAY.map((s) => (
          <div class="ml-soldier-card">
            <div class="ml-soldier-card__rank">{s.rank}</div>
            <div class="ml-soldier-card__en">{s.rankEn}</div>
            <div class="ml-soldier-card__service">{s.serviceMonths}</div>
            <div class="ml-soldier-card__base">
              <span class="ml-soldier-card__base-label">기본급</span>
              <strong>{fmtWon(s.monthlyBase)}원</strong>
              <span class="ts-badge ts-badge--official">공식</span>
            </div>
            <div class="ml-soldier-card__net">
              세후 약 <strong>{fmtWon(s.monthlyNet)}원</strong>
              <span class="ts-badge ts-badge--estimate">추정</span>
            </div>
            <p class="ml-soldier-card__note">{s.note}</p>
          </div>
        ))}
      </div>

      <div class="ml-chart-wrap">
        <canvas id="ml-soldier-chart"
          data-labels={JSON.stringify(soldierChartLabels)}
          data-values={JSON.stringify(soldierChartData)}
        ></canvas>
      </div>
    </section>

    <!-- E. 부사관 봉급표 -->
    <section class="content-section" aria-labelledby="ml-nco-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">부사관 봉급</p>
        <h2 id="ml-nco-title">2026 부사관 계급별 봉급표 <span class="ts-badge ts-badge--official">공식</span></h2>
        <p>하사~원사 대표 호봉 기준. 세후 실수령은 미혼·부양가족 없음 추정치입니다.</p>
      </div>

      <div class="ml-nco-tabs" role="tablist" aria-label="부사관 계급">
        <button class="ml-nco-tab is-active" data-tab="하사"  aria-selected="true">하사</button>
        <button class="ml-nco-tab"             data-tab="중사"  aria-selected="false">중사</button>
        <button class="ml-nco-tab"             data-tab="상사"  aria-selected="false">상사</button>
        <button class="ml-nco-tab"             data-tab="원사"  aria-selected="false">원사</button>
      </div>

      {[
        { key: "하사",  rows: ncoHasa,   hidden: false },
        { key: "중사",  rows: ncoJungsa, hidden: true  },
        { key: "상사",  rows: ncoSangsa, hidden: true  },
        { key: "원사",  rows: ncoWonsa,  hidden: true  },
      ].map(({ key, rows, hidden }) => (
        <div class="ml-nco-table-wrap" data-tab={key} {...(hidden ? { hidden: true } : {})}>
          <table class="ml-nco-table">
            <thead>
              <tr>
                <th>계급</th>
                <th>호봉</th>
                <th>월 기본급</th>
                <th>세전 연봉</th>
                <th>세후 실수령 (추정)</th>
              </tr>
            </thead>
            <tbody>
              {rows.map((r) => (
                <tr>
                  <td><strong>{r.rank}</strong></td>
                  <td>{r.step}호봉{r.note ? <span class="ml-note-badge"> · {r.note}</span> : null}</td>
                  <td>{fmtWon(r.monthlyBase)}원</td>
                  <td>{fmtWon(r.annualGross)}원</td>
                  <td>
                    약 {fmtWon(r.monthlyNet)}원
                    <span class="ts-badge ts-badge--estimate">추정</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </section>

    <!-- F. 장교 봉급표 -->
    <section class="content-section" aria-labelledby="ml-officer-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">장교 봉급</p>
        <h2 id="ml-officer-title">2026 장교 계급별 봉급표 <span class="ts-badge ts-badge--official">공식</span></h2>
        <p>소위~대장 대표 호봉 기준. 세후 실수령은 미혼·부양가족 없음 추정치입니다.</p>
      </div>

      <div class="ml-officer-tabs" role="tablist" aria-label="장교 계급">
        <button class="ml-officer-tab is-active" data-tab="위관"  aria-selected="true">위관 (소위·중위·대위)</button>
        <button class="ml-officer-tab"             data-tab="영관"  aria-selected="false">영관 (소령·중령·대령)</button>
        <button class="ml-officer-tab"             data-tab="장성"  aria-selected="false">장성 (준장~대장)</button>
      </div>

      {[
        { key: "위관",  rows: officerWigwan,   hidden: false },
        { key: "영관",  rows: officerYeongwan, hidden: true  },
        { key: "장성",  rows: officerJangseong, hidden: true  },
      ].map(({ key, rows, hidden }) => (
        <div class="ml-officer-table-wrap" data-tab={key} {...(hidden ? { hidden: true } : {})}>
          <table class="ml-officer-table">
            <thead>
              <tr>
                <th>계급</th>
                <th>호봉</th>
                <th>월 기본급</th>
                <th>세전 연봉</th>
                <th>세후 실수령 (추정)</th>
              </tr>
            </thead>
            <tbody>
              {rows.map((r) => (
                <tr>
                  <td><strong>{r.rank}</strong></td>
                  <td>{r.step}호봉{r.note ? <span class="ml-note-badge"> · {r.note}</span> : null}</td>
                  <td>{fmtWon(r.monthlyBase)}원</td>
                  <td>{fmtWon(r.annualGross)}원</td>
                  <td>
                    약 {fmtWon(r.monthlyNet)}원
                    <span class="ts-badge ts-badge--estimate">추정</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ))}
    </section>

    <!-- G. 수당 구조 -->
    <section class="content-section" aria-labelledby="ml-allowance-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">수당 구조</p>
        <h2 id="ml-allowance-title">군인 수당 구조 — 기본급 외 추가 수령</h2>
        <p>계급·직책·특기에 따라 기본급 외 다양한 수당이 지급됩니다.</p>
      </div>

      <div class="ts-allowance-tabs" role="tablist" aria-label="수당 유형">
        <button class="ts-allowance-tab is-active" data-tab="fixed"   aria-selected="true">고정 수당</button>
        <button class="ts-allowance-tab"             data-tab="special" aria-selected="false">특수 수당</button>
        <button class="ts-allowance-tab"             data-tab="annual"  aria-selected="false">연간 지급</button>
      </div>

      <div class="ts-allowance-list" data-tab="fixed">
        {allowanceFixed.map((a) => (
          <div class="ts-allowance-card">
            <div class="ts-allowance-card__top">
              <strong>{a.name}</strong>
              <span class="ts-allowance-card__amount">{a.amount}</span>
            </div>
            <p class="ts-allowance-card__cond">{a.condition}</p>
          </div>
        ))}
      </div>
      <div class="ts-allowance-list" data-tab="special" hidden>
        {allowanceSpecial.map((a) => (
          <div class="ts-allowance-card">
            <div class="ts-allowance-card__top">
              <strong>{a.name}</strong>
              <span class="ts-allowance-card__amount">{a.amount}</span>
            </div>
            <p class="ts-allowance-card__cond">{a.condition}</p>
          </div>
        ))}
      </div>
      <div class="ts-allowance-list" data-tab="annual" hidden>
        {allowanceAnnual.map((a) => (
          <div class="ts-allowance-card">
            <div class="ts-allowance-card__top">
              <strong>{a.name}</strong>
              <span class="ts-allowance-card__amount">{a.amount}</span>
            </div>
            <p class="ts-allowance-card__cond">{a.condition}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- H. 민간 vs 군인 비교 -->
    <section class="content-section" aria-labelledby="ml-civilian-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">민간 비교</p>
        <h2 id="ml-civilian-title">군인 vs 민간 직장인 — 총보상 비교</h2>
        <p>급여 외 주거·식비·연금·의료 등 실질 총보상을 함께 비교해야 합니다.</p>
      </div>
      <div class="ml-civilian-table-wrap">
        <table class="ml-civilian-table">
          <thead>
            <tr>
              <th>항목</th>
              <th>군인</th>
              <th>민간 직장인</th>
              <th>비고</th>
            </tr>
          </thead>
          <tbody>
            {CIVILIAN_COMP.map((row) => (
              <tr>
                <td><strong>{row.category}</strong></td>
                <td>{row.military}</td>
                <td>{row.civilian}</td>
                <td class="ml-civilian-note">{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- I. FAQ -->
    <section class="content-section" aria-labelledby="ml-faq-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">자주 묻는 질문</p>
        <h2 id="ml-faq-title">군인 월급·연봉 FAQ</h2>
      </div>
      <div class="ml-faq-list" itemscope itemtype="https://schema.org/FAQPage">
        {MILITARY_FAQ.map((item) => (
          <div class="ml-faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <button class="ml-faq-q" itemprop="name" aria-expanded="false">
              {item.q}
              <span class="ml-faq-icon">▼</span>
            </button>
            <div class="ml-faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" hidden>
              <p itemprop="text">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- J. 관련 콘텐츠 -->
    <section class="content-section" aria-labelledby="ml-related-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">내부 연결</p>
        <h2 id="ml-related-title">같이 보면 좋은 계산기·리포트</h2>
      </div>
      <div class="ts-link-grid">
        <a class="ts-link-card" href={withBase("/tools/military-salary-calculator/")}>
          <span class="ts-link-card__eyebrow">계산기</span>
          <strong>군인 월급 계산기 2027</strong>
          <p>병사·부사관·장교 계급을 선택해 월급과 실수령액을 바로 계산합니다.</p>
        </a>
        <a class="ts-link-card" href={withBase("/tools/military-savings-calculator/")}>
          <span class="ts-link-card__eyebrow">계산기</span>
          <strong>장병내일준비적금 계산기</strong>
          <p>전역 시 받을 수 있는 적금 총수령액을 미리 계산합니다.</p>
        </a>
        <a class="ts-link-card" href={withBase("/tools/salary/")}>
          <span class="ts-link-card__eyebrow">계산기</span>
          <strong>연봉 실수령 계산기</strong>
          <p>장교·부사관 연봉을 넣고 세후 실수령을 확인합니다.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/police-salary-2026/")}>
          <span class="ts-link-card__eyebrow">관련 리포트</span>
          <strong>경찰관 계급별 연봉 2026</strong>
          <p>공직 유니폼 시리즈 — 경찰 편.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/firefighter-salary-2026/")}>
          <span class="ts-link-card__eyebrow">관련 리포트</span>
          <strong>소방관 계급별 연봉 2026</strong>
          <p>공직 유니폼 시리즈 — 소방관 편.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/public-servant-salary-2026/")}>
          <span class="ts-link-card__eyebrow">관련 리포트</span>
          <strong>공무원 9급 연봉 2026</strong>
          <p>공무원 봉급표 비교.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/teacher-salary-2026/")}>
          <span class="ts-link-card__eyebrow">관련 리포트</span>
          <strong>교사 연봉·호봉 완전 정리 2026</strong>
          <p>교육직 연봉 비교.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/")}>
          <span class="ts-link-card__eyebrow">리포트 모음</span>
          <strong>전체 비교 리포트 보기</strong>
          <p>다른 직업·자산·생활 리포트까지 탐색.</p>
        </a>
      </div>
    </section>

    <SeoContent
      introTitle="군인 월급·연봉 계급별 완전 정리 2026 — 비교계산소 해설"
      intro={[
        "2026년 병장 월급은 125만 원으로 최근 몇 년간 큰 폭으로 인상됐습니다. 급식·피복 현물 지원까지 합산하면 실질 가치는 더 높으며, 정부는 2027년까지 추가 인상을 목표로 하고 있습니다.",
        "장교·부사관의 연봉은 기본급 외 직책수당·특수수당·관사 제공 등을 더하면 민간 동일 연차 대비 경쟁력이 있습니다. 특히 20년 복무 후 즉시 수령 가능한 군인연금은 장기복무의 핵심 혜택입니다.",
        "단, 위관급 장교는 대위~소령 진급 시 선발 경쟁이 있으며, 탈락 시 전역 후 제2커리어를 준비해야 합니다. 부사관은 전문 기술을 쌓아 안정적인 장기복무 경로를 선택할 수 있습니다.",
