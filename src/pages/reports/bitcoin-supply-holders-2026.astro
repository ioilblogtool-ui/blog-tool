---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  BSH_META,
  BSH_SUPPLY,
  BSH_CATEGORIES,
  BSH_COUNTRIES,
  BSH_CORPORATES,
  BSH_SATOSHI,
  BSH_ETFS,
  BSH_MINING_TIMELINE,
  BSH_FAQ,
  BSH_RELATED_LINKS,
  BSH_SOURCE_LINKS,
  formatBtc,
  formatUsdBillion,
} from "../../data/bitcoinSupplyHolders2026";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${BSH_META.slug}/`;
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const CURRENT_PRICE = 60000;
const totalCorporateBtc = BSH_CORPORATES.reduce((s, c) => s + c.btcHeld, 0);
const totalEtfBtc = BSH_ETFS.reduce((s, e) => s + e.btcHeld, 0);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: BSH_META.title,
    description: BSH_META.description,
    dateModified: BSH_META.updatedAt,
    mainEntityOfPage: reportUrl,
    author: { "@type": "Organization", name: "비교계산소" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: BSH_FAQ.map((f) => ({
      "@type": "Question",
      name: f.question,
      acceptedAnswer: { "@type": "Answer", text: f.answer },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
      { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
      { "@type": "ListItem", position: 3, name: BSH_META.title, item: reportUrl },
    ],
  },
];
---

<BaseLayout title={BSH_META.seoTitle} description={BSH_META.seoDescription} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page bsh-page" data-report="bitcoin-supply-holders-2026">
    <CalculatorHero
      eyebrow="암호화폐 리포트"
      title={BSH_META.title}
      description="2,100만 개 한도 중 지금까지 채굴된 1,974만 개 — 국가·기업·사토시·ETF·개인이 각각 얼마나 갖고 있는지 2026년 기준으로 분석합니다."
      badges={["비트코인", "보유 현황", "기업 트레저리", "국가 보유", "2026"]}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        BSH_META.dataNote,
        "기업·국가 보유량은 공식 공시 또는 온체인 분석 추정치이며 실시간 변동이 있습니다. $60,000 기준 평가금액은 참고용입니다.",
      ]}
    />

    <!-- KPI -->
    <section class="content-section bsh-kpi-section" aria-labelledby="bsh-kpi-title">
      <div class="bsh-section-heading">
        <p>채굴 현황</p>
        <h2 id="bsh-kpi-title">2,100만 개 한도 중 지금 몇 개가 존재하나</h2>
        <span>2026년 6월 기준. 남은 126만 개는 2140년까지 점진적으로 채굴됩니다.</span>
      </div>
      <div class="bsh-kpi-grid">
        <article class="bsh-kpi-card bsh-kpi-card--main">
          <span class="bsh-kpi-label">현재까지 채굴된 BTC</span>
          <strong class="bsh-kpi-value">{BSH_SUPPLY.mined.toLocaleString()}</strong>
          <div class="bsh-supply-bar">
            <div class="bsh-supply-bar-fill" style={`width:${BSH_SUPPLY.minedPct}%`} />
          </div>
          <small>전체 한도의 {BSH_SUPPLY.minedPct}% 채굴 완료</small>
        </article>
        <article class="bsh-kpi-card">
          <span class="bsh-kpi-label">남은 채굴량</span>
          <strong class="bsh-kpi-value">{BSH_SUPPLY.remaining.toLocaleString()} BTC</strong>
          <small>약 114년 후 소진 예정 (2140년)</small>
        </article>
        <article class="bsh-kpi-card bsh-kpi-card--lost">
          <span class="bsh-kpi-label">분실·접근 불가 추정</span>
          <strong class="bsh-kpi-value">~{BSH_SUPPLY.lostEstimate.toLocaleString()} BTC</strong>
          <small>채굴량의 약 {BSH_SUPPLY.lostPct}% — 영구 소멸 추정</small>
        </article>
        <article class="bsh-kpi-card">
          <span class="bsh-kpi-label">실질 유통량 추정</span>
          <strong class="bsh-kpi-value">{BSH_SUPPLY.circulatingEstimate.toLocaleString()} BTC</strong>
          <small>분실분 제외 추정 유통량</small>
        </article>
        <article class="bsh-kpi-card">
          <span class="bsh-kpi-label">현재 블록 보상</span>
          <strong class="bsh-kpi-value">{BSH_SUPPLY.currentBlockReward} BTC</strong>
          <small>4차 반감기 이후 / 약 10분마다 생성</small>
        </article>
        <article class="bsh-kpi-card">
          <span class="bsh-kpi-label">다음 반감기</span>
          <strong class="bsh-kpi-value">{BSH_SUPPLY.nextHalvingYear}년</strong>
          <small>{BSH_SUPPLY.nextHalvingReward} BTC로 감소 예정</small>
        </article>
      </div>
    </section>

    <!-- 보유 주체별 분포 -->
    <section class="content-section bsh-dist-section" aria-labelledby="bsh-dist-title">
      <div class="bsh-section-heading">
        <p>보유 분포</p>
        <h2 id="bsh-dist-title">비트코인의 94%는 누가 갖고 있나</h2>
        <span>채굴된 1,974만 BTC 기준 추정 분포입니다.</span>
      </div>
      <div class="bsh-dist-grid">
        {BSH_CATEGORIES.map((cat) => (
          <article class="bsh-dist-card">
            <div class="bsh-dist-header">
              <span class="bsh-dist-dot" style={`background:${cat.color}`} />
              <strong>{cat.label}</strong>
            </div>
            <div class="bsh-dist-bar-wrap">
              <div
                class="bsh-dist-bar"
                style={`width:${Math.min(cat.pctOfMined, 100)}%; background:${cat.color}`}
              />
            </div>
            <div class="bsh-dist-nums">
              <span>~{cat.estimatedBtc.toLocaleString()} BTC</span>
              <span class="bsh-dist-pct">{cat.pctOfMined}%</span>
            </div>
            <p class="bsh-dist-desc">{cat.description}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- 채굴 타임라인 -->
    <section class="content-section bsh-timeline-section" aria-labelledby="bsh-timeline-title">
      <div class="bsh-section-heading">
        <p>채굴 타임라인</p>
        <h2 id="bsh-timeline-title">반감기마다 채굴 속도가 절반으로 줄었다</h2>
        <span>초기 14년에 전체의 94%가 채굴됐고, 나머지 6%는 앞으로 114년에 걸쳐 나옵니다.</span>
      </div>
      <div class="table-wrap bsh-table-wrap">
        <table class="bsh-timeline-table">
          <caption>비트코인 채굴 진행 타임라인</caption>
          <thead>
            <tr>
              <th>연도</th>
              <th>누적 채굴량</th>
              <th>진행률</th>
              <th>진행 바</th>
              <th>주요 이벤트</th>
            </tr>
          </thead>
          <tbody>
            {BSH_MINING_TIMELINE.map((m) => (
              <tr class:list={[m.year === 2026 && "bsh-current-row"]}>
                <td class="bsh-year-cell">
                  <strong>{m.year}</strong>
                  {m.year === 2026 && <span class="bsh-now-badge">현재</span>}
                </td>
                <td class="bsh-btc-cell">{m.btcMined.toLocaleString()} BTC</td>
                <td class="bsh-pct-cell">{m.pctMined}%</td>
                <td class="bsh-bar-cell">
                  <div class="bsh-prog-track">
                    <div class="bsh-prog-fill" style={`width:${m.pctMined}%`} />
                  </div>
                </td>
                <td class="bsh-event-cell">{m.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- 국가별 보유 -->
    <section class="content-section bsh-country-section" aria-labelledby="bsh-country-title">
      <div class="bsh-section-heading">
        <p>국가 보유</p>
        <h2 id="bsh-country-title">어느 나라가 얼마나 갖고 있나</h2>
        <span>몰수·압류·전략 비축·채굴 등 다양한 경로로 취득합니다.</span>
      </div>
      <div class="bsh-country-grid">
        {BSH_COUNTRIES.map((c) => (
          <article class="bsh-country-card">
            <div class="bsh-country-header">
              <span class="bsh-flag">{c.flag}</span>
              <div>
                <strong class="bsh-country-name">{c.country}</strong>
                <span class:list={["bsh-status-badge", `bsh-status-badge--${c.status}`]}>
                  {c.status === "confirmed" ? "공식 확인" : c.status === "seized" ? "몰수·압류" : "추정"}
                </span>
              </div>
              <span class="bsh-country-rank">#{c.rank}</span>
            </div>
            <div class="bsh-country-btc">
              <span class="bsh-country-amount">{c.estimatedBtc.toLocaleString()} BTC</span>
              <span class="bsh-country-usd">≈ {formatUsdBillion(c.estimatedBtc * CURRENT_PRICE)}</span>
            </div>
            <p class="bsh-country-note">{c.note}</p>
            <small class="bsh-country-source">출처: {c.source}</small>
          </article>
        ))}
      </div>
    </section>

    <!-- 기업 트레저리 -->
    <section class="content-section bsh-corp-section" aria-labelledby="bsh-corp-title">
      <div class="bsh-section-heading">
        <p>기업 트레저리</p>
        <h2 id="bsh-corp-title">기업들이 보유한 비트코인 — Strategy가 압도적 1위</h2>
        <span>
          상위 8개 기업 합산 약 {totalCorporateBtc.toLocaleString()} BTC
          (≈ {formatUsdBillion(totalCorporateBtc * CURRENT_PRICE)}, $60,000 기준)
        </span>
      </div>
      <div class="bsh-corp-list">
        {BSH_CORPORATES.map((corp) => {
          const barWidth = Math.min((corp.btcHeld / BSH_CORPORATES[0].btcHeld) * 100, 100);
          const currentVal = corp.btcHeld * CURRENT_PRICE;
          const pnl = corp.avgCostUsd ? ((CURRENT_PRICE - corp.avgCostUsd) / corp.avgCostUsd) * 100 : null;
          return (
            <article class="bsh-corp-card">
              <div class="bsh-corp-header">
                <div class="bsh-corp-meta">
                  <span class="bsh-corp-rank">#{corp.rank}</span>
                  <span class="bsh-corp-flag">{corp.flag}</span>
                  <strong class="bsh-corp-name">{corp.company}</strong>
                  {corp.ticker && <span class="bsh-corp-ticker">{corp.ticker}</span>}
                </div>
                <div class="bsh-corp-btc-wrap">
                  <span class="bsh-corp-btc">{corp.btcHeld.toLocaleString()} BTC</span>
                  <span class="bsh-corp-val">{formatUsdBillion(currentVal)}</span>
                </div>
              </div>
              <div class="bsh-corp-bar-wrap">
                <div class="bsh-corp-bar" style={`width:${barWidth}%`} />
              </div>
              {corp.avgCostUsd && pnl !== null && (
                <div class="bsh-corp-pnl">
                  <span>평균 매수가 {formatUsdBillion(corp.avgCostUsd).replace('$','$')}</span>
                  <span class:list={[pnl >= 0 ? "bsh-positive" : "bsh-negative"]}>
                    {pnl >= 0 ? "+" : ""}{pnl.toFixed(0)}% 평가손익
                  </span>
                </div>
              )}
              <p class="bsh-corp-strategy">{corp.strategy}</p>
              <small class="bsh-corp-note">{corp.note}</small>
            </article>
          );
        })}
      </div>
    </section>

    <!-- 사토시 나카모토 -->
    <section class="content-section bsh-satoshi-section" aria-labelledby="bsh-satoshi-title">
      <div class="bsh-section-heading">
        <p>사토시 나카모토</p>
        <h2 id="bsh-satoshi-title">17년째 잠든 110만 BTC — 세계 최대 미스터리 자산</h2>
        <span>$60,000 기준 약 66조 원. 단 한 번도 이동하지 않았습니다.</span>
      </div>
      <div class="bsh-satoshi-box">
        <div class="bsh-satoshi-kpi-grid">
          <div class="bsh-satoshi-kpi">
            <span>추정 보유량</span>
            <strong>~{BSH_SATOSHI.estimatedBtc.toLocaleString()} BTC</strong>
          </div>
          <div class="bsh-satoshi-kpi">
            <span>채굴량 대비</span>
            <strong>{BSH_SATOSHI.pctOfMined}%</strong>
          </div>
          <div class="bsh-satoshi-kpi">
            <span>현재 추정 가치</span>
            <strong>{formatUsdBillion(BSH_SATOSHI.valueAtCurrentUsd)}</strong>
          </div>
          <div class="bsh-satoshi-kpi">
            <span>마지막 활동</span>
            <strong>{BSH_SATOSHI.lastKnownActivity}</strong>
          </div>
        </div>
        <ul class="bsh-satoshi-facts">
          {BSH_SATOSHI.keyFacts.map((fact) => (
            <li>{fact}</li>
          ))}
        </ul>
        <div class="bsh-satoshi-identity">
          <p class="bsh-satoshi-identity-title">신원 주장자 / 추정 인물</p>
          <div class="bsh-identity-grid">
            {BSH_SATOSHI.identityClaimants.map((p) => (
              <div class="bsh-identity-card">
                <strong>{p.name}</strong>
                <span>{p.country}</span>
                <small>{p.verdict}</small>
              </div>
            ))}
          </div>
        </div>
        <p class="bsh-satoshi-research">연구 기준: {BSH_SATOSHI.researchSource}</p>
      </div>
    </section>

    <!-- ETF 현황 -->
    <section class="content-section bsh-etf-section" aria-labelledby="bsh-etf-title">
      <div class="bsh-section-heading">
        <p>ETF 보유</p>
        <h2 id="bsh-etf-title">미국 현물 ETF가 BTC 수요를 흡수하고 있다</h2>
        <span>
          상위 5개 ETF 합산 약 {totalEtfBtc.toLocaleString()} BTC
          (≈ {formatUsdBillion(totalEtfBtc * CURRENT_PRICE)}, $60,000 기준)
        </span>
      </div>
      <div class="bsh-etf-grid">
        {BSH_ETFS.map((etf, i) => (
          <article class="bsh-etf-card">
            <div class="bsh-etf-rank">#{i + 1}</div>
            <div class="bsh-etf-info">
              <strong>{etf.name}</strong>
              <span class="bsh-etf-ticker">{etf.ticker}</span>
              <span class="bsh-etf-issuer">{etf.issuer}</span>
            </div>
            <div class="bsh-etf-nums">
              <span class="bsh-etf-btc">{etf.btcHeld.toLocaleString()} BTC</span>
              <span class="bsh-etf-aum">AUM {etf.aum}</span>
            </div>
            <p class="bsh-etf-note">{etf.note}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- 관련 리포트 -->
    <section class="content-section bsh-related-section" aria-labelledby="bsh-related-title">
      <div class="bsh-section-heading">
        <p>관련 리포트</p>
        <h2 id="bsh-related-title">함께 보면 좋은 콘텐츠</h2>
      </div>
      <div class="bsh-related-grid">
        {BSH_RELATED_LINKS.map((link) => (
          <a class="bsh-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <span>{link.desc}</span>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="비트코인 보유 현황 자주 묻는 질문"
      intro={[
        BSH_META.dataNote,
        "비트코인은 총 2,100만 개로 발행량이 고정되어 있으며, 2026년 6월 기준 약 94%(1,974만 개)가 이미 채굴됐습니다.",
      ]}
      inputPoints={[
        "채굴 현황과 남은 공급량을 확인할 수 있습니다.",
        "국가별·기업별·ETF별 보유량을 비교할 수 있습니다.",
        "사토시 나카모토 추정 보유량과 신원 미스터리를 정리합니다.",
      ]}
      criteria={[
        "기업 보유량 출처: Bitcoin Treasuries (bitcointreasuries.net)",
        "분실 BTC 추정: Chainalysis 분석",
        "ETF 보유량: SEC EDGAR 공시 기준",
      ]}
      faq={BSH_FAQ.map((f) => ({ question: f.question, answer: f.answer }))}
      related={BSH_RELATED_LINKS.map((l) => ({ href: l.href, label: l.label }))}
    />
  </main>
</BaseLayout>
