---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  BFD_FAQ,
  BFD_META,
  BFD_CTA_CARDS,
  BFD_RELATED_LINKS,
  OPTIONS,
  CUMULATIVE_COST_ROWS,
  FOOD_BUYING_CHECKLIST,
  FOOD_DECISION_CARDS,
  MONTHLY_CONSUMPTION,
  COOKING_TOOLS,
  SUBSCRIPTION_BENEFITS,
  HOMEMADE_TIME_COST_6M,
  HOMEMADE_TOTAL_WITH_TIME_6M,
} from "../../data/babyFoodCostComparison2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const won = (n: number) => n.toLocaleString("ko-KR") + "원";
const manWon = (n: number) => {
  const m = Math.floor(n / 10000);
  const r = n % 10000;
  return m > 0 ? (r > 0 ? `${m}만 ${r.toLocaleString()}원` : `${m}만 원`) : won(n);
};

const homemadeOption = OPTIONS.find((o) => o.type === "homemade")!;
const brandOptions = OPTIONS.filter((o) => o.type === "brand");

// 최저·최고 누적 비용
const minCost = Math.min(...CUMULATIVE_COST_ROWS.map((r) => r.totalCost));
const maxCost = Math.max(...CUMULATIVE_COST_ROWS.map((r) => r.totalCost));
const costDiff = maxCost - minCost;
const cheapestRow = CUMULATIVE_COST_ROWS.find((r) => r.totalCost === minCost) ?? CUMULATIVE_COST_ROWS[0];
const priciestRow = CUMULATIVE_COST_ROWS.find((r) => r.totalCost === maxCost) ?? CUMULATIVE_COST_ROWS[CUMULATIVE_COST_ROWS.length - 1];
const cheapestBrandRow = CUMULATIVE_COST_ROWS.filter((r) => r.option !== "홈메이드 이유식").sort((a, b) => a.totalCost - b.totalCost)[0];

// JSON-LD
const faqSchema = BFD_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: { "@type": "Answer", text: item.answer },
}));

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: BFD_META.seoTitle,
      description: BFD_META.description,
      inLanguage: "ko-KR",
      dateModified: BFD_META.updatedAt,
      mainEntityOfPage: `https://bigyocalc.com/reports/${BFD_META.slug}/`,
      publisher: { "@type": "Organization", name: "비교계산소", url: "https://bigyocalc.com" },
    },
    { "@type": "FAQPage", mainEntity: faqSchema },
  ],
};

// 차트 데이터 (인라인 스크립트용)
const lineChartData = {
  labels: MONTHLY_CONSUMPTION.map((r) => r.ageRangeLabel),
  datasets: [
    { label: "홈메이드 이유식", pricePerHundredG: 1900, borderColor: "#0F6E56" },
    { label: "마이리틀쉐프 (시판 저가)", pricePerHundredG: 5160, borderColor: "#B45309" },
    { label: "오가닉스타트 (시판 고가)", pricePerHundredG: 7940, borderColor: "#B91C1C" },
  ],
};

const barChartData = {
  labels: CUMULATIVE_COST_ROWS.map((r) => r.option),
  data: CUMULATIVE_COST_ROWS.map((r) => r.totalCost),
  colors: CUMULATIVE_COST_ROWS.map((r) => (r.isLowest ? "#0F6E56" : "#93C5BE")),
};

const timeCostChartData = {
  labels: ["홈메이드 (재료비만)", "홈메이드 (재료비+시간 비용)", "시판 저가 (마이리틀쉐프)", "시판 고가 (오가닉스타트)"],
  data: [minCost, HOMEMADE_TOTAL_WITH_TIME_6M, cheapestBrandRow.totalCost, maxCost],
};
---

<BaseLayout
  title={BFD_META.seoTitle}
  description={BFD_META.description}
  ogImage="/og/og-home.png"
  jsonLd={jsonLd}
>
  <SiteHeader />

  <main class="container page-shell report-page bfd-page">
    <CalculatorHero
      eyebrow="이유식 비교 리포트"
      title="이유식 비교 2026"
      description="베베쿡·잇마플·오가닉스타트 등 6개 브랜드와 직접 만들기를 100g 단가, 6개월 누적 비용, 시간 비용 기준으로 비교합니다."
      badges={["이유식 비교표", "직접 만들기", "6개월 비용", "추정"]}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        BFD_META.dataNote,
        "직접 만들기 시간 비용은 2026년 최저시급 가정 기준 추정값이며 실제 조리 시간과 다를 수 있습니다.",
        "직접 만들기와 시판 중 어느 쪽이 '더 나은 선택'인지는 절대적인 기준이 없습니다. 가정의 시간 여유와 예산을 함께 고려하세요.",
      ]}
    />

    <!-- 핵심 요약 카드 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">한눈에 보는 결론</p>
        <h2>이유식은 재료비만 보지 말고 시간 비용까지 더해서 비교해야 합니다</h2>
        <p>직접 만들기는 재료비가 가장 저렴하지만 조리·소분·세척 시간이 들고, 시판은 비싸지만 시간이 절약됩니다. 가정의 시간 여유에 맞는 선택이 중요합니다.</p>
      </div>
      <div class="bfd-summary-grid">
        <div class="bfd-summary-card bfd-summary-card--accent">
          <span class="bfd-summary-label">가장 저렴한 옵션</span>
          <span class="bfd-summary-value">{cheapestRow.option}</span>
          <span class="bfd-summary-note">6개월 약 {manWon(minCost)} (재료비만, 추정)</span>
        </div>
        <div class="bfd-summary-card">
          <span class="bfd-summary-label">시판 중 최저가</span>
          <span class="bfd-summary-value">{cheapestBrandRow.option}</span>
          <span class="bfd-summary-note">6개월 약 {manWon(cheapestBrandRow.totalCost)} (정기배송 기준, 추정)</span>
        </div>
        <div class="bfd-summary-card bfd-summary-card--warn">
          <span class="bfd-summary-label">시간 비용 포함 시</span>
          <span class="bfd-summary-value">약 {manWon(HOMEMADE_TOTAL_WITH_TIME_6M)}</span>
          <span class="bfd-summary-note">홈메이드 실질 비용 — 시판 저가 옵션과 비슷한 수준 (추정)</span>
        </div>
        <div class="bfd-summary-card">
          <span class="bfd-summary-label">절약 팁</span>
          <span class="bfd-summary-value">정기배송 최대 12%</span>
          <span class="bfd-summary-note">베베쿡·오가닉스타트 정기배송 적용 시 월 1~2만 원 절감 (추정)</span>
        </div>
      </div>
    </section>

    <DesignTrustPanel updatedAt="2026년 6월" />

    <section class="content-section bfd-conclusion">
      <p class="section-header__eyebrow">30초 결론</p>
      <h2>직접 만들기는 재료비 35만 원, 시간 비용 더하면 100만 원 안팎까지 올라갑니다</h2>
      <div class="bfd-conclusion-grid">
        <article>
          <strong>재료비 기준</strong>
          <p>홈메이드 이유식은 6개월 누적 약 {manWon(minCost)}로 가장 저렴합니다. 단, 배치 조리 시간이 필요합니다.</p>
        </article>
        <article>
          <strong>시판 기준</strong>
          <p>{cheapestBrandRow.option}부터 {priciestRow.option}까지 약 {manWon(cheapestBrandRow.totalCost)}~{manWon(maxCost)} 범위입니다. 정기배송 할인을 적용하면 더 낮출 수 있습니다.</p>
        </article>
        <article>
          <strong>실전 선택 기준</strong>
          <p>시간 여유가 있으면 직접 만들기, 맞벌이라면 시판 저가 브랜드, 절반씩이라면 평일 시판 + 주말 직접 만들기 혼합이 합리적입니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section bfd-quick-cta-section" aria-labelledby="bfd-quick-cta-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">다음 단계</p>
        <h2 id="bfd-quick-cta-title">이유식 다음에 같이 보면 좋은 콘텐츠</h2>
        <p>분유에서 이유식으로 넘어오는 시기, 함께 확인하면 좋은 비교표와 계산기입니다.</p>
      </div>
      <div class="bfd-cta-card-grid">
        {BFD_CTA_CARDS.map((card) => (
          <a class="bfd-cta-card" href={withBase(card.href)}>
            <span>{card.eyebrow}</span>
            <strong>{card.title}</strong>
            <p>{card.description}</p>
            <em>{card.cta}</em>
          </a>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="bfd-decision-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">요즘식 선택법</p>
        <h2 id="bfd-decision-title">이유식 추천보다 먼저 봐야 할 4가지 상황</h2>
        <p>이유식은 랭킹보다 우리 집 조건이 먼저입니다. 시간 여유, 예산, 원료 선호를 나눠 보면 선택이 쉬워집니다.</p>
      </div>
      <div class="bfd-decision-grid">
        {FOOD_DECISION_CARDS.map((item) => (
          <article class="bfd-decision-card">
            <span>{item.title}</span>
            <strong>{item.headline}</strong>
            <p>{item.body}</p>
            <small>{item.linksTo}</small>
          </article>
        ))}
      </div>
    </section>

    <!-- 이유식 선택이 왜 고민거리인가 -->
    <section class="content-section bfd-copy-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">비용 판단 기준</p>
        <h2>이유식 선택이 왜 고민거리인가</h2>
      </div>
      <p>이유식을 시작하는 시점은 분유에서 한 단계 넘어가는 중요한 전환기이지만, 동시에 "직접 만들 것인가 시판 제품을 살 것인가"라는 새로운 비용 결정이 시작되는 시점이기도 합니다. 직접 만들기와 비교하면 6개월 기준 최대 {manWon(costDiff)}까지 차이가 날 수 있습니다. (추정)</p>
      <p>단순히 재료비만 비교하면 직접 만들기가 압도적으로 저렴합니다. 그러나 직접 만들기에는 조리·소분·세척에 드는 시간이라는 숨겨진 비용이 있습니다. 시급을 가정해 시간 비용을 환산하면 <strong>실질 비용</strong>이 달라집니다.</p>
    </section>

    <!-- 단계별 기준 + 소비량 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">단계별 기준</p>
        <h2>이유식 단계별 월 소비량은 이렇게 늘어납니다</h2>
        <p>대한소아과학회 권고를 참고한 단계별 소비량 추정입니다. 단계가 진행될수록 1일 섭취 횟수와 양이 늘어 비용도 함께 늘어납니다.</p>
      </div>
      <div class="bfd-table-wrap">
        <table class="bfd-month-table">
          <thead>
            <tr>
              <th>단계</th>
              <th>월령</th>
              <th>1일 섭취 횟수</th>
              <th>1일 소비량</th>
              <th>월 소비량</th>
            </tr>
          </thead>
          <tbody>
            {MONTHLY_CONSUMPTION.map((row) => (
              <tr>
                <td><strong>{row.ageRangeLabel}</strong></td>
                <td>{row.ageRangeLabel}</td>
                <td>{row.dailyServings}회</td>
                <td>{row.dailyGrams}g</td>
                <td>{row.monthlyGrams.toLocaleString("ko-KR")}g</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bfd-table-note">단계별 소비량은 추정값이며 아기의 발달 속도에 따라 차이가 있을 수 있습니다.</p>
    </section>

    <!-- 직접 만들기 비용 구조 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">직접 만들기</p>
        <h2>직접 만들기 비용 구조: 재료비 + 조리도구</h2>
        <p>배치 조리(주 1~2회 대량 조리 후 냉동 소분)를 가정한 단계별 재료비와 초기 조리도구 구매비입니다.</p>
      </div>

      <article class="bfd-homemade-card">
        <div class="bfd-homemade-head">
          <span class="bfd-option-tag bfd-option-tag--homemade">홈메이드</span>
          <h3 class="bfd-option-name">{homemadeOption.name}</h3>
          <p class="bfd-homemade-best"><strong>추천 대상</strong> {homemadeOption.bestFor}</p>
        </div>
        <ul class="bfd-option-pros">
          {homemadeOption.pros.map((p) => <li>{p}</li>)}
        </ul>
        <ul class="bfd-option-cons">
          {homemadeOption.cons.map((c) => <li>{c}</li>)}
        </ul>
      </article>

      <div class="bfd-stage-cost-row">
        {homemadeOption.stages.map((stage) => (
          <div class="bfd-stage-cost-chip">
            <span class="bfd-stage-cost-label">{stage.stageLabel}</span>
            <strong class="bfd-stage-cost-value">{won(stage.pricePerHundredG)}</strong>
            <span class="bfd-stage-cost-sub">100g당 재료비 (추정)</span>
          </div>
        ))}
      </div>

      <h3 class="bfd-subhead">초기 조리도구 구매비</h3>
      <div class="bfd-tool-grid">
        {COOKING_TOOLS.map((tool) => (
          <div class={`bfd-tool-card ${tool.necessity === "essential" ? "bfd-tool-card--essential" : "bfd-tool-card--optional"}`}>
            <span class="bfd-tool-badge">{tool.necessity === "essential" ? "필수" : "선택"}</span>
            <strong class="bfd-tool-name">{tool.name}</strong>
            <span class="bfd-tool-price">{won(tool.price)}</span>
          </div>
        ))}
      </div>
      <p class="bfd-table-note">필수 항목 합계 약 14.3만 원 (추정). 6개월 이상 직접 만들기를 지속하면 재료비 절감으로 회수 가능합니다.</p>
    </section>

    <!-- 시판 브랜드별 가격 비교표 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">단가 비교</p>
        <h2>이유식 비교표: 단계별 100g 단가 <span class="badge badge--warning">추정</span></h2>
        <p>이유식 비교표는 1회분 가격보다 100g 단가를 먼저 봐야 합니다. 실제 구매가는 시기·플랫폼·쿠폰 적용 여부에 따라 달라집니다.</p>
      </div>
      <div class="bfd-table-wrap">
        <table class="bfd-compare-table">
          <thead>
            <tr>
              <th>옵션</th>
              <th>단계</th>
              <th>1회분 용량</th>
              <th>정가</th>
              <th>정기배송가</th>
              <th>100g 단가</th>
              <th>구매</th>
            </tr>
          </thead>
          <tbody>
            <Fragment>
              {[homemadeOption, ...brandOptions].map((option) =>
                option.stages.map((stage, si) => (
                  <tr>
                    {si === 0 && (
                      <td rowspan={option.stages.length} class="bfd-option-cell">
                        {option.name}
                        {option.type === "homemade" && <span>재료비 추정</span>}
                      </td>
                    )}
                    <td>{stage.stageLabel}</td>
                    <td>{stage.servingG}g</td>
                    <td>{stage.listPrice ? won(stage.listPrice) : "-"}</td>
                    <td>{stage.subscriptionPrice ? won(stage.subscriptionPrice) : "-"}</td>
                    <td class={stage.pricePerHundredG <= 2500 ? "bfd-lowest" : stage.pricePerHundredG >= 7000 ? "bfd-highest" : ""}>
                      {won(stage.pricePerHundredG)}
                    </td>
                    <td>
                      {option.type === "homemade"
                        ? <span class="bfd-empty">재료 직접 구매</span>
                        : stage.coupaUrl
                          ? <a class="bfd-buy-btn" href={stage.coupaUrl} target="_blank" rel="noopener sponsored">쿠팡 보기</a>
                          : <span class="bfd-empty">-</span>
                      }
                    </td>
                  </tr>
                ))
              )}
            </Fragment>
          </tbody>
        </table>
      </div>
      <p class="bfd-table-note">※ 100g 단가 초록색: 최저 구간 / 빨간색: 최고 구간. 모든 가격은 추정값입니다.</p>
    </section>

    <!-- 단계별 월 비용 환산 차트 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">단계별 흐름</p>
        <h2>단계별 이유식 비용 추이</h2>
        <p>단계가 진행될수록 소비량이 늘어 월 비용도 함께 상승합니다.</p>
      </div>
      <div class="bfd-chart-panel">
        <div class="bfd-chart-wrap">
          <canvas id="bfdLineChart" aria-label="대표 옵션 단계별 이유식 비용 추이 차트"></canvas>
        </div>
      </div>
      <p class="bfd-chart-note">전체 옵션 비교는 위 가격 비교표를 참고하세요.</p>
    </section>

    <!-- 6개월 누적 비용 차트 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">6개월 누적</p>
        <h2>옵션별 6개월 누적 이유식 비용 비교 <span class="badge badge--warning">추정</span></h2>
        <p>단계별 권장 소비량 기준 6개월 누적 비용입니다. 실제 소비량과 구매가에 따라 달라집니다.</p>
      </div>
      <div class="bfd-chart-panel">
        <div class="bfd-bar-chart-wrap">
          <canvas id="bfdBarChart" aria-label="옵션별 6개월 누적 이유식 비용 비교 차트"></canvas>
        </div>
      </div>
    </section>

