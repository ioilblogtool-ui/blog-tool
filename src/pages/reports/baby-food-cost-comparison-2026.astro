<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script define:vars={{ lineChartData, barChartData, timeCostChartData, MONTHLY_CONSUMPTION }}>
  window.addEventListener("load", () => {
    if (typeof window.Chart === "undefined") return;

    // ── 라인 차트 (단계별 월 비용) ──────────────────────
    const lineCtx = document.getElementById("bfdLineChart");
    if (lineCtx) {
      const labels = MONTHLY_CONSUMPTION.map((r) => r.ageRangeLabel);
      const datasets = lineChartData.datasets.map((ds) => ({
        label: ds.label,
        data: MONTHLY_CONSUMPTION.map((r) => Math.round((r.monthlyGrams / 100) * ds.pricePerHundredG)),
        borderColor: ds.borderColor,
        backgroundColor: ds.borderColor + "18",
        borderWidth: 2,
        pointRadius: 3,
        tension: 0.35,
      }));

      new window.Chart(lineCtx, {
        type: "line",
        data: { labels, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: "index", intersect: false },
          plugins: {
            legend: { position: "top", labels: { font: { size: 12 }, padding: 12 } },
            tooltip: {
              callbacks: {
                label: (ctx) => `${ctx.dataset.label}: ${Math.round(ctx.parsed.y).toLocaleString("ko-KR")}원`,
              },
            },
          },
          scales: {
            x: { grid: { display: false } },
            y: {
              ticks: {
                callback: (v) => Math.round(Number(v) / 10000) + "만",
              },
            },
          },
        },
      });
    }

    // ── 가로 막대 차트 (6개월 누적 비용) ───────────────
    const barCtx = document.getElementById("bfdBarChart");
    if (barCtx) {
      new window.Chart(barCtx, {
        type: "bar",
        data: {
          labels: barChartData.labels,
          datasets: [{
            label: "6개월 누적 비용 (추정)",
            data: barChartData.data,
            backgroundColor: barChartData.colors,
            borderRadius: 4,
          }],
        },
        options: {
          indexAxis: "y",
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx) => ` 약 ${Math.round(Number(ctx.parsed.x) / 10000).toLocaleString("ko-KR")}만 원`,
              },
            },
          },
          scales: {
            x: {
              ticks: {
                callback: (v) => Math.round(Number(v) / 10000) + "만",
              },
            },
            y: { grid: { display: false } },
          },
        },
      });
    }

    // ── 그룹 막대 차트 (시간 비용 포함 비교) ───────────────
    const timeCtx = document.getElementById("bfdTimeCostChart");
    if (timeCtx) {
      new window.Chart(timeCtx, {
        type: "bar",
        data: {
          labels: timeCostChartData.labels,
          datasets: [{
            label: "6개월 비용 (추정)",
            data: timeCostChartData.data,
            backgroundColor: ["#0F6E56", "#B45309", "#93C5BE", "#B91C1C"],
            borderRadius: 4,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx) => ` 약 ${Math.round(Number(ctx.parsed.y) / 10000).toLocaleString("ko-KR")}만 원`,
              },
            },
          },
          scales: {
            x: { grid: { display: false } },
            y: {
              ticks: {
                callback: (v) => Math.round(Number(v) / 10000) + "만",
              },
            },
          },
        },
      });
    }
  });
</script>
