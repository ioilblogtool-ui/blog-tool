---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import { healthCheckupCostComparison2026 as report } from "../../data/healthCheckupCostComparison2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const faqItems = report.faq.map((item) => ({ question: item.question, answer: item.answer }));
const basisLabel = {
  official: "공식",
  estimate: "추정",
  private: "민간사례",
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: report.meta.title,
      description: report.meta.description,
      inLanguage: "ko-KR",
      dateModified: "2026-06-07",
      mainEntityOfPage: `https://bigyocalc.com/reports/${report.meta.slug}/`,
      author: { "@type": "Organization", name: "비교계산소" },
      publisher: { "@type": "Organization", name: "비교계산소" },
      keywords: ["건강검진 비용", "국가건강검진", "사설 종합검진", "국가암검진", "임신 검사 비용"],
    },
    {
      "@type": "FAQPage",
      mainEntity: report.faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<BaseLayout title={report.meta.title} description={report.meta.description}>
  <SiteHeader />

  <main class="container page-shell report-page hcc-page">
    <CalculatorHero
      eyebrow={report.meta.eyebrow}
      title={report.meta.h1}
      description="국가건강검진은 무엇을 무료로 해주고, 사설 종합검진은 어디부터 돈값을 하는지 비용·항목·연령대·임신 시기 기준으로 정리했습니다."
      badges={["국가검진", "사설검진", "국가암검진", "임신검사", "2026"]}
      updatedAt={report.meta.updatedAt}
    />

    <InfoNotice
      title="비용 기준"
      lines={[
        "국가검진 비용 구조는 국민건강보험공단·건강검진 실시기준·암검진 비용 지원 안내를 기준으로 정리했습니다.",
        "사설 종합검진 비용은 민간 검진센터 공개 가격과 일반적인 시장 범위를 묶은 참고 범위입니다.",
        "검진 목적 비급여와 질병 진료 목적 급여는 비용 구조가 다릅니다. 증상이 있으면 검진센터보다 진료 상담을 먼저 받으세요.",
      ]}
    />

    <section class="content-section hcc-summary-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">한눈에 보기</p>
        <h2>국가검진은 무료에 가깝고, 사설검진은 선택검사에서 비용 차이가 납니다</h2>
        <p>
          건강검진 비용을 비교할 때 핵심은 “패키지 가격”이 아니라 국가검진으로 이미 받을 수 있는 항목과 돈을 내고 추가해야 하는 빈칸을 분리하는 것입니다.
        </p>
      </div>
      <div class="hcc-summary-grid">
        {report.summaryCards.map((card) => (
          <article>
            <span>{card.label}</span>
            <strong>{card.value}</strong>
            <p>{card.desc}</p>
            <em>{basisLabel[card.basis]}</em>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section hcc-principle-section">
      <div>
        <p class="hcc-section-eyebrow">결론 먼저</p>
        <h2>가장 싼 선택은 국가검진만 받는 것이지만, 가장 좋은 선택은 “국가검진 + 내 위험요인 보완”입니다</h2>
        <p>
          국가 일반건강검진은 혈압, 혈당, 간수치, 신장기능, 빈혈, 흉부 X-ray처럼 넓고 기본적인 위험을 잡는 데 강합니다.
          반면 사설 종합검진은 복부초음파, 내시경, 심장·뇌혈관 영상검사처럼 국가검진의 빈칸을 메우는 데 의미가 있습니다.
          따라서 무증상 20~30대는 국가검진을 먼저 받고, 40대 이후나 가족력이 있는 사람은 암검진과 필요한 장기 중심의 선택검사를 붙이는 방식이 효율적입니다.
        </p>
      </div>
      <div class="hcc-principle-list">
        <article>
          <strong>1. 무료 항목 먼저 확인</strong>
          <p>올해 국가 일반검진·암검진 대상인지 확인하면 수십만 원짜리 사설 패키지와 겹치는 항목을 줄일 수 있습니다.</p>
        </article>
        <article>
          <strong>2. 가족력은 장기별로 반영</strong>
          <p>위암 가족력은 위내시경, 대장암 가족력은 대장내시경, 뇌졸중 가족력은 혈압·지질·경동맥 평가처럼 좁혀야 합니다.</p>
        </article>
        <article>
          <strong>3. 임신 가능성은 먼저 알림</strong>
          <p>임신 중에는 일반 종합검진보다 산전검사 일정이 우선이고, X-ray·CT·진정 내시경은 의료진 상담이 필요합니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section hcc-table-section" id="national-vs-private">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">국가 vs 사설</p>
        <h2>건강검진 유형별 비용·포함 항목·한계 비교</h2>
        <p>공식 제도는 “공식”, 사설 패키지 가격 범위는 “추정” 또는 “민간사례” 배지로 구분했습니다.</p>
      </div>
      <div class="hcc-table-wrap">
        <table class="hcc-comparison-table">
          <thead>
            <tr>
              <th>유형</th>
              <th>대상</th>
              <th>본인부담</th>
              <th>포함 항목</th>
              <th>강점</th>
              <th>한계</th>
              <th>추천 기준</th>
            </tr>
          </thead>
          <tbody>
            {report.comparisonRows.map((row) => (
              <tr>
                <td><strong>{row.type}</strong><span>{basisLabel[row.basis]}</span></td>
                <td>{row.target}</td>
                <td class="hcc-cost">{row.outOfPocket}</td>
                <td>{row.included}</td>
                <td>{row.strength}</td>
                <td>{row.limit}</td>
                <td>{row.recommendation}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section hcc-addon-section" id="addon-exams">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">선택검사</p>
        <h2>사설 검진 비용을 올리는 핵심 항목</h2>
        <p>
          사설 종합검진은 기본형보다 선택검사에서 비용이 크게 달라집니다. 예약 전 수면료, 조직검사, 용종 제거, 조영제, 판독료 포함 여부를 꼭 확인해야 합니다.
        </p>
      </div>
      <div class="hcc-addon-grid">
        {report.addonExamRows.map((item) => (
          <article>
            <h3>{item.exam}</h3>
            <p>{item.why}</p>
            <dl>
              <div><dt>국가검진 경로</dt><dd>{item.nationalRoute}</dd></div>
              <div><dt>사설 비용 범위</dt><dd>{item.privateRange}</dd></div>
              <div><dt>예약 전 확인</dt><dd>{item.checkBeforeBooking}</dd></div>
            </dl>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section hcc-scenario-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">케이스별 추천</p>
        <h2>연령대·가족력·임신 상황별 검진 예산</h2>
      </div>
      <div class="hcc-scenario-grid">
        {report.scenarioRows.map((item) => (
          <article>
            <span>{item.persona}</span>
            <h3>{item.recommendedRoute}</h3>
            <strong>{item.expectedCost}</strong>
            <p>{item.reason}</p>
            <em>피할 것: {item.avoid}</em>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section hcc-pregnancy-section" id="pregnancy-checkup">
      <div class="hcc-pregnancy-copy">
        <p class="hcc-section-eyebrow">임신 시기별 검사</p>
        <h2>임신 중에는 “종합검진”보다 산전검사 일정이 먼저입니다</h2>
        <p>
          임신 준비, 임신 초기, 정밀초음파 시기에는 일반 건강검진 패키지보다 산부인과 산전검사와 보건소 지원 항목을 먼저 확인해야 합니다.
          특히 임신 가능성이 있으면 흉부 X-ray, CT, 진정 내시경, 일부 약물 사용 검사는 예약 전에 반드시 알려야 합니다.
        </p>
        <div class="hcc-pregnancy-actions">
          <a class="button button--primary" href={withBase("/reports/pregnancy-checkup-cost-2026/")}>임신 주수별 검사 비용 보기</a>
          <a class="button button--secondary" href={withBase("/tools/pregnancy-checkup-cost/")}>검사비 계산기 열기</a>
        </div>
      </div>
      <div class="hcc-pregnancy-timeline">
        {report.pregnancyCheckupRows.map((item) => (
          <article>
            <span>{item.period}</span>
            <strong>{item.coreExams}</strong>
            <p>{item.checkupDecision}</p>
            <em>{item.costMemo}</em>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section hcc-checklist-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">예약 체크리스트</p>
        <h2>건강검진 결제 전에 확인할 5가지</h2>
      </div>
      <ol class="hcc-checklist">
        {report.bookingChecklist.map((item) => <li>{item}</li>)}
      </ol>
    </section>

    <section class="content-section hcc-source-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">출처</p>
        <h2>공식 제도와 민간 가격 사례를 분리해 확인했습니다</h2>
      </div>
      <div class="hcc-source-grid">
        {report.sources.map((source) => (
          <a href={source.href} target="_blank" rel="noopener noreferrer">
            <span>{source.organization}</span>
            <strong>{source.label}</strong>
            <p>{source.note}</p>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="건강검진 비용 비교를 읽는 법"
      intro={[
        "건강검진 비용은 국가검진과 사설 종합검진을 같은 선에서 비교하면 헷갈립니다. 국가검진은 국민건강보험공단이 대상자에게 제공하는 기본 선별검사이고, 사설 종합검진은 본인이 원하는 검사 범위를 넓히는 비급여·패키지 성격이 강합니다.",
        "가장 먼저 확인할 것은 올해 국가 일반건강검진 대상 여부입니다. 대상자라면 기본 검진은 본인부담 없이 받을 수 있고, 40대 이후에는 위암·간암·유방암·자궁경부암, 50대 이후에는 대장암 등 국가암검진 항목을 확인해야 합니다. 이 단계를 건너뛰고 사설 검진부터 결제하면 이미 무료로 받을 수 있는 항목에 돈을 낼 수 있습니다.",
        "사설 종합검진은 나쁜 선택이 아닙니다. 다만 비용 대비 효율은 선택검사를 어떻게 고르느냐에 달려 있습니다. 가족력이 있는 장기, 이전 검진에서 이상 소견이 있었던 항목, 흡연·비만·고혈압·당뇨처럼 위험요인이 있는 영역부터 보완해야 합니다.",
        "임신 준비 또는 임신 중이라면 일반 종합검진보다 산전검사 흐름이 우선입니다. 보건소 산전검사, 산부인과 기본 혈액검사, 기형아검사, 정밀초음파, 임신성 당뇨검사는 시기가 정해져 있고, 일부 영상검사나 진정검사는 의료진 상담이 필요합니다.",
      ]}
      criteria={[
        "국가 일반건강검진과 국가암검진은 공식 제도 기준으로 설명했습니다.",
        "사설 기본·정밀 검진 가격은 민간 검진센터 공개 가격과 시장 범위를 바탕으로 한 참고 범위입니다.",
        "비급여 검사는 병원, 장비, 판독 방식, 수면 여부, 조직검사 여부에 따라 실제 결제액이 달라집니다.",
        "증상이 있거나 질병이 의심되면 예방 목적 건강검진이 아니라 진료를 먼저 받아야 합니다.",
      ]}
      faq={faqItems}
      related={report.relatedLinks}
    />
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</BaseLayout>
