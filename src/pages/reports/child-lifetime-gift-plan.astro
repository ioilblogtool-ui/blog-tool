---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import { childLifetimeGiftPlan } from "../../data/childLifetimeGiftPlan";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const report = childLifetimeGiftPlan;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: report.meta.seoTitle,
      description: report.meta.description,
      inLanguage: "ko-KR",
      dateModified: "2026-06-28",
      mainEntityOfPage: `https://bigyocalc.com/reports/${report.meta.slug}/`,
      publisher: { "@type": "Organization", name: "비교계산소", url: "https://bigyocalc.com" },
    },
    {
      "@type": "FAQPage",
      mainEntity: report.faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<BaseLayout
  title={report.meta.seoTitle}
  description={report.meta.description}
  ogImage="/og/reports/child-lifetime-gift-plan.svg"
  jsonLd={jsonLd}
>
  <SiteHeader />

  <main class="container page-shell report-page clg-page">
    <CalculatorHero
      eyebrow="세금 리포트"
      title={report.meta.title}
      description="0세부터 성년, 결혼·출산, 주택자금까지 자녀 증여 한도를 생애 흐름으로 정리했습니다."
      badges={["자녀 증여", "10년 공제", "결혼자금", "주택자금"]}
    />

    <InfoNotice
      title="세금 신고 전 확인하세요"
      lines={[
        report.meta.caution,
        "혼인·출산 추가공제, 신고기한, 자금출처 판단은 실제 증여일과 가족관계에 따라 달라질 수 있습니다.",
        report.meta.updatedAt,
      ]}
    />

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">30초 요약</p>
        <h2>자녀 증여는 한 번의 금액보다 생애 타이밍이 중요합니다</h2>
        <p>미성년·성년 기본공제, 결혼·출산 추가공제, 주택자금 자금출처를 따로 보지 말고 한 흐름으로 봐야 합니다.</p>
      </div>
      <div class="clg-summary-grid" aria-label="자녀 증여 핵심 요약">
        {report.summaryCards.map((card) => (
          <article class={`clg-summary-card clg-badge-${card.badge}`}>
            <span>{card.badge}</span>
            <p>{card.label}</p>
            <strong>{card.value}</strong>
            <small>{card.note}</small>
          </article>
        ))}
      </div>
      <div class="clg-quick-actions" aria-label="증여세 계산 바로가기">
        <a class="clg-button clg-button--primary" href={withBase("/tools/gift-tax-calculator/")}>이번 증여금액으로 세금 계산하기</a>
        <a class="clg-button" href={withBase("/tools/gift-tax-child-calculator/")}>자녀 나이별 한도 확인하기</a>
      </div>
    </section>

    <DesignTrustPanel
      title="증여 플랜 데이터 기준"
      updatedAt="2026년 6월"
      items={[
        {
          label: "공식",
          title: "법령 기준 공제",
          description: "증여재산공제와 혼인·출산 증여재산공제처럼 법령 기준으로 확인되는 항목입니다.",
        },
        {
          label: "참고",
          title: "조건부 해석",
          description: "기본공제와 추가공제를 함께 볼 때처럼 실제 요건 확인이 필요한 해석입니다.",
        },
        {
          label: "주의",
          title: "자금출처 리스크",
          description: "주택자금·차용 관계처럼 세액보다 증빙과 소명이 중요해지는 항목입니다.",
        },
      ]}
      notes={[
        "이 리포트는 일반적인 세금 이해를 돕기 위한 콘텐츠이며, 신고서 작성이나 세무 자문을 대신하지 않습니다.",
        "큰 금액을 증여하거나 주택 취득자금과 연결되는 경우 국세청 홈택스 또는 세무 전문가 확인을 권장합니다.",
      ]}
    />

    <section class="content-section" aria-labelledby="clg-timeline-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">생애 타임라인</p>
        <h2 id="clg-timeline-title">0세부터 주택자금까지 증여 한도는 어떻게 달라질까?</h2>
        <p>아래 금액은 "무조건 줄 수 있는 금액"이 아니라, 최근 10년 증여 이력과 요건을 확인해야 하는 대표 구간입니다.</p>
      </div>
      <div class="clg-timeline">
        {report.timeline.map((item) => (
          <article class={`clg-timeline-card clg-badge-${item.badge}`}>
            <span class="clg-timeline-card__age">{item.ageLabel}</span>
            <span class="clg-timeline-card__badge">{item.badge}</span>
            <h3>{item.event}</h3>
            <p>{item.deductionLabel}</p>
            <strong>{item.amountLabel}</strong>
            <small>{item.note}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="clg-rules-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">기본 원칙</p>
        <h2 id="clg-rules-title">증여세 한도는 10년 단위로 봅니다</h2>
        <p>자녀 증여에서 가장 흔한 착각은 한도가 매년 새로 생긴다고 생각하는 것입니다.</p>
      </div>
      <div class="clg-rule-grid">
        {report.rules.map((rule) => (
          <article class={`clg-rule-card clg-badge-${rule.badge}`}>
            <span>{rule.badge}</span>
            <h3>{rule.title}</h3>
            <p>{rule.body}</p>
            <div class="clg-example-box">{rule.example}</div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section clg-marriage-section" aria-labelledby="clg-marriage-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">결혼·출산 공제</p>
        <h2 id="clg-marriage-title">결혼·출산 시점에는 추가 1억 원 공제를 검토할 수 있습니다</h2>
        <p>성년 자녀 기본공제 5,000만 원과 혼인·출산 추가공제를 함께 볼 수 있지만, 요건 충족과 기사용액 확인이 먼저입니다.</p>
      </div>
      <div class="clg-marriage-panel">
        <div class="clg-marriage-lead">
          <span>참고</span>
          <strong>성년 기본공제 5,000만 원 + 혼인·출산 추가공제 1억 원</strong>
          <p>조건이 맞으면 1억 5,000만 원 구간을 검토할 수 있습니다. 다만 최근 10년 증여 이력, 혼인·출산 공제 사용 이력, 기간 요건에 따라 실제 공제 가능액은 달라질 수 있습니다.</p>
        </div>
        <div class="clg-marriage-list">
          {report.marriageBirthRules.map((item) => (
            <article>
              <span>{item.label}</span>
              <strong>{item.value}</strong>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </div>
      <div class="clg-quick-actions clg-quick-actions--left">
        <a class="clg-button clg-button--primary" href={withBase("/tools/gift-tax-child-calculator/")}>혼인·출산 한도 계산하기</a>
      </div>
    </section>

    <section class="content-section" aria-labelledby="clg-housing-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">주택자금 오해</p>
        <h2 id="clg-housing-title">자녀 주택자금은 별도 비과세 한도가 있을까?</h2>
        <p>주택 구입 자금이라고 해서 자동으로 별도 비과세 한도가 생기는 것은 아닙니다. 증여인지 차용인지, 자금출처를 설명할 수 있는지가 중요합니다.</p>
      </div>
      <div class="clg-myth-grid">
        {report.housingMyths.map((item) => (
          <article class="clg-myth-card">
            <span>오해</span>
            <h3>{item.myth}</h3>
            <strong>정리: {item.fact}</strong>
            <p>주의: {item.risk}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="clg-scenarios-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">플랜 비교</p>
        <h2 id="clg-scenarios-title">우리 집은 어떤 증여 플랜에 가까울까?</h2>
        <p>정답은 하나가 아닙니다. 증여 목적, 자녀 나이, 결혼·주택 계획에 따라 관리 방식이 달라집니다.</p>
      </div>
      <div class="clg-scenario-grid">
        {report.scenarios.map((scenario) => (
          <article class={`clg-scenario-card clg-scenario-card--${scenario.id}`}>
            <span>{scenario.title}</span>
            <h3>{scenario.summary}</h3>
            <ul>
              {scenario.steps.map((step) => <li>{step}</li>)}
            </ul>
            <p><strong>장점</strong>{scenario.strength}</p>
            <p><strong>주의</strong>{scenario.caution}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="clg-checklist-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">신고·증빙</p>
        <h2 id="clg-checklist-title">증여세 0원보다 중요한 것은 기록입니다</h2>
        <p>공제 한도 안이라도 나중에 자금출처를 설명해야 할 수 있습니다. 특히 주택 구입과 연결되는 돈은 기록을 남기는 편이 좋습니다.</p>
      </div>
      <div class="clg-checklist">
        {report.checklist.map((item) => (
          <article class={`clg-check-item ${item.level === "warn" ? "clg-check-item--warn" : ""}`}>
            <span aria-hidden="true">✓</span>
            <div>
              <strong>{item.text}</strong>
              <p>{item.reason}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="clg-related-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">다음 계산기</p>
        <h2 id="clg-related-title">실제 금액은 계산기로 이어서 확인하세요</h2>
        <p>리포트에서 구조를 이해했다면, 증여금액과 주택 취득 관련 세금은 계산기로 다시 확인하는 흐름이 좋습니다.</p>
      </div>
      <div class="clg-related-grid">
        {report.relatedLinks.map((link) => (
          <a class="clg-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
            <span>바로가기</span>
          </a>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="clg-faq-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">FAQ</p>
        <h2 id="clg-faq-title">자주 묻는 질문</h2>
      </div>
      <div class="clg-faq-list">
        {report.faq.map((item, index) => (
          <details class="clg-faq-item" open={index === 0}>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="clg-sources-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">기준과 출처</p>
        <h2 id="clg-sources-title">이 리포트의 기준</h2>
        <p>세법은 개정될 수 있으므로 실제 신고 전 최신 기준을 다시 확인해야 합니다.</p>
      </div>
      <div class="clg-source-panel">
        <p>이 리포트는 2026년 6월 기준 상속세 및 증여세법상 일반 증여재산공제와 혼인·출산 증여재산공제 구조를 설명합니다. 실제 신고 단계에서는 증여일, 증여자 관계, 최근 10년 증여 이력, 재산 평가 방식, 특례 적용 여부를 별도로 확인해야 합니다.</p>
        <ul>
          {report.sources.map((source) => (
            <li>
              <a href={source.href} target="_blank" rel="noopener noreferrer">{source.label}</a>
              <span>{source.note}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <SeoContent
      introTitle="자녀 생애 증여 플랜을 읽는 법"
      intro={[
        "자녀 증여는 한 번에 얼마를 줄지보다 언제, 어떤 명목으로, 어떤 기록을 남길지가 중요합니다.",
        "미성년 2,000만 원과 성년 5,000만 원 공제는 10년 단위로 판단하고, 결혼·출산 추가공제는 요건을 충족하는지 따로 확인해야 합니다.",
        "주택자금은 증여세 계산과 별도로 자금출처 소명 가능성을 함께 봐야 하므로, 증여와 차용을 섞어 생각하지 않는 것이 좋습니다.",
      ]}
      criteria={[
        "증여재산공제는 최근 10년 증여 이력을 합산해 판단합니다.",
        "혼인·출산 추가공제는 요건 충족 시 검토할 수 있으며, 무조건 비과세로 단정하지 않습니다.",
        "주택자금은 별도 비과세 한도보다 자금출처 증빙과 실제 상환 내역이 중요합니다.",
      ]}
      faq={report.faq}
      related={report.relatedLinks.map((link) => ({ href: link.href, label: link.label }))}
    />
  </main>
</BaseLayout>
