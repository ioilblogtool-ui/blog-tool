    category: "estate",
    isNew: true,
  },
  "seoul-jeonwolse-ratio-2026": {
    eyebrow: "서울 전월세",
    tags: [{ label: "서울", mod: "asset" }, { label: "전월세", mod: "asset" }, { label: "2026", mod: "asset" }],
    category: "estate",
    isNew: true,
  },
  "2026-seoul-apt-cheonyak-cutline": {
    eyebrow: "서울 청약",
    tags: [{ label: "서울", mod: "asset" }, { label: "청약", mod: "asset" }, { label: "2026", mod: "asset" }],
