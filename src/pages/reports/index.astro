---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import { reports } from "../../data/reports";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;


type ReportCategory = "salary" | "estate" | "asset" | "life" | "culture";
type ReportTagMod = "salary" | "asset";

type ReportIndexMeta = {
  eyebrow: string;
  tags: { label: string; mod: ReportTagMod }[];
  category: ReportCategory;
  isNew: boolean;
};

const reportMetaBySlug: Record<string, ReportIndexMeta> = {
  "new-employee-salary-2026": {
    eyebrow: "연봉 비교",
    tags: [{ label: "70개 기업", mod: "salary" }, { label: "연봉", mod: "salary" }],
    category: "salary",
    isNew: false,
  },
  "it-salary-top10": {
    eyebrow: "IT 초봉",
    tags: [{ label: "IT", mod: "salary" }, { label: "TOP10", mod: "salary" }],
    category: "salary",
    isNew: false,
  },
  "it-si-sm-salary-comparison-2026": {
    eyebrow: "IT 서비스",
    tags: [{ label: "IT서비스", mod: "salary" }, { label: "평균 연봉", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "insurance-salary-bonus-comparison-2026": {
    eyebrow: "보험 비교",
    tags: [{ label: "보험", mod: "salary" }, { label: "총보상", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "construction-salary-bonus-comparison-2026": {
    eyebrow: "건설 비교",
    tags: [{ label: "건설", mod: "salary" }, { label: "총보상", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "large-company-salary-growth-by-years-2026": {
    eyebrow: "연차별 성장",
    tags: [{ label: "연차별", mod: "salary" }, { label: "성장곡선", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "seoul-housing-2016-vs-2026": {
    eyebrow: "서울 집값",
    tags: [{ label: "서울", mod: "asset" }, { label: "10년 비교", mod: "asset" }, { label: "PIR", mod: "asset" }],
    category: "estate",
    isNew: true,
  },
  "seoul-84-apartment-prices": {
    eyebrow: "부동산 비교",
    tags: [{ label: "서울", mod: "asset" }, { label: "84㎡", mod: "asset" }, { label: "부동산", mod: "asset" }],
    category: "estate",
    isNew: true,
  },
  "wedding-cost-2016-vs-2026": {
    eyebrow: "결혼 비용",
    tags: [{ label: "결혼", mod: "asset" }, { label: "10년 비교", mod: "asset" }, { label: "예산", mod: "asset" }],
    category: "life",
    isNew: true,
  },
  "salary-asset-2016-vs-2026": {
    eyebrow: "연봉·자산",
    tags: [{ label: "연봉", mod: "asset" }, { label: "자산", mod: "asset" }, { label: "10년 비교", mod: "asset" }],
    category: "asset",
    isNew: true,
  },
  "baby-cost-guide-first-year": {
    eyebrow: "육아 비용",
    tags: [{ label: "육아", mod: "salary" }, { label: "비용비교", mod: "salary" }, { label: "신생아~돌", mod: "salary" }],
    category: "life",
    isNew: true,
  },
  "baby-cost-2016-vs-2026": {
    eyebrow: "육아 10년비교",
    tags: [{ label: "육아", mod: "salary" }, { label: "10년 비교", mod: "salary" }, { label: "체감비용", mod: "salary" }],
    category: "life",
    isNew: true,
  },
  "lee-jaemyung-government-officials-assets-salary-2026": {
    eyebrow: "공개재산 비교",
    tags: [{ label: "공직자", mod: "asset" }, { label: "재산공개", mod: "asset" }, { label: "2026", mod: "asset" }],
    category: "asset",
    isNew: true,
  },
  "korea-rich-top10-assets": {
    eyebrow: "자산 비교",
    tags: [{ label: "KRW", mod: "asset" }, { label: "자산", mod: "asset" }],
    category: "asset",
    isNew: false,
  },
  "seoul-apartment-jeonse-report": {
    eyebrow: "서울 전세",
    tags: [{ label: "서울", mod: "asset" }, { label: "전세", mod: "asset" }, { label: "실수요", mod: "asset" }],
    category: "estate",
    isNew: true,
  },
  "us-rich-top10-patterns": {
    eyebrow: "미국 자산",
    tags: [{ label: "USD", mod: "asset" }, { label: "패턴 분석", mod: "asset" }],
    category: "asset",
    isNew: false,
  },
  "korean-movie-break-even-profit": {
    eyebrow: "영화 손익",
    tags: [{ label: "영화", mod: "salary" }, { label: "손익분기점", mod: "salary" }, { label: "2026신작", mod: "salary" }],
    category: "culture",
    isNew: true,
  },
  "semiconductor-etf-2026": {
    eyebrow: "반도체 ETF",
    tags: [{ label: "ETF", mod: "asset" }, { label: "반도체", mod: "asset" }, { label: "2026", mod: "asset" }],
    category: "asset",
    isNew: true,
  },
  "semiconductor-value-chain": {
    eyebrow: "산업 구조",
    tags: [{ label: "반도체", mod: "asset" }, { label: "밸류체인", mod: "asset" }, { label: "AI", mod: "asset" }],
    category: "asset",
    isNew: true,
  },
  "police-salary-2026": {
    eyebrow: "공무원 연봉",
    tags: [{ label: "경찰", mod: "salary" }, { label: "계급별", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "firefighter-salary-2026": {
    eyebrow: "공무원 연봉",
    tags: [{ label: "소방", mod: "salary" }, { label: "교대근무", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "nurse-salary-2026": {
    eyebrow: "직업 연봉",
    tags: [{ label: "간호사", mod: "salary" }, { label: "병원비교", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "teacher-salary-2026": {
    eyebrow: "교사 연봉",
    tags: [{ label: "교사", mod: "salary" }, { label: "호봉표", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "postpartum-center-cost-2026": {
    eyebrow: "출산 비용",
    tags: [{ label: "산후조리원", mod: "salary" }, { label: "비용비교", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "life",
    isNew: true,
  },
  "national-pension-generational-comparison-2026": {
    eyebrow: "국민연금",
    tags: [
      { label: "국민연금", mod: "asset" },
      { label: "연금개혁", mod: "asset" },
      { label: "2026", mod: "asset" },
    ],
    category: "asset",
    isNew: true,
  },
};

const reportEntries = reports
  .map((report) => {
    const meta = reportMetaBySlug[report.slug];
    if (!meta) return null;
    return {
      slug: report.slug,
      eyebrow: meta.eyebrow,
      title: report.title,
      desc: report.description,
      tags: meta.tags,
      category: meta.category,
      isNew: meta.isNew,
      order: report.order,
    };
  })
  .filter(Boolean)
  .sort((a, b) => a.order - b.order);

const salarySeries = reportEntries.filter((report) => report.category === "salary");
const estateSeries = reportEntries.filter((report) => report.category === "estate");
const lifeSeries = reportEntries.filter((report) => report.category === "life");
const assetSeries = reportEntries.filter((report) => report.category === "asset");
const cultureSeries = reportEntries.filter((report) => report.category === "culture");

const totalReports = reportEntries.length;
---

<BaseLayout
  title="비교 리포트 모음 | 비교계산소"
  description="직접 입력 없이 공개 데이터를 선택하고 비교해서 읽는 인터랙티브 리포트 모음입니다. 연봉, 자산, 부동산 데이터를 빠르게 비교할 수 있습니다."
  ogImage="/og/reports-index.png"
>
  <SiteHeader />

  <main class="container page-shell report-library-page">
    <CalculatorHero
      eyebrow="인터랙티브 리포트"
      title="숫자를 읽는 비교 리포트"
      description="직접 입력 없이 공개 데이터를 선택하고 비교해서 읽는 리포트 모음입니다. 연봉, 자산, 부동산 비교를 한 흐름에서 이어서 볼 수 있습니다."
    />

    <div class="reports-hero-stats">
      <div class="reports-hero-stat">
        <span class="reports-hero-stat__num">{totalReports}</span>
        <span class="reports-hero-stat__label">리포트</span>
      </div>
      <div class="reports-hero-stat">
        <span class="reports-hero-stat__num">5</span>
        <span class="reports-hero-stat__label">시리즈</span>
      </div>
      <div class="reports-hero-stat">
        <span class="reports-hero-stat__num">확장중</span>
        <span class="reports-hero-stat__label">업데이트</span>
      </div>
    </div>

    <div class="reports-filter-bar">
      <button class="reports-filter-chip is-active" data-filter="all">전체</button>
      <button class="reports-filter-chip" data-filter="salary">연봉</button>
      <button class="reports-filter-chip" data-filter="estate">부동산</button>
      <button class="reports-filter-chip" data-filter="asset">자산</button>
      <button class="reports-filter-chip" data-filter="life">생활</button>
      <button class="reports-filter-chip" data-filter="culture">문화·엔터</button>
      <button class="reports-filter-chip" data-filter="new">신규</button>
    </div>

    <a href={withBase("/reports/seoul-84-apartment-prices/")} class="reports-featured-card" data-category="estate" data-tag="new">
      <div class="reports-featured-card__top">
        <p class="reports-featured-card__eyebrow">부동산 리포트 · 신규</p>
        <h2 class="reports-featured-card__title">서울 국평 아파트 가격 비교<br />강남·서초·송파·마포·성동·강동</h2>
        <p class="reports-featured-card__desc">
          서울 6개 구 대단지 84㎡ 아파트를 최고가, 평균가, 연봉 대비 체감 기준으로 바로 비교하고 매매 자금 계산기로 이어집니다.
        </p>
        <div class="reports-featured-card__tags">
          <span class="reports-featured-tag reports-featured-tag--new">신규</span>
          <span class="reports-featured-tag">부동산</span>
          <span class="reports-featured-tag">84㎡</span>
          <span class="reports-featured-tag">체감 비교</span>
        </div>
      </div>
      <div class="reports-featured-card__bottom">
        <span class="reports-featured-card__meta">2026년 3월 업데이트</span>
        <span class="reports-featured-card__cta">리포트 보기 →</span>
      </div>
    </a>

    <section class="reports-series" data-series="salary">
      <h3 class="reports-series__label">연봉·초봉 시리즈</h3>
      <div class="reports-card-grid">
        {salarySeries.map((r) => (
          <a href={withBase(`/reports/${r.slug}/`)} class="report-card-item" data-category={r.category} data-tag={r.isNew ? "new" : ""}>
            <p class="rc-eyebrow">{r.eyebrow}</p>
            <p class="rc-title">{r.title}</p>
            <p class="rc-desc">{r.desc}</p>
            <div class="rc-footer">
              <div class="rc-tags">
                {r.tags.map((t) => (
                  <span class={`rc-tag rc-tag--${t.mod}`}>{t.label}</span>
                ))}
              </div>
              <span class="rc-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="reports-series" data-series="life">
      <h3 class="reports-series__label">생활·결혼 시리즈</h3>
      <div class="reports-card-grid">
        {lifeSeries.map((r) => (
          <a href={withBase(`/reports/${r.slug}/`)} class="report-card-item" data-category={r.category} data-tag={r.isNew ? "new" : ""}>
            <p class="rc-eyebrow">{r.eyebrow}</p>
            <p class="rc-title">{r.title}</p>
            <p class="rc-desc">{r.desc}</p>
            <div class="rc-footer">
              <div class="rc-tags">
                {r.tags.map((t) => (
                  <span class={`rc-tag rc-tag--${t.mod}`}>{t.label}</span>
                ))}
              </div>
              <span class="rc-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="reports-series" data-series="estate">
      <h3 class="reports-series__label">부동산 시리즈</h3>
      <div class="reports-card-grid">
        {estateSeries.map((r) => (
          <a href={withBase(`/reports/${r.slug}/`)} class="report-card-item" data-category={r.category} data-tag={r.isNew ? "new" : ""}>
            <p class="rc-eyebrow">{r.eyebrow}</p>
            <p class="rc-title">{r.title}</p>
            <p class="rc-desc">{r.desc}</p>
            <div class="rc-footer">
              <div class="rc-tags">
                {r.tags.map((t) => (
                  <span class={`rc-tag rc-tag--${t.mod}`}>{t.label}</span>
                ))}
              </div>
              <span class="rc-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="reports-series" data-series="asset">
      <h3 class="reports-series__label">자산·부자 시리즈</h3>
      <div class="reports-card-grid">
        {assetSeries.map((r) => (
          <a href={withBase(`/reports/${r.slug}/`)} class="report-card-item" data-category={r.category} data-tag={r.isNew ? "new" : ""}>
            <p class="rc-eyebrow">{r.eyebrow}</p>
            <p class="rc-title">{r.title}</p>
            <p class="rc-desc">{r.desc}</p>
            <div class="rc-footer">
              <div class="rc-tags">
                {r.tags.map((t) => (
                  <span class={`rc-tag rc-tag--${t.mod}`}>{t.label}</span>
                ))}
              </div>
              <span class="rc-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    {cultureSeries.length > 0 && (
      <section class="reports-series" data-series="culture">
        <h3 class="reports-series__label">문화·엔터 시리즈</h3>
        <div class="reports-card-grid">
          {cultureSeries.map((r) => (
            <a href={withBase(`/reports/${r.slug}/`)} class="report-card-item" data-category={r.category} data-tag={r.isNew ? "new" : ""}>
              <p class="rc-eyebrow">{r.eyebrow}</p>
              <p class="rc-title">{r.title}</p>
              <p class="rc-desc">{r.desc}</p>
              <div class="rc-footer">
                <div class="rc-tags">
                  {r.tags.map((t) => (
                    <span class={`rc-tag rc-tag--${t.mod}`}>{t.label}</span>
                  ))}
                </div>
                <span class="rc-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="reports-content-block">
      <div class="reports-content-block__lead">
        <p class="reports-content-block__eyebrow">리포트 안내</p>
        <h2 class="reports-content-block__title">비교계산소의 리포트는 숫자를 바로 읽게 만드는 비교 페이지입니다</h2>
        <p class="reports-content-block__desc">
          이 영역의 리포트는 사용자가 값을 직접 입력하는 계산기와 달리, 공개된 수치와 비교 지표를 한 번에 읽을 수 있도록 구성한 인터랙티브 콘텐츠입니다.
          연봉, 자산, 부동산처럼 해석이 필요한 데이터를 카드, 차트, 티어, 분포 구조로 정리해 다음 판단으로 이어지게 돕습니다.
        </p>
      </div>

      <div class="reports-content-grid">
        <article class="reports-content-card">
          <strong>어떻게 읽으면 되나요?</strong>
          <p>상단 요약 카드로 전체 판도를 먼저 보고, 중간의 차트와 티어 보드로 분포를 확인한 뒤, 하단의 상세 카드와 참고 링크까지 이어서 보는 흐름을 권장합니다.</p>
        </article>
        <article class="reports-content-card">
          <strong>계산기와 무엇이 다른가요?</strong>
          <p>계산기는 입력값을 넣고 결과를 바로 확인하는 도구이고, 리포트는 비교 대상 자체를 읽고 해석하는 페이지입니다. 필요하면 리포트에서 계산기로 바로 이어질 수 있습니다.</p>
        </article>
        <article class="reports-content-card">
          <strong>수치는 어디까지 믿어야 하나요?</strong>
          <p>리포트의 수치와 해석은 공개 자료를 기준으로 정리한 참고용 정보입니다. 실제 의사결정 전에는 사업보고서, 공식 공고, 원출처 데이터를 다시 확인하는 것이 안전합니다.</p>
        </article>
      </div>
    </section>

    <div class="reports-coming">
      <h3 class="reports-coming__title">다음으로 확장할 리포트</h3>
      <div class="reports-coming__grid">
        <div class="reports-coming__card">
          <p class="reports-coming__cat">부동산</p>
          <p class="reports-coming__name">서울 전세·월세 10년 비교 확장판</p>
          <span class="reports-coming__badge">준비 중</span>
        </div>
        <div class="reports-coming__card">
          <p class="reports-coming__cat">연봉</p>
          <p class="reports-coming__name">대기업 연차별 연봉 성장 비교</p>
          <span class="reports-coming__badge">준비 중</span>
        </div>
        <div class="reports-coming__card">
          <p class="reports-coming__cat">자산</p>
          <p class="reports-coming__name">서울 국평 환산 자산 리포트 확장판</p>
          <span class="reports-coming__badge">준비 중</span>
        </div>
      </div>
    </div>

    <div class="tl-notice">
      리포트의 수치와 해석은 공개 자료를 기준으로 정리한 참고용 정보입니다. 실제 의사결정 전에는 원출처 데이터를 다시 확인해 주세요.
    </div>
  </main>
</BaseLayout>

<script>
  document.querySelectorAll('.reports-filter-chip').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.reports-filter-chip').forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      const filter = btn.dataset.filter;

      const featured = document.querySelector('.reports-featured-card');
      if (featured) {
        if (filter === 'all' || featured.dataset.category === filter || featured.dataset.tag === filter) {
          featured.style.display = '';
        } else {
          featured.style.display = 'none';
        }
      }

      document.querySelectorAll('.reports-series').forEach((series) => {
        let hasVisible = false;
        series.querySelectorAll('.report-card-item').forEach((card) => {
          const show = filter === 'all' || card.dataset.category === filter || card.dataset.tag === filter;
          card.style.display = show ? '' : 'none';
          if (show) hasVisible = true;
        });
        series.style.display = hasVisible ? '' : 'none';
      });
    });
  });
</script>
























