    category: "asset",
    isNew: true,
  },
  "police-salary-2026": {
    eyebrow: "공무원 연봉",
    tags: [{ label: "경찰", mod: "salary" }, { label: "계급별", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "firefighter-salary-2026": {
    eyebrow: "공무원 연봉",
    tags: [{ label: "소방", mod: "salary" }, { label: "교대근무", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "nurse-salary-2026": {
    eyebrow: "직업 연봉",
    tags: [{ label: "간호사", mod: "salary" }, { label: "병원비교", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "teacher-salary-2026": {
    eyebrow: "교사 연봉",
    tags: [{ label: "교사", mod: "salary" }, { label: "호봉표", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "salary",
    isNew: true,
  },
  "postpartum-center-cost-2026": {
    eyebrow: "출산 비용",
    tags: [{ label: "산후조리원", mod: "salary" }, { label: "비용비교", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "life",
    isNew: true,
  },
  "fetal-insurance-guide-2026": {
    eyebrow: "출산 가이드",
    tags: [{ label: "태아보험", mod: "salary" }, { label: "가입시기", mod: "salary" }, { label: "2026", mod: "salary" }],
    category: "life",
    isNew: true,
  },
  "national-pension-generational-comparison-2026": {
    eyebrow: "국민연금",
    tags: [
      { label: "국민연금", mod: "asset" },
      { label: "연금개혁", mod: "asset" },
      { label: "2026", mod: "asset" },
    ],
    category: "asset",
    isNew: true,
  },
  "pension-irp-comparison-2026": {
    eyebrow: "연금 비교",
    tags: [
      { label: "연금저축", mod: "asset" },
      { label: "IRP", mod: "asset" },
      { label: "2026", mod: "asset" },
    ],
    category: "asset",
    isNew: true,
  },
  "bitcoin-gold-sp500-10year-comparison-2026": {
    eyebrow: "투자 비교",
    tags: [
      { label: "비트코인", mod: "asset" },
      { label: "금", mod: "asset" },
      { label: "S&P500", mod: "asset" },
    ],
    category: "asset",
    isNew: true,
  },
};

const reportEntries = reports
  .map((report) => {
    const meta = reportMetaBySlug[report.slug];
    if (!meta) return null;
    return {
      slug: report.slug,
      eyebrow: meta.eyebrow,
      title: report.title,
      desc: report.description,
      tags: meta.tags,
      category: meta.category,
      isNew: meta.isNew,
      order: report.order,
    };
  })
  .filter(Boolean)
  .sort((a, b) => a.order - b.order);

const salarySeries = reportEntries.filter((report) => report.category === "salary");
const estateSeries = reportEntries.filter((report) => report.category === "estate");
const lifeSeries = reportEntries.filter((report) => report.category === "life");
const assetSeries = reportEntries.filter((report) => report.category === "asset");
const cultureSeries = reportEntries.filter((report) => report.category === "culture");

const totalReports = reportEntries.length;

const recommendedReports = [
  {
    slug: "new-employee-salary-2026",
    reason: "취업과 이직을 앞두고 시장 초봉 감각을 빠르게 잡기 좋습니다.",
  },
  {
    slug: "seoul-housing-2016-vs-2026",
    reason: "서울 주거비 체감이 왜 달라졌는지 큰 흐름부터 이해하기 좋습니다.",
  },
  {
    slug: "postpartum-center-cost-2026",
    reason: "출산 준비 과정에서 실제 예산 판단에 바로 연결되는 주제입니다.",
  },
  {
    slug: "national-pension-generational-comparison-2026",
    reason: "연금개혁과 세대별 손익 구조를 한 번에 읽기 좋습니다.",
  },
  {
    slug: "overseas-travel-cost-compare-2026",
    reason: "항공권, 숙소, 식비를 같이 비교해 여행 예산 감을 잡기 쉽습니다.",
  },
].map((item) => {
  const report = reportEntries.find((entry) => entry.slug === item.slug);
  return report ? { ...report, reason: item.reason } : null;
}).filter(Boolean);

const seriesIntroductions: Record<ReportCategory, string> = {
  salary: "입사, 이직, 직무 선택처럼 보상 판단이 필요한 순간에 먼저 보는 시리즈입니다.",
  estate: "집값, 전세, 체감 주거비처럼 실수요 판단에 직접 연결되는 시리즈입니다.",
  asset: "자산 격차, 연금, ETF, 투자 수익처럼 장기 판단 기준을 잡을 때 읽기 좋습니다.",
  life: "결혼, 출산, 육아, 여행처럼 생활비와 선택 기준이 함께 필요한 주제를 모았습니다.",
  culture: "흥행, 손익, 산업 구조처럼 숫자를 읽는 재미가 있는 비교형 리포트입니다.",
};

const reportToToolBridges = [
  {
    title: "리포트를 읽고 내 상황까지 계산하고 싶다면",
    desc: "공개 데이터로 시장 감각을 잡은 뒤 내 입력값으로 다시 계산하면 의사결정이 더 빨라집니다.",
    links: [
      { href: "/tools/home-purchase-fund/", label: "집 마련 자금 계산기" },
      { href: "/tools/national-pension-calculator/", label: "국민연금 계산기" },
      { href: "/tools/overseas-travel-cost/", label: "해외여행 비용 계산기" },
    ],
  },
];
---

<BaseLayout
  title="비교 리포트 모음 | 비교계산소"
  description="직접 입력 없이 공개 데이터를 선택하고 비교해서 읽는 인터랙티브 리포트 모음입니다. 연봉, 자산, 부동산 데이터를 빠르게 비교할 수 있습니다."
  ogImage="/og/reports-index.png"
>
  <SiteHeader />

  <main class="container page-shell report-library-page">
    <CalculatorHero
      eyebrow="인터랙티브 리포트"
      title="숫자를 읽는 비교 리포트"
      description="직접 입력 없이 공개 데이터를 선택하고 비교해서 읽는 리포트 모음입니다. 연봉, 자산, 부동산 비교를 한 흐름에서 이어서 볼 수 있습니다."
    />

    <div class="reports-hero-stats">
      <div class="reports-hero-stat">
        <span class="reports-hero-stat__num">{totalReports}</span>
        <span class="reports-hero-stat__label">리포트</span>
      </div>
      <div class="reports-hero-stat">
        <span class="reports-hero-stat__num">5</span>
        <span class="reports-hero-stat__label">시리즈</span>
      </div>
      <div class="reports-hero-stat">
        <span class="reports-hero-stat__num">확장중</span>
        <span class="reports-hero-stat__label">업데이트</span>
      </div>
    </div>

    <section class="reports-intro">
      <div class="reports-intro__lead">
        <p class="reports-intro__eyebrow">리포트 소개</p>
        <h2 class="reports-intro__title">비교 리포트는 숫자의 맥락을 먼저 읽게 만드는 페이지입니다</h2>
        <div class="reports-intro__copy">
          <p>비교계산소의 리포트는 단순 기사형 요약이 아니라, 공개 데이터를 기준으로 여러 선택지를 같은 기준에서 읽을 수 있게 만든 비교형 콘텐츠입니다. 숫자 자체보다도 무엇을 비교해야 하는지, 어떤 차이가 실제 판단에 영향을 주는지 이해하도록 돕는 데 초점을 맞춥니다.</p>
          <p>계산기가 개인 입력값으로 내 상황을 보는 도구라면, 리포트는 시장과 제도, 가격 흐름을 먼저 읽는 도구에 가깝습니다. 둘을 같이 보면 숫자의 맥락과 내 선택 기준을 훨씬 빨리 잡을 수 있습니다.</p>
        </div>
      </div>
      <div class="reports-intro__panel">
        <article class="reports-intro-card">
          <span class="reports-intro-card__label">리포트가 하는 일</span>
          <strong class="reports-intro-card__title">숫자를 해석 가능한 기준으로 바꾸기</strong>
          <p class="reports-intro-card__desc">같은 데이터라도 무엇을 먼저 봐야 하는지 정리해 주면 실제 의사결정 속도가 훨씬 빨라집니다.</p>
        </article>
        <article class="reports-intro-card reports-intro-card--accent">
          <span class="reports-intro-card__label">가장 좋은 활용법</span>
          <strong class="reports-intro-card__title">리포트로 맥락을 읽고 계산기로 내 상황 확인</strong>
          <p class="reports-intro-card__desc">시장 흐름과 공개 데이터를 먼저 이해한 뒤 개인 입력값으로 다시 계산하면 훨씬 실전적인 판단이 가능합니다.</p>
        </article>
      </div>
    </section>

    <div class="reports-filter-bar">
      <button class="reports-filter-chip is-active" data-filter="all">전체</button>
      <button class="reports-filter-chip" data-filter="salary">연봉</button>
      <button class="reports-filter-chip" data-filter="estate">부동산</button>
      <button class="reports-filter-chip" data-filter="asset">자산</button>
      <button class="reports-filter-chip" data-filter="life">생활</button>
      <button class="reports-filter-chip" data-filter="culture">문화·엔터</button>
      <button class="reports-filter-chip" data-filter="new">신규</button>
    </div>

    <a href={withBase("/reports/seoul-84-apartment-prices/")} class="reports-featured-card" data-category="estate" data-tag="new">
      <div class="reports-featured-card__top">
        <p class="reports-featured-card__eyebrow">부동산 리포트 · 신규</p>
        <h2 class="reports-featured-card__title">서울 국평 아파트 가격 비교<br />강남·서초·송파·마포·성동·강동</h2>
        <p class="reports-featured-card__desc">
          서울 6개 구 대단지 84㎡ 아파트를 최고가, 평균가, 연봉 대비 체감 기준으로 바로 비교하고 집 마련 자금 계산기로 이어집니다.
        </p>
        <div class="reports-featured-card__tags">
          <span class="reports-featured-tag reports-featured-tag--new">신규</span>
          <span class="reports-featured-tag">부동산</span>
          <span class="reports-featured-tag">84㎡</span>
          <span class="reports-featured-tag">체감 비교</span>
        </div>
      </div>
      <div class="reports-featured-card__bottom">
        <span class="reports-featured-card__meta">2026년 3월 업데이트</span>
        <span class="reports-featured-card__cta">리포트 보기 →</span>
      </div>
    </a>

    <section class="reports-picks">
      <div class="reports-section-head">
        <div>
          <p class="reports-section-head__eyebrow">입문용 추천</p>
          <h2>처음이라면 이 리포트부터 보세요</h2>
        </div>
        <p class="reports-section-head__summary">지금 바로 실생활 판단에 도움이 되는 주제부터 먼저 읽는 것을 권장합니다.</p>
      </div>

      <div class="reports-picks__grid">
        {recommendedReports.map((report) => (
          <a href={withBase(`/reports/${report.slug}/`)} class="reports-pick-card">
            <p class="reports-pick-card__eyebrow">{report.eyebrow}</p>
            <strong>{report.title}</strong>
            <p>{report.reason}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="reports-series" data-series="salary">
      <div class="reports-series__head">
        <h3 class="reports-series__label">연봉·초봉 시리즈</h3>
        <p class="reports-series__desc">{seriesIntroductions.salary}</p>
      </div>
      <div class="reports-card-grid">
        {salarySeries.map((r) => (
          <a href={withBase(`/reports/${r.slug}/`)} class="report-card-item" data-category={r.category} data-tag={r.isNew ? "new" : ""}>
