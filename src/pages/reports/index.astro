const reportEntries = reports
  .map((report) => {
    const meta = reportMetaBySlug[report.slug];
    if (!meta) return null;
    return {
      slug: report.slug,
      eyebrow: meta.eyebrow,
      title: report.title,
      desc: report.description,
      tags: meta.tags,
      category: meta.category,
      isNew: meta.isNew,
      order: report.order,
    };
  })
  .filter(Boolean)
  .sort((a, b) => a.order - b.order);

const salarySeries = reportEntries.filter((report) => report.category === "salary");
const bonusSeries = reportEntries.filter((report) => report.category === "bonus");
