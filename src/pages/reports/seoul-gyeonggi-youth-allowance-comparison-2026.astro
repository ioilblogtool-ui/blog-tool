---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  SGYA_META,
  SGYA_PROGRAMS,
  SGYA_SUMMARY_CARDS,
  SGYA_COMPARISON_ROWS,
  SGYA_SCENARIOS,
  SGYA_MIGRATION_POINTS,
  SGYA_SOURCE_LINKS,
  SGYA_FAQ,
  SGYA_SEO_INTRO,
  SGYA_SEO_CRITERIA,
  SGYA_RELATED_LINKS,
} from "../../data/seoulGyeonggiYouthAllowanceComparison2026";

const faqItems = SGYA_FAQ.map((item) => ({ question: item.q, answer: item.a }));
const related = SGYA_RELATED_LINKS.map((item) => ({ href: item.href, label: item.label }));

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteUrl}/reports/seoul-gyeonggi-youth-allowance-comparison-2026/`;

const badgeClass = (badge: string) =>
  badge === "공식" ? "official" : badge === "확인 필요" ? "check" : "ref";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": `${pageUrl}#article`,
      url: pageUrl,
      name: SGYA_META.seoTitle,
      description: SGYA_META.seoDescription,
      inLanguage: "ko-KR",
      datePublished: SGYA_META.updatedAt,
      dateModified: SGYA_META.updatedAt,
    },
    {
      "@type": "FAQPage",
      "@id": `${pageUrl}#faq`,
      mainEntity: SGYA_FAQ.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.a,
        },
      })),
    },
  ],
};
---

<BaseLayout
  title={SGYA_META.seoTitle}
  description={SGYA_META.seoDescription}
  jsonLd={jsonLd}
>
  <SiteHeader />

  <main class="container page-shell report-page sgya-page">
    <CalculatorHero
      eyebrow="청년지원금 지역 비교"
      title="서울 vs 경기 청년수당 비교 2026"
      description="서울 청년수당과 경기도 청년기본소득을 나이·거주·소득·취업상태·지급방식 기준으로 비교합니다. 검색어로 쓰이는 경기 청년수당과 공식 제도명의 차이도 함께 정리했습니다."
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        `${SGYA_META.dataSourceLabel} 기준으로 대표 구조를 정리했습니다. 기준일: ${SGYA_META.updatedAt}`,
        SGYA_META.notice,
      ]}
    />

    <section class="content-section sgya-section" aria-labelledby="sgya-summary-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">빠른 결론</p>
        <h2 id="sgya-summary-title">같은 청년지원금처럼 보여도 대상자가 다릅니다</h2>
        <p>서울은 구직활동 지원, 경기는 만 24세 기본소득으로 보는 것이 가장 안전합니다.</p>
      </div>

      <div class="sgya-summary-grid">
        {SGYA_SUMMARY_CARDS.map((card) => (
          <article class="sgya-summary-card">
            <span class={`sgya-badge sgya-badge--${badgeClass(card.badge)}`}>{card.badge}</span>
            <p class="sgya-summary-card__label">{card.label}</p>
            <strong class="sgya-summary-card__value">{card.value}</strong>
            <p class="sgya-summary-card__note">{card.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section sgya-section" aria-labelledby="sgya-program-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">제도 카드</p>
        <h2 id="sgya-program-title">서울 청년수당과 경기도 청년기본소득 핵심 구조</h2>
      </div>

      <div class="sgya-program-grid">
        {SGYA_PROGRAMS.map((program) => (
          <article class={`sgya-program-card sgya-program-card--${program.tone}`}>
            <div class="sgya-program-card__head">
              <span class="sgya-program-card__region">{program.region}</span>
              <span class={`sgya-badge sgya-badge--${badgeClass(program.badge)}`}>{program.badge}</span>
            </div>
            <h3>{program.officialName}</h3>
            <p class="sgya-program-card__search">검색어: {program.searchName}</p>
            <p class="sgya-program-card__desc">{program.oneLine}</p>
            <dl class="sgya-program-card__list">
              <div>
                <dt>대상 핵심</dt>
                <dd>{program.targetCore}</dd>
              </div>
              <div>
                <dt>지원 금액</dt>
                <dd>{program.amountLabel}</dd>
              </div>
              <div>
                <dt>지급 방식</dt>
                <dd>{program.paymentMethod}</dd>
              </div>
              <div>
                <dt>먼저 볼 것</dt>
                <dd>{program.firstCheck}</dd>
              </div>
            </dl>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section sgya-section" aria-labelledby="sgya-table-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">비교표</p>
        <h2 id="sgya-table-title">조건별 차이 한눈에 보기</h2>
        <p>나이·거주·소득·취업 상태가 실제 신청 가능성을 가르는 핵심 항목입니다.</p>
      </div>

      <div class="sgya-table-wrap">
        <table class="sgya-compare-table">
          <thead>
            <tr>
              <th>항목</th>
              <th>서울 청년수당</th>
              <th>경기도 청년기본소득</th>
              <th>읽는 법</th>
            </tr>
          </thead>
          <tbody>
            {SGYA_COMPARISON_ROWS.map((row) => (
              <tr>
                <th scope="row">
                  {row.item}
                  <span class={`sgya-badge sgya-badge--${badgeClass(row.badge)}`}>{row.badge}</span>
                </th>
                <td>{row.seoul}</td>
                <td>{row.gyeonggi}</td>
                <td>{row.takeaway}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section sgya-section" aria-labelledby="sgya-scenario-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">대상자 예시</p>
        <h2 id="sgya-scenario-title">내 상황이라면 무엇부터 확인할까</h2>
      </div>

      <div class="sgya-scenario-grid">
        {SGYA_SCENARIOS.map((scenario) => (
          <article class="sgya-scenario-card">
            <p class="sgya-scenario-card__person">{scenario.person}</p>
            <h3>{scenario.title}</h3>
            <strong>{scenario.likelyProgram}</strong>
            <p>{scenario.reason}</p>
            <span>{scenario.caution}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section sgya-section sgya-migration" aria-labelledby="sgya-migration-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">서울↔경기 이동</p>
        <h2 id="sgya-migration-title">이사 전후에는 기준일을 먼저 보세요</h2>
        <p>주소지가 바뀌면 같은 청년이라도 확인해야 할 제도가 달라집니다.</p>
      </div>

      <div class="sgya-step-list">
        {SGYA_MIGRATION_POINTS.map((point, index) => (
          <article class="sgya-step-card">
            <span class="sgya-step-card__num">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3>{point.title}</h3>
              <p>{point.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section sgya-section" aria-labelledby="sgya-sources-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">공식 확인</p>
        <h2 id="sgya-sources-title">신청 전 마지막으로 볼 공식 경로</h2>
        <p>모집기간, 생년월일 범위, 제외 대상, 제출서류는 공식 공고가 최종 기준입니다.</p>
      </div>

      <div class="sgya-source-grid">
        {SGYA_SOURCE_LINKS.map((source) => (
          <a
            class="sgya-source-card"
            href={source.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span>{source.type}</span>
            <strong>{source.label}</strong>
            <em>공식 사이트에서 확인</em>
          </a>
        ))}
      </div>
    </section>

    <section class="content-section sgya-section" aria-labelledby="sgya-faq-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">FAQ</p>
        <h2 id="sgya-faq-title">자주 묻는 질문</h2>
      </div>

      <div class="sgya-faq-list">
        {SGYA_FAQ.map((item) => (
          <details class="sgya-faq-item">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="content-section sgya-section" aria-labelledby="sgya-related-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">함께 보기</p>
        <h2 id="sgya-related-title">청년 지원금과 저축 상품을 같이 비교하세요</h2>
      </div>

      <div class="sgya-related-grid">
        {SGYA_RELATED_LINKS.map((link) => (
          <a class="sgya-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <span>바로 보기</span>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="서울 vs 경기 청년수당 비교 리포트 읽는 법"
      intro={SGYA_SEO_INTRO}
      criteria={SGYA_SEO_CRITERIA}
      faq={faqItems}
      related={related}
    />
  </main>
</BaseLayout>
