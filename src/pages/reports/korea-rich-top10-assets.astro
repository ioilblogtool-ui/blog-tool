---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  koreaRichTop10Seed,
  koreaCurrentTop10HistorySeed,
  usdBillionToKrw,
  krwToSeoul84Count,
  krwToGrandeurCount,
  formatKrwLarge,
  formatUsdB
} from "../../data/koreaRichTop10Current";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const selectedEntry = koreaRichTop10Seed.entries[0];
const defaults = koreaRichTop10Seed.conversionDefaults;
const overviewEntries = koreaRichTop10Seed.entries.map((entry) => ({
  ...entry,
  krwValue: usdBillionToKrw(entry.netWorthUsdB, defaults.usdKrwRate)
}));
const totalKrwValue = overviewEntries.reduce((sum, entry) => sum + entry.krwValue, 0);
const topThreeShare = Math.round(
  (overviewEntries.slice(0, 3).reduce((sum, entry) => sum + entry.krwValue, 0) / totalKrwValue) * 100
);
const wealthTypeCounts = koreaRichTop10Seed.entries.reduce(
  (acc, entry) => {
    acc[entry.wealthType] += 1;
    return acc;
  },
  { inherited: 0, "self-made": 0, mixed: 0 }
);
const selectedKrwValue = usdBillionToKrw(selectedEntry.netWorthUsdB, defaults.usdKrwRate);
const faqItems = koreaRichTop10Seed.faq.map((item) => ({ question: item.q, answer: item.a }));
const cautionNotes = [
  koreaRichTop10Seed.meta.methodology,
  koreaRichTop10Seed.meta.caution
];
const distributionGroups = [
  {
    title: "업종 분포",
    summary: "재벌·전자, 금융, 바이오·제약, 자동차가 함께 섞여 있는 한국형 상위 부자 구성을 보여줍니다.",
    items: koreaRichTop10Seed.sectorSummaries.map((item) => ({ label: item.label, body: item.description }))
  },
  {
    title: "부의 형성 방식",
    summary: "상속형 6명과 자수성가형 4명이 함께 상위권을 구성하는 점이 핵심입니다.",
    items: koreaRichTop10Seed.wealthTypeSummaries.map((item) => ({ label: item.label, body: item.description }))
  }
];

const yoy = koreaRichTop10Seed.yearOverYear;
const topEntry = overviewEntries[0];
const topGainUsdB = topEntry.prevNetWorthUsdB != null ? topEntry.netWorthUsdB - topEntry.prevNetWorthUsdB : null;
const topGainPercent =
  topEntry.prevNetWorthUsdB != null && topEntry.prevNetWorthUsdB > 0 && topGainUsdB != null
    ? Math.round((topGainUsdB / topEntry.prevNetWorthUsdB) * 100)
    : null;
const rankStatusLabel: Record<string, string> = {
  up: "상승",
  down: "하락",
  same: "유지",
  new: "신규 진입"
};
---

<BaseLayout title={koreaRichTop10Seed.meta.title} description={koreaRichTop10Seed.meta.subtitle}>
  <SiteHeader />

  <SimpleToolShell calculatorId="korea-rich-top10-assets" pageClass="us-rich-report-page korea-rich-report-page">
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="Interactive Report"
        title={koreaRichTop10Seed.meta.title}
        description={koreaRichTop10Seed.meta.subtitle}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetKoreaRichProfileBtn" copyId="copyKoreaRichProfileLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel usr-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">선택 패널</p>
            <h2 class="panel__title">인물 선택</h2>
          </div>
          <p class="panel-heading__summary">인물과 환산 기준을 같이 조정하면 본문 카드와 차트가 함께 바뀝니다.</p>
        </div>

        <label class="field usr-field">
          <span>한 명씩 자세히 보기</span>
          <select id="koreaRichProfileSelect">
            {
              koreaRichTop10Seed.entries.map((entry) => (
                <option value={entry.slug} selected={entry.slug === selectedEntry.slug}>
                  {entry.rank}위 · {entry.name}
                </option>
              ))
            }
          </select>
        </label>

        <div class="kr-config-grid">
          <label class="field">
            <span>환율</span>
            <input id="usdKrwRateInput" type="number" min="1000" step="10" value={defaults.usdKrwRate} />
          </label>
          <label class="field">
            <span>서울 국평 가격</span>
            <input id="seoul84PriceInput" type="number" min="100000000" step="10000000" value={defaults.seoul84PriceKrw} />
          </label>
          <label class="field">
            <span>그랜저 가격</span>
            <input id="grandeurPriceInput" type="number" min="10000000" step="1000000" value={defaults.grandeurPriceKrw} />
          </label>
        </div>
      </article>

      <article class="panel usr-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">TOP 10</p>
            <h2 class="panel__title">빠른 비교 카드</h2>
          </div>
          <p class="panel-heading__summary">왼쪽 카드에서 바로 선택하고, 우측 상세 카드와 차트를 이어서 읽을 수 있습니다.</p>
        </div>

        <div class="usr-overview-list">
          {
            koreaRichTop10Seed.entries.map((entry) => (
              <article class="usr-overview-card" data-profile-trigger={entry.slug} tabindex="0" role="button" aria-label={`${entry.name} 상세 보기`}>
                <p>{entry.rank}위</p>
                <strong>{entry.name}</strong>
                <span>{formatUsdB(entry.netWorthUsdB)}</span>
                <em>{entry.sector}</em>
              </article>
            ))
          }
        </div>
      </article>

      <InfoNotice title="기준 안내" lines={cautionNotes} />
    </Fragment>

    <section class="usr-section">
      <div class="usr-section__head">
        <p class="usr-section__eyebrow">핵심 수치</p>
        <h2>한국 부자 TOP 10에서 먼저 읽을 숫자</h2>
        <p class="usr-section__sub">원화 환산 총량, 상위 집중도, 상속형과 자수성가형 비중을 먼저 보여줍니다.</p>
      </div>
      <div class="usr-kpi-grid">
        <article class="usr-kpi-card usr-kpi-card--primary">
          <p>현재 1위 자산</p>
          <strong>{formatKrwLarge(overviewEntries[0].krwValue)}</strong>
          <span>{overviewEntries[0].name} · {formatUsdB(overviewEntries[0].netWorthUsdB)}</span>
        </article>
        <article class="usr-kpi-card">
          <p>TOP 10 합산 자산</p>
          <strong>{formatKrwLarge(totalKrwValue)}</strong>
          <span>환율 {defaults.usdKrwRate.toLocaleString("ko-KR")}원 기준</span>
        </article>
        <article class="usr-kpi-card">
          <p>자수성가형</p>
          <strong>{wealthTypeCounts["self-made"]}명</strong>
          <span>금융·바이오·제약 중심</span>
        </article>
        <article class="usr-kpi-card usr-kpi-card--soft">
          <p>상위 3명 집중도</p>
          <strong>{topThreeShare}%</strong>
          <span>TOP 10 합산 자산 대비</span>
        </article>
      </div>
    </section>

    <section class="usr-section">
      <div class="usr-section__head">
        <p class="usr-section__eyebrow">선택 결과</p>
        <h2>선택 인물 상세 카드</h2>
        <p class="usr-section__sub">원화 환산 자산과 체감 환산, 업종, 부의 원천, 태그를 한 카드에 정리했습니다.</p>
      </div>

      <article class="panel usr-profile-card kr-profile-card">
        <div class="usr-profile-card__hero">
          <div class="usr-profile-card__header">
            <div>
              <p class="panel-heading__eyebrow">선택 인물</p>
              <h2 id="koreaProfileName">{selectedEntry.name}</h2>
              <p class="kr-profile-card__sub" id="koreaProfileNameEn">{selectedEntry.nameEn}</p>
            </div>
            <div class="usr-rank-chip" id="koreaProfileRank">{selectedEntry.rank}위</div>
          </div>
        </div>

        <div class="usr-profile-card__summary">
          <article class="usr-kpi-card usr-kpi-card--primary usr-kpi-card--wide">
            <p>원화 환산 자산</p>
            <strong id="koreaProfileKrwValue">{formatKrwLarge(selectedKrwValue)}</strong>
            <span id="koreaProfileUsdValue">{formatUsdB(selectedEntry.netWorthUsdB)}</span>
          </article>
          <article class="usr-kpi-card">
            <p>서울 국평 환산</p>
            <strong id="koreaProfileSeoulCount">약 {Math.round(krwToSeoul84Count(selectedKrwValue, defaults.seoul84PriceKrw)).toLocaleString("ko-KR")}채</strong>
            <span>체감 비교용 참고값</span>
          </article>
          <article class="usr-kpi-card">
            <p>그랜저 환산</p>
            <strong id="koreaProfileGrandeurCount">약 {Math.round(krwToGrandeurCount(selectedKrwValue, defaults.grandeurPriceKrw)).toLocaleString("ko-KR")}대</strong>
            <span>체감 비교용 참고값</span>
          </article>
        </div>

        <div class="usr-profile-card__detail">
          <div class="usr-detail-list">
            <div class="usr-detail-row">
              <span>부의 원천</span>
              <strong id="koreaProfileSource">{selectedEntry.sourceOfWealth}</strong>
            </div>
            <div class="usr-detail-row">
              <span>업종</span>
              <strong id="koreaProfileSector">{selectedEntry.sector}</strong>
            </div>
            <div class="usr-detail-row">
              <span>유형</span>
              <strong id="koreaProfileWealthType">{selectedEntry.wealthType}</strong>
            </div>
          </div>

          <div class="usr-profile-card__aside">
            <div class="usr-tag-block">
              <span class="usr-tag-block__label">태그</span>
              <div class="usr-tag-list" id="koreaProfileTags">
                {selectedEntry.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
          </div>
        </div>

        <div class="usr-profile-card__footer">
          <p id="koreaProfileSummary">{selectedEntry.summary}</p>
        </div>
      </article>
    </section>

    <section class="usr-section">
      <div class="usr-section__head">
        <p class="usr-section__eyebrow">자산 차트</p>
        <h2>순위별 자산 규모 비교</h2>
        <p class="usr-section__sub">상위권 자산 집중도를 가로 바 차트로 먼저 읽고, 색상으로 부의 형성 유형을 구분합니다.</p>
      </div>
      <article class="panel usr-chart-panel">
        <div class="usr-chart-wrap kr-chart-wrap--overview" id="koreaTop10Overview">
          <canvas id="koreaOverviewCanvas"></canvas>
        </div>
        <div class="kr-chart-legend">
          <span class="is-self-made">자수성가형</span>
          <span class="is-inherited">상속형</span>
          <span class="is-mixed">혼합형</span>
        </div>
        <div class="usr-chart-insights">
          {
            koreaRichTop10Seed.interpretationPoints.slice(0, 2).map((item) => (
              <div class="usr-chart-insight">
                <strong>{item.title}</strong>
                <p>{item.body}</p>
              </div>
            ))
          }
        </div>
      </article>
    </section>

    <section class="usr-section">
      <div class="usr-section__head">
        <p class="usr-section__eyebrow">2025 → 2026 변화</p>
        <h2>TOP 10 자산은 1년 사이 얼마나 늘었을까</h2>
        <p class="usr-section__sub">Forbes가 2026년 4월 발표한 Korea's 50 Richest 순위를 2025년 발표본과 비교했습니다.</p>
      </div>
      <div class="usr-kpi-grid">
        <article class="usr-kpi-card usr-kpi-card--primary">
          <p>2026년 한국 1위</p>
          <strong>{topEntry.name} · {formatUsdB(topEntry.netWorthUsdB)}</strong>
          <span>
            {topGainUsdB != null ? `전년 대비 +${formatUsdB(topGainUsdB)}` : "-"}
            {topGainPercent != null ? ` (+${topGainPercent}%)` : ""}
          </span>
        </article>
        <article class="usr-kpi-card">
          <p>상위 50명 합산 자산</p>
          <strong>{`$${yoy.totalTop50UsdB}B`}</strong>
          <span>전년 {`$${yoy.totalTop50PrevUsdB}B`} 대비 +{yoy.totalTop50ChangePercent}%</span>
        </article>
        <article class="usr-kpi-card">
          <p>50위 진입 최소 자산</p>
          <strong>{formatUsdB(yoy.minEntryUsdB)}</strong>
          <span>사상 처음 10억 달러 돌파</span>
        </article>
        <article class="usr-kpi-card usr-kpi-card--soft">
          <p>TOP 10 신규 진입</p>
          <strong>{yoy.newEntrantNames.length}명</strong>
          <span>{yoy.newEntrantNames.join(", ")}</span>
        </article>
      </div>

      <article class="panel kr-yoy-panel">
        <div class="kr-yoy-table-wrap">
          <table class="kr-yoy-table">
            <thead>
              <tr>
                <th>2026 순위</th>
                <th>이름</th>
                <th>2026 자산</th>
                <th>2025 자산</th>
                <th>변동</th>
              </tr>
            </thead>
            <tbody>
              {
                overviewEntries.map((entry) => {
                  const gain = entry.prevNetWorthUsdB != null ? entry.netWorthUsdB - entry.prevNetWorthUsdB : null;
                  return (
                    <tr>
                      <td>{entry.rank}위</td>
                      <td>{entry.name}</td>
                      <td>{formatUsdB(entry.netWorthUsdB)}</td>
                      <td>{entry.prevNetWorthUsdB != null ? formatUsdB(entry.prevNetWorthUsdB) : "TOP10 밖"}</td>
                      <td class={`kr-yoy-change is-${entry.rankStatus}`}>
                        {entry.rankStatus === "new"
                          ? "신규 진입"
                          : `${rankStatusLabel[entry.rankStatus]} (${entry.prevRank}위→${entry.rank}위)`}
                        {gain != null ? ` · ${gain >= 0 ? "+" : ""}${formatUsdB(gain)}` : ""}
                      </td>
                    </tr>
                  );
                })
              }
            </tbody>
          </table>
        </div>
        <p class="kr-yoy-note">2025년 TOP10이었던 쿠팡 김범석, 카카오 김범수는 2026년 TOP10 밖으로 밀려났습니다.</p>
      </article>
    </section>

    <section class="usr-section">
      <div class="usr-section__head">
        <p class="usr-section__eyebrow">연도별 자산 변화</p>
        <h2>선택 인물의 Forbes 발표 자산 추이</h2>
        <p class="usr-section__sub">2016년부터 2026년까지 각 연도 Forbes 발표 시점의 추정 자산입니다. 연속된 시계열이 아니라 연간 평가 결과이므로 참고용으로 확인해주세요.</p>
      </div>
      <article class="panel usr-chart-panel">
        <div class="usr-chart-wrap kr-chart-wrap--history" id="koreaHistoryChart">
          <canvas id="koreaHistoryCanvas"></canvas>
        </div>
        <div class="usr-chart-insights">
          <div class="usr-chart-insight">
            <strong>연도별 공개 편차</strong>
            <p>초기 연도는 공개 데이터가 비어 있는 경우가 있어 회색 막대로 구분해 보여줍니다.</p>
          </div>
          <div class="usr-chart-insight">
            <strong>환율 조정 연동</strong>
            <p>히스토리 툴팁에서도 현재 입력한 환율 기준 원화 환산값을 함께 확인할 수 있습니다.</p>
          </div>
        </div>
      </article>
    </section>

    <section class="usr-section">
      <div class="usr-section__head">
        <p class="usr-section__eyebrow">재미 환산</p>
        <h2>서울 국평과 그랜저로 보면 체감이 더 쉽습니다</h2>
        <p class="usr-section__sub">현재 입력한 환율과 기준 가격을 바탕으로 생활 단위 환산값을 바로 보여줍니다.</p>
      </div>
      <div class="usr-kpi-grid usr-kpi-grid--fun">
        <article class="usr-kpi-card usr-kpi-card--soft">
          <p>원화 환산</p>
          <strong id="koreaFunKrwValue">{formatKrwLarge(selectedKrwValue)}</strong>
          <span>환율 {defaults.usdKrwRate.toLocaleString("ko-KR")}원 기준</span>
        </article>
        <article class="usr-kpi-card">
          <p>서울 국평 아파트</p>
          <strong id="koreaFunSeoulCount">약 {Math.round(krwToSeoul84Count(selectedKrwValue, defaults.seoul84PriceKrw)).toLocaleString("ko-KR")}채</strong>
          <span>기준값 {defaults.seoul84PriceKrw.toLocaleString("ko-KR")}원</span>
        </article>
        <article class="usr-kpi-card">
          <p>그랜저</p>
          <strong id="koreaFunGrandeurCount">약 {Math.round(krwToGrandeurCount(selectedKrwValue, defaults.grandeurPriceKrw)).toLocaleString("ko-KR")}대</strong>
          <span>기준값 {defaults.grandeurPriceKrw.toLocaleString("ko-KR")}원</span>
        </article>
        <article class="usr-kpi-card">
          <p>달러 기준 자산</p>
          <strong id="koreaFunUsdValue">{formatUsdB(selectedEntry.netWorthUsdB)}</strong>
          <span>공개 순위 원자료 기준</span>
        </article>
      </div>
    </section>

    <section class="usr-section">
      <div class="usr-section__head">
        <p class="usr-section__eyebrow">패턴 요약</p>
        <h2>한국 상위 부자 구성을 읽을 때 보이는 흐름</h2>
      </div>
      <div class="usr-pattern-grid">
        {
          koreaRichTop10Seed.interpretationPoints.map((pattern) => (
            <article class="usr-pattern-card">
              <strong>{pattern.title}</strong>
              <p>{pattern.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="usr-section">
      <div class="usr-section__head">
        <p class="usr-section__eyebrow">분포 비교</p>
        <h2>업종과 부의 형성 방식 분포</h2>
      </div>
      <div class="usr-distribution-grid kr-distribution-grid">
        {
          distributionGroups.map((group) => (
            <article class="panel usr-distribution-card kr-distribution-card">
              <h3>{group.title}</h3>
              <p class="usr-distribution-card__summary">{group.summary}</p>
              <div class="kr-distribution-copy">
                {
                  group.items.map((item) => (
                    <div class="kr-distribution-copy__item">
                      <strong>{item.label}</strong>
                      <p>{item.body}</p>
                    </div>
                  ))
                }
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="한국 부자 TOP 10 리포트 읽는 법"
        intro={[
          "한국 부자들의 자산 규모를 보면 막연하게 크다고만 느껴지지, 실제로 얼마나 차이가 나는지는 가늠하기 어렵습니다. 이 페이지는 Forbes가 2026년 4월 발표한 Korea's 50 Richest 순위를 기준으로 한국 부자 TOP 10의 자산 규모와 전년 대비 변화를 비교해보는 인터랙티브 리포트입니다.",
          "2026년 리스트는 AI 반도체 랠리로 이재용 삼성전자 회장이 다시 1위에 올라섰고, 한국 상위 50명의 합산 자산도 전년 990억 달러에서 1,750억 달러로 77% 늘어난 역대 최고치를 기록했습니다. 인물을 선택하면 자산 구성과 순위 변화, 환산 비교까지 함께 확인할 수 있습니다.",
