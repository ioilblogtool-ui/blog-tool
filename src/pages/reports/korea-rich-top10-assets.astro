---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  koreaRichTop10Seed,
  koreaCurrentTop10HistorySeed,
  usdBillionToKrw,
  krwToSeoul84Count,
  krwToGrandeurCount,
  formatKrwLarge,
  formatUsdB
} from "../../data/koreaRichTop10Current";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const selectedEntry = koreaRichTop10Seed.entries[0];
const selectedHistory = koreaCurrentTop10HistorySeed.find((item) => item.slug === selectedEntry.slug);
const defaults = koreaRichTop10Seed.conversionDefaults;
const overviewEntries = koreaRichTop10Seed.entries.map((entry) => ({
  ...entry,
  krwValue: usdBillionToKrw(entry.netWorthUsdB, defaults.usdKrwRate)
}));
const wealthTypeCounts = koreaRichTop10Seed.entries.reduce(
  (acc, entry) => {
    acc[entry.wealthType] += 1;
    return acc;
  },
  { inherited: 0, "self-made": 0, mixed: 0 }
);
const selectedKrwValue = usdBillionToKrw(selectedEntry.netWorthUsdB, defaults.usdKrwRate);
const topEntry = overviewEntries[0];
const faqItems = koreaRichTop10Seed.faq.map((item) => ({ question: item.q, answer: item.a }));
const selectedHistoryMaxUsd = selectedHistory
  ? Math.max(...selectedHistory.history.map((item) => item.netWorthUsdB ?? 0), 0)
  : 0;
---

<BaseLayout title={koreaRichTop10Seed.meta.title} description={koreaRichTop10Seed.meta.subtitle}>
  <SiteHeader />

  <main class="container page-shell report-page us-rich-report-page korea-rich-report-page">
    <CalculatorHero
      eyebrow="Interactive Report"
      title={koreaRichTop10Seed.meta.title}
      description={koreaRichTop10Seed.meta.subtitle}
    />

    <InfoNotice
      title="기준 안내"
      lines={[
        koreaRichTop10Seed.meta.methodology,
        koreaRichTop10Seed.meta.caution
      ]}
    />

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">현재 TOP 10</p>
        <h2>2026년 현재 볼 수 있는 최신 공개 기준</h2>
      </div>
      <div class="report-kpi-grid">
        <article class="report-stat-card">
          <p>현재 1위 자산</p>
          <strong>{formatKrwLarge(topEntry.krwValue)}</strong>
          <span>{topEntry.name} · {formatUsdB(topEntry.netWorthUsdB)}</span>
        </article>
        <article class="report-stat-card">
          <p>상위 10명 합산</p>
          <strong>{formatKrwLarge(overviewEntries.reduce((sum, item) => sum + item.krwValue, 0))}</strong>
          <span>환율 {defaults.usdKrwRate.toLocaleString("ko-KR")}원 기준</span>
        </article>
        <article class="report-stat-card">
          <p>상속형 인원</p>
          <strong>{wealthTypeCounts.inherited}명</strong>
          <span>재벌·승계형 비중</span>
        </article>
        <article class="report-stat-card">
          <p>자수성가형 인원</p>
          <strong>{wealthTypeCounts["self-made"]}명</strong>
          <span>금융·바이오·플랫폼 중심</span>
        </article>
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">상위 10명 개요</p>
        <h2>원화 기준으로 먼저 훑어보기</h2>
      </div>
      <div class="korea-overview-grid" id="koreaTop10Overview">
        {
          overviewEntries.map((entry) => (
            <article class="report-overview-card korea-overview-card" data-entry-card={entry.slug}>
              <p>{entry.rank}위 · {entry.name}</p>
              <strong>{formatKrwLarge(entry.krwValue)}</strong>
              <span>{formatUsdB(entry.netWorthUsdB)}</span>
              <em>{entry.sector}</em>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">인물 선택</p>
        <h2>한 명씩 자세히 보기</h2>
        <p>김병주부터 정의선까지, 선택한 인물의 자산 규모와 환산값을 자세히 확인할 수 있습니다.</p>
      </div>

      <article class="panel report-control-panel korea-report-controls">
        <label class="field">
          <span>인물 선택</span>
          <select id="koreaRichProfileSelect">
            {
              koreaRichTop10Seed.entries.map((entry) => (
                <option value={entry.slug} selected={entry.slug === selectedEntry.slug}>
                  {entry.rank}위 · {entry.name}
                </option>
              ))
            }
          </select>
        </label>

        <div class="korea-report-controls__config">
          <label class="field">
            <span>환율</span>
            <input id="usdKrwRateInput" type="number" min="1000" step="10" value={defaults.usdKrwRate} />
          </label>
          <label class="field">
            <span>서울 국평 가격</span>
            <input id="seoul84PriceInput" type="number" min="100000000" step="10000000" value={defaults.seoul84PriceKrw} />
          </label>
          <label class="field">
            <span>그랜저 가격</span>
            <input id="grandeurPriceInput" type="number" min="10000000" step="1000000" value={defaults.grandeurPriceKrw} />
          </label>
        </div>
      </article>

      <article class="panel report-profile-card korea-report-profile-card">
        <div class="report-profile-card__header">
          <div>
            <p class="panel-heading__eyebrow">선택 인물</p>
            <h2 id="koreaProfileName">{selectedEntry.name}</h2>
            <p class="korea-report-profile-card__sub" id="koreaProfileNameEn">{selectedEntry.nameEn}</p>
          </div>
          <div class="report-rank-chip" id="koreaProfileRank">{selectedEntry.rank}위</div>
        </div>

        <div class="report-profile-card__summary korea-report-profile-card__summary">
          <article class="report-stat-card report-stat-card--primary">
            <p>원화 환산 자산</p>
            <strong id="koreaProfileKrwValue">{formatKrwLarge(selectedKrwValue)}</strong>
            <span id="koreaProfileUsdValue">{formatUsdB(selectedEntry.netWorthUsdB)}</span>
          </article>
          <article class="report-stat-card">
            <p>서울 국평 환산</p>
            <strong id="koreaProfileSeoulCount">약 {Math.round(krwToSeoul84Count(selectedKrwValue, defaults.seoul84PriceKrw)).toLocaleString("ko-KR")}채</strong>
            <span>참고 비교</span>
          </article>
          <article class="report-stat-card">
            <p>그랜저 환산</p>
            <strong id="koreaProfileGrandeurCount">약 {Math.round(krwToGrandeurCount(selectedKrwValue, defaults.grandeurPriceKrw)).toLocaleString("ko-KR")}대</strong>
            <span>참고 비교</span>
          </article>
        </div>

        <div class="report-profile-card__detail">
          <div class="report-detail-list">
            <div class="report-detail-row">
              <span>부의 원천</span>
              <strong id="koreaProfileSource">{selectedEntry.sourceOfWealth}</strong>
            </div>
            <div class="report-detail-row">
              <span>업종</span>
              <strong id="koreaProfileSector">{selectedEntry.sector}</strong>
            </div>
            <div class="report-detail-row">
              <span>유형</span>
              <strong id="koreaProfileWealthType">{selectedEntry.wealthType}</strong>
            </div>
          </div>

          <div class="report-profile-card__aside">
            <div class="report-tag-block">
              <span class="report-tag-block__label">태그</span>
              <div class="report-tag-list" id="koreaProfileTags">
                {selectedEntry.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
          </div>
        </div>

        <div class="report-profile-card__footer">
          <p id="koreaProfileSummary">{selectedEntry.summary}</p>
        </div>
      </article>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">최근 10년 흐름</p>
        <h2>선택 인물 기준 자산 변화</h2>
        <p>2016년부터 2025년까지 공개 앵커 기준으로 확인되는 자산 흐름을 정리했습니다.</p>
      </div>
      <article class="panel korea-history-panel">
        <div class="korea-history-grid" id="koreaHistoryChart">
          {
            selectedHistory?.history.map((point) => {
              const width = selectedHistoryMaxUsd > 0 && point.netWorthUsdB
                ? (point.netWorthUsdB / selectedHistoryMaxUsd) * 100
                : 0;
              const krwValue = point.netWorthUsdB
                ? formatKrwLarge(usdBillionToKrw(point.netWorthUsdB, defaults.usdKrwRate))
                : "데이터 없음";
              const usdValue = point.netWorthUsdB ? formatUsdB(point.netWorthUsdB) : "공개값 확인 어려움";
              const statusLabel = point.inTop10 === true ? "TOP 10 진입" : "기준 확인 어려움";

              return (
                <article class={`korea-history-card${point.netWorthUsdB ? "" : " is-empty"}`}>
                  <div class="korea-history-card__head">
                    <strong>{point.year}</strong>
                    <span>{statusLabel}</span>
                  </div>
                  <p class="korea-history-card__krw">{krwValue}</p>
                  <p class="korea-history-card__usd">{usdValue}</p>
                  <div class="korea-history-card__track">
                    <span class="korea-history-card__fill" style={`width:${width}%`}></span>
                  </div>
                  <p class="korea-history-card__source">{point.sourceRef ?? "공개 앵커 데이터 미확보"}</p>
                </article>
              );
            })
          }
        </div>
      </article>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">자산 비교</p>
        <h2>상위 10명 자산 규모를 한 줄로 비교</h2>
        <p>원화 기준이 메인이고, 달러 값은 보조 기준으로 같이 보여줍니다.</p>
      </div>
      <article class="panel distribution-card korea-asset-chart-card">
        <div class="distribution-list" id="koreaAssetChart">
          {
            overviewEntries.map((entry) => {
              const width = (entry.netWorthUsdB / topEntry.netWorthUsdB) * 100;
              return (
                <div class="distribution-row">
                  <div class="distribution-row__head distribution-row__head--stacked">
                    <span>{entry.rank}위 · {entry.name}</span>
                    <strong>{formatKrwLarge(entry.krwValue)}</strong>
                  </div>
                  <div class="distribution-row__track korea-asset-chart__track">
                    <span class="distribution-row__fill" style={`width:${width}%`}></span>
                  </div>
                  <p class="korea-asset-chart__meta">{formatUsdB(entry.netWorthUsdB)} · {entry.sector}</p>
                </div>
              );
            })
          }
        </div>
      </article>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">참고 비교</p>
        <h2>서울 국평과 그랜저로 보면 더 직관적입니다</h2>
        <p>숫자 자체보다 어느 정도 체감 규모인지 같이 보면 자산 격차가 더 잘 보입니다.</p>
      </div>
      <article class="panel fun-conversion-panel korea-fun-panel">
        <div class="fun-conversion-grid">
          <article class="fun-conversion-card">
            <p>서울 국평 아파트</p>
            <strong id="koreaFunSeoulCount">약 {Math.round(krwToSeoul84Count(selectedKrwValue, defaults.seoul84PriceKrw)).toLocaleString("ko-KR")}채</strong>
            <span>기준값 {defaults.seoul84PriceKrw.toLocaleString("ko-KR")}원</span>
          </article>
          <article class="fun-conversion-card">
            <p>그랜저</p>
            <strong id="koreaFunGrandeurCount">약 {Math.round(krwToGrandeurCount(selectedKrwValue, defaults.grandeurPriceKrw)).toLocaleString("ko-KR")}대</strong>
            <span>기준값 {defaults.grandeurPriceKrw.toLocaleString("ko-KR")}원</span>
          </article>
        </div>
        <p class="fun-conversion-panel__note">가격과 환율은 바뀔 수 있어 참고용 기준값으로 제공합니다.</p>
      </article>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">패턴 요약</p>
        <h2>업종과 유형으로 보면 더 잘 보이는 흐름</h2>
      </div>
      <div class="pattern-grid">
        {koreaRichTop10Seed.interpretationPoints.map((item) => (
          <article class="pattern-card">
            <strong>{item.title}</strong>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
      <div class="distribution-grid korea-distribution-grid">
        {koreaRichTop10Seed.sectorSummaries.map((item) => (
          <article class="panel distribution-card">
            <h3>{item.label}</h3>
            <p>{item.description}</p>
          </article>
        ))}
        {koreaRichTop10Seed.wealthTypeSummaries.map((item) => (
          <article class="panel distribution-card">
            <h3>{item.label}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="한국 부자 TOP 10 리포트 읽는 법"
      intro={[
        "이 페이지는 2026년 현재 공개된 최신 Forbes Korea 순위(2025 발표본)를 기준으로 한국 부자 TOP 10의 자산 규모를 비교해보는 인터랙티브 리포트입니다.",
        "원화 환산을 메인으로 보여주고, 서울 국평과 그랜저 환산값을 재미 요소로 함께 배치해 체감 규모를 더 쉽게 읽을 수 있게 구성했습니다."
      ]}
      inputPoints={[
        "상위 10명 자산을 원화 기준으로 먼저 비교할 수 있습니다.",
        "인물을 선택하면 업종, 부의 원천, 유형, 태그를 함께 볼 수 있습니다.",
        "환율과 기준 가격을 바꾸면 재미 환산 결과도 같이 바뀝니다."
      ]}
      criteria={[
        "2026년 현재 공개된 최신 Forbes Korea 순위(2025 발표본)를 기준으로 정리합니다.",
        "원화 환산은 기준 환율을 적용한 참고값입니다.",
        "서울 국평과 그랜저 환산은 재미를 위한 비교이며 투자나 재무 판단 기준이 아닙니다.",
        "가격과 환율은 시장 상황에 따라 달라질 수 있어 직접 조정할 수 있게 구성했습니다."
      ]}
      faq={faqItems}
      related={[
        { href: "/reports/us-rich-top10-patterns/", label: "미국 부자 TOP 10 성공 패턴 리포트" },
        { href: "/reports/", label: "비교 리포트 모아보기" },
        { href: "/tools/household-income/", label: "가구 소득 계산기" }
      ]}
    />
  </main>

  <script id="koreaRichTop10Data" type="application/json" set:html={JSON.stringify(koreaRichTop10Seed)}></script>
  <script id="koreaRichTop10HistoryData" type="application/json" set:html={JSON.stringify(koreaCurrentTop10HistorySeed)}></script>
  <script type="module" src={withBase("/scripts/korea-rich-top10-assets.js")}></script>
</BaseLayout>
