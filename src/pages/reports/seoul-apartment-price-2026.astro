---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  seoulApartmentBudgetBands,
  seoulApartmentDistricts,
  seoulApartmentFaq,
  seoulApartmentGroupDescriptions,
  seoulApartmentLookupSteps,
  seoulApartmentMarketSummary,
  seoulApartmentSources,
  seoulApartmentTimeline,
} from "../../data/seoulApartmentPrice2026";

const eok = (value: number) => `${(value / 100000000).toFixed(1).replace(".0", "")}억`;
const man = (value: number) => `${Math.round(value / 10000).toLocaleString("ko-KR")}만`;
const sorted = [...seoulApartmentDistricts].sort((a, b) => b.price84 - a.price84);
const topYoy = [...seoulApartmentDistricts].sort((a, b) => b.yoy - a.yoy).slice(0, 5);
const topJeonse = [...seoulApartmentDistricts].sort((a, b) => b.jeonseRatio - a.jeonseRatio).slice(0, 5);
const valueDistricts = [...seoulApartmentDistricts]
  .filter((item) => item.price84 <= 1050000000)
  .sort((a, b) => b.trades - a.trades)
  .slice(0, 6);
const premiumDistricts = [...seoulApartmentDistricts]
  .map((item) => ({
    ...item,
    premium: Math.round(((item.newAverage - item.oldAverage) / item.oldAverage) * 1000) / 10,
  }))
  .sort((a, b) => b.premium - a.premium)
  .slice(0, 6);
const groupStats = seoulApartmentGroupDescriptions.map((group) => {
  const districts = seoulApartmentDistricts.filter((item) => item.group === group.group);
  const count = districts.length || 1;
  return {
    ...group,
    average: districts.reduce((sum, item) => sum + item.average, 0) / count,
    price84: districts.reduce((sum, item) => sum + item.price84, 0) / count,
    yoy: districts.reduce((sum, item) => sum + item.yoy, 0) / count,
    jeonseRatio: districts.reduce((sum, item) => sum + item.jeonseRatio, 0) / count,
    trades: districts.reduce((sum, item) => sum + item.trades, 0),
  };
});
const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "2026 서울 구별 아파트 실거래가 완전 분석",
  description: "서울 25개 구 아파트 가격을 84㎡ 환산가, 평균가, 전세가율, 예산별 접근 가능 구간으로 비교한 리포트입니다.",
  inLanguage: "ko-KR",
  dateModified: seoulApartmentMarketSummary.updatedAt,
  author: {
    "@type": "Organization",
    name: "비교계산소",
  },
};
---

<BaseLayout title="2026 서울 구별 아파트 실거래가 완전 분석 | 25개 구 가격 순위" description="2026년 서울 25개 구 아파트 가격을 84㎡ 환산가, 평균가, 중앙값, 전세가율, 신축 프리미엄, 예산별 접근 가능 구간 기준으로 비교합니다." jsonLd={articleJsonLd}>
  <SiteHeader />
  <main class="container page-shell report-page op-page sap-page">
    <CalculatorHero eyebrow="부동산 데이터 리포트" title="2026 서울 구별 아파트 실거래가 완전 분석" description="서울 주요 구 아파트 실거래가를 84㎡ 환산가, 평균가, 전년 대비, 전세가율 기준으로 비교합니다." />
    <InfoNotice title="실거래가 해석 기준" lines={["본 콘텐츠는 공개 실거래 구조를 바탕으로 한 표본·추정 리포트이며 특정 지역이나 단지 매수를 권유하지 않습니다.", "실거래가는 신고 취소, 정정, 지연 반영에 따라 달라질 수 있습니다.", "실제 매수 전에는 국토교통부 실거래가 공개시스템에서 최신 거래, 등기, 대출 가능 여부, 세금을 함께 확인해야 합니다."]} />
      <DesignTrustPanel title="서울 아파트 가격 리포트 기준" updatedAt={seoulApartmentMarketSummary.updatedAt} notes={["구별 가격은 면적, 층, 연식, 단지 규모, 거래량에 따라 다르게 보일 수 있습니다.", "표 안의 가격은 시장 구조를 이해하기 위한 비교용 환산값이며 공식 시세가 아닙니다.", "리포트는 시장 이해를 위한 참고 정보이며 매수·매도 판단을 대신하지 않습니다."]} />

    <section class="op-section">
      <div class="op-result-grid">
        <article class="op-result-card op-result-card--main"><p>최고 84㎡ 환산가</p><strong>{sorted[0].district}</strong><span>{eok(sorted[0].price84)}</span></article>
        <article class="op-result-card"><p>서울 84㎡ 평균</p><strong>{eok(seoulApartmentMarketSummary.averagePrice84)}</strong><span>표본 환산 기준</span></article>
        <article class="op-result-card"><p>평균 전세가율</p><strong>{seoulApartmentMarketSummary.averageJeonseRatio}%</strong><span>구별 표본 평균</span></article>
        <article class="op-result-card"><p>표본 거래량</p><strong>{seoulApartmentMarketSummary.totalTrades.toLocaleString("ko-KR")}건</strong><span>거래량은 신뢰도 보조 지표</span></article>
      </div>
      <p class="op-message">{seoulApartmentMarketSummary.basis}입니다. 평균 실거래가보다 84㎡ 환산가, 중앙값, 거래량, 전세가율을 함께 봐야 구별 가격 차이가 덜 왜곡됩니다.</p>
    </section>

    <section class="op-section">
      <h2>서울 25개 구 84㎡ 환산가 랭킹</h2>
      <div class="op-table-wrap"><table><thead><tr><th>순위</th><th>구</th><th>그룹</th><th>84㎡ 환산가</th><th>평균가</th><th>중앙값</th><th>평당가</th><th>전년 대비</th><th>전세가율</th><th>거래량</th></tr></thead><tbody>{sorted.map((item, index) => <tr><td>{index + 1}</td><td>{item.district}</td><td>{item.group}</td><td>{eok(item.price84)}</td><td>{eok(item.average)}</td><td>{eok(item.median)}</td><td>{man(item.pyeongPrice)}</td><td>{item.yoy}%</td><td>{item.jeonseRatio}%</td><td>{item.trades}건</td></tr>)}</tbody></table></div>
      <p class="op-message">거래량이 적은 구는 고가 단지 1~2건만으로 평균가가 크게 움직일 수 있습니다. 그래서 순위표는 가격 서열보다 “내 예산에서 어느 권역까지 접근 가능한가”를 보는 용도로 활용하는 편이 안전합니다.</p>
    </section>

    <section class="op-section">
      <h2>강남3구·마용성·노도강 그룹 비교</h2>
      <div class="op-table-wrap">
        <table>
          <thead><tr><th>그룹</th><th>포함 구</th><th>평균가</th><th>84㎡ 환산가</th><th>전년 대비</th><th>전세가율</th><th>거래량</th><th>해석</th></tr></thead>
          <tbody>
            {groupStats.map((item) => (
              <tr><td>{item.group}</td><td>{item.districts}</td><td>{eok(item.average)}</td><td>{eok(item.price84)}</td><td>{item.yoy.toFixed(1)}%</td><td>{item.jeonseRatio.toFixed(0)}%</td><td>{item.trades.toLocaleString("ko-KR")}건</td><td>{item.description}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="op-section">
      <h2>전년 대비 상승률 상위 구간</h2>
      <div class="op-card-grid">
        {topYoy.map((item, index) => (
          <article><strong>{index + 1}. {item.district}</strong><p>전년 대비 {item.yoy}% · 84㎡ 환산 {eok(item.price84)}. {item.note}</p></article>
        ))}
      </div>
    </section>

    <section class="op-section">
      <h2>신축과 구축 가격 격차가 큰 구</h2>
      <div class="op-table-wrap">
        <table>
          <thead><tr><th>구</th><th>신축 평균가</th><th>구축 평균가</th><th>신축 프리미엄</th><th>해석</th></tr></thead>
          <tbody>
            {premiumDistricts.map((item) => (
              <tr><td>{item.district}</td><td>{eok(item.newAverage)}</td><td>{eok(item.oldAverage)}</td><td>{item.premium}%</td><td>{item.premium >= 30 ? "신축 선호가 강한 구간" : "일반적 신축 프리미엄 구간"}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="op-message">같은 구 안에서도 신축과 구축은 다른 시장처럼 움직일 수 있습니다. 실거주 매수자는 구 평균보다 후보 단지의 준공연도, 주차, 관리비, 학군, 역세권 여부를 먼저 확인해야 합니다.</p>
    </section>

    <section class="op-section">
      <h2>외곽 실수요 접근권 후보</h2>
      <div class="op-card-grid">
        {valueDistricts.map((item) => (
          <article><strong>{item.district}</strong><p>84㎡ 환산 {eok(item.price84)} · 전세가율 {item.jeonseRatio}% · 거래량 {item.trades}건. {item.note}</p></article>
        ))}
      </div>
    </section>

    <section class="op-section">
      <h2>전세가율 높은 구 TOP5</h2>
      <div class="op-table-wrap">
        <table>
          <thead><tr><th>순위</th><th>구</th><th>84㎡ 환산가</th><th>전세가율</th><th>리스크 해석</th></tr></thead>
          <tbody>
            {topJeonse.map((item, index) => (
              <tr><td>{index + 1}</td><td>{item.district}</td><td>{eok(item.price84)}</td><td>{item.jeonseRatio}%</td><td>{item.jeonseRatio >= 70 ? "전세가율이 높아 하락장 갭 리스크 점검 필요" : "전세 수요와 매매가 괴리를 함께 확인"}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="op-section">
      <h2>예산별 접근 가능 구간</h2>
      <div class="op-table-wrap">
        <table>
          <thead><tr><th>예산</th><th>가능한 선택지</th><th>추천 전략</th><th>주의점</th></tr></thead>
          <tbody>
            {seoulApartmentBudgetBands.map((item) => (
              <tr><td>{item.budget}</td><td>{item.options}</td><td>{item.strategy}</td><td>{item.caution}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="op-section">
      <h2>2024년부터 2026년까지 흐름</h2>
      <ul class="op-timeline">
        {seoulApartmentTimeline.map((item) => (
          <li><b>{item.period}</b><span>{item.flow}</span><em>{item.detail}</em></li>
        ))}
      </ul>
    </section>

    <section class="op-section">
      <h2>실거래가 직접 확인 순서</h2>
      <div class="op-card-grid">
        {seoulApartmentLookupSteps.map((item, index) => (
          <article><strong>{index + 1}단계</strong><p>{item}</p></article>
        ))}
      </div>
    </section>

    <section class="op-section">
      <h2>참고 출처와 원자료</h2>
      <div class="op-card-grid">
        {seoulApartmentSources.map((source) => (
          <article>
            <strong>{source.label}</strong>
            <p>{source.basis}</p>
            <a href={source.href} target="_blank" rel="noopener noreferrer">원문 확인</a>
          </article>
        ))}
      </div>
    </section>

    <section class="op-section op-cta"><h2>전세와 월세 비용도 함께 비교하세요</h2><p>매수 전에는 현재 주거비와 대출이자, 보증금 기회비용을 함께 봐야 합니다.</p><a class="button button--secondary" href="/tools/jeonse-vs-wolse-calculator/">전세 vs 월세 손익 계산기</a></section>

    <SeoContent introTitle="서울 아파트 실거래가를 볼 때 중요한 기준" intro={[
      "서울 아파트 가격은 평균가만으로 판단하기 어렵습니다. 거래량이 적은 구에서는 고가 단지 1~2건만으로 평균가가 크게 움직일 수 있어 84㎡ 환산가와 중앙값을 함께 봐야 왜곡이 줄어듭니다.",
      "2026년 기준 서울 25개 구 84㎡ 환산가는 강남구가 최상단에 위치하고, 강북·노원·도봉 등 외곽 구는 상대적으로 접근 가능한 가격대를 형성합니다. 같은 서울이라도 강남3구와 외곽 구 간 84㎡ 환산가 격차는 수억 원 이상 벌어집니다.",
      "전세가율은 실수요 지지력을 보여주는 동시에 갭 리스크 지표이기도 합니다. 전세가율이 70%를 넘는 구는 매매가 하락 시 전세가와의 역전 위험이 커지기 때문에 매수자와 전세 임차인 모두 주의가 필요합니다.",
      "신축과 구축의 가격 격차가 큰 구일수록 같은 구 평균가로 비교하면 오해가 생깁니다. 신축 단지는 구축 대비 20~50% 이상 높은 가격을 형성하는 경우가 많아 후보 단지의 준공연도·세대수·역세권 여부를 개별 확인해야 합니다.",
      "예산별 접근 가능 구간을 파악할 때는 대출 한도, 조정대상지역 여부, DSR 규제를 함께 고려해야 합니다. 10억 원 이하 예산에서 서울 내 실거주 선택지는 외곽 구나 소형 면적으로 좁혀지는 구조이며, 거래량이 충분한 구간에서 협상력이 생깁니다.",
    ]} criteria={["84㎡ 환산가는 거래금액을 전용면적 기준으로 보정한 비교 지표입니다.", "거래량이 적은 지역은 평균가 변동이 크게 나타날 수 있습니다.", "전세가율은 실수요 지지력을 보여줄 수 있지만 갭 리스크도 함께 키울 수 있습니다.", "본 콘텐츠는 투자 권유가 아니라 공개 데이터 구조를 바탕으로 한 표본·추정 비교 리포트입니다."]} faq={seoulApartmentFaq} related={[{ href: "/tools/apt-cheonyak-gajum-calculator/", label: "아파트 청약 가점 계산기" }, { href: "/tools/jeonse-vs-wolse-calculator/", label: "전세 vs 월세 손익 계산기" }, { href: "/tools/home-purchase-fund/", label: "주택 구입 자금 계산기" }, { href: "/reports/seoul-housing-2016-vs-2026/", label: "서울 집값 2016 vs 2026" }]} />
  </main>
</BaseLayout>


