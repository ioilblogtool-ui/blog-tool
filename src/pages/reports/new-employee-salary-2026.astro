---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import { newEmployeeSalary2026, formatKrwM } from "../../data/newEmployeeSalary2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const seed = newEmployeeSalary2026;
const entries = seed.entries;
const tiers = seed.tiers;
const selected = entries[0];

const topEntry = entries[0];
const secondEntry = entries[1];
const thirdEntry = entries[2];
const podiumEntries = entries.slice(0, 3);
const itEntries = entries.filter((e) => e.sectorType === "it");
const itAvg = Math.round(itEntries.reduce((s, e) => s + e.annualKrwM, 0) / itEntries.length);
const publicEntries = entries.filter((e) => e.sectorType === "public");
const publicAvg = Math.round(publicEntries.reduce((s, e) => s + e.annualKrwM, 0) / publicEntries.length);
const totalCompanyCount = tiers.reduce((s, t) => s + t.companies.length, 0);
const topGap = topEntry && secondEntry ? topEntry.annualKrwM - secondEntry.annualKrwM : 0;
const salaryBand = entries.length
  ? `${formatKrwM(entries[entries.length - 1].annualKrwM)} ~ ${formatKrwM(entries[0].annualKrwM)}`
  : "-";

const faqItems = seed.faq.map((item) => ({ question: item.q, answer: item.a }));

const NOTE_LABEL: Record<string, string> = {
  it: "IT",
  public: "공공",
  sub: "하단",
};

const reportHighlights = [
  {
    title: "가장 높은 초봉",
    value: topEntry ? formatKrwM(topEntry.annualKrwM) : "-",
    body: topEntry ? `${topEntry.name}가 2026년 기준 가장 높은 초봉 구간을 형성합니다.` : "",
  },
  {
    title: "1위와 2위 격차",
    value: formatKrwM(topGap),
    body: secondEntry ? `${topEntry.name}와 ${secondEntry.name}의 초봉 차이입니다.` : "상위권 기업 간 격차를 보여줍니다.",
  },
  {
    title: "리포트 범위",
    value: `${totalCompanyCount}개`,
    body: `${tiers.length}개 티어로 나눠 업종별 초봉 판도를 비교합니다.`,
  },
];
---

<BaseLayout title={seed.meta.title} description={seed.meta.subtitle}>
  <SiteHeader />

  <main class="container page-shell report-page salary-report-page salary-report-page--editorial">
    <CalculatorHero
      eyebrow="Interactive Report"
      title={seed.meta.title}
      description={seed.meta.subtitle}
    />

    <InfoNotice
      title="기준 안내"
      lines={[seed.meta.methodology, seed.meta.caution, seed.meta.updatedAt]}
    />

    <section class="content-section salary-report-hero-board">
      <div class="salary-report-lead">
        <p class="salary-report-lead__eyebrow">Editor&apos;s Brief</p>
        <h2>2026 신입 초봉 시장, 어디가 강하고 어디서 격차가 벌어질까</h2>
        <p class="salary-report-lead__body">
          이 페이지는 단순히 "내 연봉이 몇 티어인지" 계산하는 도구가 아니라,
          업종별 초봉 시장을 한 번에 읽고 대표 기업을 비교하는 리포트입니다.
          상단에서는 올해 판도를 요약하고, 중간에서는 차트로 비교하고,
          하단에서는 기업별 세부 보상 구조를 탐색할 수 있게 구성했습니다.
        </p>
        <div class="salary-report-lead__chips">
          <span>초봉 범위 {salaryBand}</span>
          <span>상위권 중심 반도체·IT 강세</span>
          <span>공공·금융은 안정형 구간</span>
        </div>
      </div>

      <div class="salary-report-highlight-grid">
        {reportHighlights.map((item) => (
          <article class="salary-highlight-card">
            <p>{item.title}</p>
            <strong>{item.value}</strong>
            <span>{item.body}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 수치</p>
        <h2>숫자로 먼저 보는 2026 신입 초봉 요약</h2>
      </div>
      <div class="report-kpi-grid salary-kpi-grid">
        <article class="report-stat-card report-stat-card--primary">
          <p>최고 초봉 기업</p>
          <strong>{topEntry.name}</strong>
          <span>{formatKrwM(topEntry.annualKrwM)} · 기본급 기준 추정</span>
        </article>
        <article class="report-stat-card">
          <p>IT 평균</p>
          <strong>{formatKrwM(itAvg)}</strong>
          <span>IT·게임 계열 평균</span>
        </article>
        <article class="report-stat-card">
          <p>공공 평균</p>
          <strong>{formatKrwM(publicAvg)}</strong>
          <span>공공기관·공무원 평균</span>
        </article>
        <article class="report-stat-card">
          <p>비교 기업 수</p>
          <strong>{totalCompanyCount}개</strong>
          <span>{tiers.length}개 티어로 구분</span>
        </article>
      </div>
    </section>

    <section class="content-section salary-podium-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">상위권 판도</p>
        <h2>올해 초봉 시장을 끌어올리는 대표 기업</h2>
        <p>상위 3개 기업을 먼저 보면, 어떤 업종이 시장 상단을 형성하는지 빠르게 읽을 수 있습니다.</p>
      </div>

      <div class="salary-podium-grid">
        {podiumEntries.map((entry, index) => (
          <article class={`salary-podium-card salary-podium-card--${index + 1}`}>
            <span class="salary-podium-card__rank">TOP {index + 1}</span>
            <h3>{entry.name}</h3>
            <p class="salary-podium-card__value">{formatKrwM(entry.annualKrwM)}</p>
            <p class="salary-podium-card__meta">{entry.sector}</p>
            <p class="salary-podium-card__body">{entry.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section salary-overview-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">리포트 차트</p>
        <h2>전체 초봉과 월 실수령을 나눠서 읽기</h2>
        <p>왼쪽은 연봉 수준, 오른쪽은 실제 체감에 가까운 월 실수령 추정입니다.</p>
      </div>

      <div class="salary-chart-board">
        <article class="salary-chart-panel">
          <div class="salary-chart-panel__head">
            <h3>기업별 초봉 비교</h3>
            <p>바를 클릭하면 아래 기업 상세 카드가 바뀝니다.</p>
          </div>
          <div class="salary-chart-wrap" id="salaryChartWrap">
            <canvas id="salaryOverviewCanvas"></canvas>
          </div>
          <div class="salary-chart-legend">
            <span class="is-it">IT·플랫폼·게임</span>
            <span class="is-semiconductor">반도체</span>
            <span class="is-auto">자동차</span>
            <span class="is-battery">배터리·소재</span>
            <span class="is-logistics">물류·유통</span>
            <span class="is-food">식품</span>
            <span class="is-public">공공</span>
          </div>
        </article>

        <article class="salary-chart-panel salary-chart-panel--soft">
          <div class="salary-chart-panel__head">
            <h3>월 실수령 추정 비교</h3>
            <p>초봉 격차가 실수령으로는 어떻게 줄어드는지 같이 확인합니다.</p>
          </div>
          <div class="salary-net-chart-wrap" id="salaryNetChartWrap">
            <canvas id="salaryNetCanvas"></canvas>
          </div>
          <p class="salary-chart-hint">4대보험 + 근로소득 공제를 반영한 추정치이며 실제 수령액과는 차이가 있을 수 있습니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section salary-explorer-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">리포트 탐색</p>
        <h2>내 기준으로 보고, 기업별로 더 깊게 보기</h2>
        <p>여기부터는 리포트 하단의 탐색 영역입니다. 내 연봉을 가볍게 대입해 보고, 원하는 기업의 상세 구조를 확인할 수 있습니다.</p>
      </div>

      <div class="salary-explorer-grid">
        <div class="salary-lab-column">
          <article class="salary-benchmark-panel">
            <div class="salary-benchmark-panel__head">
              <p class="salary-benchmark-panel__eyebrow">Benchmark</p>
              <h3>내 연봉을 기준선으로 올려보기</h3>
              <p>리포트 안에서 참고선처럼 활용하는 비교 기능입니다. 계산기 메인 기능보다는 판독 보조용으로 배치했습니다.</p>
            </div>

            <div class="salary-my-input-row">
              <label for="mySalInput">내 연봉 (만원)</label>
              <input type="number" id="mySalInput" placeholder="예: 7500" min="0" max="20000" step="100" />
              <span id="mySalHint" class="salary-my-hint">입력하면 차트에 내 위치를 함께 보여드립니다.</span>
            </div>

            <div class="salary-result-card" id="salaryResultCard">
              <p id="salaryResultTitle" class="salary-result-title"></p>
              <div class="salary-result-grid">
                <div class="salary-result-cell"><strong id="r-pct">—</strong><span>전체 상위 %</span></div>
                <div class="salary-result-cell"><strong id="r-diff">—</strong><span>평균 대비</span></div>
                <div class="salary-result-cell"><strong id="r-tier">—</strong><span>연봉 티어</span></div>
              </div>
              <p id="similarText" class="salary-similar-text"></p>
            </div>
          </article>

          <article class="salary-market-panel">
            <div class="salary-market-panel__head">
              <h3>업종별 시장 맵</h3>
              <p>업종 필터를 바꿔가며 초봉 분포를 탐색할 수 있습니다.</p>
            </div>

            <div class="salary-summary-bar" id="salarySummaryBar"></div>

            <div class="salary-filter-row">
              <button class="salary-ftab is-active" data-filter="all">전체</button>
              <button class="salary-ftab" data-filter="semi">반도체</button>
              <button class="salary-ftab" data-filter="car">완성차·조선·방산</button>
              <button class="salary-ftab" data-filter="it">IT·플랫폼</button>
              <button class="salary-ftab" data-filter="chem">화학·에너지·철강</button>
              <button class="salary-ftab" data-filter="fin">금융·유통</button>
              <button class="salary-ftab" data-filter="for">외국계</button>
              <select id="salarySort" class="salary-sort-sel">
                <option value="desc">높은순</option>
                <option value="asc">낮은순</option>
                <option value="name">가나다순</option>
              </select>
            </div>

            <div id="salaryInteractiveChart"></div>
            <p class="salary-chart-hint">커뮤니티 기반 추정치 · 성과급 포함 영끌 기준 · 야근·특수수당 제외</p>
          </article>
        </div>

        <div class="salary-profile-column">
          <article class="panel salary-control-panel">
            <label class="field">
              <span>기업 선택</span>
              <select id="salaryCompanySelect">
                {
                  entries.map((e) => (
                    <option value={e.slug} selected={e.slug === selected.slug}>
                      {e.rank}위 · {e.name} ({formatKrwM(e.annualKrwM)})
                    </option>
                  ))
                }
              </select>
            </label>
          </article>

          <article class="panel salary-profile-card" id="salaryProfileCard">
            <div class="salary-profile-card__header">
              <div>
                <p class="panel-heading__eyebrow">선택 기업</p>
                <h2 id="profileName">{selected.name}</h2>
                <p class="salary-profile-card__sub" id="profileNameEn">{selected.nameEn}</p>
              </div>
              <div class="report-rank-chip" id="profileRank">{selected.rank}위</div>
            </div>

            <div class="salary-profile-card__summary">
              <article class="report-stat-card report-stat-card--primary">
                <p>연봉 (기본급 기준 추정)</p>
                <strong id="profileAnnual">{formatKrwM(selected.annualKrwM)}</strong>
                <span id="profileSector">{selected.sector}</span>
              </article>
              <article class="report-stat-card">
                <p>월 실수령 추정</p>
                <strong id="profileMonthlyNet">약 {selected.monthlyNetKrwM}만원</strong>
                <span>4대보험+근로소득 공제 추정</span>
              </article>
              <article class="report-stat-card">
                <p>성과급 포함 총보상 추정</p>
                <strong id="profileTotal">{selected.totalCompM ? `약 ${formatKrwM(selected.totalCompM)}` : "—"}</strong>
                <span>연도별 실적에 따라 변동</span>
              </article>
            </div>

            <div class="salary-profile-card__detail">
              <div class="report-detail-list">
                <div class="report-detail-row">
                  <span>업종</span>
                  <strong id="profileSectorDetail">{selected.sector}</strong>
                </div>
                <div class="report-detail-row">
                  <span>월 환산 연봉</span>
                  <strong id="profileMonthlyGross">{Math.round(selected.annualKrwM / 12)}만원</strong>
                </div>
              </div>
              <div class="report-profile-card__aside">
                <div class="report-tag-block">
                  <span class="report-tag-block__label">태그</span>
                  <div class="report-tag-list" id="profileTags">
                    {selected.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                </div>
              </div>
            </div>

            <div class="salary-benefits-block">
              <p class="salary-benefits-block__label">주요 복리후생</p>
              <ul class="salary-benefits-list" id="profileBenefits">
                {selected.benefits.map((b) => <li>{b}</li>)}
              </ul>
            </div>

            <div class="report-profile-card__footer">
              <p id="profileSummary">{selected.summary}</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="content-section salary-tier-board-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">티어 보드</p>
        <h2>초봉 티어별 기업 분포를 표처럼 읽기</h2>
        <p>
          기본급 기준 연봉 티어로 나눈 목록입니다.
          <span class="salary-legend-inline">
            <span class="salary-note-tag is-it">IT</span> IT 계열 ·
            <span class="salary-note-tag is-public">공공</span> 공공 부문 ·
            <span class="salary-note-tag is-sub">하단</span> 티어 하단 추정
          </span>
        </p>
      </div>

      <div class="salary-tier-list">
        {
          tiers.map((tier) => (
            <div class="salary-tier-row">
              <div class="salary-tier-row__level">
                <strong>{tier.label}</strong>
                <span class="salary-tier-row__net">
                  월 실수령 약 {Math.round((tier.salaryKrwM / 12) * 0.82)}만원 추정
                </span>
              </div>
              <div class="salary-tier-row__companies">
                {tier.companies.map((c) => (
                  <span class={`salary-note-tag${c.note ? " is-" + c.note : ""}`}>
                    {c.note && NOTE_LABEL[c.note] ? <em>{NOTE_LABEL[c.note]}</em> : null}
                    {c.name}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">패턴 요약</p>
        <h2>초봉 데이터로 읽는 2026 채용 시장 흐름</h2>
      </div>
      <div class="pattern-grid">
        {
          seed.patternPoints.map((item) => (
            <article class="pattern-card">
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>

      <div class="distribution-grid salary-sector-grid">
        {
          seed.sectorSummaries.map((item) => (
            <article class="panel distribution-card">
              <h3>{item.label}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <SeoContent
      introTitle="2026 신입사원 초봉 비교 리포트 읽는 법"
      intro={[
        "이 페이지는 2026년 현재 잡플래닛·블라인드 집계, 공개 채용 공고, 언론 보도를 바탕으로 국내 주요 기업의 신입사원 초봉(기본급 기준 연봉)을 업종별로 비교하는 인터랙티브 리포트입니다.",
        "상단은 올해 초봉 시장의 판도를 읽는 영역이고, 중단은 차트로 흐름을 비교하는 영역이며, 하단은 기업별 보상 구조를 더 깊게 보는 탐색 영역으로 구성했습니다. 계산기처럼 즉시 결과만 보여주기보다, 리포트처럼 읽고 해석할 수 있게 설계했습니다.",
      ]}
      inputPoints={[
        "상위권 기업과 업종별 초봉 판도를 먼저 요약해서 읽을 수 있습니다.",
        "전체 초봉 차트와 월 실수령 추정 차트를 나눠서 비교할 수 있습니다.",
        "기업 선택과 내 연봉 기준선 기능으로 세부 탐색까지 이어갈 수 있습니다.",
      ]}
      criteria={[
        "잡플래닛·블라인드 집계, 공개 채용 공고, 언론 보도 기반의 추정치입니다.",
        "기본급 중심 연봉 기준이며, 성과급은 별도 표기했습니다.",
        "월 실수령은 4대보험 및 근로소득 공제를 반영한 추정치입니다.",
        "모든 수치는 참고용이며 채용·처우 협상의 공식 근거로 사용하지 마세요.",
      ]}
      faq={faqItems}
      related={[
        { href: "/tools/salary-tier/", label: "연봉 티어 계산기" },
        { href: "/tools/salary/", label: "연봉 인상 계산기" },
        { href: "/tools/negotiation/", label: "이직 계산기" },
        { href: "/reports/", label: "비교 리포트 모아보기" },
      ]}
    />
  </main>

  <script id="salaryReportData" type="application/json" set:html={JSON.stringify(newEmployeeSalary2026)}></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/new-employee-salary-2026.js")}></script>
</BaseLayout>
