---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  SALARY_COMPARE_META,
  SALARY_COMPARE_DATA,
  SALARY_COMPARE_INSIGHTS,
  SALARY_COMPARE_FAQ,
  SALARY_COMPARE_AFFILIATE,
} from "../../data/salaryCompare2026";

const totalCount = SALARY_COMPARE_DATA.length;
const allSals = SALARY_COMPARE_DATA.map((e) => e.sal);
const overallAvg = Math.round(allSals.reduce((a, b) => a + b, 0) / allSals.length);
const maxSal = Math.max(...allSals);

const faqItems = SALARY_COMPARE_FAQ.map((f) => ({ question: f.q, answer: f.a }));

// 직렬화해서 클라이언트에 전달
const dataJson = JSON.stringify(SALARY_COMPARE_DATA);
const affiliateJson = JSON.stringify(SALARY_COMPARE_AFFILIATE);
---

<BaseLayout title={SALARY_COMPARE_META.title} description={SALARY_COMPARE_META.subtitle}>
  <SiteHeader />

  <main class="container page-shell report-page salary-compare-page">
    <CalculatorHero
      eyebrow="2026 연봉 비교 리포트"
      title="신입 연봉 비교 — 70개 기업 초봉 순위"
      description="반도체·완성차·IT·금융·외국계 주요 기업의 신입 영끌 연봉을 한눈에 비교합니다. 내 연봉을 입력하면 전체 대비 위치를 바로 확인할 수 있습니다."
    />

    <InfoNotice
      title="기준 안내"
      lines={[SALARY_COMPARE_META.methodology, SALARY_COMPARE_META.caution, SALARY_COMPARE_META.updatedAt]}
    />

    <!-- ① KPI 요약 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 수치</p>
        <h2>2026 신입 연봉 현황 요약</h2>
      </div>
      <div class="sc-kpi-grid">
        <article class="report-stat-card report-stat-card--primary">
          <p>비교 기업 수</p>
          <strong>{totalCount}개</strong>
          <span>반도체·완성차·IT 등 6개 업종</span>
        </article>
        <article class="report-stat-card">
          <p>전체 평균 (영끌)</p>
          <strong>{overallAvg.toLocaleString("ko-KR")}만원</strong>
          <span>현금성 복지 포함, 야근수당 제외</span>
        </article>
        <article class="report-stat-card">
          <p>최고 연봉</p>
          <strong>{maxSal.toLocaleString("ko-KR")}만원</strong>
          <span>SK하이닉스 OPI 포함 추정</span>
        </article>
        <article class="report-stat-card">
          <p>S티어 기준</p>
          <strong>9,000만원 이상</strong>
          <span>연봉 상위 약 12% 해당</span>
        </article>
      </div>
    </section>

    <!-- ② 내 연봉 입력 -->
    <section class="content-section sc-my-salary-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">내 위치 확인</p>
        <h2>내 연봉, 전체 기업 대비 몇 위?</h2>
        <p>현재 연봉(또는 제안받은 연봉)을 입력하면 전체 기업 순위 중 내 위치를 보여드립니다.</p>
      </div>

      <div class="sc-input-row">
        <label for="sc-my-sal">내 연봉 (만원)</label>
        <input
          type="number"
          id="sc-my-sal"
          placeholder="예: 4200"
          min="0"
          max="20000"
          step="100"
        />
        <span class="sc-hint" id="sc-hint-text">입력하면 위치를 표시해드려요</span>
      </div>

      <div class="sc-result-card" id="sc-result-card">
        <p class="sc-result-title" id="sc-result-title"></p>
        <div class="sc-result-grid">
          <div class="sc-res-cell"><div class="sc-res-num" id="sc-r-pct">—</div><div class="sc-res-label">전체 상위 %</div></div>
          <div class="sc-res-cell"><div class="sc-res-num" id="sc-r-diff">—</div><div class="sc-res-label">평균 대비</div></div>
          <div class="sc-res-cell"><div class="sc-res-num" id="sc-r-tier">—</div><div class="sc-res-label">연봉 티어</div></div>
        </div>
        <div class="sc-similar-box" id="sc-similar-text"></div>
      </div>
    </section>

    <!-- ③ 바 차트 비교 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">전체 기업 비교</p>
        <h2>업종별 연봉 순위 한눈에 보기</h2>
      </div>

      <div class="sc-summary-bar" id="sc-summary-bar"></div>

      <div class="sc-filter-row">
        <button class="sc-ftab sc-ftab--on" data-cat="all">전체</button>
        <button class="sc-ftab" data-cat="semi">반도체</button>
        <button class="sc-ftab" data-cat="car">완성차·부품</button>
        <button class="sc-ftab" data-cat="it">IT·플랫폼</button>
        <button class="sc-ftab" data-cat="chem">화학·에너지</button>
        <button class="sc-ftab" data-cat="fin">금융</button>
        <button class="sc-ftab" data-cat="for">외국계</button>
        <select class="sc-sort-sel" id="sc-sort-sel">
          <option value="desc">높은순</option>
          <option value="asc">낮은순</option>
          <option value="name">가나다순</option>
        </select>
      </div>

      <div id="sc-chart-area"></div>
    </section>

    <!-- ④ 업종별 인사이트 -->
    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">업종별 분석</p>
        <h2>업종별 연봉 인사이트 — 어느 업종이 유리한가</h2>
        <p>단순 연봉 숫자 외에 업종 특성과 성과급 구조 차이를 함께 살펴보세요.</p>
      </div>
      <div class="sc-insight-grid">
        {SALARY_COMPARE_INSIGHTS.map((ins) => (
          <article class="sc-ins-card">
            <div class="sc-ins-industry">
              <span class="sc-ins-dot" style={`background:${ins.color}`}></span>
              {ins.industry}
            </div>
            <div class="sc-ins-range">{ins.range}</div>
            <p class="sc-ins-note">{ins.note}</p>
            <span class="sc-ins-avg">{ins.avg}</span>
          </article>
        ))}
      </div>
    </section>

  

    <SeoContent
      introTitle="2026 신입 연봉 비교 리포트 읽는 법"
      intro={[
        "이 페이지는 2026년 현재 잡플래닛·블라인드 집계, 공개 채용 공고, 언론 보도를 바탕으로 반도체·완성차·IT·금융·외국계 등 주요 기업 70개의 신입 영끌 연봉을 한눈에 비교하는 인터랙티브 리포트입니다.",
        "내 연봉(또는 제안받은 연봉)을 입력하면 전체 기업 순위 중 내 위치와 연봉 티어를 즉시 확인할 수 있습니다. 업종 필터와 정렬 옵션을 활용해 원하는 비교 구간만 골라볼 수 있습니다.",
      ]}
      inputPoints={[
        "70개 기업의 신입 영끌 연봉을 업종별로 필터링하고 비교할 수 있습니다.",
        "내 연봉을 입력하면 전체 대비 상위 % · 평균 대비 차이 · 연봉 티어(S/A/B/C)를 즉시 표시합니다.",
        "업종별 인사이트에서 반도체·완성차·IT·금융·외국계의 성과급 구조 차이를 확인할 수 있습니다.",
      ]}
      criteria={[
        "잡플래닛·블라인드 집계, 공개 채용 공고, 언론 보도 기반의 추정치입니다.",
        "영끌 연봉은 기본급 + 현금성 복지(식대·교통비 등) + 평균적 성과급(OPI/PS) 포함 기준입니다.",
        "야근수당·특별상여 등 비정기 지급분은 제외했습니다.",
        "모든 수치는 참고용이며 채용·처우 협상의 공식 근거로 사용하지 마세요.",
      ]}
      faq={faqItems}
      related={[
        { href: "/tools/negotiation/", label: "이직 계산기" },
        { href: "/tools/bonus-simulator/", label: "대기업 성과급 시뮬레이터" },
        { href: "/tools/salary/", label: "연봉 인상 계산기" },
        { href: "/reports/new-employee-salary-2026/", label: "2026 신입사원 초봉 리포트" },
      ]}
    />
  </main>
</BaseLayout>

<script define:vars={{ dataJson, affiliateJson }}>
  const DATA = JSON.parse(dataJson);
  const MAX_SAL = 15000;
  const AVG = Math.round(DATA.reduce((s, e) => s + e.sal, 0) / DATA.length);

  let curFilter = "all";
  let curSort = "desc";
  let mySal = null;

  const TIER_META = {
    s: { label: "S티어 · 9,000만 이상",     color: "#9FE1CB", textColor: "#085041" },
    a: { label: "A티어 · 6,000 ~ 9,000만",  color: "#C0DD97", textColor: "#27500A" },
    b: { label: "B티어 · 5,000 ~ 6,500만",  color: "#D3D1C7", textColor: "#444441" },
    c: { label: "C티어 · 5,000만 미만",      color: "#FAC775", textColor: "#633806" },
  };

  function getFiltered() {
    let d = curFilter === "all" ? [...DATA] : DATA.filter((x) => x.cat === curFilter);
    if (curSort === "desc") d.sort((a, b) => b.sal - a.sal);
    else if (curSort === "asc") d.sort((a, b) => a.sal - b.sal);
    else d.sort((a, b) => a.name.localeCompare(b.name, "ko"));
    return d;
  }

  function renderChart() {
    const area = document.getElementById("sc-chart-area");
    const filtered = getFiltered();

    let html = "";
    for (const tier of ["s", "a", "b", "c"]) {
      const rows = filtered.filter((x) => x.tier === tier);
      if (!rows.length) continue;
      const m = TIER_META[tier];
      html += `<div class="sc-tier-label">
        <span style="width:8px;height:8px;border-radius:50%;background:${m.color};display:inline-block;flex-shrink:0;"></span>
        ${m.label}
      </div>`;
      for (const co of rows) {
        const pct = Math.round((co.sal / MAX_SAL) * 100);
        const myPct = mySal ? Math.round((mySal / MAX_SAL) * 100) : null;
        html += `<div class="sc-bar-row">
          <div class="sc-bar-company" title="${co.name}">${co.name}</div>
          <div class="sc-bar-track">
            <div class="sc-bar-fill" style="width:${pct}%;background:${m.color}">
              <span class="sc-bar-val" style="color:${m.textColor}">${co.sal.toLocaleString()}만</span>
              ${co.note ? `<span class="sc-bar-tag">${co.note}</span>` : ""}
            </div>
            ${myPct ? `<div class="sc-my-line" style="left:${myPct}%;"></div>` : ""}
          </div>
        </div>`;
      }
    }
    area.innerHTML = html;

    // 요약 바
    const allSals = filtered.map((x) => x.sal);
    const avg = allSals.length ? Math.round(allSals.reduce((a, b) => a + b, 0) / allSals.length) : 0;
    const max = allSals.length ? Math.max(...allSals) : 0;
    const min = allSals.length ? Math.min(...allSals) : 0;
    document.getElementById("sc-summary-bar").innerHTML = `
      <div class="sc-sum-cell"><div class="sc-sum-num">${filtered.length}<span style="font-size:13px">개</span></div><div class="sc-sum-label">표시 기업 수</div></div>
      <div class="sc-sum-cell"><div class="sc-sum-num" style="color:#1D9E75;">${max.toLocaleString()}<span style="font-size:11px">만</span></div><div class="sc-sum-label">최고 연봉</div></div>
      <div class="sc-sum-cell"><div class="sc-sum-num">${avg.toLocaleString()}<span style="font-size:11px">만</span></div><div class="sc-sum-label">필터 평균</div></div>
      <div class="sc-sum-cell"><div class="sc-sum-num" style="color:#BA7517;">${min.toLocaleString()}<span style="font-size:11px">만</span></div><div class="sc-sum-label">최저 연봉</div></div>
    `;
  }

  function updateMyPos() {
    const val = parseInt(document.getElementById("sc-my-sal").value);
    if (!val || val < 500) {
      mySal = null;
      document.getElementById("sc-result-card").style.display = "none";
      document.getElementById("sc-hint-text").textContent = "입력하면 위치를 표시해드려요";
      renderChart();
      return;
    }
    mySal = val;
    renderChart();

    const allSals = DATA.map((x) => x.sal).sort((a, b) => a - b);
    const rank = allSals.filter((s) => s <= val).length;
    const pct = Math.round((rank / allSals.length) * 100);
    const diff = val - AVG;
    const diffStr = diff >= 0 ? `+${diff.toLocaleString()}만` : `${diff.toLocaleString()}만`;
    const tier = val >= 9000 ? "S" : val >= 6000 ? "A" : val >= 5000 ? "B" : "C";
    const similar = DATA.filter((x) => Math.abs(x.sal - val) <= 500).slice(0, 4).map((x) => x.name);
    const above = DATA.filter((x) => x.sal > val).sort((a, b) => a.sal - b.sal).slice(0, 2)
      .map((x) => `${x.name}(${x.sal.toLocaleString()}만)`);

    document.getElementById("sc-r-pct").textContent = `${pct}%`;
    document.getElementById("sc-r-diff").textContent = diffStr;
    document.getElementById("sc-r-tier").textContent = tier + "티어";
    document.getElementById("sc-result-title").textContent = `내 연봉 ${val.toLocaleString()}만원 기준 위치`;

    let simHTML = "";
    if (similar.length) simHTML += `비슷한 수준의 기업: <strong>${similar.join(", ")}</strong><br>`;
    if (above.length) simHTML += `<span style="font-size:12px;color:var(--color-text-tertiary);">바로 위 기업: ${above.join(" · ")}</span>`;
    document.getElementById("sc-similar-text").innerHTML = simHTML || "비교 구간 내 데이터가 없습니다.";

    document.getElementById("sc-result-card").style.display = "block";
    document.getElementById("sc-hint-text").innerHTML = `<strong>상위 ${pct}%</strong> · 평균 대비 ${diffStr} · ${tier}티어`;
  }

  // 필터 버튼
  document.querySelectorAll(".sc-ftab").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".sc-ftab").forEach((b) => b.classList.remove("sc-ftab--on"));
      btn.classList.add("sc-ftab--on");
      curFilter = btn.dataset.cat;
      renderChart();
    });
  });

  // 정렬 셀렉트
  document.getElementById("sc-sort-sel").addEventListener("change", (e) => {
    curSort = e.target.value;
    renderChart();
  });

  // 연봉 입력
  document.getElementById("sc-my-sal").addEventListener("input", updateMyPos);

  // 초기 렌더
  renderChart();

</script>
