---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  SPAP_APARTMENTS,
  SPAP_AREA_CARDS,
  SPAP_CONTEXT,
  SPAP_FAQ,
  SPAP_META,
  SPAP_METHOD,
  SPAP_RELATED_LINKS,
  SPAP_RISKS,
  SPAP_SEO_CRITERIA,
  SPAP_SEO_INTRO,
} from "../../data/songpaApartmentPrice2026";
import { withBase } from "../../utils/base";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${SPAP_META.slug}/`;
const defaultApartment = SPAP_APARTMENTS[0];
const maxPrice = SPAP_APARTMENTS.reduce((max, row) => (row.latestTradePriceManwon > max.latestTradePriceManwon ? row : max), defaultApartment);
const maxGain = SPAP_APARTMENTS.reduce((max, row) => (row.estimatedGainManwon > max.estimatedGainManwon ? row : max), defaultApartment);
const jamsilCount = SPAP_APARTMENTS.filter((row) => row.areaGroup === "잠실·신천권").length;
const southeastCount = SPAP_APARTMENTS.filter((row) => row.areaGroup === "가락·헬리오시티권" || row.areaGroup === "문정·장지권").length;
const redevelopmentCount = SPAP_APARTMENTS.filter((row) => row.areaGroup === "재건축 기대권").length;

const formatEok = (manwon: number) => {
  const eok = manwon / 10000;
  const fixed = eok >= 10 ? eok.toFixed(1) : eok.toFixed(2);
  return `${fixed.replace(/\.0$/, "")}억원`;
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: SPAP_META.title,
      description: SPAP_META.description,
      dateModified: SPAP_META.updatedAt,
      inLanguage: "ko-KR",
      mainEntityOfPage: reportUrl,
      author: { "@type": "Organization", name: "비교계산소" },
      about: ["송파 아파트", "잠실 아파트", "헬리오시티", "잠실엘스", "송파 실거래가"],
    },
    {
      "@type": "FAQPage",
      mainEntity: SPAP_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
        { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
        { "@type": "ListItem", position: 3, name: SPAP_META.title, item: reportUrl },
      ],
    },
  ],
};
---

<BaseLayout title={SPAP_META.seoTitle} description={SPAP_META.description} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page spap-page" data-report="songpa-apartment-price-2026">
    <CalculatorHero
      eyebrow="송파 실거래가 리포트"
      title="송파 대장 아파트, 최저가일 때 샀다면 지금 얼마를 벌었을까?"
      description={SPAP_META.description}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        SPAP_META.notice,
        "이 리포트는 서울특별시 송파구 행정구역을 기준으로 하며, 생활권은 잠실·올림픽공원·가락·문정 등으로 나눠 표시합니다.",
        "재건축 기대감은 현재 실거래가와 분리해서 해석해야 하며, 사업 속도·분담금·입주시점은 확정값처럼 표시하지 않습니다.",
        "최저가 대비 금액은 세금·중개보수·대출이자·보유비용을 반영하지 않은 평가차익(추정)입니다.",
        "이 리포트는 투자 권유가 아니며, 실제 거래 판단은 국토교통부 실거래가 공개시스템과 현장 확인을 기준으로 해야 합니다.",
      ]}
    />

    <section class="spap-summary" aria-labelledby="spap-summary-title">
      <div class="spap-section-head">
        <p>요약</p>
        <h2 id="spap-summary-title">송파 Top10 후보 기준 한눈에 보기</h2>
      </div>
      <div class="spap-summary-grid">
        <article class="spap-summary-card">
          <span>데이터 기준</span>
          <strong>{SPAP_META.updatedAt}</strong>
          <p>{SPAP_META.dataAsOf}</p>
        </article>
        <article class="spap-summary-card">
          <span>최고 기준가</span>
          <strong>{formatEok(maxPrice.latestTradePriceManwon)}</strong>
          <p>{maxPrice.complexName} 후보값</p>
        </article>
        <article class="spap-summary-card">
          <span>최대 평가차익(추정)</span>
          <strong>{formatEok(maxGain.estimatedGainManwon)}</strong>
          <p>{maxGain.complexName} 기준 단순 시세 차이</p>
        </article>
        <article class="spap-summary-card">
          <span>생활권 구성</span>
          <strong>{jamsilCount}/{southeastCount}/{redevelopmentCount}</strong>
          <p>잠실권 / 가락·문정권 / 재건축 기대권</p>
        </article>
      </div>
    </section>

    <section class="spap-picker" aria-labelledby="spap-picker-title">
      <div class="spap-section-head">
        <p>단지별 카드</p>
        <h2 id="spap-picker-title">최저가일 때 샀다면 지금 평가차익은?</h2>
      </div>

      <div class="spap-tabs" role="tablist" aria-label="송파 아파트 단지 선택">
        {SPAP_APARTMENTS.map((row, index) => (
          <button
            class={`spap-tab${index === 0 ? " is-active" : ""}`}
            type="button"
            data-complex={row.id}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            {row.rank}. {row.complexName}
          </button>
        ))}
      </div>

      <article class="spap-profit-card" aria-live="polite">
        <div class="spap-profit-card__main">
          <span class="spap-badge" data-spap-field="badge">{defaultApartment.badge}</span>
          <h3 data-spap-field="complexName">{defaultApartment.complexName}</h3>
          <p class="spap-area-line" data-spap-field="areaLine">
            {defaultApartment.legalDongLabel} · {defaultApartment.areaGroup} · {defaultApartment.stationLabel}
          </p>
          <p data-spap-field="profitSentence">
            {defaultApartment.fiveYearLowDate} {formatEok(defaultApartment.fiveYearLowPriceManwon)}에 거래됐고, 현재 기준가는 {formatEok(defaultApartment.latestTradePriceManwon)}입니다.
          </p>
          <div class="spap-profit-card__numbers">
            <div>
              <span>평가차익(추정)</span>
              <strong data-spap-field="gain">{formatEok(defaultApartment.estimatedGainManwon)}</strong>
            </div>
            <div>
              <span>상승률(추정)</span>
              <strong data-spap-field="gainRate">{defaultApartment.estimatedGainRate}%</strong>
            </div>
          </div>
        </div>
        <dl class="spap-profit-card__meta">
          <div><dt>최근 기준가</dt><dd data-spap-field="latest">{formatEok(defaultApartment.latestTradePriceManwon)}</dd></div>
          <div><dt>거래월·면적</dt><dd data-spap-field="latestMeta">{defaultApartment.latestTradeDate} · {defaultApartment.latestTradeArea}</dd></div>
          <div><dt>5년 저점 참고</dt><dd data-spap-field="low">{formatEok(defaultApartment.fiveYearLowPriceManwon)}</dd></div>
          <div><dt>생활권 메모</dt><dd data-spap-field="parkNote">{defaultApartment.parkNote}</dd></div>
          <div><dt>재건축 메모</dt><dd data-spap-field="redevelopmentNote">{defaultApartment.redevelopmentNote ?? "재건축 기대 단지로 분류하지 않았습니다."}</dd></div>
          <div><dt>주의</dt><dd data-spap-field="note">{defaultApartment.note}</dd></div>
        </dl>
      </article>
      <p class="spap-plain-note">
        이 금액은 취득세, 중개보수, 보유세, 대출이자, 양도소득세를 반영하지 않은 단순 시세 차이입니다. 같은 단지라도 동·층·향·면적·거래 시점에 따라 실제 가격은 크게 달라질 수 있습니다.
      </p>
    </section>

    <section class="spap-table-section" aria-labelledby="spap-table-title">
      <div class="spap-section-head spap-section-head--row">
        <div>
          <p>비교표</p>
          <h2 id="spap-table-title">송파 대장 아파트 Top10 실거래가</h2>
        </div>
        <div class="spap-sort-controls" aria-label="정렬 기준">
          <button class="is-active" type="button" data-sort="rank">순위</button>
          <button type="button" data-sort="gain">평가차익</button>
          <button type="button" data-sort="gainRate">상승률</button>
          <button type="button" data-sort="latestPrice">최근가</button>
          <button type="button" data-sort="area">생활권</button>
        </div>
      </div>
      <div class="spap-table-wrap">
        <table class="spap-table">
          <caption>송파 아파트 Top10 후보의 최근 기준가와 5년 저점 대비 평가차익 비교</caption>
          <thead>
            <tr>
              <th scope="col">순위</th>
              <th scope="col">단지명</th>
              <th scope="col">법정동</th>
              <th scope="col">생활권</th>
              <th scope="col">최근 실거래가</th>
              <th scope="col">거래월</th>
              <th scope="col">2025 대비</th>
              <th scope="col">5년 저점 참고</th>
              <th scope="col">평가차익(추정)</th>
              <th scope="col">전세가율</th>
              <th scope="col">주의</th>
            </tr>
          </thead>
          <tbody data-spap-table-body>
            {SPAP_APARTMENTS.map((row) => (
              <tr data-row-id={row.id}>
                <td>{row.rank}</td>
                <th scope="row">
                  <strong>{row.complexName}</strong>
                  <span>{row.mainAreaLabel}</span>
                </th>
                <td>{row.legalDongLabel}</td>
                <td>{row.areaGroup}</td>
                <td>{formatEok(row.latestTradePriceManwon)}</td>
                <td>{row.latestTradeDate}</td>
                <td>{row.previousYearPriceManwon ? `${formatEok(row.latestTradePriceManwon - row.previousYearPriceManwon)} 상승 참고` : "확인 필요"}</td>
                <td>{formatEok(row.fiveYearLowPriceManwon)}</td>
                <td>{formatEok(row.estimatedGainManwon)} · {row.estimatedGainRate}%</td>
                <td>{row.jeonseRatio ? `${row.jeonseRatio}% 참고` : "확인 필요"}</td>
                <td>{row.tradeCountNote}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="spap-area-map" aria-labelledby="spap-area-title">
      <div class="spap-section-head">
        <p>생활권 분해</p>
        <h2 id="spap-area-title">잠실·올림픽공원·가락·문정 생활권 가격 차이</h2>
      </div>
      <div class="spap-area-grid" data-spap-area-cards>
        {SPAP_AREA_CARDS.map((card) => (
          <article class={`spap-area-card${card.areaGroup === defaultApartment.areaGroup ? " is-selected" : ""}`} data-area-group={card.areaGroup}>
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
            <strong>{card.priceInterpretation}</strong>
            <small>{card.caution}</small>
          </article>
        ))}
      </div>
      <p class="spap-plain-note">
        송파구는 잠실 대단지와 헬리오시티, 올림픽공원권 구축, 문정 업무지구 인접 단지의 가격 논리가 다릅니다. 같은 송파구 안에서도 생활권, 입주연식, 재건축 기대감, 면적, 거래 시점에 따라 가격 차이가 크게 나타날 수 있습니다.
      </p>
    </section>

    <section class="spap-chart" aria-labelledby="spap-chart-title">
      <div class="spap-section-head">
        <p>막대 비교</p>
        <h2 id="spap-chart-title">현재 기준가 vs 5년 저점 참고가</h2>
      </div>
      <div class="spap-bar-list" data-spap-bars>
        {SPAP_APARTMENTS.map((row) => (
          <article class="spap-bar-row" data-row-id={row.id}>
            <div class="spap-bar-row__label">
              <strong>{row.complexName}</strong>
              <span>{row.areaGroup} · {row.badge}</span>
            </div>
            <div class="spap-bar-row__bars">
              <span class="spap-bar spap-bar--latest" style={`width: ${(row.latestTradePriceManwon / maxPrice.latestTradePriceManwon) * 100}%`}>{formatEok(row.latestTradePriceManwon)}</span>
              <span class="spap-bar spap-bar--low" style={`width: ${(row.fiveYearLowPriceManwon / maxPrice.latestTradePriceManwon) * 100}%`}>{formatEok(row.fiveYearLowPriceManwon)}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="spap-context" aria-labelledby="spap-context-title">
      <div class="spap-section-head">
        <p>가격 맥락</p>
        <h2 id="spap-context-title">송파 아파트가 비싼 이유와 해석 기준</h2>
      </div>
      <div class="spap-context-grid">
        {SPAP_CONTEXT.map((card) => (
          <article class="spap-context-card">
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="spap-data-method" aria-labelledby="spap-method-title">
      <div class="spap-section-head">
        <p>데이터 기준</p>
        <h2 id="spap-method-title">송파 실거래가 데이터 기준</h2>
      </div>
      <ul class="spap-risk-list">
        {SPAP_METHOD.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="spap-risk" aria-labelledby="spap-risk-title">
      <div class="spap-section-head">
        <p>리스크</p>
        <h2 id="spap-risk-title">평가차익보다 먼저 봐야 하는 변수</h2>
      </div>
      <ul class="spap-risk-list">
        {SPAP_RISKS.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="spap-related" aria-labelledby="spap-related-title">
      <div class="spap-section-head">
        <p>다음 단계</p>
        <h2 id="spap-related-title">송파 가격 확인 뒤 이어서 볼 리포트와 계산기</h2>
      </div>
      <div class="spap-related-grid">
        {SPAP_RELATED_LINKS.map((link) => (
          <a class="spap-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="송파 아파트 실거래가를 볼 때 먼저 확인할 것"
      intro={SPAP_SEO_INTRO}
      criteria={SPAP_SEO_CRITERIA}
      faq={SPAP_FAQ}
      related={SPAP_RELATED_LINKS}
    />

    <script type="application/json" id="spap-data" set:html={JSON.stringify(SPAP_APARTMENTS)}></script>
    <script type="application/json" id="spap-area-data" set:html={JSON.stringify(SPAP_AREA_CARDS)}></script>
    <script src={withBase("/scripts/songpa-apartment-price-2026.js")} defer></script>
  </main>
</BaseLayout>
