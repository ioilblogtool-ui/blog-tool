---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  GROUP_HUB_META,
  GROUP_SUMMARY_ROWS,
  GROUP_HUB_KPIS,
  STRUCTURE_TYPE_LABELS,
  STRUCTURE_TYPE_DESCRIPTIONS,
  LISTING_DEPTH_ROWS,
  DOUBLE_LISTING_ROWS,
  INVESTMENT_EXPOSURE_ROWS,
  HUB_CALCULATOR_LINKS,
  GROUP_HUB_FAQ,
} from "../../data/groupOwnershipSummary2026";

const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteUrl}/reports/group-ownership-hub-2026/`;

const title = "대한민국 대기업 9개 그룹 지분구조 비교 2026 | 공식 기준일·구조 유형 정리";
const description =
  "삼성·SK·현대차·LG·한화·롯데·HD현대·LS·두산 9개 그룹의 지분구조를 2026년 공정위 기준일과 검증 상태 중심으로 비교합니다.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": pageUrl,
  url: pageUrl,
  headline: title,
  description,
  inLanguage: "ko-KR",
  datePublished: GROUP_HUB_META.updatedAt,
  dateModified: GROUP_HUB_META.updatedAt,
};

const sortedByRank = [...GROUP_SUMMARY_ROWS].sort((a, b) => a.rank - b.rank);
const legalHoldingCount = sortedByRank.filter((row) => row.legalHoldingCompany !== "없음" && row.legalHoldingCompany !== "공식 확인 필요").length;
const circularCount = sortedByRank.filter((row) => row.structureType === "CIRCULAR").length;
const restructuringCount = sortedByRank.filter((row) => row.volatility === "높음" || row.structureType === "RESTRUCTURING").length;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiteHeader />
  <main class="container page-shell gho-page">
    <CalculatorHero
      eyebrow="대기업 지분구조"
      title="대한민국 대기업 9개 그룹 지분구조 비교 2026"
      description="상세 페이지의 지분율을 한 화면에 무리하게 모으기보다, 공식 기준일·검증 상태·구조 유형을 중심으로 보수적으로 비교했습니다."
    />

    <InfoNotice
      title="데이터 기준과 검증 범위"
      lines={[
        `공식 기준일은 ${GROUP_HUB_META.baseDate}입니다. 공정위는 2026년 공시대상기업집단 ${GROUP_HUB_META.officialGroupCount}개, 소속회사 ${GROUP_HUB_META.officialAffiliateCount.toLocaleString("ko-KR")}개를 지정했습니다.`,
        "이 허브는 그룹 간 비교용 요약입니다. 지분율·계산식·개별 출처는 그룹별 상세 페이지에서 확인하는 구조로 분리했습니다.",
        "상장 계열사 수는 '확인 국내 상장 계열사' 기준이며, 그룹별 기준일과 검증 범위가 다를 수 있어 상태값을 함께 표시합니다.",
      ]}
    />

    <section class="content-section" aria-labelledby="kpi-title">
      <h2 id="kpi-title">비교 허브 핵심 KPI</h2>
      <div class="gho-kpi-grid">
        {
          GROUP_HUB_KPIS.map((card) => (
            <article class="gho-kpi-card">
              <span>{card.label}</span>
              <strong>{card.value}</strong>
              <p>{card.note}</p>
            </article>
          ))
        }
      </div>
      <p class="gho-small-note">
        9개 그룹 중 법적 지주회사 중심으로 볼 수 있는 곳은 {legalHoldingCount}곳, 순환 연결이 핵심인 곳은 {circularCount}곳,
        구조 변동성이 높은 곳은 {restructuringCount}곳으로 분류했습니다.
      </p>
    </section>

    <section class="content-section" aria-labelledby="summary-title">
      <h2 id="summary-title">9개 그룹 핵심 비교표</h2>
      <div class="gho-summary-table-wrap">
        <table class="gho-summary-table">
          <thead>
            <tr>
              <th>순위</th>
              <th>그룹</th>
              <th>법적 지주회사</th>
              <th>구조 유형</th>
              <th>계열사 수</th>
              <th>확인 상장사</th>
              <th>상장 깊이</th>
              <th>구조 상태</th>
              <th>핵심 특징</th>
            </tr>
          </thead>
          <tbody>
            {
              sortedByRank.map((row) => (
                <tr>
                  <td><span class="gho-rank">{row.rank}</span></td>
                  <td><a href={`/reports/${row.slug}/`}>{row.groupName}</a></td>
                  <td>{row.legalHoldingCompany}</td>
                  <td><span class={`gho-type gho-type--${row.structureType.toLowerCase()}`}>{row.structureLabel}</span></td>
                  <td>{row.affiliateCount}개</td>
                  <td>{row.listedCount}개 · {row.listedCountStatus}</td>
                  <td>{row.maxListedDepth}</td>
                  <td>{row.restructuringStatus}</td>
                  <td>{row.keyFeature}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section" aria-labelledby="type-title">
      <h2 id="type-title">구조 유형별로 보기</h2>
      <div class="gho-type-grid">
        {
          STRUCTURE_TYPE_DESCRIPTIONS.map((item) => (
            <article>
              <span>{STRUCTURE_TYPE_LABELS[item.type]}</span>
              <strong>{item.groups}</strong>
              <p>{item.note}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="affiliate-title">
      <h2 id="affiliate-title">계열사 수와 확인 상장사 수</h2>
      <div class="gho-bar-list">
        {
          sortedByRank.map((row) => (
            <article>
              <div>
                <strong>{row.groupName}</strong>
                <span>{row.affiliateCount}개 계열사 · 상장 {row.listedCount}개 ({row.listedCountStatus})</span>
              </div>
              <meter min="0" max="151" value={row.affiliateCount}>{row.affiliateCount}</meter>
            </article>
          ))
        }
      </div>
      <p class="gho-small-note">계열사 수는 공정위 지정 자료 기준이며, 상장사 수는 허브 내 비교를 위한 확인 범위입니다.</p>
    </section>

    <section class="content-section" aria-labelledby="depth-title">
      <h2 id="depth-title">최대 상장 깊이와 대표 경로</h2>
      <table class="gho-summary-table">
        <thead>
          <tr>
            <th>그룹</th>
            <th>대표 상장 경로</th>
            <th>깊이</th>
            <th>해석</th>
          </tr>
        </thead>
        <tbody>
          {
            LISTING_DEPTH_ROWS.map((row) => (
              <tr>
                <td>{row.group}</td>
                <td>{row.path}</td>
                <td>{row.depth}</td>
                <td>{row.note}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="double-title">
      <h2 id="double-title">중복상장·상장 자회사 이슈</h2>
      <table class="gho-summary-table">
        <thead>
          <tr>
            <th>그룹</th>
            <th>대표 구조</th>
            <th>투자자 관점</th>
          </tr>
        </thead>
        <tbody>
          {
            DOUBLE_LISTING_ROWS.map((row) => (
              <tr>
                <td>{row.group}</td>
                <td>{row.structure}</td>
                <td>{row.investorIssue}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="exposure-title">
      <h2 id="exposure-title">직접 사업회사 주식과 간접 지주사 투자의 차이</h2>
      <table class="gho-summary-table">
        <thead>
          <tr>
            <th>투자 테마</th>
            <th>직접적인 회사</th>
            <th>간접·분산 노출</th>
          </tr>
        </thead>
        <tbody>
          {
            INVESTMENT_EXPOSURE_ROWS.map((row) => (
              <tr>
                <td>{row.theme}</td>
                <td>{row.direct}</td>
                <td>{row.indirect}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <p class="gho-small-note">직접 사업회사가 항상 더 좋다는 뜻은 아닙니다. 실적 민감도, 할인 요인, 포트폴리오 분산 효과가 서로 다릅니다.</p>
    </section>

    <section class="content-section" aria-labelledby="cards-title">
      <h2 id="cards-title">그룹별 상세 리포트</h2>
      <div class="gho-card-grid">
        {
          sortedByRank.map((row) => (
            <a class="gho-group-card" href={`/reports/${row.slug}/`}>
              <span>{row.structureLabel}</span>
              <h3>{row.groupName}그룹</h3>
              <p>{row.investorNote}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="calculator-title">
      <h2 id="calculator-title">관련 계산기와 리포트</h2>
      <div class="gho-link-grid">
        {
          HUB_CALCULATOR_LINKS.map((item) => (
            <a href={item.href}>
              <strong>{item.label}</strong>
              <span>{item.description}</span>
            </a>
          ))
        }
      </div>
    </section>

    <SeoContent
      introTitle="대기업 9개 그룹, 같은 기준으로 비교해야 보입니다"
      intro={[
        "대기업 지분구조를 비교할 때 가장 위험한 방식은 상세 페이지의 지분율과 재편 이슈를 검증 상태 없이 한 표에 모두 모으는 것입니다. 이 허브는 2026년 5월 1일 공정위 공시대상기업집단 지정 기준을 출발점으로 삼고, 그룹별 세부 지분율은 상세 리포트로 분리했습니다.",
        "삼성은 법적 지주회사가 없는 복합 지분 연결, SK는 지주사와 중간지주, 현대차는 순환 연결, LG는 상대적으로 단순한 지주회사형, 한화는 재편 진행형, 롯데는 국내 지주와 한일 연결, HD현대는 조선 중간지주, LS는 병렬 사촌경영, 두산은 복합기업형 핵심회사로 나눠 볼 수 있습니다.",
        "투자자에게 중요한 질문은 '누가 지배하나'만이 아닙니다. 내가 사는 주식이 사업회사인지, 지주사인지, 중간지주인지, 상장 자회사를 다시 보유한 회사인지에 따라 실적 민감도와 할인 요인이 달라집니다.",
      ]}
      criteria={[
        `공식 기준일은 ${GROUP_HUB_META.baseDate}이며, 공정위 발표의 공시대상기업집단 ${GROUP_HUB_META.officialGroupCount}개·소속회사 ${GROUP_HUB_META.officialAffiliateCount.toLocaleString("ko-KR")}개 수치를 기준으로 삼았습니다.`,
        "상장 계열사 수는 그룹별 상세 리포트에서 확인한 국내 상장사 기준이며, 완전한 공식 집계처럼 보이지 않도록 검증 상태를 함께 표시했습니다.",
        "순환출자, 병렬 사촌경영, 재편 진행, 법적 지주회사 여부는 같은 의미가 아니므로 별도 컬럼으로 분리했습니다.",
        "간접 지분율과 NAV 계산은 허브가 아니라 상세 리포트와 계산기에서 다룹니다.",
      ]}
      faq={GROUP_HUB_FAQ}
      related={[
        { href: "/tools/indirect-ownership-calculator/", label: "간접 지분율 계산기 2026" },
        { href: "/reports/samsung-group-ownership-2026/", label: "삼성그룹 지분구조 2026" },
        { href: "/reports/sk-group-ownership-2026/", label: "SK그룹 지분구조 2026" },
        { href: "/reports/hyundai-motor-group-ownership-2026/", label: "현대차그룹 지분구조 2026" },
        { href: "/reports/lg-group-ownership-2026/", label: "LG그룹 지분구조 2026" },
        { href: "/reports/hanwha-group-ownership-2026/", label: "한화그룹 지분구조 2026" },
        { href: "/reports/lotte-group-ownership-2026/", label: "롯데그룹 지분구조 2026" },
        { href: "/reports/hd-hyundai-group-ownership-2026/", label: "HD현대그룹 지분구조 2026" },
        { href: "/reports/ls-group-ownership-2026/", label: "LS그룹 지분구조 2026" },
        { href: "/reports/doosan-group-ownership-2026/", label: "두산그룹 지분구조 2026" },
      ]}
    />
  </main>
</BaseLayout>
