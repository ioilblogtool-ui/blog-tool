---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  calcFinancialAssetRatio,
  calcNetAssets,
  calcOtherAssets,
  calcRealEstateRatio,
  formatManwon,
  formatPercent,
  seoulMayorCandidateAssets2026,
} from "../../data/seoulMayorCandidateAssets2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const report = seoulMayorCandidateAssets2026;
const candidates = report.candidates;
const ohCandidate = candidates.find((candidate) => candidate.id === "oh-sehoon") ?? candidates[0];
const jungCandidate = candidates.find((candidate) => candidate.id === "jung-wonoh") ?? candidates[1];
const faqItems = report.faq.map((item) => ({ question: item.q, answer: item.a }));
const maxTotal = Math.max(...candidates.map((candidate) => candidate.totalAssetsManwon));
const assetGap = ohCandidate.totalAssetsManwon - jungCandidate.totalAssetsManwon;
const assetMultiple = ohCandidate.totalAssetsManwon / jungCandidate.totalAssetsManwon;

const tableRows = [
  { label: "총재산 신고액", getter: (id: string) => candidates.find((c) => c.id === id)?.totalAssetsManwon, badge: "재산공개" },
  { label: "부동산 합계", getter: (id: string) => candidates.find((c) => c.id === id)?.realEstateManwon, badge: "보도확인" },
  { label: "토지", getter: (id: string) => candidates.find((c) => c.id === id)?.landManwon, badge: "보도확인" },
  { label: "건물·아파트", getter: (id: string) => candidates.find((c) => c.id === id)?.buildingManwon, badge: "보도확인" },
  { label: "예금", getter: (id: string) => candidates.find((c) => c.id === id)?.depositsManwon, badge: "보도확인" },
  { label: "증권", getter: (id: string) => candidates.find((c) => c.id === id)?.securitiesManwon, badge: "보도확인" },
  { label: "채무", getter: (id: string) => candidates.find((c) => c.id === id)?.debtsManwon, badge: "보도확인" },
  { label: "기타·차액", getter: (id: string) => calcOtherAssets(candidates.find((c) => c.id === id)!), badge: "계산" },
  { label: "순재산", getter: (id: string) => calcNetAssets(candidates.find((c) => c.id === id)!), badge: "재산공개" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: report.meta.title,
      description: report.meta.description,
      keywords: ["오세훈 재산", "오세훈 재산신고", "오세훈 재산목록", "서울시장 후보 재산"],
      about: [
        { "@type": "Person", name: "오세훈" },
        { "@type": "Thing", name: "서울시장 후보 재산신고액" },
      ],
      inLanguage: "ko-KR",
      dateModified: "2026-06-06",
      mainEntityOfPage: `https://bigyocalc.com/reports/${report.meta.slug}/`,
      author: { "@type": "Organization", name: "비교계산소" },
      publisher: { "@type": "Organization", name: "비교계산소" },
    },
    {
      "@type": "FAQPage",
      mainEntity: report.faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    },
  ],
};
---

<BaseLayout title={report.meta.title} description={report.meta.description} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page smca-page" data-report="seoul-mayor-candidate-assets-2026">
    <CalculatorHero
      eyebrow={report.meta.eyebrow}
      title={report.meta.h1}
      description="오세훈 재산 신고액과 정원오 재산신고액을 총재산, 부동산, 예금, 증권, 채무 기준으로 나눠 비교합니다."
      badges={["오세훈 재산", "재산신고액", "재산목록"]}
      updatedAt={report.meta.updatedAt}
    />

    <div class="smca-meta-strip" aria-label="리포트 기준 정보">
      <span>최근 업데이트: {report.meta.updatedAt}</span>
      <span>선거일: {report.meta.electionDate}</span>
      <span>기준: {report.meta.dataBasis}</span>
      <span>단위: 만 원·억 원 병행</span>
    </div>

    <InfoNotice
      title="후보자 재산 공개자료 안내"
      lines={[
        report.meta.caution,
        "총재산과 주요 세부 항목은 2026년 공직자 정기 재산변동사항을 인용한 보도 확인값을 반영했습니다.",
        "재산 신고액에는 후보자 본인 외 신고 대상 가족 재산이 포함될 수 있으며, 부동산 신고액은 실제 현재 시세와 다를 수 있습니다.",
      ]}
    />

    <section class="content-section smca-oh-focus-section" id="oh-sehoon-assets">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">오세훈 재산</p>
        <h2>오세훈 재산 신고액은 약 {formatManwon(ohCandidate.totalAssetsManwon)}</h2>
        <p>
          보도 확인 기준 오세훈 재산 headline은 {formatManwon(ohCandidate.totalAssetsManwon)}입니다.
          정원오 재산신고액 {formatManwon(jungCandidate.totalAssetsManwon)}과 비교하면 총재산 신고액 기준 약
          {assetMultiple.toLocaleString("ko-KR", { maximumFractionDigits: 1 })}배입니다.
        </p>
      </div>
      <div class="smca-focus-grid">
        <article>
          <span>오세훈 재산</span>
          <strong>{formatManwon(ohCandidate.totalAssetsManwon)}</strong>
          <p>2026년 공직자 정기 재산변동사항 보도 확인값 기준입니다.</p>
        </article>
        <article>
          <span>정원오 재산</span>
          <strong>{formatManwon(jungCandidate.totalAssetsManwon)}</strong>
          <p>같은 기준으로 비교한 서울시장 후보 재산신고액입니다.</p>
        </article>
        <article>
          <span>재산 신고액 차이</span>
          <strong>{formatManwon(assetGap)}</strong>
          <p>총재산 headline 기준 단순 차액입니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section smca-answer-section" id="quick-answers">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">검색 의도별 빠른 답</p>
        <h2>오세훈 재산·재산신고·재산목록 핵심 정리</h2>
        <p>
          검색에서 많이 들어오는 표현을 기준으로 바로 확인할 수 있는 답변만 먼저 모았습니다.
          자세한 금액과 원문 확인법은 아래 비교표와 체크리스트에서 이어서 볼 수 있습니다.
        </p>
      </div>
      <div class="smca-answer-grid">
        {report.searchIntentAnswers.map((item) => (
          <a href={item.anchor}>
            <span>{item.query}</span>
            <strong>{item.answer}</strong>
          </a>
        ))}
      </div>
    </section>

    <section class="content-section smca-candidate-section" id="candidate-assets">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">후보 요약</p>
        <h2>서울시장 후보 재산 신고액 한눈에 보기</h2>
        <p>오세훈·정원오 후보를 같은 기준과 같은 한계로 표시합니다. 후보 카드를 선택하면 아래 구성 카드도 함께 강조됩니다.</p>
      </div>
      <div class="smca-candidate-grid">
        {candidates.map((candidate) => (
          <article class="smca-candidate-card" data-smca-candidate-card={candidate.id}>
            <div class="smca-candidate-card__head">
              <span class="smca-party-badge">{candidate.partyName}</span>
              <span class="smca-source-badge">{candidate.sourceBadge}</span>
            </div>
            <h3 class="smca-candidate-card__name">{candidate.candidateName}</h3>
            <p class="smca-candidate-card__role">{candidate.currentRole}</p>
            <strong class="smca-candidate-card__money" data-smca-money={candidate.totalAssetsManwon}>
              {formatManwon(candidate.totalAssetsManwon)}
            </strong>
            <p>{candidate.summary}</p>
            <div class="smca-tag-row">
              {candidate.assetTags.map((tag) => <span>{tag}</span>)}
            </div>
            <a href={candidate.sourceUrl} target="_blank" rel="noopener noreferrer">출처 확인하기</a>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section smca-metric-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 수치</p>
        <h2>오세훈 재산과 정원오 재산신고액 비교 포인트</h2>
        <p>
          오세훈 후보의 총재산 신고액은 정원오 후보보다 {formatManwon(assetGap)} 높고,
          headline 기준으로 약 {assetMultiple.toLocaleString("ko-KR", { maximumFractionDigits: 1 })}배입니다.
        </p>
      </div>
      <div class="smca-metric-grid">
        {report.metricCards.map((card) => (
          <article class={`smca-metric-card smca-metric-card--${card.tone}`}>
            <span>{card.badge}</span>
            <p>{card.label}</p>
            <strong>{card.value}</strong>
            <small>{card.description}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section smca-checklist-section" id="asset-disclosure-checklist">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">재산목록 확인 상태</p>
        <h2>오세훈 재산목록 세부 항목 확인값</h2>
        <p>
          총재산만 보면 차이가 크게 보이고, 항목별로 보면 오세훈은 증권·부동산·예금이 모두 큰 구조입니다.
          후보자별 원문 명세는 공직윤리시스템 또는 전자관보에서 최종 대조합니다.
        </p>
      </div>
      <div class="smca-checklist-grid">
        {report.disclosureChecklist.map((item) => (
          <article>
            <span class="smca-source-badge">{item.status}</span>
            <h3>{item.label}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section smca-table-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">상세 비교표</p>
        <h2>오세훈 vs 정원오 재산 항목 비교</h2>
        <p>보도 확인된 주요 항목을 만 원 단위 데이터로 정리했습니다. 기타·차액은 공개된 주요 항목과 총재산 신고액 사이의 차이를 맞춘 계산값입니다.</p>
      </div>
      <div class="smca-unit-toggle" aria-label="금액 단위 선택">
        <button type="button" class="is-active" data-smca-unit-toggle="eok" aria-pressed="true">억 원</button>
        <button type="button" data-smca-unit-toggle="manwon" aria-pressed="false">만 원</button>
      </div>
      <div class="smca-table-wrap">
        <table class="smca-comparison-table">
          <caption>2026 서울시장 후보 재산 신고액 비교표</caption>
          <thead>
            <tr>
              <th>항목</th>
              {candidates.map((candidate) => <th>{candidate.candidateName}</th>)}
              <th>상태</th>
            </tr>
          </thead>
          <tbody>
            {tableRows.map((row) => (
              <tr>
                <th>{row.label}</th>
                {candidates.map((candidate) => {
                  const value = row.getter(candidate.id);
                  return (
                    <td class="smca-money-cell" data-smca-money={value ?? ""}>
                      {formatManwon(value)}
                    </td>
                  );
                })}
                <td><span class="smca-source-badge">{row.badge}</span></td>
              </tr>
            ))}
            <tr>
              <th>부동산 비중</th>
              {candidates.map((candidate) => <td>{formatPercent(calcRealEstateRatio(candidate))}</td>)}
              <td><span class="smca-source-badge">계산</span></td>
            </tr>
            <tr>
              <th>금융자산 비중</th>
              {candidates.map((candidate) => <td>{formatPercent(calcFinancialAssetRatio(candidate))}</td>)}
              <td><span class="smca-source-badge">계산</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section smca-composition-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">자산 구성</p>
        <h2>오세훈은 증권·부동산 비중, 정원오는 아파트·예금 비중이 큽니다</h2>
      </div>
      <div class="smca-composition-grid">
        {candidates.map((candidate) => {
          const pct = Math.max(8, Math.round((candidate.totalAssetsManwon / maxTotal) * 100));
          return (
            <article class="smca-composition-card" data-smca-candidate-detail={candidate.id}>
              <div class="smca-composition-card__head">
                <strong>{candidate.candidateName}</strong>
                <span>{formatManwon(candidate.totalAssetsManwon)}</span>
              </div>
              <div class="smca-total-bar" aria-label={`${candidate.candidateName} 총재산 상대 크기`}>
                <span style={`width:${pct}%`}></span>
              </div>
              <dl>
                <div><dt>부동산</dt><dd>{formatManwon(candidate.realEstateManwon)}</dd></div>
                <div><dt>예금</dt><dd>{formatManwon(candidate.depositsManwon)}</dd></div>
                <div><dt>증권</dt><dd>{formatManwon(candidate.securitiesManwon)}</dd></div>
                <div><dt>기타·차액</dt><dd>{formatManwon(calcOtherAssets(candidate))}</dd></div>
              </dl>
            </article>
          );
        })}
      </div>
      <p class="smca-section-note">색상 막대는 두 후보 총재산 신고액의 상대 크기를 보여줍니다. 기타·차액은 공개 보도에서 별도 항목으로 나뉘지 않은 금액을 맞춘 계산값입니다.</p>
    </section>

    <section class="content-section smca-breakdown-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">해석 기준</p>
        <h2>재산 신고액을 볼 때 주의할 점</h2>
      </div>
      <div class="smca-breakdown-grid">
        <article>
          <h3>총재산과 현재 시세</h3>
          <p>후보 재산 신고액은 공개자료의 신고 기준 금액입니다. 부동산 현재 시세나 실거래가와 같다고 보면 안 됩니다.</p>
        </article>
        <article>
          <h3>세부 항목 확인</h3>
          <p>부동산, 예금, 증권, 채무는 보도 확인값을 우선 반영했습니다. 원문 대조가 필요한 세부 명세는 출처 확인 링크로 분리했습니다.</p>
        </article>
        <article>
          <h3>채무와 순자산</h3>
          <p>순자산 추정은 총재산 신고액에서 채무 신고액을 뺀 단순 계산입니다. 채무 세부 성격에 따라 해석이 달라질 수 있습니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section smca-policy-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">공약과 분리해서 보기</p>
        <h2>후보 개인 재산과 서울 부동산 공약은 별도 정보입니다</h2>
        <p>재산 신고액은 후보자의 개인 자산 공개자료이고, 부동산 공약은 서울시 정책 방향입니다. 둘은 함께 참고할 수 있지만 하나가 다른 하나를 자동으로 증명하지는 않습니다.</p>
      </div>
      <div class="smca-policy-grid">
        {report.policySummaries.map((policy) => (
          <article>
            <h3>{policy.candidateName}</h3>
            <dl>
              <div><dt>주택 공급</dt><dd>{policy.housingSupplySummary}</dd></div>
              <div><dt>정비사업</dt><dd>{policy.redevelopmentSummary}</dd></div>
              <div><dt>주거 안정</dt><dd>{policy.rentalHousingSummary}</dd></div>
            </dl>
            <a href={policy.sourceUrl} target="_blank" rel="noopener noreferrer">{policy.sourceLabel}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section smca-guide-section" id="source-guide">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">원문 확인법</p>
        <h2>서울시장 후보자 공개자료 보는 법</h2>
      </div>
      <ol class="smca-guide-steps">
        {report.guideSteps.map((step) => (
          <li>
            <strong>{step.title}</strong>
            <p>{step.body}</p>
            {step.href && <a href={step.href} target="_blank" rel="noopener noreferrer">공식 사이트 열기</a>}
          </li>
        ))}
      </ol>
    </section>

    <section class="content-section smca-related-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">관련 콘텐츠</p>
        <h2>같이 보면 좋은 재산 순위 리포트와 계산기</h2>
      </div>
      <div class="smca-related-grid">
        {report.relatedLinks.map((link) => (
          <a href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <span>{link.description}</span>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="오세훈 재산과 서울시장 후보 재산 비교 리포트 읽는 법"
      intro={report.seoIntro}
      inputPoints={[
        "오세훈 재산 신고액 headline과 정원오 재산신고액을 같은 기준으로 비교할 수 있습니다.",
        "부동산·예금·증권·채무 세부 항목을 보도 확인값과 계산값으로 구분해 볼 수 있습니다.",
        "서울시장 후보 재산 공개자료와 부동산 공약을 어디에서 확인하는지 함께 안내합니다.",
      ]}
      criteria={report.seoCriteria}
      faq={faqItems}
      related={report.relatedLinks.map((link) => ({ href: link.href, label: link.label }))}
    />
  </main>

  <script id="smca-data" type="application/json" set:html={JSON.stringify(candidates)}></script>
  <script type="module" src={withBase("/scripts/seoul-mayor-candidate-assets-2026.js")}></script>
</BaseLayout>
