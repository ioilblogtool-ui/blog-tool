---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  calcFinancialAssetRatio,
  calcNetAssets,
  calcOtherAssets,
  calcRealEstateRatio,
  formatManwon,
  formatPercent,
  seoulMayorCandidateAssets2026,
} from "../../data/seoulMayorCandidateAssets2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const report = seoulMayorCandidateAssets2026;
const candidates = report.candidates;
const faqItems = report.faq.map((item) => ({ question: item.q, answer: item.a }));
const maxTotal = Math.max(...candidates.map((candidate) => candidate.totalAssetsManwon));

const tableRows = [
  { label: "총재산", getter: (id: string) => candidates.find((c) => c.id === id)?.totalAssetsManwon, badge: "보도확인" },
  { label: "부동산", getter: (id: string) => candidates.find((c) => c.id === id)?.realEstateManwon, badge: "확인필요" },
  { label: "토지", getter: (id: string) => candidates.find((c) => c.id === id)?.landManwon, badge: "확인필요" },
  { label: "건물", getter: (id: string) => candidates.find((c) => c.id === id)?.buildingManwon, badge: "확인필요" },
  { label: "예금", getter: (id: string) => candidates.find((c) => c.id === id)?.depositsManwon, badge: "확인필요" },
  { label: "증권", getter: (id: string) => candidates.find((c) => c.id === id)?.securitiesManwon, badge: "확인필요" },
  { label: "채무", getter: (id: string) => candidates.find((c) => c.id === id)?.debtsManwon, badge: "확인필요" },
  { label: "순자산 추정", getter: (id: string) => calcNetAssets(candidates.find((c) => c.id === id)!), badge: "계산" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: report.meta.title,
      description: report.meta.description,
      inLanguage: "ko-KR",
      dateModified: "2026-05-31",
      mainEntityOfPage: `https://bigyocalc.com/reports/${report.meta.slug}/`,
      author: { "@type": "Organization", name: "비교계산소" },
      publisher: { "@type": "Organization", name: "비교계산소" },
    },
    {
      "@type": "FAQPage",
      mainEntity: report.faq.map((item) => ({
        "@type": "Question",
        name: item.q,
        acceptedAnswer: { "@type": "Answer", text: item.a },
      })),
    },
  ],
};
---

<BaseLayout
  title="서울시장 후보 재산·부동산 비교 2026｜오세훈·정원오 재산 신고액"
  description={report.meta.description}
  jsonLd={jsonLd}
>
  <SiteHeader />

  <main class="container page-shell report-page smca-page" data-report="seoul-mayor-candidate-assets-2026">
    <CalculatorHero
      eyebrow={report.meta.eyebrow}
      title={report.meta.h1}
      description="오세훈·정원오 서울시장 후보의 재산 신고액을 총재산, 부동산, 예금, 증권, 채무 기준으로 나눠 비교합니다."
    />

    <div class="smca-meta-strip" aria-label="리포트 기준 정보">
      <span>최근 업데이트: {report.meta.updatedAt}</span>
      <span>선거일: {report.meta.electionDate}</span>
      <span>기준: {report.meta.dataBasis}</span>
      <span>단위: 만원·억원 병행</span>
    </div>

    <InfoNotice
      title="후보자 재산 공개자료 안내"
      lines={[
        report.meta.caution,
        "headline 총재산은 2026년 5월 후보 등록 재산 보도 확인값을 우선 반영했습니다. 세부 항목은 선관위 원문 확인 전까지 확인 필요로 표시합니다.",
        "재산 신고액에는 후보자 본인 외 신고 대상 가족 재산이 포함될 수 있으며, 부동산 신고액은 실제 현재 시세와 다를 수 있습니다.",
      ]}
    />

    <section class="content-section smca-candidate-section" id="candidate-assets">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">후보 스냅샷</p>
        <h2>서울시장 후보 재산 신고액 한눈에 보기</h2>
        <p>두 후보 카드는 같은 기준과 같은 위계로 표시합니다. 후보 선택을 유도하지 않고 공개된 숫자의 기준과 한계를 함께 보여줍니다.</p>
      </div>
      <div class="smca-candidate-grid">
        {candidates.map((candidate) => (
          <article class="smca-candidate-card" data-smca-candidate-card={candidate.id}>
            <div class="smca-candidate-card__head">
              <span class="smca-party-badge">{candidate.partyName}</span>
              <span class="smca-source-badge">{candidate.sourceBadge}</span>
            </div>
            <h3 class="smca-candidate-card__name">{candidate.candidateName}</h3>
            <p class="smca-candidate-card__role">{candidate.currentRole}</p>
            <strong class="smca-candidate-card__money" data-smca-money={candidate.totalAssetsManwon}>
              {formatManwon(candidate.totalAssetsManwon)}
            </strong>
            <p>{candidate.summary}</p>
            <div class="smca-tag-row">
              {candidate.assetTags.map((tag) => <span>{tag}</span>)}
            </div>
            <a href={candidate.sourceUrl} target="_blank" rel="noopener noreferrer">출처 확인하기</a>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section smca-metric-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 수치</p>
        <h2>총재산 headline과 확인 필요 항목을 분리해서 보기</h2>
      </div>
      <div class="smca-metric-grid">
        {report.metricCards.map((card) => (
          <article class={`smca-metric-card smca-metric-card--${card.tone}`}>
            <span>{card.badge}</span>
            <p>{card.label}</p>
            <strong>{card.value}</strong>
            <small>{card.description}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section smca-table-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">상세 비교표</p>
        <h2>오세훈 vs 정원오 재산 항목 비교</h2>
        <p>확인되지 않은 세부 항목은 숫자를 추정하지 않고 확인 필요로 표시합니다.</p>
      </div>
      <div class="smca-unit-toggle" aria-label="금액 단위 선택">
        <button type="button" class="is-active" data-smca-unit-toggle="eok" aria-pressed="true">억원</button>
        <button type="button" data-smca-unit-toggle="manwon" aria-pressed="false">만원</button>
      </div>
      <div class="smca-table-wrap">
        <table class="smca-comparison-table">
          <caption>2026 서울시장 후보 재산 신고액 비교표</caption>
          <thead>
            <tr>
              <th>항목</th>
              {candidates.map((candidate) => <th>{candidate.candidateName}</th>)}
              <th>상태</th>
            </tr>
          </thead>
          <tbody>
            {tableRows.map((row) => (
              <tr>
                <th>{row.label}</th>
                {candidates.map((candidate) => {
                  const value = row.getter(candidate.id);
                  return (
                    <td class="smca-money-cell" data-smca-money={value ?? ""}>
                      {formatManwon(value)}
                    </td>
                  );
                })}
                <td><span class="smca-source-badge">{row.badge}</span></td>
              </tr>
            ))}
            <tr>
              <th>부동산 비중</th>
              {candidates.map((candidate) => <td>{formatPercent(calcRealEstateRatio(candidate))}</td>)}
              <td><span class="smca-source-badge">계산</span></td>
            </tr>
            <tr>
              <th>금융자산 비중</th>
              {candidates.map((candidate) => <td>{formatPercent(calcFinancialAssetRatio(candidate))}</td>)}
              <td><span class="smca-source-badge">계산</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section smca-composition-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">자산 구성</p>
        <h2>총재산 규모는 보도 확인, 구성 비중은 원문 확인 후 업데이트</h2>
      </div>
      <div class="smca-composition-grid">
        {candidates.map((candidate) => {
          const pct = Math.max(8, Math.round((candidate.totalAssetsManwon / maxTotal) * 100));
          return (
            <article class="smca-composition-card" data-smca-candidate-detail={candidate.id}>
              <div class="smca-composition-card__head">
                <strong>{candidate.candidateName}</strong>
                <span>{formatManwon(candidate.totalAssetsManwon)}</span>
              </div>
              <div class="smca-total-bar" aria-label={`${candidate.candidateName} 총재산 상대 크기`}>
                <span style={`width:${pct}%`}></span>
              </div>
              <dl>
                <div><dt>부동산</dt><dd>{formatManwon(candidate.realEstateManwon)}</dd></div>
                <div><dt>예금</dt><dd>{formatManwon(candidate.depositsManwon)}</dd></div>
                <div><dt>증권</dt><dd>{formatManwon(candidate.securitiesManwon)}</dd></div>
                <div><dt>기타</dt><dd>{formatManwon(calcOtherAssets(candidate) === candidate.totalAssetsManwon ? null : calcOtherAssets(candidate))}</dd></div>
              </dl>
            </article>
          );
        })}
      </div>
      <p class="smca-section-note">색상 막대는 두 후보 총재산 headline의 상대 크기만 보여줍니다. 부동산·예금·증권 구성 막대는 세부 항목 확인 후 업데이트합니다.</p>
    </section>

    <section class="content-section smca-breakdown-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">부동산·금융·채무</p>
        <h2>세부 항목은 원문 확인 전까지 단정하지 않습니다</h2>
      </div>
      <div class="smca-breakdown-grid">
        <article>
          <h3>부동산 신고액</h3>
          <p>부동산 신고액은 실제 현재 시세가 아니라 공개자료의 신고 기준 금액입니다. 토지·건물·전세권 구분이 확보되면 이 섹션에 후보별 세부값을 분리해 표시합니다.</p>
        </article>
        <article>
          <h3>예금·증권</h3>
          <p>증권 보유 내역은 신고 시점의 평가액 기준이며 현재 평가액이나 실제 수익률을 의미하지 않습니다. 예금과 증권 합산 비중은 원문 확인 후 계산합니다.</p>
        </article>
        <article>
          <h3>채무와 순자산</h3>
          <p>순자산 추정 = 총재산 신고액 - 채무 신고액입니다. 채무 세부 항목은 주택담보대출, 임대보증금, 금융채무 등 성격이 다를 수 있습니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section smca-policy-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">공약 분리해서 보기</p>
        <h2>후보 개인 재산과 서울 부동산 공약은 별도 정보입니다</h2>
        <p>재산 신고액은 후보자의 개인 자산 공개자료이고, 부동산 공약은 서울시 정책 방향입니다. 둘은 함께 참고할 수 있지만 하나가 다른 하나의 옳고 그름을 자동으로 증명하지는 않습니다.</p>
      </div>
      <div class="smca-policy-grid">
        {report.policySummaries.map((policy) => (
          <article>
            <h3>{policy.candidateName}</h3>
            <dl>
              <div><dt>주택 공급</dt><dd>{policy.housingSupplySummary}</dd></div>
              <div><dt>정비사업</dt><dd>{policy.redevelopmentSummary}</dd></div>
              <div><dt>주거 안정</dt><dd>{policy.rentalHousingSummary}</dd></div>
            </dl>
            <a href={policy.sourceUrl} target="_blank" rel="noopener noreferrer">{policy.sourceLabel}</a>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section smca-guide-section" id="source-guide">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">원문 확인법</p>
        <h2>서울시장 후보자 공개자료 보는 법</h2>
      </div>
      <ol class="smca-guide-steps">
        {report.guideSteps.map((step) => (
          <li>
            <strong>{step.title}</strong>
            <p>{step.body}</p>
            {step.href && <a href={step.href} target="_blank" rel="noopener noreferrer">공식 사이트 열기</a>}
          </li>
        ))}
      </ol>
    </section>

    <section class="content-section smca-related-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">관련 콘텐츠</p>
        <h2>같이 보면 좋은 리포트와 계산기</h2>
      </div>
      <div class="smca-related-grid">
        {report.relatedLinks.map((link) => (
          <a href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <span>{link.description}</span>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="서울시장 후보 재산 비교 리포트 읽는 법"
      intro={report.seoIntro}
      inputPoints={[
        "오세훈·정원오 후보의 총재산 신고액 headline을 비교할 수 있습니다.",
        "부동산·예금·증권·채무 기준으로 후보별 자산 구조를 확인할 수 있도록 원문 확인 항목을 분리했습니다.",
        "서울시장 후보자 공개자료와 공약을 어디서 확인하는지 알 수 있습니다.",
      ]}
      criteria={report.seoCriteria}
      faq={faqItems}
      related={report.relatedLinks.map((link) => ({ href: link.href, label: link.label }))}
    />
  </main>

  <script id="smca-data" type="application/json" set:html={JSON.stringify(candidates)}></script>
  <script type="module" src={withBase("/scripts/seoul-mayor-candidate-assets-2026.js")}></script>
</BaseLayout>

