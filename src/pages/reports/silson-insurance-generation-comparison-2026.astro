---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  SIGC_ACTION_PLAN,
  SIGC_AGE_MATRIX,
  SIGC_BREAK_EVEN_ROWS,
  SIGC_COMBINATION_ROWS,
  SIGC_COVERAGE_ROWS,
  SIGC_DENIAL_REASONS,
  SIGC_DUPLICATE_TIPS,
  SIGC_FAQ,
  SIGC_INSURER_CLAUSES,
  SIGC_KPI,
  SIGC_META,
  SIGC_POLICY_CHANGES,
  SIGC_PREMIUM_ROWS,
  SIGC_PREMIUM_TRENDS,
  SIGC_REFUND_SCENARIOS,
  SIGC_REFUND_SIMULATION_ROWS,
  SIGC_RELATED,
  SILSON_GENERATIONS,
} from "../../data/silsonInsuranceGenerationComparison2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const faqItems = SIGC_FAQ.map((item) => ({ question: item.q, answer: item.a }));
const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const bundleScenario = SIGC_REFUND_SCENARIOS.find((scenario) => scenario.id === "bundle");
const ageLabelMap: Record<string, string> = {
  "20s": "20대",
  "30s": "30대",
  "40s": "40대",
  "50s": "50대",
};
const usageLabelMap: Record<string, string> = {
  low: "병원 이용 적음",
  medium: "병원 이용 보통",
  high: "비급여 이용 많음",
};
---

<BaseLayout
  title={SIGC_META.seoTitle}
  description={SIGC_META.description}
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    headline: SIGC_META.seoTitle,
    description: SIGC_META.description,
    url: `${siteUrl}/reports/silson-insurance-generation-comparison-2026/`,
    dateModified: "2026-05-19",
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faqItems.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  }}
>
  <SiteHeader />

  <main class="container page-shell report-page sigc-page" data-report="silson-insurance-generation-comparison-2026">
    <CalculatorHero
      eyebrow="보험 리포트"
      title={SIGC_META.title}
      description={SIGC_META.subtitle}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        `${SIGC_META.updatedAt}. ${SIGC_META.methodology}`,
        SIGC_META.caution,
        "2026년 5월 6일 이후 신규 가입 시장의 5세대 실손보험은 제도 변화 박스에서 별도 안내하고, 본문 비교는 1~4세대 보유계약 중심으로 정리합니다.",
      ]}
    />

    <section class="content-section sigc-kpi-section">
      <div class="sigc-kpi-grid">
        {SIGC_KPI.map((item) => (
          <article class="sigc-kpi-card">
            <p>{item.label}</p>
            <strong>{item.value}</strong>
            <span>{item.note}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section sigc-toc-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">목차</p>
        <h2>먼저 확인할 비교 축</h2>
      </div>
      <nav class="sigc-toc" aria-label="실손보험 세대별 비교 목차">
        <a href="#sigc-generations">세대 변천사</a>
        <a href="#sigc-premium">보험료 비교</a>
        <a href="#sigc-coverage">보장 범위</a>
        <a href="#sigc-refund">환급 시뮬레이션</a>
        <a href="#sigc-switch">4세대 전환 손익</a>
        <a href="#sigc-age">연령대별 판단</a>
        <a href="#sigc-action">액션 플랜</a>
      </nav>
    </section>

    <section id="sigc-generations" class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">세대 변천사</p>
        <h2>1세대부터 4세대까지 구조가 달라진 이유</h2>
        <p>실손보험은 의료비 보장 범위와 자기부담률을 조정하며 세대가 바뀌었습니다. 같은 실손이라도 가입 시기에 따라 실제 체감이 다릅니다.</p>
      </div>
      <div class="sigc-control-row">
        <label for="sigc-generation-select">내 실손 세대</label>
        <select id="sigc-generation-select">
          {SILSON_GENERATIONS.map((generation) => (
            <option value={generation.id} selected={generation.id === "gen2"}>{generation.label}</option>
          ))}
        </select>
      </div>
      <div class="sigc-generation-grid">
        {SILSON_GENERATIONS.map((generation) => (
          <article class="sigc-generation-card" data-generation-card={generation.id}>
            <span>{generation.salePeriod}</span>
            <h3>{generation.label}</h3>
            <p class="sigc-generation-card__structure">{generation.structure}</p>
            <strong>{generation.mainFeature}</strong>
            <div class="sigc-mini-cols">
              <div>
                <p>장점</p>
                <ul>{generation.pros.map((item) => <li>{item}</li>)}</ul>
              </div>
              <div>
                <p>주의</p>
                <ul>{generation.cons.map((item) => <li>{item}</li>)}</ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="sigc-premium" class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">보험료 현황</p>
        <h2>2026년 인상률은 세대별로 다르게 보입니다</h2>
        <p>전체 평균 인상률만 보면 부족합니다. 절대 보험료와 인상률, 비급여 이용 패턴을 함께 봐야 유지·전환 판단이 가능합니다.</p>
      </div>
      <div class="sigc-table-wrap">
        <table class="sigc-table">
          <thead>
            <tr>
              <th>세대</th>
              <th>2026 평균 인상률</th>
              <th>30대 기준 월납</th>
              <th>해석</th>
            </tr>
          </thead>
          <tbody>
            {SIGC_PREMIUM_ROWS.map((row) => (
              <tr>
                <td><strong>{row.label}</strong></td>
                <td>{row.increaseRate2026}</td>
                <td><span class="sigc-chip sigc-chip--muted">{row.monthlyPremium30s}</span></td>
                <td>{row.interpretation}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section id="sigc-coverage" class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">보장 구조</p>
        <h2>보험료보다 먼저 볼 것은 급여·비급여 자기부담률</h2>
        <p>특히 4세대는 급여와 비급여가 분리되고 비급여 자기부담률이 높아진 구조라 병원 이용 패턴에 따라 유불리가 크게 갈립니다.</p>
      </div>
      <div class="sigc-table-wrap">
        <table class="sigc-table sigc-table--coverage">
          <thead>
            <tr>
              <th>구분</th>
              <th>1세대</th>
              <th>2세대</th>
              <th>3세대</th>
              <th>4세대</th>
            </tr>
          </thead>
          <tbody>
            {SIGC_COVERAGE_ROWS.map((row) => (
              <tr>
                <td><strong>{row.item}</strong></td>
                <td>{row.gen1}</td>
                <td>{row.gen2}</td>
                <td>{row.gen3}</td>
                <td>{row.gen4}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="sigc-footnote">실제 자기부담률과 공제금액은 가입 시기, 보험회사, 선택형 여부, 특약 가입 여부에 따라 달라질 수 있습니다.</p>
    </section>

    <section id="sigc-refund" class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">환급 시뮬레이션</p>
        <h2>도수치료·MRI·비급여주사는 체감 차이가 큽니다</h2>
        <p>아래 값은 세대별 구조를 이해하기 위한 단순 추정입니다. 실제 청구 전에는 특약, 횟수, 한도, 공제금액을 확인해야 합니다.</p>
      </div>
      <div class="sigc-scenario-grid">
        {SIGC_REFUND_SCENARIOS.map((scenario) => (
          <article class="sigc-scenario-card">
            <span>{scenario.category}</span>
            <strong>{scenario.label}</strong>
            <p>{scenario.medicalCost.toLocaleString("ko-KR")}원</p>
            <small>{scenario.description}</small>
          </article>
        ))}
      </div>
      <div class="sigc-table-wrap">
        <table class="sigc-table">
          <caption>{bundleScenario?.label ?? "고액 비급여 묶음"} 기준 단순 환급 예시</caption>
          <thead>
            <tr>
              <th>세대</th>
              <th>예상 환급액</th>
              <th>본인부담액</th>
              <th>한도 차감</th>
              <th>다음 보험료 영향</th>
            </tr>
          </thead>
          <tbody>
            {SIGC_REFUND_SIMULATION_ROWS.map((row) => {
              const generation = SILSON_GENERATIONS.find((item) => item.id === row.generation);
              return (
                <tr>
                  <td><strong>{generation?.label}</strong></td>
                  <td>{row.estimatedRefund.toLocaleString("ko-KR")}원</td>
                  <td>{row.outOfPocket.toLocaleString("ko-KR")}원</td>
                  <td>{row.limitNote}</td>
                  <td>{row.renewalImpact}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <section id="sigc-switch" class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">4세대 전환 손익</p>
        <h2>월 보험료 절감액과 추가 본인부담액을 같은 연간 기준으로 비교하세요</h2>
      </div>
      <div class="sigc-calculator">
        <div class="sigc-input-grid">
          <label>현재 월 보험료<input id="sigc-current-premium" type="number" value="42000" min="0" step="1000" /></label>
          <label>4세대 예상 월 보험료<input id="sigc-target-premium" type="number" value="18000" min="0" step="1000" /></label>
          <label>연간 급여 진료비<input id="sigc-covered-cost" type="number" value="300000" min="0" step="10000" /></label>
          <label>연간 비급여 진료비<input id="sigc-non-covered-cost" type="number" value="500000" min="0" step="10000" /></label>
          <label>연간 통원 횟수<input id="sigc-outpatient-visits" type="number" value="6" min="0" step="1" /></label>
        </div>
        <aside class="sigc-result-card" id="sigc-break-even-result" data-tone="neutral" aria-live="polite">
          <p>전환 판단</p>
          <strong id="sigc-decision-label">비교 필요</strong>
          <dl>
            <div><dt>연간 보험료 절감액</dt><dd id="sigc-switch-saving">0원</dd></div>
            <div><dt>추가 본인부담 추정</dt><dd id="sigc-extra-out-of-pocket">0원</dd></div>
            <div><dt>전환 순효과</dt><dd id="sigc-net-benefit">0원</dd></div>
          </dl>
          <span id="sigc-decision-message"></span>
        </aside>
      </div>
      <div class="sigc-break-grid">
        {SIGC_BREAK_EVEN_ROWS.map((row) => (
          <article>
            <span>{row.nonCoveredCost}</span>
            <strong>{row.decision}</strong>
            <p>{row.interpretation}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="sigc-age" class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">연령대별 매트릭스</p>
        <h2>나이와 비급여 이용량에 따라 판단이 달라집니다</h2>
      </div>
      <div class="sigc-control-row sigc-control-row--split">
        <label for="sigc-age-group">연령대</label>
        <select id="sigc-age-group">
          {Object.entries(ageLabelMap).map(([value, label]) => <option value={value} selected={value === "30s"}>{label}</option>)}
        </select>
        <label for="sigc-usage-level">의료 이용량</label>
        <select id="sigc-usage-level">
          {Object.entries(usageLabelMap).map(([value, label]) => <option value={value} selected={value === "medium"}>{label}</option>)}
        </select>
      </div>
      <article class="sigc-matrix-result">
        <p>선택 조건 기준</p>
        <strong id="sigc-matrix-result">손익분기 계산 필요</strong>
      </article>
      <div class="sigc-table-wrap">
        <table class="sigc-table">
          <thead>
            <tr>
              <th>연령대</th>
              <th>병원 이용 적음</th>
              <th>병원 이용 보통</th>
              <th>비급여 이용 많음</th>
            </tr>
          </thead>
          <tbody>
            {SIGC_AGE_MATRIX.map((row) => (
              <tr>
                <td><strong>{row.label}</strong></td>
                <td>{row.low}</td>
                <td>{row.medium}</td>
                <td>{row.high}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">인상률 추이</p>
        <h2>갱신 보험료는 한 해가 아니라 흐름으로 봐야 합니다</h2>
      </div>
      <div class="sigc-trend-list">
        {SIGC_PREMIUM_TRENDS.map((row) => (
          <article class="sigc-trend-row">
            <strong>{row.year}</strong>
            <div class="sigc-bars">
              {(["overall", "gen1", "gen2", "gen3", "gen4"] as const).map((key) => row[key] !== null && (
                <span>
                  <em>{key === "overall" ? "전체" : key.replace("gen", "") + "세대"}</em>
                  <b>{row[key]}%</b>
                </span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">주의사항</p>
        <h2>중복 가입과 청구 거절 사유를 먼저 확인하세요</h2>
      </div>
      <div class="sigc-two-col">
        <article class="sigc-panel">
          <h3>중복 가입 체크</h3>
          <ul>{SIGC_DUPLICATE_TIPS.map((tip) => <li>{tip}</li>)}</ul>
        </article>
        <article class="sigc-panel">
          <h3>청구 거절 사유 TOP 5</h3>
          <ol>{SIGC_DENIAL_REASONS.map((reason) => <li><strong>{reason.title}</strong><span>{reason.detail}</span></li>)}</ol>
        </article>
      </div>
    </section>

    <section class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">보험 조합</p>
        <h2>실손은 의료비 보장이고, 종신·정기는 목적이 다릅니다</h2>
      </div>
      <div class="sigc-table-wrap">
        <table class="sigc-table">
          <thead>
            <tr><th>조합</th><th>월 부담</th><th>맞는 경우</th><th>주의</th></tr>
          </thead>
          <tbody>
            {SIGC_COMBINATION_ROWS.map((row) => (
              <tr><td><strong>{row.type}</strong></td><td>{row.monthlyCost}</td><td>{row.fit}</td><td>{row.caution}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section sigc-policy-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">2026 제도 변화</p>
        <h2>5세대 실손은 신규 가입 시장의 변화로 따로 봐야 합니다</h2>
      </div>
      <div class="sigc-policy-grid">
        {SIGC_POLICY_CHANGES.map((item) => (
          <article>
            <strong>{item.title}</strong>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">약관 확인표</p>
        <h2>보험사별 추천보다 약관 원문 확인이 먼저입니다</h2>
      </div>
      <div class="sigc-table-wrap">
        <table class="sigc-table">
          <thead>
            <tr><th>확인 대상</th><th>급여 한도</th><th>비급여 한도</th><th>특약</th><th>청구 방식</th><th>메모</th></tr>
          </thead>
          <tbody>
            {SIGC_INSURER_CLAUSES.map((row) => (
              <tr>
                <td><strong>{row.insurer}</strong></td>
                <td>{row.coveredLimit}</td>
                <td>{row.nonCoveredLimit}</td>
                <td>{row.specialRider}</td>
                <td>{row.appClaim}</td>
                <td>{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section id="sigc-action" class="content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">액션 플랜</p>
        <h2>유지·전환 전 이 순서로 확인하세요</h2>
      </div>
      <div class="sigc-action-grid">
        {SIGC_ACTION_PLAN.map((item) => (
          <article>
            <span>{item.step}</span>
            <strong>{item.title}</strong>
            <p>{item.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="실손보험 세대별 비교를 읽는 법"
      intro={[
        "실손보험은 세대명만으로 좋고 나쁨을 단정하기 어렵습니다. 같은 2세대라도 선택형 여부, 특약, 가입 시기, 보험회사 약관에 따라 자기부담률과 공제금액이 달라질 수 있습니다.",
        "4세대 전환은 보험료 절감액만 보면 유리해 보일 수 있지만, 비급여 진료가 잦은 경우 환급 감소액과 다음 갱신 보험료 영향을 함께 봐야 합니다.",
        "이 페이지의 표와 시뮬레이션은 유지·전환 판단을 위한 1차 점검표입니다. 실제 전환 전에는 반드시 보험사 상품공시실과 약관 원문을 확인하세요.",
      ]}
      inputPoints={[
        "내 실손 가입일과 세대를 먼저 확인합니다.",
        "최근 1년 급여·비급여·3대 비급여 청구액을 나눠 봅니다.",
        "월 보험료 절감액과 추가 본인부담액을 연간 기준으로 비교합니다.",
      ]}
      criteria={[
