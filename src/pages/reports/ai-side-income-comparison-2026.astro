---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  ASICR_FAQ,
  ASICR_GUIDE,
  ASICR_INSIGHTS,
  ASICR_JOBS,
  ASICR_META,
  ASICR_RELATED_LINKS,
  ASICR_SIMULATION,
} from "../../data/aiSideIncomeComparison2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const maxNetIncome = Math.max(...ASICR_SIMULATION.map((r) => r.netIncome));

const impactLabel: Record<string, string> = { high: "높음", medium: "중간", low: "낮음" };
const barrierLabel: Record<string, string> = { high: "높음", medium: "중간", low: "낮음" };
const growthLabel: Record<string, string> = { high: "높음", medium: "중간", low: "낮음" };

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: ASICR_META.title,
  description: ASICR_META.description,
  inLanguage: "ko-KR",
  dateModified: "2026-05-11",
  mainEntityOfPage: `https://bigyocalc.com/reports/${ASICR_META.slug}/`,
};
---

<BaseLayout
  title="AI 부업 수입 비교 2026 — 업종별 월수입·AI 효율·진입 장벽 완전 정리"
  description={ASICR_META.description}
  jsonLd={jsonLd}
>
  <SiteHeader />
  <main class="container page-shell report-page op-page asicr-page">

    <CalculatorHero
      eyebrow="AI 부업 수입 리포트"
      title={ASICR_META.title}
      description="개발 외주, 프리랜서, 강의, 콘텐츠, 데이터 라벨링 등 7개 업종의 월 수입·AI 효율·진입 장벽을 한눈에 비교합니다."
    />

    <InfoNotice
      title="수입 범위 안내"
      lines={[
        "아래 수입 범위는 시장 사례와 추정을 바탕으로 한 참고값입니다.",
        "실제 수입은 경력·클라이언트 조건·AI 숙련도·전문 분야에 따라 크게 달라질 수 있습니다.",
        `업데이트 기준: ${ASICR_META.updatedAt}`,
      ]}
    />
    <DesignTrustPanel
      title="AI 부업 수입 비교 기준"
      updatedAt="2026-05-11"
      notes={[
        "수입 범위는 시장 참고 추정값이며 소득 보장을 의미하지 않습니다.",
        "AI 도구 활용 효율은 개인 숙련도에 따라 실제 차이가 큽니다.",
      ]}
    />

    {/* ─── 핵심 인사이트 카드 ─── */}
    <section class="op-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 인사이트</p>
        <h2>2026 AI 부업 시장의 핵심 포인트</h2>
      </div>
      <div class="asicr-insight-grid">
        {ASICR_INSIGHTS.map((item) => (
          <article class="asicr-insight-card">
            <p class="asicr-insight-card__title">{item.title}</p>
            <p class="asicr-insight-card__body">{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    {/* ─── 전체 업종 비교 표 ─── */}
    <section class="op-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">업종별 비교</p>
        <h2>7개 업종 월수입·AI 향상률·시급·진입 장벽·성장성 비교</h2>
      </div>
      <div class="op-table-wrap">
        <table class="asicr-table">
          <thead>
            <tr>
              <th>업종</th>
              <th>월 시간</th>
              <th>월 수입 범위</th>
              <th>AI 향상률</th>
              <th>시급 범위</th>
              <th>AI 임팩트</th>
              <th>진입 장벽</th>
              <th>성장성</th>
            </tr>
          </thead>
          <tbody>
            {ASICR_JOBS.map((job) => (
              <tr>
                <td><strong>{job.name}</strong></td>
                <td>{job.monthlyHoursRange[0]}~{job.monthlyHoursRange[1]}h</td>
                <td>{Math.round(job.incomeRange.min / 10000)}~{Math.round(job.incomeRange.max / 10000)}만 원</td>
                <td>{job.aiBoostRange.min}~{job.aiBoostRange.max}%</td>
                <td>{Math.round(job.hourlyRateRange[0] / 10000)}~{Math.round(job.hourlyRateRange[1] / 10000)}만 원</td>
                <td>
                  <span class={`asicr-impact-badge asicr-impact-badge--${job.aiImpact}`}>
                    {impactLabel[job.aiImpact]}
                  </span>
                </td>
                <td>{barrierLabel[job.entryBarrier]}</td>
                <td>{growthLabel[job.growthPotential]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    {/* ─── TOP 3 상세 카드 ─── */}
    <section class="op-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">AI 임팩트 높은 업종</p>
        <h2>AI 활용 효율이 높은 추천 업종 상세</h2>
      </div>
      <div class="asicr-top-grid">
        {ASICR_JOBS.filter((j) => j.aiImpact === "high").map((job) => (
          <article class="asicr-top-card">
            <div class="asicr-top-card__head">
              <p class="asicr-top-card__name">{job.name}</p>
              <span class="asicr-impact-badge asicr-impact-badge--high">AI 임팩트 높음</span>
            </div>
            <p class="asicr-top-card__range">
              월 {Math.round(job.incomeRange.min / 10000)}~{Math.round(job.incomeRange.max / 10000)}만 원
            </p>
            <p class="asicr-top-card__rate">AI 향상률 {job.aiBoostRange.min}~{job.aiBoostRange.max}%</p>
            <ul class="asicr-top-card__tools">
              {job.requiredTools.map((t) => <li>{t}</li>)}
            </ul>
            <p class="asicr-top-card__note">{job.note}</p>
            <p class="asicr-top-card__best">추천 대상: <strong>{job.bestFor}</strong></p>
          </article>
        ))}
      </div>
    </section>

    {/* ─── 월 20시간 투자 시 수입 비교 ─── */}
    <section class="op-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">시간 투자 효율</p>
        <h2>월 20시간 투자 시 업종별 예상 순수입 비교</h2>
      </div>
      <p class="asicr-sim-note">AI 향상률 50% 적용, AI 도구 구독료 3만 원 차감 기준 추정값입니다.</p>
      <div class="asicr-bar-grid">
        {ASICR_SIMULATION.map((row) => {
          const pct = Math.round((row.netIncome / maxNetIncome) * 100);
          return (
            <div class="asicr-bar-row">
              <span class="asicr-bar-label">{row.name}</span>
              <div class="asicr-bar-wrap">
                <div class="asicr-bar-fill" style={`width:${pct}%`}></div>
              </div>
              <span class="asicr-bar-value">{Math.round(row.netIncome / 10000)}만 원</span>
            </div>
          );
        })}
      </div>
    </section>

    {/* ─── 업종 선택 기준 가이드 ─── */}
    <section class="op-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">업종 선택 가이드</p>
        <h2>내 상황에 맞는 AI 부업 업종 찾기</h2>
      </div>
      <div class="asicr-guide-grid">
        {ASICR_GUIDE.map((item) => (
          <article class="asicr-guide-card">
            <p class="asicr-guide-card__situation">{item.situation}</p>
            <strong class="asicr-guide-card__recommend">{item.recommend}</strong>
            <p class="asicr-guide-card__reason">{item.reason}</p>
          </article>
        ))}
      </div>
    </section>

    {/* ─── CTA ─── */}
    <section class="op-section asicr-cta-section">
      <div>
        <p class="section-header__eyebrow">내 수입 직접 계산</p>
        <h2>도구비 빼고 실제 남는 금액을 계산해보세요</h2>
        <p>업종, 월 투입 시간, 시급, AI 향상률을 입력하면 도구 구독료 차감 후 실제 순수입을 계산합니다.</p>
      </div>
      <a href={withBase("/tools/ai-side-income-calculator/")}>AI 부업 수입 계산하기</a>
    </section>

    <SeoContent
      introTitle="AI 부업, 어떤 업종이 가장 효율적일까 — 2026 업종별 수입 비교"
      intro={[
        "2026년 AI 도구의 급속한 발전으로 누구나 부업 시장에 진입하기 쉬워졌습니다. ChatGPT, Claude, Cursor, Midjourney 등 AI 도구를 활용하면 혼자서도 글쓰기·번역·개발·디자인·콘텐츠 제작을 빠르게 처리할 수 있습니다. 하지만 업종마다 시장 단가, AI 활용 효율, 진입 장벽, 장기 성장성이 크게 다릅니다. 이 리포트는 7개 주요 AI 부업 업종을 같은 기준으로 비교해 어떤 업종이 본인에게 맞는지 판단하는 데 도움을 드립니다.",
        "AI 임팩트가 가장 큰 업종은 개발 외주·코딩 대행과 데이터 라벨링입니다. 개발 외주는 AI 코드 생성으로 생산성이 50~100% 향상되어 실효 시급이 최대 10만 원 이상으로 올라갈 수 있지만, 결과물 품질을 검수할 수 있는 개발 역량이 전제됩니다. 데이터 라벨링은 진입 장벽이 낮아 당장 시작할 수 있지만, AI 자동화가 진행되면서 단순 라벨링 수요는 줄어드는 추세이고 전문 도메인 검수로 이동하는 것이 유리합니다.",
        "시간 투자 효율 측면에서는 온라인 강의·튜터링이 돋보입니다. 강의 자체의 시급은 4~15만 원 수준으로 높고, 한 번 만든 콘텐츠가 구독·재판매로 반복 수익을 냅니다. AI로 강의 자료·예제·퀴즈 제작 시간을 줄이면 초기 투자 시간을 대폭 낮출 수 있습니다. 반면 초기 수강생 모집과 신뢰 구축에 시간이 필요하므로 단기 수입으로는 적합하지 않습니다.",
        "유튜브·블로그 콘텐츠는 수익화까지 가장 오래 걸리지만 장기적으로 성장성이 높은 채널입니다. AI로 스크립트, 썸네일, SEO 키워드를 빠르게 처리할 수 있어 콘텐츠 생산량을 늘리는 데 유리합니다. 다만 AI 생성 콘텐츠만으로는 알고리즘과 독자의 외면을 받을 수 있으므로, 차별화된 관점과 전문성이 함께 필요합니다. 월 10만 원 이상의 수입을 내기까지 최소 6개월~1년이 걸리는 경우가 많습니다.",
        "모든 수입 범위는 시장 사례와 추정을 바탕으로 한 참고값이며, 실제 수입은 경력, 클라이언트 조건, AI 도구 숙련도, 전문 분야에 따라 크게 달라집니다. 위 계산기에서 본인의 업종, 시간, 시급, AI 향상률을 직접 입력해 더 정확한 예상 수입을 계산해 보세요.",
      ]}
      criteria={[
        "수입 범위는 시장 참고 추정값이며 실제 소득을 보장하지 않습니다.",
        "AI 향상률은 도구 숙련도와 업무 유형에 따라 개인차가 큽니다.",
        "월 20시간 시뮬레이션은 AI 향상률 50%, 도구비 3만 원 차감 기준의 단순 추정입니다.",
        "세금·사회보험료는 별도로 확인해야 합니다.",
      ]}
      faq={ASICR_FAQ}
      related={ASICR_RELATED_LINKS}
    />

  </main>
</BaseLayout>
