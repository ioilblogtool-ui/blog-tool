---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import CompareCta from "../../components/CompareCta.astro";
import {
  BONUS_RANKING_ENTRIES,
  BONUS_RANKING_INDUSTRY_LABELS,
  BONUS_RANKING_FAQ,
  BONUS_HUB_CARDS,
  CBR_BASE_SALARY,
  CBR_TAX_RATE,
  CBR_KPI,
  CBR_META,
  BONUS_RANKING_INDUSTRY_COLORS,
  formatCbrWon,
} from "../../data/corporateBonusRankingTop10_2026";

const sorted = [...BONUS_RANKING_ENTRIES].sort((a, b) => b.salaryPercent - a.salaryPercent);
const top10 = sorted.slice(0, 10);

const singleCards = BONUS_HUB_CARDS.filter((c) => c.category === "단독 계산기");
const compareCards = BONUS_HUB_CARDS.filter((c) => c.category === "업종 비교 계산기");

const industries = Object.keys(BONUS_RANKING_INDUSTRY_LABELS) as Array<keyof typeof BONUS_RANKING_INDUSTRY_LABELS>;

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/reports/${CBR_META.slug}/`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: CBR_META.seoTitle,
      description: CBR_META.description,
      inLanguage: "ko-KR",
      dateModified: CBR_META.updatedAt,
      mainEntityOfPage: pageUrl,
      author: { "@type": "Organization", name: "비교계산소" },
      publisher: { "@type": "Organization", name: "비교계산소" },
    },
    {
      "@type": "FAQPage",
      mainEntity: BONUS_RANKING_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
    {
      "@type": "ItemList",
      name: "성과급 계산기 모음",
      itemListElement: BONUS_HUB_CARDS.map((card, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: card.label,
        url: `${siteBase}${card.href}`,
      })),
    },
  ],
};

const config = {
  entries: sorted,
  top10,
  baseSalary: CBR_BASE_SALARY,
  taxRate: CBR_TAX_RATE,
  industryLabels: BONUS_RANKING_INDUSTRY_LABELS,
  industryColors: BONUS_RANKING_INDUSTRY_COLORS,
};

const seoIntro = [
  "대기업 성과급은 회사마다, 사업부마다, 심지어 같은 회사라도 연도마다 크게 달라집니다. 삼성전자 MX(모바일) 부문은 2025년 OPI 50%를 확정받았지만, DS(반도체) 부문은 47%로 발표되었습니다. 같은 삼성전자 직원이라도 소속 부문에 따라 성과급이 완전히 달라지는 것이 현실입니다.",
  "SK하이닉스는 2025년 9월 노사가 '영업이익의 10% 성과급 재원 배분, 상한선 폐지'에 합의하면서 업계 완전한 별도 구조로 올라섰습니다. 연봉 1억원 직원 기준 약 1억 4,820만원이 지급되었다는 보도가 나올 정도로, 다른 기업과 비교 자체가 어려운 수준의 성과급을 지급했습니다.",
  "게임업계에서는 크래프톤과 넥슨이 2025년 나란히 역대 최고 영업이익(각각 1조 544억, 1조 1,765억원)을 기록하면서 업계 내 성과급 양극화가 극대화되었습니다. 반면 엔씨소프트는 대규모 인력 감축을 단행하는 등 같은 게임업계 내에서도 격차가 크게 벌어지고 있습니다.",
  "금융·증권업은 이자이익 개선과 증권 IB 실적 호조에 힘입어 상위권을 유지하고 있습니다. 한국투자증권·미래에셋증권·삼성증권은 성과 인센티브 비중이 높은 구조로, 실적에 따라 연봉의 20~25% 수준의 성과급을 받는 것으로 추정됩니다.",
  "자동차(현대차·기아)와 조선(HD현대중공업)은 이 순위에 포함되지 않았습니다. 두 업종은 성과급을 연봉 대비 비율(%)이 아닌 '월급 배수(4~6개월치)' 방식으로 지급하기 때문입니다. 단순 % 비교 시 수치가 왜곡될 수 있어, 별도 업종 비교 계산기를 통해 확인하시길 권장합니다.",
  "이 순위의 모든 수치는 노사협의 확정 또는 실적 기반 추정입니다. '확정' 표시 항목은 노사합의문, 주요 언론 복수 보도로 확인한 값이며, '추정' 항목은 해당 연도 영업이익과 업계 관행을 기반으로 산출한 참고값입니다. 실제 개인 지급액은 소속 부문, 직급, 평가등급에 따라 달라집니다.",
];
---

<BaseLayout title={CBR_META.seoTitle} description={CBR_META.description} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page cbr-page" data-report={CBR_META.slug}>
    <CalculatorHero
      eyebrow="성과급 순위 허브"
      title={CBR_META.title}
      description="SK하이닉스·삼성전자·크래프톤 등 25개사 성과급률을 노사협의 확정·실적 기반으로 비교합니다."
      badges={["노사협의 기반", "2026", "25개사", "업종 필터"]}
    />

    <InfoNotice
      title="시뮬레이션 기준 안내"
      lines={[
        "이 순위는 연봉 6,000만원 기준 각 기업 성과급률(%)을 적용한 시뮬레이션입니다. 실제 지급액·지급 여부와 무관합니다.",
        "'확정' 항목은 노사합의·공시·언론 복수 보도 기반이며, '추정' 항목은 실적 기반 참고값입니다.",
        "삼성전자는 사업부(MX·DS)별 성과급이 다르며 각각 별도 항목으로 표기되어 있습니다.",
        "자동차·조선은 월급 배수 방식으로 % 비교가 어려워 이 순위에서 제외했습니다.",
      ]}
    />

    <!-- KPI -->
    <section class="content-section cbr-kpi-section">
      <div class="cbr-kpi-grid">
        <div class="cbr-kpi-card">
          <span class="cbr-kpi-label">성과급률 1위</span>
          <strong class="cbr-kpi-value">{CBR_KPI.topCompany}</strong>
          <span class="cbr-kpi-sub">연봉 대비 {CBR_KPI.topPercent}% (추정, 실제 더 높음)</span>
        </div>
        <div class="cbr-kpi-card">
          <span class="cbr-kpi-label">비교 기업 수</span>
          <strong class="cbr-kpi-value">{CBR_KPI.companiesCount}개사</strong>
          <span class="cbr-kpi-sub">10개 업종 대표 기업</span>
        </div>
        <div class="cbr-kpi-card">
          <span class="cbr-kpi-label">전체 평균 성과급률</span>
          <strong class="cbr-kpi-value">{CBR_KPI.avgPercent}%</strong>
          <span class="cbr-kpi-sub">25개사 단순 평균</span>
        </div>
        <div class="cbr-kpi-card">
          <span class="cbr-kpi-label">6천만원 기준 1위 추정액</span>
          <strong class="cbr-kpi-value">{formatCbrWon(60_000_000 * CBR_KPI.topPercent / 100)}</strong>
          <span class="cbr-kpi-sub">세전 기준 시뮬레이션</span>
        </div>
      </div>
    </section>

    <!-- 필터 탭 + 차트 -->
    <section class="content-section cbr-chart-section" id="ranking-chart">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">성과급률 순위</p>
        <h2>TOP 10 성과급률 비교 (연봉 대비 %)</h2>
        <p>업종 탭을 클릭하면 해당 업종만 필터링됩니다.</p>
      </div>

      <div class="cbr-filter-tabs" role="tablist" aria-label="업종 필터">
        <button class="cbr-filter-tab is-active" data-cbr-filter="all" role="tab" aria-selected="true">전체</button>
        {industries.map((ind) => (
          <button class="cbr-filter-tab" data-cbr-filter={ind} role="tab" aria-selected="false">
            {BONUS_RANKING_INDUSTRY_LABELS[ind]}
          </button>
        ))}
      </div>

      <div class="cbr-chart-wrap">
        <canvas id="cbrRankingChart" aria-label="성과급률 순위 차트"></canvas>
      </div>
    </section>

    <!-- 전체 테이블 -->
    <section class="content-section cbr-table-section" id="full-table">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">전체 비교</p>
        <h2>전체 기업 성과급률 비교표</h2>
        <p>연봉 6,000만원 기준 시뮬레이션 금액입니다.</p>
      </div>

      <div class="cbr-table-wrap" id="cbrTableWrap">
        <table class="cbr-table" id="cbrTable">
          <thead>
            <tr>
              <th>순위</th>
              <th>회사</th>
              <th>업종</th>
              <th>성과급률</th>
              <th class="cbr-col-gross">추정액(세전)</th>
              <th class="cbr-col-net">추정액(세후)</th>
              <th class="cbr-col-conf">신뢰도</th>
              <th class="cbr-col-link">상세 계산기</th>
            </tr>
          </thead>
          <tbody id="cbrTableBody">
            {sorted.map((entry, i) => {
              const gross = CBR_BASE_SALARY * entry.salaryPercent / 100;
              const net = gross * (1 - CBR_TAX_RATE);
              return (
                <tr data-cbr-industry={entry.industry}>
                  <td><span class="cbr-rank-badge">{i + 1}</span></td>
                  <td>
                    <span class="cbr-company-name">{entry.name}</span>
                    <span class="cbr-company-note">{entry.note}</span>
                  </td>
                  <td>
                    <span class="cbr-industry-badge" data-industry={entry.industry}>
                      {BONUS_RANKING_INDUSTRY_LABELS[entry.industry]}
                    </span>
                  </td>
                  <td>
                    <span class="cbr-percent-value">{entry.salaryPercent}%</span>
                  </td>
                  <td class="cbr-col-gross">{formatCbrWon(gross)}</td>
                  <td class="cbr-col-net">{formatCbrWon(net)}</td>
                  <td class="cbr-col-conf">
                    <span class={`cbr-conf-badge cbr-conf-badge--${entry.confidence}`}>
                      {entry.confidence === "confirmed" ? "확정" : "추정"}
                    </span>
                  </td>
                  <td class="cbr-col-link">
                    <a href={entry.calculatorHref} class="cbr-calc-link">계산기 →</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- 허브 카드 -->
    <section class="content-section cbr-hub-section" id="calculator-hub">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">계산기 모음</p>
        <h2>성과급 계산기 전체 보기</h2>
        <p>내 연봉 기준으로 각 회사 추정 성과급을 직접 계산해보세요.</p>
      </div>

      <div class="cbr-hub-group">
        <h3 class="cbr-hub-group-title">단독 계산기</h3>
        <div class="cbr-hub-grid">
          {singleCards.map((card) => (
            <a href={card.href} class="cbr-hub-card">
              <span class="cbr-hub-label">{card.label}</span>
              <span class="cbr-hub-desc">{card.description}</span>
            </a>
          ))}
        </div>
      </div>

      <div class="cbr-hub-group">
        <h3 class="cbr-hub-group-title">업종 비교 계산기</h3>
        <div class="cbr-hub-grid">
          {compareCards.map((card) => (
            <a href={card.href} class="cbr-hub-card">
              <span class="cbr-hub-label">{card.label}</span>
              <span class="cbr-hub-desc">{card.description}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <SeoContent
      introTitle="대기업 성과급 순위, 어떻게 봐야 할까요?"
      intro={seoIntro}
      faq={BONUS_RANKING_FAQ}
    />

    <CompareCta
      eyebrow="다음 계산"
      title="내 연봉 기준 성과급을 직접 계산해보세요"
      description="순위 확인 후 각 회사 계산기에서 나의 실제 연봉을 입력해 추정 성과급을 확인하세요."
      variant="bonus"
      links={[
        { href: "/tools/semiconductor-bonus-comparison/", label: "반도체 성과급 비교", tone: "primary" },
        { href: "/reports/corporate-bonus-comparison-2026/", label: "대기업 성과급 완전 비교", tone: "secondary" },
        { href: "/compare/bonus/", label: "성과급 계산기 모음", tone: "secondary" },
      ]}
    />
  </main>

</BaseLayout>

<script id="cbrConfig" type="application/json" set:html={JSON.stringify(config)}></script>
<script src="/scripts/corporate-bonus-ranking-top10-2026.js" defer></script>
