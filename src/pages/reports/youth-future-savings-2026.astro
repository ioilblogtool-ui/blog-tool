---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import CompareCta from "../../components/CompareCta.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  ACCOUNT_TYPE_COMPARISONS,
  APPLICATION_CHECKS,
  BANK_RATE_INFOS,
  BANK_RATE_SUMMARY,
  BANK_SELECTION_GUIDES,
  DECISION_CARDS,
  ELIGIBILITY_CHECKS,
  LEAP_COMPARISON_ROWS,
  MATURITY_SCENARIOS,
  RELATED_LINKS,
  SEO_CRITERIA,
  SEO_INTRO,
  SOURCE_LINKS,
  SUMMARY_METRICS,
  YOUTH_FUTURE_FAQS,
  YOUTH_FUTURE_META,
  formatMaturityRange,
} from "../../data/youthFutureSavings2026";

const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteUrl}/reports/${YOUTH_FUTURE_META.slug}/`;
const title = `${YOUTH_FUTURE_META.title} | 비교계산소`;
const relatedForSeo = RELATED_LINKS.map((item) => ({ href: item.href, label: item.title }));
const criteriaForSeo = SEO_CRITERIA.map((item) => `${item.title}: ${item.body}`);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: YOUTH_FUTURE_META.title,
      description: YOUTH_FUTURE_META.description,
      dateModified: "2026-06-22",
      mainEntityOfPage: pageUrl,
      publisher: {
        "@type": "Organization",
        name: "비교계산소",
        url: siteUrl,
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: YOUTH_FUTURE_FAQS.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout title={title} description={YOUTH_FUTURE_META.description} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page yfs-page">
    <CalculatorHero
      eyebrow="2026년 6월 22일 비교공시"
      title={YOUTH_FUTURE_META.title}
      description="은행별 기본금리·최고금리·우대조건과 내 상황에 유리한 은행 선택 기준을 한 번에 정리합니다."
      updatedAt={YOUTH_FUTURE_META.updatedAt}
      badges={["청년미래적금 금리", "은행별 비교", "우대조건"]}
    />

    <InfoNotice
      title="정책금융 안내"
      lines={[
        "이 콘텐츠는 금융상품 가입 권유가 아니라 정책금융 정보 정리와 계산 보조 콘텐츠입니다.",
        "만기 수령액은 월 납입액, 적용금리, 우대조건, 정부기여금 지급 방식에 따라 달라지는 추정값입니다.",
        "은행별 금리는 2026년 6월 22일 은행연합회 청년미래적금 비교공시 기준이며, 실제 가입 전 상품설명서와 상세정보를 다시 확인하세요.",
      ]}
    />

    <section class="content-section yfs-section yfs-summary-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">요약</p>
        <h2>청년미래적금 금리 핵심 숫자</h2>
        <p>기본금리는 모든 은행이 5.00%로 같고, 차이는 우대금리 달성 가능성에서 갈립니다.</p>
      </div>

      <div class="yfs-summary-grid">
        {SUMMARY_METRICS.map((metric) => (
          <article class="yfs-summary-card">
            <span class={`yfs-badge yfs-badge--${metric.badge.replace(" ", "-")}`}>{metric.badge}</span>
            <p>{metric.label}</p>
            <strong>{metric.value}</strong>
            <small>{metric.note}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">은행별 결론</p>
        <h2>최고금리만 보면 8%, 실제 선택은 조건 달성 가능성입니다</h2>
        <p>같은 8%라도 급여이체, 카드, 자동이체, 첫거래, 연계가입 조건이 다릅니다. 내가 이미 쓰는 은행에서 쉽게 채울 수 있는 조건이 많은지 먼저 보세요.</p>
      </div>
      <div class="yfs-rate-summary-grid">
        {BANK_RATE_SUMMARY.map((item) => (
          <article class={`yfs-rate-summary-card yfs-rate-summary-card--${item.tone}`}>
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <p>{item.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">나에게 유리한 은행</p>
        <h2>청년미래적금 은행 선택은 이렇게 나누면 쉽습니다</h2>
        <p>최고금리 은행을 고르는 것보다 내가 실제로 우대조건을 끝까지 유지할 수 있는 은행을 고르는 편이 안전합니다.</p>
      </div>
      <div class="yfs-bank-choice-grid">
        {BANK_SELECTION_GUIDES.map((guide) => (
          <article class="yfs-bank-choice-card">
            <span>{guide.title}</span>
            <strong>{guide.bestBanks}</strong>
            <p>{guide.body}</p>
            <small>{guide.caution}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">가입 전 확인</p>
        <h2>대상 여부를 먼저 가르는 조건</h2>
        <p>조건이 애매하면 가입 불가로 단정하지 말고 확인 필요로 두고 공식 심사 기준을 확인하세요.</p>
      </div>

      <div class="yfs-check-grid">
        {ELIGIBILITY_CHECKS.map((check) => (
          <article class="yfs-check-card">
            <div>
              <span class="yfs-badge yfs-badge--확인-필요">확인 필요</span>
              <h3>{check.title}</h3>
            </div>
            <p>{check.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">일반형 vs 우대형</p>
        <h2>정부기여금 6%와 12% 차이</h2>
        <p>우대형은 혜택이 크지만 증빙과 소득 기준 확인이 더 중요합니다.</p>
      </div>

      <div class="yfs-type-grid">
        {ACCOUNT_TYPE_COMPARISONS.map((type) => (
          <article class="yfs-type-card">
            <div class="yfs-type-card__head">
              <span>{type.type}</span>
              <strong>{type.contribution}</strong>
            </div>
            <p>{type.bestFor}</p>
            <small>{type.caution}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section" id="maturity">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">만기 시나리오</p>
        <h2>월 납입액별 예상 만기 수령액</h2>
        <p>아래 금액은 공개된 정부기여금 구조와 입력 금리 가정을 반영한 추정값입니다.</p>
      </div>

      <div class="yfs-summary-grid">
        {MATURITY_SCENARIOS.map((scenario) => (
          <article class="yfs-summary-card">
            <span class="yfs-badge yfs-badge--추정">추정</span>
            <p>{scenario.label}</p>
            <strong>{formatMaturityRange(scenario)}</strong>
            <small>{scenario.note}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">은행 공시</p>
        <h2>청년미래적금 은행별 금리 비교표</h2>
        <p>2026년 6월 22일 기준 비교공시입니다. 기본금리는 모두 5.00%이며, 최고금리는 우대금리를 모두 채웠을 때 기준입니다.</p>
      </div>

      <div class="table-wrap yfs-bank-table-wrap">
        <table class="yfs-bank-rate-table">
          <thead>
            <tr>
              <th scope="col">은행</th>
              <th scope="col">기본금리</th>
              <th scope="col">최고금리</th>
              <th scope="col">우대조건 요약</th>
              <th scope="col">유리한 사람</th>
              <th scope="col">난이도</th>
            </tr>
          </thead>
          <tbody>
            {BANK_RATE_INFOS.map((bank) => (
              <tr>
                <th scope="row">{bank.bank}</th>
                <td>{bank.baseRate.toFixed(2)}%</td>
                <td><strong>{bank.totalRate.toFixed(2)}%</strong></td>
                <td>{bank.conditionSummary}</td>
                <td>{bank.bestFor}</td>
                <td><span class={`yfs-difficulty yfs-difficulty--${bank.difficulty}`}>{bank.difficulty}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="yfs-bank-grid">
        {BANK_RATE_INFOS.map((bank) => (
          <article class="yfs-bank-card">
            <div class="yfs-bank-card__top">
              <span class={`yfs-badge yfs-badge--${bank.badge.replace(" ", "-")}`}>{bank.badge}</span>
              <h3>{bank.bank}</h3>
            </div>
            <div class="yfs-rate-row">
              <span>기본</span>
              <strong>{bank.baseRate}%</strong>
              <span>우대</span>
              <strong>+{bank.bonusRate}%</strong>
              <span>합계</span>
              <strong>{bank.totalRate}%</strong>
            </div>
            <p>{bank.note}</p>
            <small>{bank.bestFor}</small>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">청년도약계좌 비교</p>
        <h2>갈아타기 전에 봐야 할 차이</h2>
        <p>기존 계좌를 해지하는 선택은 남은 기간과 상실 혜택을 같이 비교해야 합니다.</p>
      </div>

      <div class="table-wrap yfs-comparison-table-wrap">
        <table class="yfs-comparison-table">
          <thead>
            <tr>
              <th scope="col">항목</th>
              <th scope="col">청년미래적금</th>
              <th scope="col">청년도약계좌</th>
              <th scope="col">판단 기준</th>
            </tr>
          </thead>
          <tbody>
            {LEAP_COMPARISON_ROWS.map((row) => (
              <tr>
                <th scope="row">{row.label}</th>
                <td>{row.youthFuture}</td>
                <td>{row.youthLeap}</td>
                <td>{row.decision}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="yfs-decision-grid">
        {DECISION_CARDS.map((card) => (
          <article class="yfs-decision-card">
            <span>판단 포인트</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">신청 전 체크리스트</p>
        <h2>가입 버튼을 누르기 전 확인할 것</h2>
      </div>

      <div class="yfs-apply-grid">
        {APPLICATION_CHECKS.map((item) => (
          <article class="yfs-apply-card">
            <span aria-hidden="true"></span>
            <div>
              <h3>체크</h3>
              <p>{item}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">공식 확인 경로</p>
        <h2>최종 조건은 공식 자료에서 재확인</h2>
      </div>

      <div class="yfs-source-grid">
        {SOURCE_LINKS.map((source) => (
          <a href={source.href} target="_blank" rel="noopener" class="yfs-source-card">
            <span>공식 자료</span>
            <strong>{source.label}</strong>
          </a>
        ))}
      </div>
    </section>

    <section class="content-section yfs-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">관련 콘텐츠</p>
        <h2>다음에 같이 볼 계산기와 리포트</h2>
      </div>

      <div class="yfs-related-grid">
        {RELATED_LINKS.map((link) => (
          <a href={link.href} class="yfs-related-card">
            <span>{link.title}</span>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <CompareCta
      variant="welfare"
      title="청년미래적금과 다른 지원금 흐름도 함께 보세요"
      description="청년미래적금 조건을 확인했다면 청년 적금 계산기, 지원금 계산기, 복지급여 비교표로 다음 선택지를 좁힐 수 있습니다."
      links={[
        { href: "/tools/youth-savings-maturity-calculator/", label: "청년 적금 만기 계산" },
        { href: "/tools/high-oil-support-payment-calculator/", label: "고유가 지원금 계산" },
      ]}
    />

    <SeoContent
      introTitle="청년미래적금 조건과 만기 수령액을 해석하는 기준"
      intro={SEO_INTRO}
      inputPoints={[
        "일반형인지 우대형인지 먼저 가정합니다.",
        "월 30만 원·50만 원처럼 실제 유지 가능한 납입액으로 계산합니다.",
        "청년도약계좌 보유자는 해지 손실과 새 상품 혜택을 함께 비교합니다.",
      ]}
      criteria={criteriaForSeo}
      faq={YOUTH_FUTURE_FAQS}
      related={relatedForSeo}
    />
  </main>
</BaseLayout>
