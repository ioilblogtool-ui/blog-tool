---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const title = "임금피크제 전 퇴직연금 DB에서 DC로 바꿔야 할까";
const description =
  "임금피크제를 앞둔 직장인이 퇴직연금 DB형을 유지할지 DC형으로 전환할지 판단할 때 보는 실전 가이드입니다. 전환 시점, 유리한 조건, 체크리스트, 주의사항을 정리했습니다.";

const decisionCards = [
  {
    label: "DB 유지 검토",
    title: "임금이 계속 오르거나 승진 가능성이 크다",
    body: "DB형은 퇴직급여 산식이 퇴직 직전 평균임금과 근속기간에 민감합니다. 임금 상승이 계속된다면 전환보다 유지가 더 나을 수 있습니다.",
  },
  {
    label: "DC 전환 검토",
    title: "임금피크제로 급여가 낮아질 가능성이 있다",
    body: "퇴직 직전 평균임금이 낮아지는 구조라면 임금피크제 전 DB 적립분을 확정하고 DC로 옮기는 선택지를 검토할 만합니다.",
  },
  {
    label: "보류 검토",
    title: "투자 운용을 직접 관리하기 어렵다",
    body: "DC형은 운용 성과와 손실이 본인에게 귀속됩니다. 전환 후 예금에 방치할 계획이라면 기대효과가 생각보다 작을 수 있습니다.",
  },
];

const compareRows = [
  {
    label: "퇴직급여 기준",
    db: "퇴직 시점 평균임금과 근속기간 중심",
    dc: "회사 부담금과 본인 운용 성과 중심",
  },
  {
    label: "임금피크제 영향",
    db: "퇴직 직전 임금이 낮아지면 불리해질 수 있음",
    dc: "전환 이후 적립금은 운용 성과에 따라 변동",
  },
  {
    label: "운용 책임",
    db: "회사 중심",
    dc: "근로자 본인 중심",
  },
  {
    label: "손실 가능성",
    db: "개인 계좌 운용손실 부담은 제한적",
    dc: "상품 선택에 따라 원금손실 가능",
  },
  {
    label: "전환 후 되돌리기",
    db: "회사 규약 확인 필요",
    dc: "전환 후 재전환 가능 여부를 사전에 확인해야 함",
  },
];

const timeline = [
  {
    step: "1",
    title: "임금피크 적용 예정일 확인",
    body: "인사팀 또는 취업규칙에서 임금피크제 시작 시점, 급여 삭감률, 직무 변경 여부를 먼저 확인합니다.",
  },
  {
    step: "2",
    title: "전환 기준일의 평균임금 확인",
    body: "DB형에서 DC형으로 전환할 때 과거 근속분이 어떤 기준임금으로 산정되는지 회사 퇴직연금 규약을 확인합니다.",
  },
  {
    step: "3",
    title: "DC 운용 계획 작성",
    body: "전환 후 예금, TDF, ETF, 원리금보장형을 어떤 비율로 둘지 정합니다. 운용 계획이 없으면 전환 효과가 흐려질 수 있습니다.",
  },
  {
    step: "4",
    title: "전환 신청 전 재확인",
    body: "전환 후 DB형으로 되돌릴 수 있는지, 회사 부담금 납입 주기와 수수료가 어떤지 마지막으로 확인합니다.",
  },
];

const scenarios = [
  {
    title: "전환 검토 강도 높음",
    bullets: ["임금피크제로 급여가 단계적으로 낮아짐", "퇴직까지 3년 이상 남음", "TDF·ETF 등 장기 운용 계획이 있음"],
  },
  {
    title: "중립 또는 추가 계산 필요",
    bullets: ["임금 삭감 폭이 작음", "퇴직까지 남은 기간이 짧음", "전환 기준일과 평균임금 산정 방식이 불명확함"],
  },
  {
    title: "DB 유지 검토",
    bullets: ["임금 상승률이 여전히 높음", "승진 또는 보직수당 가능성이 큼", "투자 손실을 감당하기 어려움"],
  },
];

const checklist = [
  "임금피크제 시작일과 삭감률을 확인했다",
  "DB에서 DC로 전환되는 과거 근속분 산정 방식을 확인했다",
  "전환 후 다시 DB형으로 돌아갈 수 있는지 확인했다",
  "DC 계좌에서 선택할 상품과 리밸런싱 주기를 정했다",
  "원리금보장형과 실적배당형의 수익률·수수료를 비교했다",
  "전환 전 가족 현금흐름, 대출, 은퇴 예정 시점을 함께 검토했다",
];

const sourceLinks = [
  {
    label: "고용노동부 퇴직연금 제도 안내",
    href: "https://www.moel.go.kr",
  },
  {
    label: "금융감독원 통합연금포털",
    href: "https://100lifeplan.fss.or.kr",
  },
  {
    label: "근로자퇴직급여 보장법",
    href: "https://www.law.go.kr/LSW/lsInfoP.do?efYd=20260701&lsiSeq=271035",
  },
  {
    label: "국세청 연금계좌 세액공제 안내",
    href: "https://www.nts.go.kr/nts/cm/cntnts/cntntsView.do?cntntsId=7875&mi=2238",
  },
];

const faq = [
  {
    question: "임금피크제 전에 무조건 DC형으로 전환해야 하나요?",
    answer:
      "아닙니다. 임금피크제 적용 여부, 급여 삭감률, 퇴직까지 남은 기간, 회사 규약, 본인의 운용 능력에 따라 달라집니다. 임금이 낮아질 가능성이 있으면 검토할 이유가 생기지만, 무조건 전환이 정답은 아닙니다.",
  },
  {
    question: "DB형에서 DC형으로 전환하면 과거 근속분은 어떻게 되나요?",
    answer:
      "회사 퇴직연금 규약에 따라 전환 시점까지의 급여 산정 기준으로 부담금이 확정되어 DC 계좌로 이전되는 방식이 일반적입니다. 다만 구체적인 기준일과 평균임금 산정 방식은 회사별로 다를 수 있습니다.",
  },
  {
    question: "DC형으로 전환하면 다시 DB형으로 돌아갈 수 있나요?",
    answer:
      "회사 제도와 규약에 따라 다릅니다. 전환 신청 전 인사팀, 퇴직연금 담당자, 금융회사에 재전환 가능 여부를 반드시 확인해야 합니다.",
  },
  {
    question: "DC형 전환 후 예금만 넣어도 괜찮나요?",
    answer:
      "안정성을 중시한다면 가능하지만, DC형 전환의 핵심은 본인이 운용 성과를 가져가는 구조입니다. 예금만 둘 경우 물가상승률과 장기 수익률 측면에서 기대효과가 작을 수 있습니다.",
  },
  {
    question: "임금피크제와 퇴직금 계산에서 가장 중요한 숫자는 무엇인가요?",
    answer:
      "임금피크 적용 전 평균임금, 적용 후 삭감률, 퇴직까지 남은 근속기간, DC 전환 후 예상 운용수익률입니다. 네 숫자를 함께 봐야 DB 유지와 DC 전환의 손익을 비교할 수 있습니다.",
  },
];

const relatedLinks = [
  { href: "/tools/peak-wage-retirement-calculator/", label: "임금피크제 퇴직금 계산기" },
  { href: "/tools/retirement-dc-db-calculator/", label: "퇴직연금 DB vs DC 전환 계산기" },
  { href: "/reports/retirement-pension-dc-db-irp-2026/", label: "퇴직연금 DB·DC·IRP 비교" },
  { href: "/tools/irp-pension-calculator/", label: "IRP 연금 계산기" },
  { href: "/tools/retirement/", label: "퇴직금 계산기" },
  { href: "/tools/savings-vs-etf-retirement/", label: "은퇴자금 ETF 비교 계산기" },
  { href: "/reports/worker-retirement-reality-2026/", label: "직장인 은퇴 준비 실태" },
];
---

<BaseLayout
  title={`${title} | DB형 DC형 전환 가이드 2026`}
  description={description}
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title,
    description,
    inLanguage: "ko-KR",
    dateModified: "2026-06-05",
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  }}
>
  <SiteHeader />

  <main class="container page-shell report-page rp-switch-page">
    <CalculatorHero
      eyebrow="퇴직연금 전환 가이드"
      title={title}
      description="임금피크제를 앞두고 DB형 퇴직연금을 유지할지, DC형으로 전환할지 고민하는 직장인을 위한 판단 기준입니다."
      badges={["임금피크제", "DB형", "DC형", "퇴직연금", "2026"]}
    />

    <InfoNotice
      title="전환 전 반드시 확인하세요"
      lines={[
        "이 페이지는 일반적인 판단 기준을 정리한 참고 정보입니다. 회사 규약, 임금피크제 적용 방식, 퇴직연금 사업자 조건에 따라 결과가 달라질 수 있습니다.",
        "DC형 전환은 운용 손익이 본인에게 귀속되는 선택입니다. 전환 전 회사 인사팀과 퇴직연금 사업자 안내를 반드시 확인하세요.",
        "임금피크제 전환 이슈는 세금보다 근로조건과 퇴직급여 산정 기준의 영향이 큽니다. 전환 시점과 평균임금 기준일을 먼저 확인해야 합니다.",
      ]}
    />

    <nav class="rp-switch-nav" aria-label="임금피크제 퇴직연금 가이드 바로가기">
      <a href="#decision">30초 판단</a>
      <a href="#compare">DB·DC 차이</a>
      <a href="#timing">전환 순서</a>
      <a href="#scenarios">상황별 판단</a>
      <a href="#checklist">체크리스트</a>
      <a href="#faq">FAQ</a>
    </nav>

    <section class="rp-switch-summary" id="decision">
      <div class="rp-switch-summary__head">
        <p>30초 결론</p>
        <h2>임금피크제가 시작되기 전이라면 DB형 산정 기준을 먼저 잠그는지 확인해야 합니다</h2>
        <span>핵심은 “퇴직 직전 임금이 낮아지는가”와 “전환 후 DC 계좌를 제대로 운용할 수 있는가”입니다.</span>
      </div>
      <div class="rp-switch-card-grid">
        {decisionCards.map((item) => (
          <article class="rp-switch-card">
            <p>{item.label}</p>
            <strong>{item.title}</strong>
            <span>{item.body}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" id="compare">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">DB형 DC형 차이</p>
        <h2>임금피크제에서는 “퇴직 직전 평균임금”과 “전환 후 운용 성과”가 갈림길입니다</h2>
      </div>
      <div class="rp-switch-table-wrap">
        <table class="rp-switch-table">
          <thead>
            <tr>
              <th>구분</th>
              <th>DB형 유지</th>
              <th>DC형 전환</th>
            </tr>
          </thead>
          <tbody>
            {compareRows.map((row) => (
              <tr>
                <th>{row.label}</th>
                <td>{row.db}</td>
                <td>{row.dc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section" id="timing">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">전환 순서</p>
        <h2>DB에서 DC로 바꾸기 전 확인 순서</h2>
        <p>전환 신청서부터 쓰면 늦습니다. 기준일과 산정방식을 먼저 확인해야 합니다.</p>
      </div>
      <div class="rp-switch-timeline">
        {timeline.map((item) => (
          <article>
            <span>{item.step}</span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" id="scenarios">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">상황별 판단</p>
        <h2>내 상황이 어느 쪽에 가까운지 먼저 분류하세요</h2>
      </div>
      <div class="rp-switch-scenario-grid">
        {scenarios.map((item) => (
          <article class="rp-switch-scenario">
            <h3>{item.title}</h3>
            <ul>
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" id="checklist">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">전환 전 체크리스트</p>
        <h2>인사팀에 물어볼 질문을 먼저 정리하세요</h2>
      </div>
      <div class="rp-switch-check-grid">
        {checklist.map((item) => (
          <div class="rp-switch-check-item">
            <span>확인</span>
            <p>{item}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">공식 확인 경로</p>
        <h2>전환 신청 전 참고할 공식·공개 자료</h2>
      </div>
      <div class="rp-switch-source-grid">
        {sourceLinks.map((item) => (
          <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
        ))}
      </div>
    </section>

    <section class="content-section" id="faq">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">FAQ</p>
        <h2>임금피크제 DB·DC 전환 질문</h2>
      </div>
      <div class="rp-switch-faq-list">
        {faq.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="rp-switch-related">
      <div>
        <p>다음에 함께 볼 계산기</p>
        <h2>전환 판단 후에는 실제 금액을 계산하세요</h2>
      </div>
      <div class="rp-switch-related__links">
        {relatedLinks.map((item) => (
          <a href={withBase(item.href)}>{item.label}</a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="임금피크제 전 퇴직연금 전환 판단 기준"
      intro={[
        "임금피크제를 앞두면 퇴직연금 DB형을 유지할지 DC형으로 전환할지 고민이 커집니다. DB형은 퇴직 직전 평균임금이 중요하고, DC형은 전환 후 계좌 운용 성과가 중요해, 두 제도의 결정 기준 자체가 다릅니다.",
        "따라서 임금피크제 전환 판단은 단순히 DB형과 DC형 중 어느 제도가 좋으냐의 문제가 아닙니다. 임금 삭감 시점, 퇴직까지 남은 기간, 회사 규약, 운용 계획을 함께 봐야 본인에게 유리한 선택을 할 수 있습니다.",
        "임금 삭감 폭이 크고 남은 근속기간이 길수록 DC형 전환의 실익이 커지는 경향이 있습니다. 반대로 임금피크제까지 남은 기간이 짧다면 전환에 따른 효과가 제한적일 수 있어, 개인 상황에 맞는 시뮬레이션이 필요합니다.",
