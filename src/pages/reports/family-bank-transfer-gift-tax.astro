---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import { familyBankTransferGiftTax as report } from "../../data/familyBankTransferGiftTax";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const badgeClass = (badge: string) =>
  ({
    공식: "fbt-badge--official",
    참고: "fbt-badge--reference",
    주의: "fbt-badge--caution",
    고위험: "fbt-badge--danger",
  })[badge] ?? "fbt-badge--reference";

const riskClass = (risk: string) =>
  ({
    낮음: "low",
    중간: "medium",
    높음: "high",
    "매우 높음": "critical",
  })[risk] ?? "medium";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: report.meta.seoTitle,
      description: report.meta.description,
      inLanguage: "ko-KR",
      dateModified: "2026-06-29",
      mainEntityOfPage: `https://bigyocalc.com/reports/${report.meta.slug}/`,
      publisher: { "@type": "Organization", name: "비교계산소", url: "https://bigyocalc.com" },
    },
    {
      "@type": "FAQPage",
      mainEntity: report.faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ],
};
---

<BaseLayout
  title={report.meta.seoTitle}
  description={report.meta.description}
  ogImage="/og/reports/family-bank-transfer-gift-tax.svg"
  jsonLd={jsonLd}
>
  <SiteHeader />

  <main class="container page-shell report-page fbt-page">
    <CalculatorHero
      eyebrow="세금 리포트"
      title={report.meta.title}
      description="부모·자녀·부부 사이 계좌이체가 생활비인지, 빌린 돈인지, 증여인지 관계·용도·증빙 기준으로 정리했습니다."
      badges={["계좌이체", "증여세", "차용증", "자금출처"]}
    />

    <InfoNotice
      title="가족 간 계좌이체는 금액만으로 판단하지 않습니다"
      lines={[
        report.meta.caution,
        "생활비인지, 빌린 돈인지, 증여인지에 따라 세금 판단이 달라집니다.",
        "전세자금·주택자금·투자금처럼 목돈이 오간 경우에는 증빙이 특히 중요합니다.",
        report.meta.updatedAt,
      ]}
    />

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">30초 요약</p>
        <h2>가족이라도 돈의 목적과 사용처가 중요합니다</h2>
        <p>생활비·교육비처럼 설명 가능한 지출과 전세자금·주택자금·투자금처럼 자산으로 남는 목돈은 리스크가 다릅니다.</p>
      </div>
      <div class="fbt-summary-grid" aria-label="가족 간 계좌이체 핵심 요약">
        {report.summaryCards.map((card) => (
          <article class="fbt-summary-card">
            <span class={`fbt-badge ${badgeClass(card.badge)}`}>{card.badge}</span>
            <p>{card.label}</p>
            <strong>{card.value}</strong>
            <small>{card.note}</small>
          </article>
        ))}
      </div>
      <div class="fbt-actions">
        <a class="fbt-button fbt-button--primary" href={withBase("/tools/gift-tax-calculator/")}>증여세 계산기로 공제한도 확인하기</a>
        <a class="fbt-button" href="#fbt-loan-checklist">차용증 증빙 체크리스트 보기</a>
      </div>
    </section>

    <DesignTrustPanel
      title="가족 간 계좌이체 판단 기준"
      updatedAt="2026년 6월"
      items={[
        {
          label: "공식",
          title: "관계별 공제한도",
          description: "배우자, 자녀, 직계존속, 기타 친족의 증여재산공제는 법령상 기준을 따릅니다.",
        },
        {
          label: "참고",
          title: "생활비·부양 목적",
          description: "실제 지출 내역과 사용처가 명확하면 설명 가능성이 높아지는 영역입니다.",
        },
        {
          label: "주의",
          title: "목돈과 자산 취득",
          description: "전세보증금, 주택 구입, 투자금은 증여 또는 차용 증빙을 더 보수적으로 확인해야 합니다.",
        },
      ]}
      notes={[
        "이 리포트는 일반적인 세금 이해를 돕기 위한 콘텐츠이며, 신고서 작성이나 세무 자문을 대신하지 않습니다.",
        "큰 금액을 이체하거나 부동산 취득자금과 연결되는 경우 국세청 또는 세무 전문가 확인을 권장합니다.",
      ]}
    />

    <section class="content-section" aria-labelledby="fbt-risk-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">빠른 판정</p>
        <h2 id="fbt-risk-title">이체 목적별 증여 리스크</h2>
        <p>아래 표는 신고 여부를 확정하는 기준이 아니라, 어떤 거래가 더 많은 증빙을 요구하는지 보여주는 참고용 분류입니다.</p>
      </div>
      <div class="fbt-risk-list">
        {report.riskTable.map((item) => (
          <article class={`fbt-risk-card fbt-risk--${riskClass(item.risk)}`}>
            <div class="fbt-risk-card__head">
              <span class={`fbt-badge ${badgeClass(item.badge)}`}>{item.risk}</span>
              <h3>{item.transferType}</h3>
            </div>
            <p>{item.interpretation}</p>
            <strong>{item.checkPoint}</strong>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="fbt-relation-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">관계별 기준</p>
        <h2 id="fbt-relation-title">부모·자녀·부부·형제는 보는 포인트가 다릅니다</h2>
        <p>관계별 공제한도와 실제 돈의 사용처를 함께 확인해야 합니다.</p>
      </div>
      <div class="fbt-relation-grid">
        {report.relationGuides.map((item) => (
          <article class={`fbt-relation-card fbt-relation-card--${item.id}`}>
            <span>{item.label}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <strong>{item.deductionLabel}</strong>
            <ul>
              {item.keyPoints.map((point) => <li>{point}</li>)}
            </ul>
            <div class="fbt-caution-box">{item.caution}</div>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="fbt-deduction-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">공제한도</p>
        <h2 id="fbt-deduction-title">증여로 본다면 10년 합산 공제부터 확인합니다</h2>
        <p>공제한도는 이번 이체 1건 기준이 아니라 과거 증여를 포함한 10년 합산 기준입니다.</p>
      </div>
      <div class="table-wrap">
        <table class="fbt-table fbt-deduction-table">
          <thead>
            <tr>
              <th>관계</th>
              <th>10년 합산 공제</th>
              <th>설명</th>
            </tr>
          </thead>
          <tbody>
            {report.deductionLimits.map((item) => (
              <tr>
                <td>{item.relation}</td>
                <td><strong>{item.amountLabel}</strong></td>
                <td>{item.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="fbt-table-note">과거 현금·부동산·주식 증여가 있었다면 이번 계좌이체와 함께 합산해 봐야 합니다.</p>
    </section>

    <section id="fbt-loan-checklist" class="content-section" aria-labelledby="fbt-loan-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">차용증·상환</p>
        <h2 id="fbt-loan-title">빌린 돈이라고 주장하려면 무엇이 필요할까?</h2>
        <p>차용증은 시작점일 뿐입니다. 실제 이자 지급과 원금 상환 흐름이 계좌 기록으로 남아야 합니다.</p>
      </div>
      <div class="fbt-checklist-grid">
        {report.checklist.map((item) => (
          <article class="fbt-check-card">
            <span aria-hidden="true"></span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.reason}</p>
              <small>{item.example}</small>
            </div>
          </article>
        ))}
      </div>
      <div class="fbt-inline-cta">
        <strong>차용증만으로는 부족합니다</strong>
        <p>이자 지급, 원금 상환, 계좌 메모가 함께 남아야 가족 간 대여 흐름을 설명하기 쉽습니다.</p>
      </div>
    </section>

    <section class="content-section" aria-labelledby="fbt-case-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">사례별 해석</p>
        <h2 id="fbt-case-title">내 상황과 가장 비슷한 사례부터 확인하세요</h2>
        <p>같은 가족 간 이체라도 생활비, 보증금, 투자금, 병원비는 필요한 증빙이 달라집니다.</p>
      </div>
      <div class="fbt-case-grid">
        {report.cases.map((item) => (
          <article class={`fbt-case-card fbt-risk--${riskClass(item.risk)}`}>
            <div class="fbt-case-card__head">
              <span class={`fbt-badge ${item.risk === "낮음" ? "fbt-badge--reference" : item.risk === "중간" ? "fbt-badge--caution" : "fbt-badge--danger"}`}>{item.risk}</span>
              <strong>{item.amountLabel}</strong>
            </div>
            <h3>{item.title}</h3>
            <p>{item.situation}</p>
            <div class="fbt-case-card__interpretation">{item.interpretation}</div>
            <ul>
              {item.evidence.map((evidence) => <li>{evidence}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="fbt-audit-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">자금출처 확인</p>
        <h2 id="fbt-audit-title">나중에 확인받을 수 있는 자료들</h2>
        <p>세무 리스크는 이체 당일보다 부동산 취득, 전세보증금 형성, 자금출처 확인 과정에서 드러나는 경우가 많습니다.</p>
      </div>
      <div class="fbt-audit-grid">
        {report.auditPoints.map((item) => (
          <article class="fbt-audit-card">
            <span class={`fbt-badge ${badgeClass(item.badge)}`}>{item.badge}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="fbt-related-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">다음 계산기</p>
        <h2 id="fbt-related-title">공제한도와 관련 리포트를 이어서 확인하세요</h2>
        <p>이체 목적을 정리했다면 실제 공제한도와 자녀·배우자 증여 전략을 계산기로 다시 확인하는 흐름이 좋습니다.</p>
      </div>
      <div class="fbt-related-grid">
        {report.relatedLinks.map((link) => (
          <a class="fbt-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
            <span>바로가기</span>
          </a>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="fbt-faq-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">FAQ</p>
        <h2 id="fbt-faq-title">자주 묻는 질문</h2>
      </div>
      <div class="fbt-faq-list">
        {report.faq.map((item, index) => (
          <details class="fbt-faq-item" open={index === 0}>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="content-section" aria-labelledby="fbt-sources-title">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">기준과 출처</p>
        <h2 id="fbt-sources-title">이 리포트의 기준</h2>
        <p>세법은 개정될 수 있으므로 실제 신고 전 최신 기준을 다시 확인해야 합니다.</p>
      </div>
      <div class="fbt-source-panel">
        <p>이 리포트는 2026년 6월 기준 가족 간 계좌이체를 증여, 생활비, 차용 관계로 구분해 이해하기 위한 참고 콘텐츠입니다. 실제 신고 단계에서는 이체일, 가족관계, 최근 10년 증여 이력, 사용처, 상환 능력, 증빙 자료를 별도로 확인해야 합니다.</p>
        <ul>
          {report.sources.map((source) => (
            <li>
              <a href={source.href} target="_blank" rel="noopener noreferrer">{source.label}</a>
              <span>{source.note}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <SeoContent
      introTitle="가족 간 계좌이체 증여세 기준을 읽는 법"
      intro={[
        "가족 간 계좌이체를 볼 때 가장 먼저 피해야 할 오해는 ‘얼마까지는 무조건 괜찮다’는 식의 단일 기준입니다. 세무상 판단은 금액 하나로 끝나지 않고, 누가 누구에게 보냈는지, 왜 보냈는지, 실제 어디에 쓰였는지, 돌려받을 돈인지, 과거 10년 동안 같은 관계에서 오간 돈이 있는지를 함께 봅니다.",
        "예를 들어 부모가 성인 자녀에게 1,000만 원을 보냈더라도 실제 월세·식비·교육비로 바로 사용됐다면 생활비 성격을 설명할 여지가 있습니다. 반대로 같은 금액이 자녀 명의 예금, 주식, 코인, 전세보증금, 주택 계약금으로 남는다면 자산 취득자금으로 보일 수 있어 증여 또는 차용 증빙을 더 보수적으로 준비해야 합니다.",
        "부부간 계좌이체도 마찬가지입니다. 한쪽 배우자가 공동 생활비 계좌에 매달 돈을 넣고 관리비, 카드값, 식비로 지출했다면 일반적인 생활 공동체 비용으로 설명하기 쉽습니다. 하지만 배우자 명의 주택, 주식, 예금, 보험, 투자계좌로 목돈이 이동해 자산이 형성된다면 배우자 증여재산공제 10년 6억 원 한도와 기존 증여 이력을 함께 확인해야 합니다.",
        "부모·자녀 사이의 전세자금이나 주택구입자금 지원은 특히 주의가 필요합니다. 돈이 자녀 명의 보증금이나 부동산 취득자금으로 남기 때문에 나중에 자금출처 확인 과정에서 과거 계좌이체가 다시 문제가 될 수 있습니다. 이때 증여로 처리할 돈인지, 빌려준 돈인지, 일부는 증여이고 일부는 차용인지 구조를 미리 정리해두는 편이 좋습니다.",
        "빌린 돈이라고 설명하려면 차용증만으로 충분하지 않습니다. 실제 대여라면 원금, 이자율, 상환일, 이자 지급일이 문서에 남아야 하고, 이후 계좌에서 이자와 원금이 약정대로 오간 기록이 있어야 합니다. 계좌이체 메모에 ‘대여금’, ‘이자’, ‘원금상환’처럼 목적을 적는 것도 보조 자료가 될 수 있지만, 메모만으로 차용 관계가 완성되는 것은 아닙니다.",
        "이 리포트는 그래서 계좌이체를 ‘안전/위험’으로 단순 판정하지 않고, 생활비·교육비·전세자금·주택자금·투자금·병원비·가족 간 대여처럼 목적별로 나누어 봅니다. 본문에서 본인 상황과 가까운 사례를 찾고, 관계별 10년 합산 공제한도와 남겨야 할 증빙을 확인한 뒤 실제 금액은 증여세 계산기나 세무 전문가 상담으로 이어가는 흐름이 가장 현실적입니다.",
      ]}
      inputPoints={[
        "먼저 이체 목적을 생활비·교육비·병원비 같은 소비성 지출인지, 전세보증금·주택자금·투자금 같은 자산 형성 자금인지 구분합니다.",
        "다음으로 가족관계를 확인합니다. 배우자, 성인 자녀, 미성년 자녀, 부모, 형제·친족은 10년 합산 공제한도와 설명 포인트가 다릅니다.",
