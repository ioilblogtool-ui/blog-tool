<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script define:vars={{ bracketChartData, simChartData }}>
  window.addEventListener("load", () => {
    if (typeof window.Chart === "undefined") return;

    // ② 소득공제 vs 세액공제 그룹 막대 차트
    const bracketCtx = document.getElementById("yetsBracketChart");
    if (bracketCtx) {
      new window.Chart(bracketCtx, {
        type: "bar",
        data: {
          labels: bracketChartData.labels,
          datasets: [
            {
              label: "소득공제 100만 원 절세액",
              data: bracketChartData.incomeData,
              backgroundColor: "#93C5BE",
            },
            {
              label: "세액공제 100만 원 절세액",
              data: bracketChartData.creditData,
              backgroundColor: "#0F6E56",
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: "top", labels: { font: { size: 12 }, padding: 10 } },
            tooltip: {
              callbacks: {
                label: (ctx) => ` ${ctx.dataset.label}: ${Math.round(ctx.parsed.y / 10000).toLocaleString()}만 원`,
              },
            },
          },
          scales: {
            y: { ticks: { callback: (v) => Math.round(Number(v) / 10000) + "만" } },
            x: { grid: { display: false } },
          },
        },
      });
    }

    // ⑪ 연봉 구간별 환급 시뮬레이션 가로 막대 차트
    const simCtx = document.getElementById("yetsSimulationChart");
    if (simCtx) {
      new window.Chart(simCtx, {
        type: "bar",
        data: {
          labels: simChartData.labels,
          datasets: [{
            label: "예상 환급액 (추정)",
            data: simChartData.data,
            backgroundColor: ["#4DC4A0", "#1D9E75", "#0F6E56", "#0a5a46"],
            borderRadius: 4,
          }],
        },
        options: {
          indexAxis: "y",
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: (ctx) => ` 약 ${Math.round(Number(ctx.parsed.x) / 10000).toLocaleString()}만 원`,
              },
            },
          },
          scales: {
            x: { ticks: { callback: (v) => Math.round(Number(v) / 10000) + "만" } },
            y: { grid: { display: false } },
          },
        },
      });
    }
  });
</script>
