---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import OwnershipTree from "../../components/OwnershipTree.astro";
import {
  HD_HYUNDAI_META,
  HD_HYUNDAI_TREE_NODES,
  HD_HYUNDAI_OWNERSHIP_FACTS,
  HD_HYUNDAI_FAQ,
  HD_HYUNDAI_SEO_INTRO,
  HD_HYUNDAI_SEO_CRITERIA,
  HD_HYUNDAI_KPI_CARDS,
  HD_HYUNDAI_SHIPBUILDING_ROLES,
  HD_HYUNDAI_INDIRECT_CONNECTIONS,
  HD_HYUNDAI_MARINE_SOLUTION_COMPARISON,
  HD_HYUNDAI_CONSTRUCTION_RESTRUCTURING,
  HD_HYUNDAI_OILBANK_POINTS,
  HD_HYUNDAI_NAV_FORMULA_ROWS,
  HD_HYUNDAI_LISTING_DEPTH_ROWS,
  HD_HYUNDAI_BUSINESS_AXES,
  HD_HYUNDAI_LISTED_DETAIL_ROWS,
  HD_HYUNDAI_RESTRUCTURING_TIMELINE,
  HD_HYUNDAI_GROUP_COMPARISON,
} from "../../data/hdHyundaiGroupOwnership2026";
import type { SourceConfidence } from "../../data/groupOwnershipTypes";

const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteUrl}/reports/hd-hyundai-group-ownership-2026/`;

const title = "HD현대그룹 지분구조 2026 완전 정리 | 조선·에너지·전기 지배관계";
const description =
  "정몽준·정기선 지분부터 HD한국조선해양 중간지주, HD현대마린솔루션 직접 보유, 오일뱅크·건설기계 구조까지 정리.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": pageUrl,
  url: pageUrl,
  headline: title,
  description,
  inLanguage: "ko-KR",
  datePublished: HD_HYUNDAI_META.updatedAt,
  dateModified: HD_HYUNDAI_META.updatedAt,
};

function confidenceLabel(c: SourceConfidence): string {
  if (c === "HIGH") return "높음";
  if (c === "MEDIUM") return "중간";
  return "낮음";
}
function confidenceClass(c: SourceConfidence): string {
  if (c === "HIGH") return "high";
  if (c === "MEDIUM") return "medium";
  return "low";
}
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiteHeader />
  <main class="container page-shell hho-page">

    <CalculatorHero
      eyebrow="HD현대그룹"
      title="HD현대그룹 지분구조 2026 완전 정리"
      description="조선은 HD한국조선해양을 거치고, 마린솔루션·일렉트릭·오일뱅크는 직접 보유하는 혼합형 지주구조를 정리했습니다."
    />

    <InfoNotice
      title="데이터 안내"
      lines={[
        HD_HYUNDAI_META.dataSourceNotice,
        `계열사·상장사 수 기준일: ${HD_HYUNDAI_META.affiliateCountBaseDate} (공정거래위원회 지정)`,
        `콘텐츠 업데이트: ${HD_HYUNDAI_META.updatedAt}`,
      ]}
    />

    <!-- 섹션 1: 지주회사 체제인가 -->
    <section class="content-section hho-holding-note" aria-labelledby="holding-title">
      <h2 id="holding-title">HD현대는 지주회사 체제인가?</h2>
      <p>{HD_HYUNDAI_META.holdingCompanyNote}</p>
    </section>

    <section class="content-section" aria-labelledby="kpi-title">
      <h2 id="kpi-title">HD현대 지배구조 핵심 KPI</h2>
      <div class="hho-kpi-grid">
        {
          HD_HYUNDAI_KPI_CARDS.map((card) => (
            <article class="hho-kpi-card">
              <span>{card.label}</span>
              <strong>{card.value}</strong>
              <p>{card.note}</p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- 섹션 2: 지분 연결도 -->
    <section class="content-section" aria-labelledby="tree-title">
      <h2 id="tree-title">지분 연결도</h2>
      <OwnershipTree nodes={HD_HYUNDAI_TREE_NODES} ariaLabel="HD현대그룹 지분 연결도" />
      <p class="hho-tree-note">
        조선 부문은 HD한국조선해양을 거치지만, HD현대마린솔루션과 HD현대일렉트릭은 HD현대가 직접 보유합니다.
        HD한국조선해양→HD현대중공업은 직접 지분 69.23%와 최대주주 등 합산 69.30%를 구분해 표시했습니다.
      </p>
    </section>

    <section class="content-section" aria-labelledby="shipbuilding-title">
      <h2 id="shipbuilding-title">조선 부문은 왜 HD한국조선해양을 거치나?</h2>
      <p class="hho-section-lead">
        HD한국조선해양은 직접 선박을 대량 생산하는 조선소라기보다, 조선 계열사의 지분과 연구개발·엔지니어링·사업관리를 담당하는
        조선 부문 중간지주 성격의 회사입니다.
      </p>
      <table class="hho-fact-table">
        <thead>
          <tr>
            <th>회사</th>
            <th>성격</th>
            <th>투자 노출</th>
            <th>주요 할인</th>
          </tr>
        </thead>
        <tbody>
          {
            HD_HYUNDAI_SHIPBUILDING_ROLES.map((row) => (
              <tr>
                <td>{row.company}</td>
                <td>{row.role}</td>
                <td>{row.exposure}</td>
                <td>{row.discount}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="indirect-title">
      <h2 id="indirect-title">HD현대의 HD현대중공업 간접 연결값</h2>
      <div class="hho-formula-card">
        <strong>35.05% × 69.23% = 약 24.27%</strong>
        <p>HD현대→HD한국조선해양→HD현대중공업 경로를 단순 곱한 참고값입니다.</p>
      </div>
      <table class="hho-fact-table">
        <thead>
          <tr>
            <th>단계</th>
            <th>지분율</th>
          </tr>
        </thead>
        <tbody>
          {
            HD_HYUNDAI_INDIRECT_CONNECTIONS.map((row) => (
              <tr>
                <td>{row.step}</td>
                <td>{row.rate}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <p class="hho-small-note">
        약 24.27%는 단순 경제적 연결값입니다. HD현대가 HD현대중공업 지분을 직접 보유하거나 해당 비율의 의결권을 직접 행사한다는 뜻은 아닙니다.
      </p>
    </section>

    <section class="content-section" aria-labelledby="marine-title">
      <h2 id="marine-title">HD현대마린솔루션은 왜 별도 핵심 축인가?</h2>
      <p class="hho-section-lead">
        HD현대마린솔루션은 조선 관련 사업을 하지만, 지분구조상 HD한국조선해양 아래가 아니라 HD현대가 직접 최대주주인 상장회사입니다.
        2026년 기업지배구조보고서 기준 최대주주 등 지분율은 55.32%입니다.
      </p>
      <table class="hho-fact-table">
        <thead>
          <tr>
            <th>항목</th>
            <th>HD한국조선해양</th>
            <th>HD현대마린솔루션</th>
          </tr>
        </thead>
        <tbody>
          {
            HD_HYUNDAI_MARINE_SOLUTION_COMPARISON.map((row) => (
              <tr>
                <td>{row.item}</td>
                <td>{row.shipbuilding}</td>
                <td>{row.marine}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <!-- 섹션 3: 오너·핵심 연결 표 -->
    <section class="content-section" aria-labelledby="facts-title">
      <h2 id="facts-title">오너 및 핵심 지분 연결</h2>
      <table class="hho-fact-table">
        <thead>
          <tr>
            <th>연결</th>
            <th>지분율</th>
            <th>기준일</th>
            <th>출처</th>
            <th>신뢰도</th>
          </tr>
        </thead>
        <tbody>
          {
            HD_HYUNDAI_OWNERSHIP_FACTS.map((f) => (
              <tr>
                <td>{f.label}</td>
                <td>{f.ratePercent}%</td>
                <td>{f.baseDate}</td>
                <td><a href={f.sourceUrl} target="_blank" rel="noopener noreferrer">{f.sourceLabel}</a></td>
                <td>
                  <span class={`hho-confidence-badge hho-confidence-badge--${confidenceClass(f.confidence)}`}>
                    {confidenceLabel(f.confidence)}
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="construction-title">
      <h2 id="construction-title">건설기계 재편 전후</h2>
      <div class="hho-split-grid">
        {
          HD_HYUNDAI_CONSTRUCTION_RESTRUCTURING.map((row) => (
            <article>
              <h3>{row.label}</h3>
              <strong>{row.structure}</strong>
              <p>{row.note}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="oilbank-title">
      <h2 id="oilbank-title">HD현대오일뱅크는 왜 NAV의 핵심 변수인가?</h2>
      <ul class="hho-check-list">
        {HD_HYUNDAI_OILBANK_POINTS.map((point) => <li>{point}</li>)}
      </ul>
      <div class="hho-formula-card hho-formula-card--plain">
        <strong>HD현대오일뱅크 추정 지분가치 = 예상 기업가치 × HD현대 보유지분율</strong>
      </div>
    </section>

    <section class="content-section" aria-labelledby="depth-title">
      <h2 id="depth-title">상장 단계와 중복상장 구조</h2>
      <table class="hho-fact-table">
        <thead>
          <tr>
            <th>연결 경로</th>
            <th>상장 깊이</th>
            <th>의미</th>
          </tr>
        </thead>
        <tbody>
          {
            HD_HYUNDAI_LISTING_DEPTH_ROWS.map((row) => (
              <tr>
                <td>{row.path}</td>
                <td>{row.depth}</td>
                <td>{row.meaning}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="business-title">
      <h2 id="business-title">사업 부문별 지도</h2>
      <div class="hho-business-grid">
        {
          HD_HYUNDAI_BUSINESS_AXES.map((axis) => (
            <article>
              <h3>{axis.axis}</h3>
              <p>{axis.holder}</p>
              <small>{axis.companies}</small>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="nav-title">
      <h2 id="nav-title">HD현대 지주회사 할인 계산 구조</h2>
      <p class="hho-section-lead">
        HD현대는 상장 자회사와 비상장 핵심 자회사를 함께 보유하므로, 단순 연결 실적보다 보유 지분가치와 순차입금을 함께 보는 NAV 접근이 유용합니다.
      </p>
      <div class="hho-formula-card">
        {HD_HYUNDAI_NAV_FORMULA_ROWS.map((row) => <p>{row}</p>)}
      </div>
      <div class="hho-formula-card hho-formula-card--plain">
        <strong>지주회사 할인율 = 1 - HD현대 시가총액 ÷ 추정 NAV</strong>
      </div>
    </section>

    <!-- 섹션 4: 상장 계열사 목록 -->
    <section class="content-section" aria-labelledby="listed-title">
      <h2 id="listed-title">상장 계열사 목록 ({HD_HYUNDAI_META.listedAffiliateCount}개 확인)</h2>
      <table class="hho-listed-table">
        <thead>
          <tr>
            <th>회사명</th>
            <th>종목코드</th>
            <th>사업 분야</th>
            <th>직접 최대주주</th>
            <th>상장 단계</th>
            <th>투자 성격</th>
          </tr>
        </thead>
        <tbody>
          {
            HD_HYUNDAI_LISTED_DETAIL_ROWS.map((c) => (
              <tr>
                <td>{c.name}</td>
                <td>{c.code}</td>
                <td>{c.business}</td>
                <td>{c.parent}</td>
                <td>{c.depth}</td>
                <td>{c.nature}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="timeline-title">
      <h2 id="timeline-title">그룹 재편 타임라인</h2>
      <div class="hho-timeline">
        {
          HD_HYUNDAI_RESTRUCTURING_TIMELINE.map((item) => (
            <article>
              <span>{item.period}</span>
              <strong>{item.event}</strong>
              <p>{item.meaning}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="compare-title">
      <h2 id="compare-title">다른 그룹과 비교</h2>
      <table class="hho-fact-table">
        <thead>
          <tr>
            <th>그룹</th>
            <th>핵심 특징</th>
            <th>대표 투자 이슈</th>
          </tr>
        </thead>
        <tbody>
          {
            HD_HYUNDAI_GROUP_COMPARISON.map((row) => (
              <tr>
                <td>{row.group}</td>
                <td>{row.keyword}</td>
                <td>{row.issue}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <!-- 섹션 5: CTA -->
    <section class="content-section" aria-labelledby="cta-title">
      <h2 id="cta-title">이어서 확인하면 좋은 콘텐츠</h2>
      <div class="hho-cta-group">
        <a href="/reports/samsung-group-ownership-2026/">삼성그룹 지분구조 →</a>
        <a href="/reports/sk-group-ownership-2026/">SK그룹 지분구조 →</a>
        <a href="/reports/hyundai-motor-group-ownership-2026/">현대차그룹 지분구조 →</a>
        <a href="/reports/lg-group-ownership-2026/">LG그룹 지분구조 →</a>
        <a href="/reports/hanwha-group-ownership-2026/">한화그룹 지분구조 →</a>
        <a href="/reports/lotte-group-ownership-2026/">롯데그룹 지분구조 →</a>
        <a href="/reports/doosan-group-ownership-2026/">두산그룹 지분구조 →</a>
        <a href="/reports/group-ownership-hub-2026/">9개 그룹 비교 허브 →</a>
        <a href="/tools/">계산기 전체 보기 →</a>
        <a href="/reports/">리포트 전체 보기 →</a>
      </div>
    </section>

    <SeoContent
      introTitle="HD현대그룹 지분구조, 부문마다 다른 이유"
      intro={HD_HYUNDAI_SEO_INTRO}
      criteria={HD_HYUNDAI_SEO_CRITERIA}
      faq={HD_HYUNDAI_FAQ.map((f) => ({ question: f.question, answer: f.answer }))}
      related={[
        { href: "/reports/samsung-group-ownership-2026/", label: "삼성그룹 지분구조 2026" },
        { href: "/reports/sk-group-ownership-2026/", label: "SK그룹 지분구조 2026" },
        { href: "/reports/hyundai-motor-group-ownership-2026/", label: "현대차그룹 지분구조 2026" },
        { href: "/reports/lg-group-ownership-2026/", label: "LG그룹 지분구조 2026" },
        { href: "/reports/hanwha-group-ownership-2026/", label: "한화그룹 지분구조 2026" },
        { href: "/reports/lotte-group-ownership-2026/", label: "롯데그룹 지분구조 2026" },
        { href: "/reports/doosan-group-ownership-2026/", label: "두산그룹 지분구조 2026" },
        { href: "/reports/group-ownership-hub-2026/", label: "9개 그룹 지분구조 비교 허브" },
        { href: "/reports/", label: "리포트 전체 보기" },
        { href: "/tools/", label: "계산기 전체 보기" },
      ]}
    />
  </main>
</BaseLayout>
