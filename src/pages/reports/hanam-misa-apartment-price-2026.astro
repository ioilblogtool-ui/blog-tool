---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  HMAP_APARTMENTS,
  HMAP_AREA_CARDS,
  HMAP_CONTEXT,
  HMAP_FAQ,
  HMAP_META,
  HMAP_METHOD,
  HMAP_RELATED_LINKS,
  HMAP_RISKS,
  HMAP_SEO_CRITERIA,
  HMAP_SEO_INTRO,
} from "../../data/hanamMisaApartmentPrice2026";
import { withBase } from "../../utils/base";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${HMAP_META.slug}/`;
const defaultApartment = HMAP_APARTMENTS[0];
const maxPrice = HMAP_APARTMENTS.reduce((max, row) => (row.latestTradePriceManwon > max.latestTradePriceManwon ? row : max), defaultApartment);
const maxGain = HMAP_APARTMENTS.reduce((max, row) => (row.estimatedGainManwon > max.estimatedGainManwon ? row : max), defaultApartment);
const misaCount = HMAP_APARTMENTS.filter((row) => row.areaGroup === "미사역권" || row.areaGroup === "망월천·한강공원권").length;
const gamilCount = HMAP_APARTMENTS.filter((row) => row.areaGroup === "감일권" || row.areaGroup === "위례 하남권").length;

const formatEok = (manwon: number) => {
  const eok = manwon / 10000;
  const fixed = eok >= 10 ? eok.toFixed(1) : eok.toFixed(2);
  return `${fixed.replace(/\.0$/, "")}억원`;
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: HMAP_META.title,
      description: HMAP_META.description,
      dateModified: HMAP_META.updatedAt,
      inLanguage: "ko-KR",
      mainEntityOfPage: reportUrl,
      author: { "@type": "Organization", name: "비교계산소" },
      about: ["하남 아파트", "미사 아파트", "미사강변센트럴자이", "미사강변도시", "하남 실거래가"],
    },
    {
      "@type": "FAQPage",
      mainEntity: HMAP_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
        { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
        { "@type": "ListItem", position: 3, name: HMAP_META.title, item: reportUrl },
      ],
    },
  ],
};
---

<BaseLayout title={HMAP_META.seoTitle} description={HMAP_META.description} jsonLd={jsonLd}>
  <SiteHeader />

  <main class="container page-shell report-page hmap-page" data-report="hanam-misa-apartment-price-2026">
    <CalculatorHero
      eyebrow="하남·미사 실거래가 리포트"
      title="하남·미사 대장 아파트, 최저가일 때 샀다면 지금 얼마를 벌었을까?"
      description={HMAP_META.description}
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        HMAP_META.notice,
        "이 리포트는 경기도 하남시 행정구역을 기준으로 하며, 생활권은 미사·감일·위례 하남권·덕풍·신장 등으로 나눠 표시합니다.",
        "미사와 감일·위례는 생활권이 다를 수 있으므로 같은 하남시라도 직접 비교에 주의해야 합니다.",
        "최저가 대비 금액은 세금·중개보수·대출이자·보유비용을 반영하지 않은 평가차익(추정)입니다.",
        "이 리포트는 투자 권유가 아니며, 실제 거래 판단은 국토교통부 실거래가 공개시스템과 현장 확인을 기준으로 해야 합니다.",
      ]}
    />

    <section class="hmap-summary" aria-labelledby="hmap-summary-title">
      <div class="hmap-section-head">
        <p>요약</p>
        <h2 id="hmap-summary-title">하남·미사 Top10 후보 기준 한눈에 보기</h2>
      </div>
      <div class="hmap-summary-grid">
        <article class="hmap-summary-card">
          <span>데이터 기준</span>
          <strong>{HMAP_META.updatedAt}</strong>
          <p>{HMAP_META.dataAsOf}</p>
        </article>
        <article class="hmap-summary-card">
          <span>최고 기준가</span>
          <strong>{formatEok(maxPrice.latestTradePriceManwon)}</strong>
          <p>{maxPrice.complexName} 후보값</p>
        </article>
        <article class="hmap-summary-card">
          <span>최대 평가차익(추정)</span>
          <strong>{formatEok(maxGain.estimatedGainManwon)}</strong>
          <p>{maxGain.complexName} 기준 단순 시세 차이</p>
        </article>
        <article class="hmap-summary-card">
          <span>생활권 구성</span>
          <strong>{misaCount}/{gamilCount}/2</strong>
          <p>미사강변도시권 / 감일·위례권 / 원도심권</p>
        </article>
      </div>
    </section>

    <section class="hmap-picker" aria-labelledby="hmap-picker-title">
      <div class="hmap-section-head">
        <p>단지별 카드</p>
        <h2 id="hmap-picker-title">최저가일 때 샀다면 지금 평가차익은?</h2>
      </div>

      <div class="hmap-tabs" role="tablist" aria-label="하남·미사 아파트 단지 선택">
        {HMAP_APARTMENTS.map((row, index) => (
          <button
            class={`hmap-tab${index === 0 ? " is-active" : ""}`}
            type="button"
            data-complex={row.id}
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
          >
            {row.rank}. {row.complexName}
          </button>
        ))}
      </div>

      <article class="hmap-profit-card" aria-live="polite">
        <div class="hmap-profit-card__main">
          <span class="hmap-badge" data-hmap-field="badge">{defaultApartment.badge}</span>
          <h3 data-hmap-field="complexName">{defaultApartment.complexName}</h3>
          <p class="hmap-area-line" data-hmap-field="areaLine">
            {defaultApartment.legalDongLabel} · {defaultApartment.areaGroup} · {defaultApartment.stationLabel}
          </p>
          <p data-hmap-field="profitSentence">
            {defaultApartment.fiveYearLowDate} {formatEok(defaultApartment.fiveYearLowPriceManwon)}에 거래됐고, 현재 기준가는 {formatEok(defaultApartment.latestTradePriceManwon)}입니다.
          </p>
          <div class="hmap-profit-card__numbers">
            <div>
              <span>평가차익(추정)</span>
              <strong data-hmap-field="gain">{formatEok(defaultApartment.estimatedGainManwon)}</strong>
            </div>
            <div>
              <span>상승률(추정)</span>
              <strong data-hmap-field="gainRate">{defaultApartment.estimatedGainRate}%</strong>
            </div>
          </div>
        </div>
        <dl class="hmap-profit-card__meta">
          <div><dt>최근 기준가</dt><dd data-hmap-field="latest">{formatEok(defaultApartment.latestTradePriceManwon)}</dd></div>
          <div><dt>거래월·면적</dt><dd data-hmap-field="latestMeta">{defaultApartment.latestTradeDate} · {defaultApartment.latestTradeArea}</dd></div>
          <div><dt>5년 저점 참고</dt><dd data-hmap-field="low">{formatEok(defaultApartment.fiveYearLowPriceManwon)}</dd></div>
          <div><dt>수변·생활권 메모</dt><dd data-hmap-field="riverNote">{defaultApartment.riverNote}</dd></div>
          <div><dt>통근 메모</dt><dd data-hmap-field="commuteNote">{defaultApartment.commuteNote ?? "통근 접근성 확인 필요"}</dd></div>
          <div><dt>주의</dt><dd data-hmap-field="note">{defaultApartment.note}</dd></div>
        </dl>
      </article>
      <p class="hmap-plain-note">
        이 금액은 취득세, 중개보수, 보유세, 대출이자, 양도소득세를 반영하지 않은 단순 시세 차이입니다. 같은 단지라도 동·층·향·면적·거래 시점에 따라 실제 가격은 크게 달라질 수 있습니다.
      </p>
    </section>

    <section class="hmap-table-section" aria-labelledby="hmap-table-title">
      <div class="hmap-section-head hmap-section-head--row">
        <div>
          <p>비교표</p>
          <h2 id="hmap-table-title">하남·미사 대장 아파트 Top10 실거래가</h2>
        </div>
        <div class="hmap-sort-controls" aria-label="정렬 기준">
          <button class="is-active" type="button" data-sort="rank">순위</button>
          <button type="button" data-sort="gain">평가차익</button>
          <button type="button" data-sort="gainRate">상승률</button>
          <button type="button" data-sort="latestPrice">최근가</button>
          <button type="button" data-sort="area">생활권</button>
        </div>
      </div>
      <div class="hmap-table-wrap">
        <table class="hmap-table">
          <caption>하남·미사 아파트 Top10 후보의 최근 기준가와 5년 저점 대비 평가차익 비교</caption>
          <thead>
            <tr>
              <th scope="col">순위</th>
              <th scope="col">단지명</th>
              <th scope="col">법정동</th>
              <th scope="col">생활권</th>
              <th scope="col">최근 실거래가</th>
              <th scope="col">거래월</th>
              <th scope="col">2025 대비</th>
              <th scope="col">5년 저점 참고</th>
              <th scope="col">평가차익(추정)</th>
              <th scope="col">전세가율</th>
              <th scope="col">주의</th>
            </tr>
          </thead>
          <tbody data-hmap-table-body>
            {HMAP_APARTMENTS.map((row) => (
              <tr data-row-id={row.id}>
                <td>{row.rank}</td>
                <th scope="row">
                  <strong>{row.complexName}</strong>
                  <span>{row.mainAreaLabel}</span>
                </th>
                <td>{row.legalDongLabel}</td>
                <td>{row.areaGroup}</td>
                <td>{formatEok(row.latestTradePriceManwon)}</td>
                <td>{row.latestTradeDate}</td>
                <td>{row.previousYearPriceManwon ? `${formatEok(row.latestTradePriceManwon - row.previousYearPriceManwon)} 상승 참고` : "확인 필요"}</td>
                <td>{formatEok(row.fiveYearLowPriceManwon)}</td>
                <td>{formatEok(row.estimatedGainManwon)} · {row.estimatedGainRate}%</td>
                <td>{row.jeonseRatio ? `${row.jeonseRatio}% 참고` : "확인 필요"}</td>
                <td>{row.tradeCountNote}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="hmap-area-map" aria-labelledby="hmap-area-title">
      <div class="hmap-section-head">
        <p>생활권 분해</p>
        <h2 id="hmap-area-title">미사역권·한강공원권·감일권·위례 하남권·원도심권 가격 차이</h2>
      </div>
      <div class="hmap-area-grid" data-hmap-area-cards>
        {HMAP_AREA_CARDS.map((card) => (
          <article class={`hmap-area-card${card.areaGroup === defaultApartment.areaGroup ? " is-selected" : ""}`} data-area-group={card.areaGroup}>
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
            <strong>{card.priceInterpretation}</strong>
            <small>{card.caution}</small>
          </article>
        ))}
      </div>
      <p class="hmap-plain-note">
        하남시는 미사강변도시, 감일, 위례 하남권, 덕풍·신장 원도심의 가격 논리가 다릅니다. 같은 하남시 안에서도 5호선 접근성, 서울 접근성, 입주연식, 단지 규모, 수변 접근성에 따라 가격 차이가 크게 나타날 수 있습니다.
      </p>
    </section>

    <section class="hmap-chart" aria-labelledby="hmap-chart-title">
      <div class="hmap-section-head">
        <p>막대 비교</p>
        <h2 id="hmap-chart-title">현재 기준가 vs 5년 저점 참고가</h2>
      </div>
      <div class="hmap-bar-list" data-hmap-bars>
        {HMAP_APARTMENTS.map((row) => (
          <article class="hmap-bar-row" data-row-id={row.id}>
            <div class="hmap-bar-row__label">
              <strong>{row.complexName}</strong>
              <span>{row.areaGroup} · {row.badge}</span>
            </div>
            <div class="hmap-bar-row__bars">
              <span class="hmap-bar hmap-bar--latest" style={`width: ${(row.latestTradePriceManwon / maxPrice.latestTradePriceManwon) * 100}%`}>{formatEok(row.latestTradePriceManwon)}</span>
              <span class="hmap-bar hmap-bar--low" style={`width: ${(row.fiveYearLowPriceManwon / maxPrice.latestTradePriceManwon) * 100}%`}>{formatEok(row.fiveYearLowPriceManwon)}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="hmap-context" aria-labelledby="hmap-context-title">
      <div class="hmap-section-head">
        <p>가격 맥락</p>
        <h2 id="hmap-context-title">하남·미사 아파트 가격을 읽는 핵심 변수</h2>
      </div>
      <div class="hmap-context-grid">
        {HMAP_CONTEXT.map((card) => (
          <article class="hmap-context-card">
            <span>{card.badge}</span>
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="hmap-data-method" aria-labelledby="hmap-method-title">
      <div class="hmap-section-head">
        <p>데이터 기준</p>
        <h2 id="hmap-method-title">하남·미사 실거래가 데이터 기준</h2>
      </div>
      <ul class="hmap-risk-list">
        {HMAP_METHOD.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="hmap-risk" aria-labelledby="hmap-risk-title">
      <div class="hmap-section-head">
        <p>리스크</p>
        <h2 id="hmap-risk-title">평가차익보다 먼저 봐야 하는 변수</h2>
      </div>
      <ul class="hmap-risk-list">
        {HMAP_RISKS.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="hmap-related" aria-labelledby="hmap-related-title">
      <div class="hmap-section-head">
        <p>다음 단계</p>
        <h2 id="hmap-related-title">하남·미사 가격 확인 뒤 이어서 볼 리포트와 계산기</h2>
      </div>
      <div class="hmap-related-grid">
        {HMAP_RELATED_LINKS.map((link) => (
          <a class="hmap-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <p>{link.description}</p>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="하남·미사 아파트 실거래가를 볼 때 먼저 확인할 것"
      intro={HMAP_SEO_INTRO}
      criteria={HMAP_SEO_CRITERIA}
      faq={HMAP_FAQ}
      related={HMAP_RELATED_LINKS}
    />

    <script type="application/json" id="hmap-data" set:html={JSON.stringify(HMAP_APARTMENTS)}></script>
    <script type="application/json" id="hmap-area-data" set:html={JSON.stringify(HMAP_AREA_CARDS)}></script>
    <script src={withBase("/scripts/hanam-misa-apartment-price-2026.js")} defer></script>
  </main>
</BaseLayout>
