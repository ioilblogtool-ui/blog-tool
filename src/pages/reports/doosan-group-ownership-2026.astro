---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import OwnershipTree from "../../components/OwnershipTree.astro";
import {
  DOOSAN_META,
  DOOSAN_TREE_NODES,
  DOOSAN_OWNERSHIP_FACTS,
  DOOSAN_FAQ,
  DOOSAN_SEO_INTRO,
  DOOSAN_SEO_CRITERIA,
  DOOSAN_KPI_CARDS,
  DOOSAN_STRUCTURE_STATUS_ROWS,
  DOOSAN_BUSINESS_AXIS_ROWS,
  DOOSAN_RESTRUCTURING_TIMELINE,
  DOOSAN_VALUE_CHAIN_ROWS,
  DOOSAN_INDIRECT_CALC_ROWS,
  DOOSAN_NAV_FORMULA_ROWS,
  DOOSAN_HOLDING_CHECK_ROWS,
  DOOSAN_LISTED_DETAIL_ROWS,
  DOOSAN_GROUP_COMPARISON,
} from "../../data/doosanGroupOwnership2026";
import type { SourceConfidence } from "../../data/groupOwnershipTypes";

const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteUrl}/reports/doosan-group-ownership-2026/`;

const title = "두산그룹 지분구조 2026 완전 정리 | 두산로보틱스·두산밥캣 현재 구조";
const description =
  "두산그룹 지분구조를 2026년 공시 기준으로 정리합니다. ㈜두산·두산에너빌리티·두산로보틱스·두산밥캣의 현재 연결과 과거 재편안을 구분해 설명합니다.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": pageUrl,
  url: pageUrl,
  headline: title,
  description,
  inLanguage: "ko-KR",
  datePublished: DOOSAN_META.updatedAt,
  dateModified: DOOSAN_META.updatedAt,
};

function confidenceLabel(c: SourceConfidence): string {
  if (c === "HIGH") return "높음";
  if (c === "MEDIUM") return "중간";
  return "낮음";
}
function confidenceClass(c: SourceConfidence): string {
  if (c === "HIGH") return "high";
  if (c === "MEDIUM") return "medium";
  return "low";
}
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <SiteHeader />
  <main class="container page-shell dso-page">
    <CalculatorHero
      eyebrow="두산그룹"
      title="두산그룹 지분구조 2026 완전 정리"
      description="현재 완료된 지분구조와 과거 추진됐던 로보틱스·밥캣 재편안을 분리해, 투자자가 실제로 비교해야 할 에너지·로봇·반도체 축을 정리했습니다."
    />

    <InfoNotice
      title="데이터 안내"
      lines={[
        DOOSAN_META.dataSourceNotice,
        `계열사 수 기준일: ${DOOSAN_META.affiliateCountBaseDate} (공정거래위원회 지정 기준)`,
        `콘텐츠 업데이트: ${DOOSAN_META.updatedAt}`,
      ]}
    />

    <section class="content-section dso-holding-note" aria-labelledby="holding-title">
      <h2 id="holding-title">두산은 지주회사 체제인가?</h2>
      <p>{DOOSAN_META.holdingCompanyNote}</p>
    </section>

    <section class="content-section" aria-labelledby="kpi-title">
      <h2 id="kpi-title">두산 지배구조 핵심 KPI</h2>
      <div class="dso-kpi-grid">
        {
          DOOSAN_KPI_CARDS.map((card) => (
            <article class="dso-kpi-card">
              <span>{card.label}</span>
              <strong>{card.value}</strong>
              <p>{card.note}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section dso-warning-note" aria-labelledby="warning-title">
      <h2 id="warning-title">가장 먼저 고쳐야 할 연결도 오류</h2>
      <p>
        두산 페이지에서 가장 위험한 표현은 두산로보틱스와 두산밥캣을 현재 완료된 것처럼 연결하는 것입니다.
        2026년 공시 기준 두산로보틱스는 ㈜두산의 직접 보유 축이고, 두산밥캣은 두산에너빌리티가 최대주주인 축입니다.
        과거 재편안은 별도 타임라인으로 설명해야 투자자가 현재 구조를 오해하지 않습니다.
      </p>
    </section>

    <section class="content-section" aria-labelledby="tree-title">
      <h2 id="tree-title">현재 공시 기준 지분 연결도</h2>
      <OwnershipTree nodes={DOOSAN_TREE_NODES} ariaLabel="두산그룹 지분 연결도" />
      <p class="dso-tree-note">
        이 트리는 현재 확인 가능한 직접 최대주주 연결을 우선 표시합니다. 두산로보틱스 49.98%는 2026년 6월
        대량보유보고서 기준이며, 두산밥캣 48.17%는 두산에너빌리티 보유분을 기준으로 표시했습니다.
      </p>
    </section>

    <section class="content-section" aria-labelledby="status-title">
      <h2 id="status-title">현재 구조와 과거 추진안을 구분해서 보기</h2>
      <table class="dso-fact-table">
        <thead>
          <tr>
            <th>항목</th>
            <th>현재 구조</th>
            <th>헷갈리는 지점</th>
            <th>투자자 해석</th>
          </tr>
        </thead>
        <tbody>
          {
            DOOSAN_STRUCTURE_STATUS_ROWS.map((row) => (
              <tr>
                <td>{row.item}</td>
                <td>{row.current}</td>
                <td>{row.previous}</td>
                <td>{row.investor}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="facts-title">
      <h2 id="facts-title">주요 지분율과 출처</h2>
      <table class="dso-fact-table">
        <thead>
          <tr>
            <th>연결</th>
            <th>지분율</th>
            <th>기준일</th>
            <th>출처</th>
            <th>신뢰도</th>
          </tr>
        </thead>
        <tbody>
          {
            DOOSAN_OWNERSHIP_FACTS.map((f) => (
              <tr>
                <td>{f.label}</td>
                <td>{f.ratePercent}%</td>
                <td>{f.baseDate}</td>
                <td><a href={f.sourceUrl} target="_blank" rel="noopener noreferrer">{f.sourceLabel}</a></td>
                <td>
                  <span class={`dso-confidence-badge dso-confidence-badge--${confidenceClass(f.confidence)}`}>
                    {confidenceLabel(f.confidence)}
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="axis-title">
      <h2 id="axis-title">㈜두산·에너빌리티·로보틱스·밥캣은 무엇이 다른가?</h2>
      <table class="dso-fact-table">
        <thead>
          <tr>
            <th>축</th>
            <th>핵심 사업</th>
            <th>종목코드</th>
            <th>주가 변수</th>
          </tr>
        </thead>
        <tbody>
          {
            DOOSAN_BUSINESS_AXIS_ROWS.map((row) => (
              <tr>
                <td>{row.axis}</td>
                <td>{row.business}</td>
                <td>{row.listed}</td>
                <td>{row.signal}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="timeline-title">
      <h2 id="timeline-title">두산 지배구조 재편 타임라인</h2>
      <div class="dso-timeline">
        {
          DOOSAN_RESTRUCTURING_TIMELINE.map((row) => (
            <article>
              <span>{row.period}</span>
              <strong>{row.event}</strong>
              <p>{row.meaning}</p>
              <em>{row.status}</em>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="value-chain-title">
      <h2 id="value-chain-title">에너지·로봇·반도체 사업축 지도</h2>
      <div class="dso-value-chain">
        {
          DOOSAN_VALUE_CHAIN_ROWS.map((row) => (
            <article>
              <span>{row.stage}</span>
              <strong>{row.companies}</strong>
              <p>{row.role}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" aria-labelledby="indirect-title">
      <h2 id="indirect-title">단순 간접 지분율 계산</h2>
      <table class="dso-fact-table">
        <thead>
          <tr>
            <th>대상</th>
            <th>계산식</th>
            <th>결과</th>
            <th>주의</th>
          </tr>
        </thead>
        <tbody>
          {
            DOOSAN_INDIRECT_CALC_ROWS.map((row) => (
              <tr>
                <td>{row.target}</td>
                <td>{row.formula}</td>
                <td>{row.result}</td>
                <td>{row.note}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <p class="dso-small-note">간접 지분율은 투자 노출을 단순화한 값이며, 법적 의결권이나 연결 재무제표상 지배력을 그대로 뜻하지 않습니다.</p>
    </section>

    <section class="content-section" aria-labelledby="nav-title">
      <h2 id="nav-title">㈜두산 NAV와 지주회사 여부를 어떻게 볼까?</h2>
      <div class="dso-formula-grid">
        <article>
          <h3>복합기업 NAV 계산</h3>
          {DOOSAN_NAV_FORMULA_ROWS.map((row) => <p>{row}</p>)}
        </article>
        <article>
          <h3>지주회사 여부 체크</h3>
          <table class="dso-mini-table">
            <tbody>
              {
                DOOSAN_HOLDING_CHECK_ROWS.map((row) => (
                  <tr>
                    <th>{row.label}</th>
                    <td>
                      <strong>{row.value}</strong>
                      <span>{row.note}</span>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </article>
      </div>
    </section>

    <section class="content-section" aria-labelledby="listed-title">
      <h2 id="listed-title">상장 계열사 전체 목록 ({DOOSAN_META.listedAffiliateCount}개)</h2>
      <table class="dso-listed-table">
        <thead>
          <tr>
            <th>회사명</th>
            <th>종목코드</th>
            <th>시장</th>
            <th>핵심 사업</th>
            <th>상위 지분 연결</th>
            <th>투자 노출</th>
          </tr>
        </thead>
        <tbody>
          {
            DOOSAN_LISTED_DETAIL_ROWS.map((c) => (
              <tr>
                <td>{c.name}</td>
                <td>{c.code}</td>
                <td>{c.market}</td>
                <td>{c.business}</td>
                <td>{c.parent}</td>
                <td>{c.exposure}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="compare-title">
      <h2 id="compare-title">다른 그룹과 비교</h2>
      <table class="dso-fact-table">
        <thead>
          <tr>
            <th>그룹</th>
            <th>구조</th>
            <th>핵심 이슈</th>
          </tr>
        </thead>
        <tbody>
          {
            DOOSAN_GROUP_COMPARISON.map((row) => (
              <tr>
                <td>{row.group}</td>
                <td>{row.structure}</td>
                <td>{row.issue}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <section class="content-section" aria-labelledby="cta-title">
      <h2 id="cta-title">이어 보면 좋은 콘텐츠</h2>
      <div class="dso-cta-group">
        <a href="/reports/samsung-group-ownership-2026/">삼성그룹 지분구조</a>
        <a href="/reports/sk-group-ownership-2026/">SK그룹 지분구조</a>
        <a href="/reports/hyundai-motor-group-ownership-2026/">현대차그룹 지분구조</a>
        <a href="/reports/lg-group-ownership-2026/">LG그룹 지분구조</a>
        <a href="/reports/hanwha-group-ownership-2026/">한화그룹 지분구조</a>
        <a href="/reports/lotte-group-ownership-2026/">롯데그룹 지분구조</a>
        <a href="/reports/hd-hyundai-group-ownership-2026/">HD현대그룹 지분구조</a>
        <a href="/reports/ls-group-ownership-2026/">LS그룹 지분구조</a>
        <a href="/reports/group-ownership-hub-2026/">9개 그룹 비교 허브</a>
      </div>
    </section>

    <SeoContent
      introTitle="두산그룹 지분구조, 현재 구조와 재편안을 구분해야 하는 이유"
      intro={DOOSAN_SEO_INTRO}
      criteria={DOOSAN_SEO_CRITERIA}
      faq={DOOSAN_FAQ.map((f) => ({ question: f.question, answer: f.answer }))}
      related={[
        { href: "/reports/samsung-group-ownership-2026/", label: "삼성그룹 지분구조 2026" },
        { href: "/reports/sk-group-ownership-2026/", label: "SK그룹 지분구조 2026" },
        { href: "/reports/hyundai-motor-group-ownership-2026/", label: "현대차그룹 지분구조 2026" },
        { href: "/reports/lg-group-ownership-2026/", label: "LG그룹 지분구조 2026" },
        { href: "/reports/hanwha-group-ownership-2026/", label: "한화그룹 지분구조 2026" },
        { href: "/reports/lotte-group-ownership-2026/", label: "롯데그룹 지분구조 2026" },
        { href: "/reports/hd-hyundai-group-ownership-2026/", label: "HD현대그룹 지분구조 2026" },
        { href: "/reports/ls-group-ownership-2026/", label: "LS그룹 지분구조 2026" },
        { href: "/reports/group-ownership-hub-2026/", label: "9개 그룹 지분구조 비교 허브" },
      ]}
    />
  </main>
</BaseLayout>
