---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  PTX_META,
  PTX_OVERVIEW,
  PTX_SCHEDULE,
  PTX_ASSET_SCHEDULE,
  PTX_OWNERSHIP_CASES,
  PTX_RATES,
  PTX_EXAMPLES,
  PTX_REDUCTIONS,
  PTX_INSTALLMENT,
  PTX_PAYMENT_METHODS,
  PTX_LATE_PAYMENT_NOTES,
  PTX_FAQ,
  PTX_RELATED_LINKS,
  PTX_SOURCE_LINKS,
} from "../../data/propertyTaxPayment2026";

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const reportUrl = `${siteBase}/reports/${PTX_META.slug}/`;
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: PTX_META.title,
    description: PTX_META.description,
    dateModified: PTX_META.updatedAt,
    mainEntityOfPage: reportUrl,
    author: { "@type": "Organization", name: "비교계산소" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: PTX_FAQ.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "홈", item: siteBase },
      { "@type": "ListItem", position: 2, name: "리포트", item: `${siteBase}/reports/` },
      { "@type": "ListItem", position: 3, name: PTX_META.title, item: reportUrl },
    ],
  },
];
---

<BaseLayout
  title={PTX_META.seoTitle}
  description={PTX_META.seoDescription}
  jsonLd={jsonLd}
>
  <SiteHeader />

  <main class="container page-shell report-page ptx-page" data-report="property-tax-payment-2026">
    <CalculatorHero
      eyebrow="부동산 세금 리포트"
      title={PTX_META.title}
      description="아파트·주택·토지·건축물별 7월·9월 납부기간과 6월 1일 과세기준일을 한눈에 확인하세요."
      badges={["2026 기준", "7월·9월 납부", "주택·토지", "위택스"]}
    />

    <InfoNotice
      title="참고 안내"
      lines={[
        PTX_META.dataNote,
        "재산세는 매년 6월 1일 현재 소유자 기준으로 부과됩니다. 5월 31일 매도·6월 2일 매수 시 납부 의무가 달라집니다.",
      ]}
    />

    <!-- 핵심 요약 -->
    <section class="content-section ptx-overview-section" aria-labelledby="ptx-overview-title">
      <div class="ptx-section-heading">
        <p>핵심 요약</p>
        <h2 id="ptx-overview-title">2026년 재산세는 이 날짜만 먼저 확인하세요</h2>
        <span>재산세 검색의 핵심은 과세기준일과 7월·9월 납부기간입니다.</span>
      </div>
      <div class="ptx-overview-grid">
        {PTX_OVERVIEW.map((item) => (
          <article class="ptx-overview-card">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <p>{item.note}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- 납부 일정 -->
    <section class="content-section ptx-schedule-section" aria-labelledby="ptx-schedule-title">
      <div class="ptx-section-heading">
        <p>납부 일정</p>
        <h2 id="ptx-schedule-title">2026년 재산세는 7월 16일과 9월 16일부터 납부합니다</h2>
        <span>주택은 세액을 반씩 두 번에 나눠 고지합니다. 토지와 건축물은 납부월이 다릅니다.</span>
      </div>
      <div class="ptx-schedule-grid">
        {PTX_SCHEDULE.map((s) => (
          <article class:list={["ptx-schedule-card", `ptx-schedule-card--${s.id}`]}>
            <span class="ptx-month-badge">{s.month}</span>
            <strong>{s.period}</strong>
            <em>{s.weekday}</em>
            <p>{s.target}</p>
            <small>{s.note}</small>
            <b>{s.highlight}</b>
          </article>
        ))}
      </div>
      <div class="ptx-cta-band">
        <div>
          <strong>내 아파트 재산세가 얼마인지 먼저 확인하세요</strong>
          <p>공시가격을 입력하면 재산세·종부세·농특세까지 2026 기준으로 즉시 계산됩니다.</p>
        </div>
        <a class="button button--primary" href={withBase("/tools/apartment-holding-tax/")}>보유세 계산하기</a>
      </div>
    </section>

    <!-- 재산 종류별 납부월 -->
    <section class="content-section ptx-asset-section" aria-labelledby="ptx-asset-title">
      <div class="ptx-section-heading">
        <p>대상별 일정</p>
        <h2 id="ptx-asset-title">아파트·주택·토지·건축물별 납부월이 다릅니다</h2>
        <span>주택은 7월과 9월, 토지는 9월, 건축물은 7월에 확인합니다.</span>
      </div>
      <div class="table-wrap ptx-table-wrap" aria-label="재산 종류별 재산세 납부월">
        <table class="ptx-asset-table">
          <caption>2026년 재산 종류별 재산세 납부월</caption>
          <thead>
            <tr>
              <th>재산 종류</th>
              <th>7월</th>
              <th>9월</th>
              <th>설명</th>
            </tr>
          </thead>
          <tbody>
            {PTX_ASSET_SCHEDULE.map((row) => (
              <tr>
                <td>
                  <strong>{row.assetType}</strong>
                  {row.badge && <span class="ptx-mini-badge">{row.badge}</span>}
                </td>
                <td class="ptx-asset-month">{row.july}</td>
                <td class="ptx-asset-month">{row.september}</td>
                <td>{row.summary}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="ptx-table-note">※ 실제 고지 여부와 세액은 지자체 고지서와 위택스 조회 결과를 기준으로 확인하세요.</p>
    </section>

    <!-- 과세기준일 -->
    <section class="content-section ptx-owner-section" aria-labelledby="ptx-owner-title">
      <div class="ptx-section-heading">
        <p>누가 내나요?</p>
        <h2 id="ptx-owner-title">재산세는 6월 1일 현재 소유자가 냅니다</h2>
        <span>매수·매도 시점이 6월 1일 근처라면 잔금일과 등기일, 계약상 정산 특약을 함께 확인하세요.</span>
      </div>
      <div class="ptx-owner-grid">
        {PTX_OWNERSHIP_CASES.map((item) => (
          <article class="ptx-owner-card">
            <span>{item.dateLabel}</span>
            <h3>{item.title}</h3>
            <strong>{item.payer}</strong>
            <p>{item.explanation}</p>
            {item.caution && <small>{item.caution}</small>}
          </article>
        ))}
      </div>
    </section>

    <!-- 납부 방법 -->
    <section class="content-section ptx-payment-section" aria-labelledby="ptx-payment-title">
      <div class="ptx-section-heading">
        <p>납부 방법</p>
        <h2 id="ptx-payment-title">위택스에서 고지서 없이도 조회·납부할 수 있습니다</h2>
        <span>전자고지 신청자라면 우편 고지서가 오지 않을 수 있으므로 위택스와 스마트위택스 조회를 먼저 확인하세요.</span>
      </div>
      <div class="ptx-payment-grid">
        {PTX_PAYMENT_METHODS.map((m) => (
          <article class:list={["ptx-payment-card", m.priority === "primary" && "ptx-payment-card--primary"]}>
            <strong>{m.method}</strong>
            <span class="ptx-payment-channel">{m.channel}</span>
            <p>{m.note}</p>
            {m.url && (
              <a href={m.url} target="_blank" rel="noopener noreferrer">조회 바로가기</a>
            )}
          </article>
        ))}
      </div>
    </section>

    <!-- 납부기한 체크 -->
    <section class="content-section ptx-late-section" aria-labelledby="ptx-late-title">
      <div class="ptx-section-heading">
        <p>기한 체크</p>
        <h2 id="ptx-late-title">납부기한을 놓치기 전에 이 세 가지를 확인하세요</h2>
        <span>기한 임박 시에는 고지서 수령 여부보다 온라인 조회와 실제 납부 완료 여부가 더 중요합니다.</span>
      </div>
      <div class="ptx-late-grid">
        {PTX_LATE_PAYMENT_NOTES.map((note) => (
          <article class="ptx-late-card">
            <strong>{note.title}</strong>
            <p>{note.body}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- 분납 기준 -->
    <section class="content-section ptx-installment-section" aria-labelledby="ptx-installment-title">
      <div class="ptx-section-heading">
        <p>분납</p>
        <h2 id="ptx-installment-title">250만 원 초과 고지서는 분납 가능 여부를 확인하세요</h2>
        <span>분납 기준과 절차는 실제 고지서와 위택스 안내가 우선입니다.</span>
      </div>
      <div class="ptx-installment-box">
        <div class="ptx-installment-row">
          <span>분납 조건</span>
          <strong>{PTX_INSTALLMENT.threshold}</strong>
        </div>
        <div class="ptx-installment-row">
          <span>분납 방법</span>
          <span>{PTX_INSTALLMENT.rule}</span>
        </div>
        <div class="ptx-installment-row">
          <span>분납 기한</span>
          <span>{PTX_INSTALLMENT.deadline}</span>
        </div>
      </div>
    </section>

    <!-- 세율표 -->
    <section class="content-section ptx-rates-section" aria-labelledby="ptx-rates-title">
      <div class="ptx-section-heading">
        <p>세율 구조</p>
        <h2 id="ptx-rates-title">주택 재산세는 4단계 누진세율로 계산합니다</h2>
        <span>공시가격 × 공정시장가액비율(70%) = 과세표준. 여기에 아래 세율을 곱합니다.</span>
      </div>
      <div class="table-wrap ptx-table-wrap" aria-label="주택 재산세 세율표">
        <table class="ptx-rate-table">
          <caption>2026년 주택 재산세 세율표 (과세표준 기준)</caption>
          <thead>
            <tr>
              <th>과세표준 구간</th>
              <th>세율</th>
              <th>누진공제</th>
              <th>계산 예시 (공시가 기준)</th>
            </tr>
          </thead>
          <tbody>
            {PTX_RATES.map((row) => (
              <tr>
                <td>{row.range}</td>
                <td class="ptx-rate-value">{row.rate}</td>
                <td>{row.deduction}</td>
                <td class="ptx-example-text">{row.example}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="ptx-table-note">※ 지방교육세(재산세의 20%)와 도시지역분(과세표준의 0.14%)이 별도 합산됩니다.</p>
    </section>

    <!-- 공시가격별 예시 -->
    <section class="content-section ptx-examples-section" aria-labelledby="ptx-examples-title">
      <div class="ptx-section-heading">
        <p>세액 예시</p>
        <h2 id="ptx-examples-title">공시가격별 예상 재산세 (1세대1주택 기준)</h2>
        <span>아래 금액은 재산세 + 지방교육세 합산 추정값입니다. 도시지역분 제외.</span>
      </div>
      <div class="ptx-examples-grid">
        {PTX_EXAMPLES.map((ex) => (
          <article class:list={["ptx-example-card", ex.highlight && "ptx-example-card--highlight"]}>
            <span class="ptx-example-label">{ex.label}</span>
            <div class="ptx-example-row">
              <span>공시가격</span>
              <strong>{ex.officialPrice}</strong>
            </div>
            <div class="ptx-example-row">
              <span>과세표준</span>
              <span>{ex.taxBase}</span>
            </div>
            <div class="ptx-example-row">
              <span>재산세</span>
              <span>{ex.propertyTax}</span>
            </div>
            <div class="ptx-example-row">
              <span>지방교육세</span>
              <span>{ex.localEducation}</span>
            </div>
            <div class="ptx-example-total">
              <span>합계 (추정)</span>
              <strong>{ex.total}</strong>
            </div>
          </article>
        ))}
      </div>
      <p class="ptx-table-note">※ 1세대1주택 특례세율 미적용 기준. 실제 고지세액과 다를 수 있습니다.</p>
    </section>

    <!-- 감면·공제 -->
    <section class="content-section ptx-reductions-section" aria-labelledby="ptx-reductions-title">
      <div class="ptx-section-heading">
        <p>감면·공제</p>
        <h2 id="ptx-reductions-title">이 항목에 해당하면 세금이 줄어듭니다</h2>
        <span>1세대1주택자는 특례세율이 자동 적용됩니다. 고령자·장기보유 공제는 조건 확인이 필요합니다.</span>
      </div>
      <div class="ptx-reductions-grid">
        {PTX_REDUCTIONS.map((item) => (
          <article class="ptx-reduction-card">
            <span class="ptx-reduction-badge">{item.badge}</span>
            <h3>{item.title}</h3>
            <p class="ptx-reduction-condition">{item.condition}</p>
            <p class="ptx-reduction-effect">{item.effect}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- 관련 계산기 -->
    <section class="content-section ptx-related-section" aria-labelledby="ptx-related-title">
      <div class="ptx-section-heading">
        <p>관련 도구</p>
        <h2 id="ptx-related-title">납부기간을 확인했다면 예상 세액도 같이 보세요</h2>
      </div>
      <div class="ptx-related-grid">
        {PTX_RELATED_LINKS.map((link) => (
          <a class="ptx-related-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <span>{link.desc}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- FAQ + SEO -->
    <SeoContent
      introTitle="2026 재산세 납부기간과 계산 기준"
      intro={[
        "재산세는 매년 7월과 9월에 반복적으로 확인해야 하는 생활 세금입니다. 아파트나 주택을 보유한 사람은 두 번의 고지서를 받는 경우가 많고, 토지나 건축물을 함께 보유했다면 납부월이 달라 헷갈리기 쉽습니다. 이 리포트는 2026년 납부기간을 먼저 확인한 뒤, 내가 보유한 재산 종류에 따라 어느 달에 고지서를 확인해야 하는지 정리합니다.",
        "재산세의 출발점은 매년 6월 1일 과세기준일입니다. 이날 현재 소유자가 해당 연도 재산세 납세의무자가 되므로, 5월 말이나 6월 초에 부동산을 사고팔았다면 잔금일, 등기일, 계약상 세금 정산 특약을 함께 확인해야 합니다. 법정 납세의무와 매수자·매도자 사이의 정산은 다를 수 있어 고지서만 보고 판단하기보다 계약서도 같이 보는 편이 안전합니다.",
        "실제 고지세액은 공시가격, 공정시장가액비율, 세율, 지방교육세, 도시지역분, 감면 여부에 따라 달라집니다. 같은 공시가격이라도 1세대 1주택 여부와 감면 특례 적용 여부에 따라 최종 납부액 차이가 날 수 있습니다. 본문 하단의 공시가격별 예시는 참고용 추정값이며, 정확한 금액은 위택스 또는 관할 지자체 고지서를 기준으로 확인해야 합니다.",
        "이 리포트의 세액 추정은 일반적인 산정 기준을 적용한 참고치이며, 실제 고지세액은 지자체와 국세청의 산정 결과가 우선합니다. 정확한 금액은 위택스나 관할 지자체를 통해 확인하는 것이 안전합니다.",
      ]}
      inputPoints={[
        "2026년 7월·9월 납부 기간과 주택 1기분·2기분 기준을 확인할 수 있습니다.",
        "아파트·주택·토지·건축물별 납부월과 6월 1일 과세기준일을 함께 볼 수 있습니다.",
        "아파트 보유세 계산기로 예상 세액을 바로 이어서 계산할 수 있습니다.",
      ]}
      criteria={[
        "재산세는 6월 1일 현재 소유자 기준으로 부과됩니다.",
        "주택 과세표준은 공시가격에 공정시장가액비율을 곱해 산정합니다.",
        "출처: " + PTX_SOURCE_LINKS.map((source) => source.label).join(", "),
      ]}
      faq={PTX_FAQ.map((f) => ({ question: f.question, answer: f.answer }))}
      related={PTX_RELATED_LINKS.map((link) => ({ href: link.href, label: link.label }))}
    />
  </main>
</BaseLayout>
