---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  constructionSalaryBonusComparison2026,
  formatBonusRate,
  formatManwon,
  getCompanyTypeLabel,
} from "../../data/constructionSalaryBonusComparison2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const seed = constructionSalaryBonusComparison2026;
const entries = [...seed.entries].sort((a, b) => b.avgSalaryManwon - a.avgSalaryManwon);
const selected = entries[0];
const avgTop = entries[0];
const secondAvg = entries[1];
const bonusTop = [...entries].sort((a, b) => b.bonusRateBase - a.bonusRateBase)[0];
const totalTop3 = [...entries].sort((a, b) => b.estTotalCompBaseManwon - a.estTotalCompBaseManwon).slice(0, 3);
const newHireTop = [...entries].sort((a, b) => b.newHireSalaryManwon - a.newHireSalaryManwon)[0];
const avgSalary = Math.round(entries.reduce((sum, entry) => sum + entry.avgSalaryManwon, 0) / entries.length);
const avgTotalComp = Math.round(entries.reduce((sum, entry) => sum + entry.estTotalCompBaseManwon, 0) / entries.length);
const salaryRange = `${formatManwon(entries[entries.length - 1].avgSalaryManwon)} ~ ${formatManwon(entries[0].avgSalaryManwon)}`;
const contractorTop = [...entries].sort((a, b) => a.contractorRank - b.contractorRank)[0];
const topGap = avgTop.avgSalaryManwon - secondAvg.avgSalaryManwon;
const typeAverages = {
  construction: Math.round(
    entries.filter((entry) => entry.companyType === "construction").reduce((sum, entry) => sum + entry.avgSalaryManwon, 0) /
      entries.filter((entry) => entry.companyType === "construction").length,
  ),
  engineering: Math.round(
    entries.filter((entry) => entry.companyType === "engineering").reduce((sum, entry) => sum + entry.avgSalaryManwon, 0) /
      entries.filter((entry) => entry.companyType === "engineering").length,
  ),
  plant: Math.round(
    entries.filter((entry) => entry.companyType === "plant").reduce((sum, entry) => sum + entry.avgSalaryManwon, 0) /
      entries.filter((entry) => entry.companyType === "plant").length,
  ),
};
const faqItems = seed.faq.map((item) => ({ question: item.q, answer: item.a }));
---

<BaseLayout title={seed.meta.title} description={seed.meta.subtitle}>
  <SiteHeader />

  <main class="container page-shell report-page construction-report-page">
    <CalculatorHero eyebrow="Interactive Report" title={seed.meta.title} description={seed.meta.subtitle} />

    <InfoNotice title="기준 안내" lines={[seed.meta.methodology, seed.meta.caution, seed.meta.updatedAt]} />

    <section class="content-section con-report-hero-board">
      <div class="con-report-lead">
        <p class="con-report-lead__eyebrow">Construction Brief</p>
        <h2>건설사는 평균 연봉만이 아니라 시공능력과 사업 축, 총보상을 같이 봐야 비교가 쉬워집니다</h2>
        <p class="con-report-lead__body">
          이 페이지는 국내 주요 대형 건설사의 평균 연봉과 신입 초봉, 성과급, 총보상, 시공능력과 규모를 함께 읽는 비교 리포트입니다.
          상단에서는 업계 판도를 요약하고, 중간에서는 차트와 표로 분포를 비교하고,
          하단에서는 내 연봉 기준 총보상 계산과 회사별 상세 구조를 함께 볼 수 있게 구성했습니다.
        </p>
        <div class="con-report-lead__chips">
          <span>평균 연봉 범위 {salaryRange}</span>
          <span>종합건설 상위권은 브랜드와 규모가 같이 작동</span>
          <span>플랜트·엔지니어링은 다른 기준으로 해석 필요</span>
        </div>
      </div>

      <div class="con-highlight-grid">
        <article class="con-highlight-card">
          <p>평균 연봉 상위권</p>
          <strong>{avgTop.companyName}</strong>
          <span>{formatManwon(avgTop.avgSalaryManwon)} · {getCompanyTypeLabel(avgTop.companyType)}</span>
        </article>
        <article class="con-highlight-card">
          <p>성과급 강세</p>
          <strong>{bonusTop.companyName}</strong>
          <span>기준 시나리오 {formatBonusRate(bonusTop.bonusRateBase)} · 총보상 관점에서 재해석 필요</span>
        </article>
        <article class="con-highlight-card">
          <p>시공능력 기준점</p>
          <strong>{contractorTop.companyName}</strong>
          <span>시공능력 순위 {contractorTop.contractorRank}위 · 규모와 브랜드 해석의 기준점</span>
        </article>
        <article class="con-highlight-card">
          <p>유형별 평균 축</p>
          <strong>{formatManwon(typeAverages.construction)} / {formatManwon(typeAverages.plant)}</strong>
          <span>종합건설 평균과 플랜트 상단 평균의 간극을 같이 봐야 건설업 보상 구조가 읽힙니다.</span>
        </article>
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 수치</p>
        <h2>대형 건설사 보상 구조를 숫자로 먼저 읽기</h2>
      </div>
      <div class="report-kpi-grid con-kpi-grid">
        <article class="report-stat-card report-stat-card--primary">
          <p>평균 연봉 1위</p>
          <strong>{avgTop.companyName}</strong>
          <span>{formatManwon(avgTop.avgSalaryManwon)}</span>
        </article>
        <article class="report-stat-card">
          <p>성과급 강세 1위</p>
          <strong>{bonusTop.companyName}</strong>
          <span>기준 시나리오 {formatBonusRate(bonusTop.bonusRateBase)}</span>
        </article>
        <article class="report-stat-card">
          <p>신입 초봉 상위권</p>
          <strong>{newHireTop.companyName}</strong>
          <span>{formatManwon(newHireTop.newHireSalaryManwon)}</span>
        </article>
        <article class="report-stat-card">
          <p>비교 대상 건설사</p>
          <strong>{entries.length}개</strong>
          <span>평균 연봉 평균 {formatManwon(avgSalary)} · 총보상 평균 {formatManwon(avgTotalComp)}</span>
        </article>
      </div>

      <div class="con-market-grid">
        <article class="con-market-card con-market-card--primary">
          <p>종합건설 평균</p>
          <strong>{formatManwon(typeAverages.construction)}</strong>
          <span>브랜드 주택·도시정비·대형 시공 포트폴리오가 반영되는 축</span>
        </article>
        <article class="con-market-card">
          <p>엔지니어링 평균</p>
          <strong>{formatManwon(typeAverages.engineering)}</strong>
          <span>해외 프로젝트와 엔지니어링 성격으로 읽는 별도 축</span>
        </article>
        <article class="con-market-card">
          <p>플랜트 상단 평균</p>
          <strong>{formatManwon(typeAverages.plant)}</strong>
          <span>수주와 프로젝트 성과 반영 폭이 큰 편으로 해석되는 축</span>
        </article>
        <article class="con-market-card">
          <p>1위-2위 격차</p>
          <strong>{formatManwon(topGap)}</strong>
          <span>{avgTop.companyName}와 {secondAvg.companyName}의 평균 연봉 차이</span>
        </article>
      </div>
    </section>

    <section class="content-section con-podium-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">상위권 포디움</p>
        <h2>기준 총보상 상단을 형성하는 대표 건설사</h2>
        <p>연봉만이 아니라 성과급과 총보상을 함께 보며 상단 기업을 읽을 수 있도록 카드형으로 정리했습니다.</p>
      </div>

      <div class="con-podium-grid">
        {
          totalTop3.map((entry, index) => (
            <article class={`con-podium-card con-podium-card--${index + 1}`}>
              <span class="con-podium-card__rank">TOP {index + 1}</span>
              <h3>{entry.companyName}</h3>
              <p class="con-podium-card__value">{formatManwon(entry.estTotalCompBaseManwon)}</p>
              <p class="con-podium-card__meta">{getCompanyTypeLabel(entry.companyType)} · 시공능력 {entry.contractorRank}위</p>
              <p class="con-podium-card__body">{entry.summary}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section con-chart-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">리포트 차트</p>
        <h2>평균 연봉과 총보상 축을 분리해서 읽기</h2>
        <p>왼쪽은 평균 연봉, 오른쪽은 기준 총보상입니다. 막대를 클릭하면 아래 상세 카드가 같이 바뀝니다.</p>
      </div>

      <div class="con-chart-meta-row">
        <span class="con-chart-meta-chip con-chart-meta-chip--construction">종합건설</span>
        <span class="con-chart-meta-chip con-chart-meta-chip--engineering">엔지니어링</span>
        <span class="con-chart-meta-chip con-chart-meta-chip--plant">플랜트</span>
      </div>

      <div class="con-chart-board">
        <article class="con-chart-panel">
          <div class="con-chart-panel__head">
            <h3>건설사별 평균 연봉 비교</h3>
            <p>종합건설과 엔지니어링, 플랜트 간 상단 구간 차이를 먼저 확인합니다.</p>
          </div>
          <div class="con-chart-wrap">
            <canvas id="constructionAvgSalaryChart"></canvas>
          </div>
        </article>

        <article class="con-chart-panel con-chart-panel--soft">
          <div class="con-chart-panel__head">
            <h3>기준 총보상 비교</h3>
            <p>성과급 반영 후 체감이 어떻게 달라지는지 같이 봅니다.</p>
          </div>
          <div class="con-chart-wrap">
            <canvas id="constructionTotalCompChart"></canvas>
          </div>
        </article>
      </div>
    </section>

    <section class="content-section con-table-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">건설사 비교 테이블</p>
        <h2>핵심 보상 항목과 규모 지표를 한 표에서 비교하기</h2>
        <p>정렬과 회사 유형 필터를 바꿔가며 표 전체를 다시 읽을 수 있게 구성했습니다.</p>
      </div>

      <div class="con-filter-panel">
        <div class="con-filter-tabs" id="constructionModeTabs">
          <button class="con-tab is-active" data-mode="avgSalary">평균 연봉</button>
          <button class="con-tab" data-mode="bonus">성과급</button>
          <button class="con-tab" data-mode="newHire">신입 초봉</button>
          <button class="con-tab" data-mode="totalComp">총보상</button>
          <button class="con-tab" data-mode="contractorRank">시공능력</button>
        </div>
        <div class="con-chip-row" id="constructionTypeTabs">
          <button class="con-chip is-active" data-type="all">전체</button>
          <button class="con-chip" data-type="construction">종합건설</button>
          <button class="con-chip" data-type="engineering">엔지니어링</button>
          <button class="con-chip" data-type="plant">플랜트</button>
        </div>
        <label class="field">
          <span>정렬</span>
          <select id="constructionSortSelect">
            <option value="desc">높은순</option>
            <option value="asc">낮은순</option>
            <option value="name">가나다순</option>
          </select>
        </label>
      </div>

      <div class="con-summary-bar" id="constructionSummaryBar"></div>

      <div class="con-compare-table-wrap">
        <table class="con-compare-table">
          <thead>
            <tr>
              <th>회사명</th>
              <th>구분</th>
              <th>평균 연봉</th>
              <th>신입 초봉</th>
              <th>과장급</th>
              <th>성과급</th>
              <th>기준 총보상</th>
              <th>시공능력</th>
              <th>특징</th>
            </tr>
          </thead>
          <tbody id="constructionCompareTableBody">
            {
              entries.map((entry) => (
                <tr data-company={entry.slug}>
                  <td>{entry.companyName}</td>
                  <td>{getCompanyTypeLabel(entry.companyType)}</td>
                  <td>{formatManwon(entry.avgSalaryManwon)}</td>
                  <td>{formatManwon(entry.newHireSalaryManwon)}</td>
                  <td>{formatManwon(entry.managerSalaryManwon)}</td>
                  <td>{formatBonusRate(entry.bonusRateBase)}</td>
                  <td>{formatManwon(entry.estTotalCompBaseManwon)}</td>
                  <td>{entry.contractorRank}위</td>
                  <td>{entry.companyTag}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section class="content-section con-explorer-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">총보상 계산기</p>
        <h2>내 연봉 기준으로 건설사 총보상을 가볍게 계산하기</h2>
        <p>세후 계산이 아니라 비교용 추정치입니다. 같은 기본 연봉이라도 회사별 시나리오에 따라 총보상 체감이 어떻게 달라지는지 빠르게 볼 수 있습니다.</p>
      </div>

      <div class="con-explorer-grid">
        <div class="con-calc-column">
          <article class="con-calculator-panel">
            <div class="con-calculator-panel__head">
              <p class="con-calculator-panel__eyebrow">Compensation Lab</p>
              <h3>건설사별 총보상 시나리오</h3>
              <p>연봉과 성과급을 단순화한 추정 계산으로, 회사별 보상 체감 차이를 빠르게 비교하는 용도입니다.</p>
            </div>

            <div class="con-form-grid">
              <label class="field">
                <span>회사 선택</span>
                <select id="constructionCompanySelect">
                  {
                    entries.map((entry) => (
                      <option value={entry.slug} selected={entry.slug === selected.slug}>{entry.companyName}</option>
                    ))
                  }
                </select>
              </label>

              <label class="field">
                <span>기본 연봉 (만원)</span>
                <input type="number" id="constructionBaseSalaryInput" min="0" max="30000" step="100" value="7000" />
              </label>
            </div>

            <div class="con-scenario-row" id="constructionScenarioTabs">
              <button class="con-pill is-active" data-scenario="base">기준</button>
              <button class="con-pill" data-scenario="conservative">보수적</button>
              <button class="con-pill" data-scenario="aggressive">공격적</button>
            </div>

            <label class="con-toggle-row">
              <input type="checkbox" id="constructionExtraBonusToggle" checked />
              <span>기타 상여 포함</span>
            </label>

            <div class="con-result-card" id="constructionResultCard">
              <p class="con-result-title" id="constructionResultTitle">기준 시나리오 결과</p>
              <div class="con-result-grid">
                <div class="con-result-cell"><strong id="constructionExpectedBonus">-</strong><span>예상 성과급</span></div>
                <div class="con-result-cell"><strong id="constructionExpectedTotal">-</strong><span>예상 총보상</span></div>
                <div class="con-result-cell"><strong id="constructionTotalLevel">-</strong><span>업계 평균 대비</span></div>
              </div>
              <p class="con-similar-text" id="constructionResultComment"></p>
            </div>
          </article>
        </div>

        <div class="con-profile-column">
          <article class="panel con-profile-card" id="constructionProfileCard">
            <div class="con-profile-card__header">
              <div>
                <p class="panel-heading__eyebrow">선택 건설사</p>
                <h2 id="constructionProfileName">{selected.companyName}</h2>
                <p class="con-profile-card__sub" id="constructionProfileNameEn">{selected.nameEn}</p>
              </div>
              <div class="report-rank-chip" id="constructionProfileType">{getCompanyTypeLabel(selected.companyType)}</div>
            </div>

            <div class="con-profile-card__summary">
              <article class="report-stat-card report-stat-card--primary">
                <p>평균 연봉</p>
                <strong id="constructionProfileAvgSalary">{formatManwon(selected.avgSalaryManwon)}</strong>
                <span id="constructionProfileTagline">{selected.companyTag}</span>
              </article>
              <article class="report-stat-card">
                <p>신입 초봉</p>
                <strong id="constructionProfileNewHire">{formatManwon(selected.newHireSalaryManwon)}</strong>
                <span>신입 입사 기준 추정</span>
              </article>
              <article class="report-stat-card">
                <p>기준 총보상</p>
                <strong id="constructionProfileTotalComp">{formatManwon(selected.estTotalCompBaseManwon)}</strong>
                <span id="constructionProfileBonus">기준 성과급 {formatBonusRate(selected.bonusRateBase)}</span>
              </article>
            </div>

            <div class="con-profile-card__detail">
              <div class="con-mini-fact-grid">
                <article class="con-mini-fact-card">
                  <span>과장급 추정 연봉</span>
                  <strong id="constructionProfileManager">{formatManwon(selected.managerSalaryManwon)}</strong>
                </article>
                <article class="con-mini-fact-card">
                  <span>임직원 수</span>
                  <strong id="constructionProfileHeadcount">{selected.employeeCount.toLocaleString("ko-KR")}명</strong>
                </article>
                <article class="con-mini-fact-card">
                  <span>시공능력 순위</span>
                  <strong id="constructionProfileRank">{selected.contractorRank}위</strong>
                </article>
              </div>

              <div class="con-mini-fact-grid con-mini-fact-grid--second">
                <article class="con-mini-fact-card">
                  <span>매출 규모</span>
                  <strong id="constructionProfileRevenue">{selected.revenueText}</strong>
                </article>
                <article class="con-mini-fact-card">
                  <span>성장 포인트</span>
                  <strong id="constructionProfileGrowth">{selected.growthTag}</strong>
                </article>
                <article class="con-mini-fact-card">
                  <span>성과급 범위</span>
                  <strong id="constructionProfileBonusRange">{formatBonusRate(selected.bonusRateMin)} ~ {formatBonusRate(selected.bonusRateMax)}</strong>
                </article>
              </div>

              <div class="report-tag-block">
                <span class="report-tag-block__label">태그</span>
                <div class="report-tag-list" id="constructionProfileTags">
                  {selected.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </div>
            </div>

            <div class="con-profile-list-block">
              <div>
                <p class="con-profile-list-block__label">성과급 설명</p>
                <p id="constructionProfileBonusComment">{selected.bonusComment}</p>
              </div>
              <div>
                <p class="con-profile-list-block__label">한 줄 요약</p>
                <p id="constructionProfileSummary">{selected.summary}</p>
              </div>
            </div>

            <div class="con-profile-links" id="constructionProfileLinks">
              {selected.hiringUrl ? <a href={selected.hiringUrl} target="_blank" rel="noopener noreferrer">채용</a> : null}
              {selected.officialUrl ? <a href={selected.officialUrl} target="_blank" rel="noopener noreferrer">공식 사이트</a> : null}
              {selected.irUrl ? <a href={selected.irUrl} target="_blank" rel="noopener noreferrer">IR</a> : null}
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="content-section con-pattern-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">패턴 요약</p>
        <h2>건설업 보상 구조에서 먼저 읽히는 흐름</h2>
        <p>숫자만 나열하지 않고 종합건설, 엔지니어링, 플랜트 차이와 총보상 해석 포인트를 카드로 먼저 읽을 수 있게 정리했습니다.</p>
      </div>

