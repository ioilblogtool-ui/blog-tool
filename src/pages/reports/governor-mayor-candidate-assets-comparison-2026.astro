---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import { governorAssetsReport } from "../../data/governorCandidateAssets2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const report = governorAssetsReport;
const faqItems = report.faq.map((item) => ({ question: item.q, answer: item.a }));

// 기본 정렬: 재산 높은 순
const candidatesSorted = [...report.candidates].sort((a, b) => b.totalAssets - a.totalAssets);

// 만 원 → 억/천만 포맷
function fmtEok(v: number | null): string {
  if (v === null) return '-';
  const eok = Math.floor(v / 10000);
  const cheonMan = Math.floor((v % 10000) / 1000);
  if (eok === 0) return `${v.toLocaleString('ko-KR')}만 원`;
  if (cheonMan > 0) return `${eok}억 ${cheonMan}천만`;
  return `${eok}억`;
}

// 지역별 최고 재산 후보 (CSS bar row용)
const regionMap = new Map<string, typeof report.candidates>();
for (const c of report.candidates) {
  if (!regionMap.has(c.regionShort)) regionMap.set(c.regionShort, []);
  regionMap.get(c.regionShort)!.push(c);
}
const regionRows = Array.from(regionMap.entries())
  .map(([, list]) => list.sort((a, b) => b.totalAssets - a.totalAssets)[0])
  .sort((a, b) => a.regionCode.localeCompare(b.regionCode));
const maxRegionAssets = Math.max(...regionRows.map((r) => r.totalAssets));
---

<BaseLayout
  title={report.meta.seoTitle}
  description={report.meta.seoDescription}
>
  <SiteHeader />

  <main class="container page-shell report-page gmca-page">
    <CalculatorHero
      eyebrow="2026 지방선거 데이터 리포트"
      title="광역단체장 후보 재산 비교 2026"
      description="시도지사 후보 재산을 한눈에 비교합니다. 중앙선거관리위원회 후보 재산 신고 공개 자료를 기반으로 정리한 참고용 비교 리포트입니다."
    />

    <InfoNotice
      title="데이터 기준 안내"
      lines={[
        `출처: ${report.meta.dataSourceLabel} (${report.meta.declaredDateRange})`,
        report.meta.caution,
      ]}
    />

    <!-- KPI 요약 카드 -->
    <section class="content-section gmca-kpi-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 수치</p>
        <h2>먼저 봐야 할 숫자 4개</h2>
      </div>
      <div class="gmca-kpi-grid">
        {report.kpis.map((kpi) => (
          <article class={`gmca-kpi-card${kpi.tone ? ` is-${kpi.tone}` : ''}`}>
            <p class="gmca-kpi-card__label">{kpi.label}</p>
            <strong class="gmca-kpi-card__value">{kpi.value}</strong>
            <span class="gmca-kpi-card__sub">{kpi.sub}</span>
          </article>
        ))}
      </div>
    </section>

    <!-- 전체 후보 랭킹 테이블 -->
    <section class="content-section gmca-table-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">전체 후보 랭킹</p>
        <h2>광역단체장 후보 재산 순위</h2>
        <p>모든 수치는 중앙선관위 공개 재산 신고 기준이며, 단위는 억 원입니다. 세부 항목 미공개 시 — 로 표시합니다.</p>
      </div>

      <div class="gmca-sort-tabs" id="gmcaSortTabs">
        <button type="button" class="gmca-tab-btn is-active" data-sort="assetsDesc">재산 높은 순</button>
        <button type="button" class="gmca-tab-btn" data-sort="assetsAsc">재산 낮은 순</button>
        <button type="button" class="gmca-tab-btn" data-sort="regionAsc">지역별</button>
        <button type="button" class="gmca-tab-btn" data-sort="partyAsc">정당별</button>
      </div>

      <div class="table-wrap gmca-table-wrap">
        <table class="gmca-table" id="gmcaCandidateTable">
          <thead>
            <tr>
              <th class="col-rank">#</th>
              <th class="col-name">후보명</th>
              <th class="col-party">소속 정당</th>
              <th class="col-region">출마 지역</th>
              <th class="col-total">신고 재산 총액</th>
              <th class="col-re">부동산</th>
              <th class="col-fin">금융자산</th>
              <th class="col-debt">채무</th>
              <th class="col-note">비고</th>
            </tr>
          </thead>
          <tbody id="gmcaTableBody">
            {candidatesSorted.map((c, i) => (
              <tr
                data-total={c.totalAssets}
                data-region={c.regionCode}
                data-party={c.partyCode}
                data-name={c.name}
                data-region-short={c.regionShort}
                data-party-label={c.party}
                data-re={c.realEstate ?? ''}
                data-fin={c.financialAssets ?? ''}
                data-debt={c.debt ?? ''}
                data-note={c.note}
              >
                <td class="col-rank">{i + 1}</td>
                <td class="col-name gmca-name-cell">
                  <span class="gmca-name">{c.name}</span>
                </td>
                <td class="col-party">
                  <span class={`gmca-party-badge gmca-party-badge--${c.partyCode}`}>
                    {c.party}
                  </span>
                </td>
                <td class="col-region">{c.regionShort}</td>
                <td class="col-total gmca-total">{fmtEok(c.totalAssets)}</td>
                <td class="col-re">{fmtEok(c.realEstate)}</td>
                <td class="col-fin">{fmtEok(c.financialAssets)}</td>
                <td class="col-debt">
                  {c.debt !== null && c.debt > 0 ? (
                    <span class="gmca-debt-val">{fmtEok(c.debt)}</span>
                  ) : fmtEok(c.debt)}
                </td>
                <td class="col-note gmca-note">{c.note || ''}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="gmca-table-note">※ 단위: 억 원 (반올림). 세부 항목 미공개 시 — 표시. 순재산 = 총재산 - 채무 (참고용)</p>
    </section>

    <!-- 정당별 평균 재산 -->
    <section class="content-section gmca-chart-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">정당별 비교</p>
        <h2>정당별 후보 평균 재산</h2>
        <p>각 정당 광역단체장 후보의 평균 재산을 비교합니다. 단순 평균이며 후보 수에 따라 변동될 수 있습니다.</p>
      </div>
      <div class="gmca-chart-wrap">
        <canvas id="gmcaPartyChart"></canvas>
      </div>
      <p class="gmca-chart-note">단순 평균값이며, 후보 수와 지역 구성에 따라 편차가 큽니다. 참고용으로만 활용하세요.</p>
    </section>

    <!-- 지역별 재산 분포 -->
    <section class="content-section gmca-region-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">지역별 분포</p>
        <h2>지역별 최고 재산 후보 비교</h2>
        <p>각 지역에서 재산이 가장 많은 후보 기준으로 시각화했습니다.</p>
      </div>
      <div class="gmca-region-list">
        {regionRows.map((c) => {
          const pct = Math.max(4, Math.round((c.totalAssets / maxRegionAssets) * 100));
          return (
            <div class="gmca-region-row">
              <span class="gmca-region-row__label">{c.regionShort}</span>
              <span class="gmca-region-row__name">{c.name}</span>
              <span class={`gmca-party-badge gmca-party-badge--${c.partyCode} gmca-party-badge--sm`}>
                {c.party}
              </span>
              <div class="gmca-region-row__bar-wrap">
                <div class="gmca-region-row__bar" style={`width:${pct}%`}></div>
              </div>
              <span class="gmca-region-row__value">{fmtEok(c.totalAssets)}</span>
            </div>
          );
        })}
      </div>
    </section>

    <!-- 재산 구성 항목 해설 -->
    <section class="content-section gmca-composition-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">항목 해설</p>
        <h2>재산 신고 항목 이해하기</h2>
        <p>재산 신고 항목별 의미를 간단히 정리했습니다.</p>
      </div>
      <div class="gmca-composition-grid">
        {report.assetCompositionCards.map((card) => (
          <article class="gmca-composition-card">
            <p class="gmca-composition-card__icon">{card.icon}</p>
            <strong class="gmca-composition-card__title">{card.title}</strong>
            <p class="gmca-composition-card__desc">{card.description}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="content-section gmca-faq-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">자주 묻는 질문</p>
        <h2>FAQ</h2>
      </div>
      <div class="gmca-faq-list">
        {report.faq.map((item) => (
          <article class="gmca-faq-item">
            <p class="gmca-faq-item__q">{item.q}</p>
            <p class="gmca-faq-item__a">{item.a}</p>
          </article>
        ))}
      </div>
    </section>

    <!-- 관련 콘텐츠 CTA -->
    <section class="content-section gmca-cta-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">관련 콘텐츠</p>
        <h2>함께 보면 좋은 리포트</h2>
      </div>
      <div class="gmca-cta-grid">
        {report.relatedLinks.map((link) => (
          <a class="gmca-cta-card" href={withBase(link.href)}>
            <strong>{link.label}</strong>
            <span>{link.description}</span>
          </a>
        ))}
      </div>
    </section>

    <SeoContent
      introTitle="2026 광역단체장 후보 재산 비교 리포트 읽는 법"
      intro={[
        "이 리포트는 2026년 지방선거 광역단체장(시도지사) 후보자의 재산 신고 공개 자료를 한 화면에서 비교할 수 있도록 정리한 참고용 데이터 리포트입니다.",
        "공직선거법에 따라 후보자는 재산 내역을 중앙선거관리위원회에 신고·공개하며, 이 리포트는 해당 공개 자료만을 기반으로 구성됩니다.",
        "특정 후보를 지지하거나 비방하는 의도 없이 데이터만 제시합니다. 유권자 판단의 참고 자료로 활용하세요.",
      ]}
      criteria={[
        "모든 수치는 중앙선거관리위원회 공개 재산 신고 자료 기준입니다.",
        "부동산은 공시지가 기준이므로 실제 시장 가격과 차이가 있을 수 있습니다.",
        "세부 항목(부동산·금융·채무)이 공개되지 않은 경우 — 로 표시됩니다.",
        "정당별 평균은 집계 후보 수에 따라 변동될 수 있는 단순 평균값입니다.",
      ]}
      faq={faqItems}
      related={report.relatedLinks}
    />
  </main>

  <script id="gmcaReportData" type="application/json" set:html={JSON.stringify(report)}></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/governor-mayor-candidate-assets-comparison-2026.js")}></script>
</BaseLayout>
