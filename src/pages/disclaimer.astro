---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import CalculatorHero from "../components/CalculatorHero.astro";

const disclaimerFaq = [
  {
    question: "계산 결과와 회사·기관 공지 금액이 다른 이유는 무엇인가요?",
    answer: "비교계산소의 계산 결과는 입력한 값과 일반적인 공개 기준을 바탕으로 산출한 추정치입니다. 회사별 지급 기준, 개인별 공제 항목, 기관의 세부 운영 지침이 다르면 실제 금액과 차이가 발생할 수 있습니다.",
  },
  {
    question: "정책이나 세율이 바뀌면 계산기에 바로 반영되나요?",
    answer: "정책, 최저임금, 세율, 지급 상한 등 기준이 바뀌는 항목은 확인되는 대로 업데이트하지만, 시행 시점과 반영 시점 사이에 차이가 있을 수 있습니다. 각 페이지의 기준일 표기를 함께 확인해 주세요.",
  },
  {
    question: "계산 결과를 근거로 손해가 발생하면 책임을 질 수 있나요?",
    answer: "비교계산소는 참고용 정보를 제공할 뿐 법률·세무·투자 자문을 제공하지 않으며, 계산 결과를 근거로 한 판단이나 행동으로 발생한 손해에 대해 법적 책임을 지지 않습니다. 자세한 내용은 이용약관을 참고해 주세요.",
  },
  {
    question: "추정값과 공식값은 어떻게 구분하나요?",
    answer: "공식 자료가 있는 항목은 출처를 함께 표시하고, 변동성이 크거나 개인 조건에 따라 달라지는 항목은 '추정' 또는 '참고'로 표시합니다. 표시가 불명확하거나 오해의 소지가 있다면 문의 페이지로 알려주세요.",
  },
  {
    question: "잘못된 계산 결과를 발견하면 어떻게 해야 하나요?",
    answer: "문의 페이지 또는 이메일로 어떤 페이지에서 어떤 입력값으로 어떤 결과가 나왔는지 알려주시면 확인 후 수정합니다.",
  },
];

const disclaimerFaqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: disclaimerFaq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="이용안내 및 면책 | 비교계산소"
  description="비교계산소 계산 결과의 해석 범위와 이용 시 유의사항을 안내합니다."
  jsonLd={disclaimerFaqJsonLd}
>
  <SiteHeader />

  <main class="container page-shell info-page">
    <CalculatorHero
      eyebrow="이용안내와 면책"
      title="이용안내 및 면책"
      description="비교계산소의 계산 결과는 의사결정을 돕기 위한 참고 자료이며, 최종 판단 전에는 반드시 공식 기준과 원문 자료를 함께 확인해야 합니다."
    />

    <section class="info-layout">
      <article class="panel info-panel">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">참고용 정보</p>
          <h2 class="ip-section__title">계산 결과의 성격</h2>
        </div>
        <div class="info-copy">
          <p>
            비교계산소의 모든 계산 결과는 사용자가 입력한 값과 공개된 기준을 바탕으로 산출한 참고용 추정치입니다.
            실제 급여, 지원금, 성과급, 세후 금액은 회사 정책, 기관 안내, 개인 상황, 지급 기준, 공제 방식에 따라 달라질 수 있습니다.
          </p>
          <p>
            특히 법령, 세율, 지급 상한, 특례 제도, 회사별 운영 기준은 시기별로 변경될 수 있으므로
            최신 공지와 원문 자료를 반드시 함께 확인해야 합니다.
          </p>
        </div>
      </article>

      <article class="panel info-panel">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">전문 자문 아님</p>
          <h2 class="ip-section__title">전문 자문 제공 여부</h2>
        </div>
        <ul class="info-list">
          <li>비교계산소는 법률, 세무, 노무, 회계, 투자 자문 서비스를 제공하지 않습니다.</li>
          <li>계산 결과만을 근거로 최종 계약, 신청, 신고, 투자 판단을 진행하는 것은 권장하지 않습니다.</li>
          <li>중요한 판단이 필요한 경우 관련 기관, 회사 공지, 또는 전문가의 확인이 필요합니다.</li>
        </ul>
      </article>

      <article class="panel info-panel info-panel--wide">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">이용자 확인</p>
          <h2 class="ip-section__title">이용자 확인 책임</h2>
        </div>
        <div class="info-copy">
          <p>
            사용자는 비교계산소의 결과를 참고 자료로 활용할 수 있으나,
            실제 적용 전에는 반드시 본인 상황에 맞는 공식 기준과 원문 공지를 직접 확인해야 합니다.
          </p>
          <p>
            계산 결과 또는 설명 내용과 관련한 오류 제보나 수정 요청은 <a href="/contact/">문의 페이지</a> 또는 이메일을 통해 전달할 수 있습니다.
          </p>
        </div>
      </article>

      <article class="panel info-panel info-panel--wide">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">자주 묻는 질문</p>
          <h2 class="ip-section__title">이용안내 및 면책 FAQ</h2>
        </div>
        <div class="info-faq-list">
          {disclaimerFaq.map((item, index) => (
            <details class="info-faq-item" open={index === 0}>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </article>

      <article class="panel info-panel info-panel--wide">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">관련 페이지</p>
          <h2 class="ip-section__title">관련 페이지</h2>
        </div>
        <div class="info-link-grid">
          <a class="info-link-card" href="/terms/">
            <strong>이용약관</strong>
            <p>서비스 이용 조건과 계산 결과의 법적 성격을 확인합니다.</p>
          </a>
          <a class="info-link-card" href="/privacy/">
            <strong>개인정보처리방침</strong>
            <p>비교계산소의 개인정보 처리 기준과 쿠키 사용 안내를 확인합니다.</p>
          </a>
          <a class="info-link-card" href="/about/">
            <strong>사이트 소개</strong>
            <p>비교계산소의 운영 원칙과 콘텐츠 기준을 확인합니다.</p>
          </a>
          <a class="info-link-card" href="/contact/">
            <strong>문의 안내</strong>
            <p>계산 오류 제보, 업데이트 요청, 기타 문의를 보낼 수 있습니다.</p>
          </a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
