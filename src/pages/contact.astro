---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import CalculatorHero from "../components/CalculatorHero.astro";

const contactFaq = [
  {
    question: "문의 답변은 얼마나 걸리나요?",
    answer: "운영자가 직접 확인 후 순차적으로 답변하며, 보통 영업일 기준 며칠 내에 검토합니다. 계산 오류처럼 사이트 품질과 직접 연결되는 문의는 우선적으로 처리합니다.",
  },
  {
    question: "전화 상담이나 개인별 맞춤 상담도 가능한가요?",
    answer: "비교계산소는 이메일 문의만 받고 있으며, 개인 상담이나 법률·세무·투자 자문 서비스는 제공하지 않습니다. 일반적인 계산 기준이나 사이트 이용 관련 문의만 안내해 드릴 수 있습니다.",
  },
  {
    question: "계산기에 새로운 기능이나 항목을 추가해 달라고 요청할 수 있나요?",
    answer: "네. 어떤 계산기에 어떤 항목이나 기능이 더 필요한지 알려주시면 우선순위를 검토해 반영합니다. 다만 모든 요청이 즉시 반영되지는 않을 수 있습니다.",
  },
  {
    question: "광고나 제휴 제안은 어떻게 하나요?",
    answer: "이메일 제목에 '광고/제휴 문의'를 표기해 보내주시면 운영 정책에 맞는지 검토 후 회신합니다.",
  },
  {
    question: "오류를 제보하면 실제로 수정되나요?",
    answer: "네. 제보된 오류는 페이지 주소와 입력값을 기준으로 재현해 확인 후 수정합니다. 수정 완료 여부는 별도로 회신해 드리기 어려울 수 있지만, 확인 즉시 반영을 진행합니다.",
  },
];

const contactFaqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: contactFaq.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title="문의 안내 | 비교계산소"
  description="비교계산소의 계산기 오류, 업데이트 요청, 제휴 문의 안내 페이지입니다."
  jsonLd={contactFaqJsonLd}
>
  <SiteHeader />

  <main class="container page-shell info-page">
    <CalculatorHero
      eyebrow="문의 안내"
      title="문의 안내"
      description="계산기 오류 제보, 업데이트 요청, 콘텐츠 제안이 있다면 아래 기준에 맞춰 문의해주세요."
    />

    <section class="info-layout">
      <article class="panel info-panel">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">문의 유형</p>
          <h2 class="ip-section__title">이런 문의를 받을 수 있습니다</h2>
        </div>
        <ul class="info-list">
          <li>계산 결과 오류 또는 오타 제보</li>
          <li>정책 변경 반영 요청</li>
          <li>새 계산기/가이드 주제 제안</li>
          <li>광고, 제휴, 사이트 운영 관련 문의</li>
        </ul>
      </article>

      <article class="panel info-panel">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">작성 방법</p>
          <h2 class="ip-section__title">문의 시 함께 적어주면 좋은 정보</h2>
        </div>
        <ul class="info-list">
          <li>문제가 발생한 페이지 주소</li>
          <li>입력한 값과 기대한 결과</li>
          <li>확인한 공식 자료나 공지 링크</li>
          <li>오류가 발생한 기기 또는 브라우저 정보</li>
        </ul>
      </article>

      <article class="panel info-panel info-panel--wide">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">이메일</p>
          <h2 class="ip-section__title">이메일 문의</h2>
        </div>
        <div class="info-copy">
          <p>아래 이메일로 문의해 주세요. 계산기 오류, 기준 설명, 업데이트 요청처럼 사이트 품질과 직접 연결되는 문의는 우선적으로 검토합니다.</p>
          <p>비교계산소는 개인 상담이나 법률·세무 자문 서비스를 제공하지 않습니다.</p>
        </div>
        <a href="mailto:ioilblogtool@gmail.com" class="info-email-block">
          ioilblogtool@gmail.com
        </a>
      </article>

      <article class="panel info-panel info-panel--wide">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">자주 묻는 질문</p>
          <h2 class="ip-section__title">문의 안내 FAQ</h2>
        </div>
        <div class="info-faq-list">
          {contactFaq.map((item, index) => (
            <details class="info-faq-item" open={index === 0}>
              <summary>{item.question}</summary>
              <p>{item.answer}</p>
            </details>
          ))}
        </div>
      </article>

      <article class="panel info-panel info-panel--wide">
        <div class="ip-section__head">
          <p class="ip-section__eyebrow">관련 페이지</p>
          <h2 class="ip-section__title">관련 페이지</h2>
        </div>
        <div class="info-link-grid">
          <a class="info-link-card" href="/about/">
            <strong>사이트 소개</strong>
            <p>비교계산소의 운영 원칙과 콘텐츠 기준을 확인합니다.</p>
          </a>
          <a class="info-link-card" href="/disclaimer/">
            <strong>이용안내 및 면책</strong>
            <p>계산 결과의 참고 범위와 실제 차이가 생길 수 있는 이유를 확인합니다.</p>
          </a>
          <a class="info-link-card" href="/terms/">
            <strong>이용약관</strong>
            <p>서비스 이용 조건과 계산 결과의 법적 성격을 확인합니다.</p>
          </a>
          <a class="info-link-card" href="/privacy/">
            <strong>개인정보처리방침</strong>
            <p>비교계산소의 개인정보 처리 기준과 쿠키 사용 안내를 확인합니다.</p>
          </a>
        </div>
      </article>
    </section>
  </main>
</BaseLayout>
