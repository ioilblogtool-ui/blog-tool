---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  HBC_META,
  HBC_DEFAULT_INPUT,
  HBC_PRESETS,
  HBC_GIFT_TYPE_TABLE,
  HBC_PAY_COMPARISON_TABLE,
  HBC_BONUS_TYPE_TABLE,
  HBC_FAQ,
  HBC_RELATED_LINKS,
  HBC_SEO_CONTENT,
  calcHolidayBonus,
  getTaxBracket,
} from "../../data/holidayBonusAfterTaxCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${HBC_META.slug}/`;
const won = (value: number) => `${Math.round(value).toLocaleString("ko-KR")}원`;
const defaultResult = calcHolidayBonus(HBC_DEFAULT_INPUT);
const defaultBracket = getTaxBracket(HBC_DEFAULT_INPUT.annualSalary);
const pageData = {
  defaultInput: HBC_DEFAULT_INPUT,
  presets: HBC_PRESETS,
};
---

<BaseLayout
  title={HBC_META.seoTitle}
  description={HBC_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: HBC_META.title,
      applicationCategory: "FinanceApplication",
      operatingSystem: "All",
      inLanguage: "ko-KR",
      isAccessibleForFree: true,
      url: pageUrl,
      description: HBC_META.seoDescription,
      provider: { "@type": "Organization", name: "비교계산소" },
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: HBC_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={HBC_META.slug} pageClass="hbc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="명절 상여금 실수령"
        title={HBC_META.title}
        description="설·추석 상여금과 떡값을 받으면 세금이 얼마나 공제되고 실제로 얼마가 입금되는지 계산합니다."
        badges={["추석", "설", "간이 추정", "2026"]}
      />
      <InfoNotice
        title="계산 기준 안내"
        lines={[
          HBC_META.dataNote,
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="hbcResetBtn" copyId="hbcCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 예시</p>
            <h2 class="panel__title">프리셋으로 바로 계산</h2>
          </div>
          <p class="panel-heading__summary">연봉과 급여 구조를 가정한 예시입니다.</p>
        </div>
        <div class="hbc-preset-grid">
          {HBC_PRESETS.map((preset, index) => (
            <button type="button" class:list={["hbc-preset-btn", index === 1 && "is-active"]} data-hbc-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.summary}</span>
            </button>
          ))}
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">기본 정보</p>
            <h2 class="panel__title">상여금·연봉 입력</h2>
          </div>
        </div>
        <div class="form-grid">
          <label class="field">
            <span>명절 상여금 총액</span>
            <input type="text" inputmode="numeric" data-hbc-input="bonusGrossAmount" value={HBC_DEFAULT_INPUT.bonusGrossAmount.toLocaleString("ko-KR")} />
          </label>
          <label class="field">
            <span>연봉</span>
            <input type="text" inputmode="numeric" data-hbc-input="annualSalary" value={HBC_DEFAULT_INPUT.annualSalary.toLocaleString("ko-KR")} />
            <small>소득세 간이 추정에만 사용하며, 실제 원천징수는 부양가족·지급 대상 기간에 따라 달라집니다.</small>
          </label>
          <label class="field">
            <span>지급월</span>
            <select data-hbc-input="paymentMonth">
              {Array.from({ length: 12 }, (_, i) => i + 1).map((month) => (
                <option value={month} selected={month === HBC_DEFAULT_INPUT.paymentMonth}>
                  {month}월 {month === 9 ? "(추석)" : (month === 1 || month === 2) ? "(설)" : ""}
                </option>
              ))}
            </select>
          </label>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">공제 옵션</p>
            <h2 class="panel__title">세금·4대보험 반영 방식</h2>
          </div>
        </div>
        <label class="hbc-check-field">
          <input type="checkbox" data-hbc-input="includeLocalIncomeTax" checked />
          <span>지방소득세 포함</span>
        </label>
        <div class="form-grid">
          <label class="field">
            <span>국민연금·건강보험 반영 방식</span>
            <select data-hbc-input="pensionHealthReflection">
              <option value="notReflected" selected={HBC_DEFAULT_INPUT.pensionHealthReflection === "notReflected"}>반영 안 함 (기존 월 보험료 유지 가정)</option>
              <option value="immediate" selected={HBC_DEFAULT_INPUT.pensionHealthReflection === "immediate"}>즉시 반영 추정 (상여금 비율만큼 단순 계산)</option>
            </select>
            <small>국민연금은 기준소득월액, 건강보험은 보수총액 정산 방식이 기준이라 지급월에 곧바로 늘지 않을 수 있습니다.</small>
          </label>
        </div>
      </article>
    </Fragment>

    <article class="panel hbc-result-panel" aria-live="polite">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">계산 결과</p>
          <h2 class="panel__title">예상 실수령액 (간이 추정)</h2>
        </div>
        <p class="panel-heading__summary" data-hbc-result="bracketLabel">연봉 기준 근사 세율({defaultBracket.label}) 적용</p>
      </div>
      <div class="hbc-kpi-grid">
        <article class="hbc-kpi hbc-kpi--main">
          <span>예상 실수령액</span>
          <strong data-hbc-result="netAmount">{won(defaultResult.netAmount)}</strong>
          <small data-hbc-result="netRate">실수령률 {defaultResult.netRate.toFixed(1)}%</small>
        </article>
        <article class="hbc-kpi">
          <span>세전 상여금</span>
          <strong data-hbc-result="grossAmount">{won(HBC_DEFAULT_INPUT.bonusGrossAmount)}</strong>
        </article>
        <article class="hbc-kpi">
          <span>총 공제액</span>
          <strong data-hbc-result="totalDeduction">{won(defaultResult.totalDeduction)}</strong>
        </article>
      </div>
      <p class="hbc-disclaimer">국민연금·건강보험이 상여금 비율만큼 지급월에 곧바로 늘지 않을 수 있어 아래 시나리오를 함께 확인하세요.</p>
    </article>

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">시나리오 비교</p>
          <h2 class="panel__title">반영 범위별 예상 실수령액</h2>
        </div>
      </div>
      <div class="table-wrap hbc-table-wrap">
        <table class="hbc-scenario-table">
          <thead><tr><th>계산 방식</th><th>예상 실수령액</th></tr></thead>
          <tbody>
            <tr><td>세금만 즉시 반영</td><td data-hbc-result="scenarioTaxOnly">{won(defaultResult.scenarioTaxOnly)}</td></tr>
            <tr><td>세금+고용보험 반영</td><td data-hbc-result="scenarioTaxPlusEmployment">{won(defaultResult.scenarioTaxPlusEmployment)}</td></tr>
            <tr><td>모든 보험료 즉시 반영 가정</td><td data-hbc-result="scenarioAllImmediate">{won(defaultResult.scenarioAllImmediate)}</td></tr>
          </tbody>
        </table>
      </div>
      <p class="hbc-table-note">위 계산 방식 중 하나가 반드시 정답은 아닙니다. 실제 입금액은 회사의 급여 시스템과 4대보험 보수 신고 방식에 따라 달라집니다.</p>
    </article>

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">공제 내역</p>
          <h2 class="panel__title">항목별 분해 (현재 반영 방식 기준)</h2>
        </div>
      </div>
      <div class="hbc-breakdown">
        <div class="hbc-breakdown-row"><span>소득세</span><strong data-hbc-result="incomeTax">{won(defaultResult.incomeTax)}</strong></div>
        <div class="hbc-breakdown-row"><span>지방소득세</span><strong data-hbc-result="localIncomeTax">{won(defaultResult.localIncomeTax)}</strong></div>
        <div class="hbc-breakdown-row"><span>고용보험</span><strong data-hbc-result="employmentInsurance">{won(defaultResult.employmentInsurance)}</strong></div>
        <div class="hbc-breakdown-row"><span>국민연금</span><strong data-hbc-result="nationalPension">{won(defaultResult.nationalPension)}</strong></div>
        <div class="hbc-breakdown-row"><span>건강보험</span><strong data-hbc-result="healthInsurance">{won(defaultResult.healthInsurance)}</strong></div>
        <div class="hbc-breakdown-row"><span>장기요양보험</span><strong data-hbc-result="longTermCareInsurance">{won(defaultResult.longTermCareInsurance)}</strong></div>
      </div>
    </article>

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">왜 근사치인가</p>
          <h2 class="panel__title">명절 상여금 세금은 어떻게 계산되나?</h2>
        </div>
      </div>
      <p class="hbc-notice">
        상여금의 소득세는 단순히 상여금에 개인의 연봉 구간 세율을 곱해 계산하지 않습니다. 회사는 상여금 지급 대상 기간, 지급월 급여, 부양가족 수와 이미 지급된 급여 등을 반영해 소득세를 원천징수합니다. 이 계산기는 근로소득 간이세액표와 상여 원천징수 방식을 그대로 재현하지 않는 연봉 구간별 근사 세율 기반의 간이 추정입니다.
      </p>
      <div class="table-wrap hbc-table-wrap">
        <table class="hbc-compare-table">
          <thead><tr><th>구분</th><th>월급</th><th>명절 상여금</th></tr></thead>
          <tbody>
            {HBC_PAY_COMPARISON_TABLE.map((row) => (
              <tr><td>{row.category}</td><td>{row.regularPay}</td><td>{row.holidayBonus}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">지급 형태별</p>
          <h2 class="panel__title">현금·상품권·현물 선물, 과세는 다를까?</h2>
        </div>
      </div>
      <div class="table-wrap hbc-table-wrap">
        <table class="hbc-compare-table">
          <thead><tr><th>지급 형태</th><th>일반적인 처리</th></tr></thead>
          <tbody>
            {HBC_GIFT_TYPE_TABLE.map((row) => (
              <tr><td>{row.giftType}</td><td>{row.treatment}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="hbc-table-note">회사가 근로의 대가로 지급하는 현금 명절 상여금과 상품권은 일반적으로 과세 근로소득에 포함됩니다. 현물 선물은 지급 목적과 회사의 복리후생·급여 처리 방식에 따라 세무 처리가 달라질 수 있으므로 급여명세서 또는 회사 담당 부서에서 확인해야 합니다.</p>
    </article>

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">퇴직금·통상임금</p>
          <h2 class="panel__title">정기 명절상여 vs 일시적 격려금</h2>
        </div>
      </div>
      <div class="table-wrap hbc-table-wrap">
        <table class="hbc-compare-table">
          <thead><tr><th>구분</th><th>정기 명절상여</th><th>일시적 격려금</th></tr></thead>
          <tbody>
            {HBC_BONUS_TYPE_TABLE.map((row) => (
              <tr><td>{row.aspect}</td><td>{row.regularBonus}</td><td>{row.oneTimeBonus}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="hbc-table-note">취업규칙이나 근로계약에 따라 정기적·일률적으로 지급되고 근로의 대가로 인정되는 명절 상여금은 평균임금이나 통상임금 판단에 영향을 줄 수 있습니다. 단순히 명칭이 "떡값"이라는 이유만으로 포함 또는 제외되는 것은 아닙니다.</p>
    </article>

    <Fragment slot="seo">
      <SeoContent
        introTitle={HBC_SEO_CONTENT.introTitle}
        intro={HBC_SEO_CONTENT.intro}
        criteria={HBC_SEO_CONTENT.criteria}
        faq={HBC_FAQ}
        related={HBC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="hbc-data" type="application/json" set:html={JSON.stringify(pageData)}></script>
  <script src={withBase("/scripts/holiday-bonus-after-tax-calculator.js")} defer></script>
</BaseLayout>
