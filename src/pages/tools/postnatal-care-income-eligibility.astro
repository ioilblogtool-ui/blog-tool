---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  PNCEI_BIRTH_TYPE_OPTIONS,
  PNCEI_CHILD_ORDER_OPTIONS,
  PNCEI_DEFAULT_INPUT,
  PNCEI_EXCEPTION_REASONS,
  PNCEI_FAQ,
  PNCEI_INSURANCE_OPTIONS,
  PNCEI_REFERENCE_CARDS,
  PNCEI_REGION_OPTIONS,
  PNCEI_RELATED_LINKS,
  PNCEI_SEO,
  PNCEI_THRESHOLDS_2026,
} from "../../data/postnatalCareIncomeEligibility";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const config = {
  PNCEI_DEFAULT_INPUT,
  PNCEI_THRESHOLDS_2026,
  PNCEI_EXCEPTION_REASONS,
};

const faqSchema = PNCEI_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: {
    "@type": "Answer",
    text: item.answer,
  },
}));
---

<BaseLayout
  title={`${PNCEI_SEO.title} | 비교계산소`}
  description={PNCEI_SEO.description}
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "산후도우미 지원금 소득기준 계산기",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description: PNCEI_SEO.description,
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/postnatal-care-income-eligibility/`,
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="postnatal-care-income-eligibility" pageClass="pncei-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="출산·복지지원"
        title="산후도우미 지원금, 소득기준부터 확인하세요"
        description="가구원 수와 건강보험료를 입력하면 2026년 산모·신생아 건강관리 지원사업의 기준중위소득 150% 해당 여부와 예외지원 확인 포인트를 계산합니다."
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetPnceiBtn" copyId="copyPnceiLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">가구 정보</p>
            <h2 class="panel__title">지원 조건 입력</h2>
          </div>
          <p class="panel-heading__summary">가구원 수와 출산 조건은 소득기준 판정의 출발점입니다.</p>
        </div>

        <div class="form-grid">
          <label class="field">
            <span>거주 지역</span>
            <select id="pnceiRegion" class="select">
              {PNCEI_REGION_OPTIONS.map((item) => (
                <option value={item.key} selected={item.key === PNCEI_DEFAULT_INPUT.region}>{item.label}</option>
              ))}
            </select>
            <small>최종 예외지원은 거주지 보건소 기준을 확인합니다.</small>
          </label>

          <label class="field">
            <span>가구원 수</span>
            <select id="pnceiHouseholdSize" class="select">
              {PNCEI_THRESHOLDS_2026.map((item) => (
                <option value={item.householdSize} selected={item.householdSize === PNCEI_DEFAULT_INPUT.householdSize}>
                  {item.householdSize}인
                </option>
              ))}
            </select>
            <small>출생 예정아 포함 여부는 보건소 기준을 확인하세요.</small>
          </label>

          <label class="field">
            <span>태아 유형</span>
            <select id="pnceiBirthType" class="select">
              {PNCEI_BIRTH_TYPE_OPTIONS.map((item) => (
                <option value={item.key} selected={item.key === PNCEI_DEFAULT_INPUT.birthType}>{item.label}</option>
              ))}
            </select>
          </label>

          <label class="field">
            <span>출산 순위</span>
            <select id="pnceiChildOrder" class="select">
              {PNCEI_CHILD_ORDER_OPTIONS.map((item) => (
                <option value={item.key} selected={item.key === PNCEI_DEFAULT_INPUT.childOrder}>{item.label}</option>
              ))}
            </select>
          </label>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">소득 판정</p>
            <h2 class="panel__title">건강보험료 입력</h2>
          </div>
          <p class="panel-heading__summary">2026년 기준표는 노인장기요양보험료 미포함 건강보험료 본인부담금 기준입니다.</p>
        </div>

        <div class="pncei-mode-tabs" role="group" aria-label="판정 방식">
          <label>
            <input type="radio" name="pnceiJudgeMode" value="premium" checked={PNCEI_DEFAULT_INPUT.judgeMode === "premium"} />
            <span>건강보험료 기준</span>
          </label>
          <label>
            <input type="radio" name="pnceiJudgeMode" value="income" checked={PNCEI_DEFAULT_INPUT.judgeMode === "income"} />
            <span>월소득 보조 판정</span>
          </label>
        </div>

        <div class="form-grid">
          <label class="field">
            <span>가입 유형</span>
            <select id="pnceiInsuranceType" class="select">
              {PNCEI_INSURANCE_OPTIONS.map((item) => (
                <option value={item.key} selected={item.key === PNCEI_DEFAULT_INPUT.insuranceType}>{item.label}</option>
              ))}
            </select>
          </label>

          <label class="field">
            <span>산모 건강보험료 (원)</span>
            <input id="pnceiMotherPremium" type="text" inputmode="numeric" class="input-number" value={PNCEI_DEFAULT_INPUT.motherPremium.toLocaleString("ko-KR")} />
          </label>

          <label class="field">
            <span>배우자 건강보험료 (원)</span>
            <input id="pnceiSpousePremium" type="text" inputmode="numeric" class="input-number" value={PNCEI_DEFAULT_INPUT.spousePremium.toLocaleString("ko-KR")} />
            <small>맞벌이이면 낮은 쪽 보험료의 50%만 합산합니다.</small>
          </label>

          <label class="field">
            <span>월소득 (원)</span>
            <input id="pnceiMonthlyIncome" type="text" inputmode="numeric" class="input-number" value={PNCEI_DEFAULT_INPUT.monthlyIncome.toLocaleString("ko-KR")} />
            <small>건강보험료를 모를 때 참고용으로만 사용합니다.</small>
          </label>

          <label class="field pncei-toggle-field">
            <span>맞벌이 합산 규칙</span>
            <select id="pnceiDualIncome" class="select">
              <option value="yes" selected={PNCEI_DEFAULT_INPUT.dualIncome}>적용</option>
              <option value="no">미적용</option>
            </select>
          </label>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">예외지원</p>
            <h2 class="panel__title">해당 사항 체크</h2>
          </div>
          <p class="panel-heading__summary">150% 초과라도 확인할 이유가 있는 조건입니다.</p>
        </div>
        <div class="pncei-check-grid">
          {PNCEI_EXCEPTION_REASONS.map((item) => (
            <label class="pncei-check">
              <input type="checkbox" name="pnceiExceptions" value={item.key} />
              <span>
                <strong>{item.label}</strong>
                <small>{item.description}</small>
              </span>
            </label>
          ))}
        </div>
      </article>
    </Fragment>

    <section class="pncei-section">
      <div class="pncei-section__head">
        <p class="pncei-section__eyebrow">계산 결과</p>
        <h2>지원 대상 가능성을 먼저 판정합니다</h2>
        <p id="pnceiResultSubcopy" class="pncei-section__sub">조건을 바꾸면 결과가 바로 업데이트됩니다.</p>
      </div>

      <div class="pncei-result-grid">
        <article class="pncei-result-card pncei-result-card--status" id="pnceiStatusCard">
          <p>지원 가능성</p>
          <strong id="pnceiStatusLabel">-</strong>
          <span id="pnceiStatusNote">추정 결과</span>
        </article>
        <article class="pncei-result-card">
          <p>150% 기준 보험료</p>
          <strong id="pnceiPremiumLimit">-</strong>
          <span id="pnceiPremiumLimitNote">가입 유형 기준</span>
        </article>
        <article class="pncei-result-card">
          <p>입력 보험료 합계</p>
          <strong id="pnceiPremiumTotal">-</strong>
          <span id="pnceiPremiumTotalNote">맞벌이 규칙 반영</span>
        </article>
        <article class="pncei-result-card pncei-result-card--gap">
          <p>기준 대비 차이</p>
          <strong id="pnceiDifference">-</strong>
          <span id="pnceiDifferenceNote">낮으면 여유, 높으면 초과</span>
        </article>
      </div>

      <article class="panel pncei-status-panel">
        <div class="pncei-status-row">
          <span id="pnceiSourceBadge" class="pncei-badge pncei-badge--official">공식</span>
          <p id="pnceiSourceText">2026년 건강보험료 본인부담금 기준표를 사용합니다.</p>
        </div>
        <p id="pnceiInterpretation" class="pncei-interpretation">-</p>
        <div id="pnceiWarningList" class="pncei-warning-list"></div>
      </article>
    </section>

    <section class="pncei-section">
      <div class="pncei-section__head">
        <p class="pncei-section__eyebrow">다음 단계</p>
        <h2>소득 구간을 확인했다면 본인부담금을 계산하세요</h2>
      </div>
      <div class="pncei-next-grid">
        <a id="pnceiCostCta" class="pncei-next-card pncei-next-card--primary" href={withBase("/tools/postnatal-care-cost/")}>
          <span>1단계</span>
          <strong>산후도우미 본인부담금 계산하기</strong>
          <p>추천 소득 구간을 반영해 정부지원금과 예상 부담금을 이어서 봅니다.</p>
        </a>
        <a class="pncei-next-card" href={withBase("/tools/birth-support-money/")}>
          <span>2단계</span>
          <strong>지역별 출산지원금 확인하기</strong>
          <p>산후도우미 외에 받을 수 있는 출산지원금을 함께 점검합니다.</p>
        </a>
      </div>
    </section>

    <section class="pncei-section">
      <div class="pncei-section__head">
        <p class="pncei-section__eyebrow">예외지원 확인</p>
        <h2>150% 초과여도 확인할 조건이 있습니다</h2>
      </div>
      <div id="pnceiExceptionMessages" class="pncei-exception-grid">
        <article class="pncei-exception-card">
          <strong>체크한 예외지원 사유가 없습니다</strong>
          <p>둘째 이상, 다태아, 미숙아, 장애 산모·신생아 등은 거주지 보건소 기준을 확인하세요.</p>
        </article>
      </div>
    </section>

    <section class="pncei-section">
      <div class="pncei-section__head">
        <p class="pncei-section__eyebrow">기준표</p>
        <h2>2026년 기준중위소득 150% 건강보험료 기준</h2>
        <p class="pncei-section__sub">노인장기요양보험료 미포함 금액입니다.</p>
      </div>
      <article class="panel">
        <div class="table-wrap">
          <table class="result-table">
            <thead>
              <tr>
                <th>가구원 수</th>
                <th>소득기준</th>
                <th>직장</th>
                <th>지역</th>
                <th>혼합</th>
              </tr>
            </thead>
            <tbody>
              {PNCEI_THRESHOLDS_2026.map((item) => (
                <tr>
                  <td>{item.householdSize}인</td>
                  <td>{item.medianIncome150.toLocaleString("ko-KR")}원</td>
                  <td>{item.employeePremiumLimit.toLocaleString("ko-KR")}원</td>
                  <td>{item.localPremiumLimit.toLocaleString("ko-KR")}원</td>
                  <td>{item.mixedPremiumLimit ? `${item.mixedPremiumLimit.toLocaleString("ko-KR")}원` : "-"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>
    </section>

    <section class="pncei-section">
      <div class="pncei-guide-grid">
        <article class="pncei-guide-card">
          <span>소득 구간</span>
          <strong>가형 · 통합형 · 라형</strong>
          <p>자격확인 가구는 가형, 기준중위소득 150% 이하는 통합형, 150% 초과는 라형으로 구분됩니다.</p>
        </article>
        <article class="pncei-guide-card">
          <span>맞벌이</span>
          <strong>낮은 보험료 50% 합산</strong>
          <p>공개 기준상 맞벌이 부부는 낮은 배우자의 건강보험료를 절반만 합산합니다.</p>
        </article>
        <article class="pncei-guide-card">
          <span>신청 기간</span>
          <strong>출산 예정일 40일 전부터</strong>
          <p>출산 후 60일 이내 신청 안내가 일반적이며, 특수한 경우 퇴원일 기준이 적용될 수 있습니다.</p>
        </article>
      </div>
    </section>

    <section class="content-section pncei-reference-section">
      <div class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">공식 자료</p>
            <h2 class="panel__title">최종 신청 전 확인할 링크</h2>
          </div>
          <p class="panel-heading__summary">계산기는 참고용입니다. 신청 전에는 거주지 기준을 다시 확인하세요.</p>
        </div>
        <div class="pncei-reference-grid">
          {PNCEI_REFERENCE_CARDS.map((item) => (
            <a class="pncei-reference-card" href={item.href} target="_blank" rel="noopener noreferrer">
              <span>{item.source}</span>
              <strong>{item.title}</strong>
              <p>{item.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <InfoNotice
      title="계산 전 주의사항"
      lines={[
        "이 계산기는 2026년 공개 건강보험료 기준표를 바탕으로 한 참고 판정입니다.",
        "기준표는 노인장기요양보험료 미포함 건강보험료 본인부담금 기준입니다.",
        "실제 지원 가능 여부와 정부지원금은 거주지 보건소, 복지로, 사회서비스 전자바우처 신청 과정에서 최종 확인해야 합니다.",
      ]}
    />

    <Fragment slot="seo">
      <SeoContent
        introTitle="산후도우미 지원금 소득기준을 먼저 확인해야 하는 이유"
        intro={[
          "산후도우미 정부지원은 총 서비스 가격보다 먼저 소득 구간을 확인해야 실제 부담금을 가늠할 수 있습니다. 같은 단태아 첫째아 표준형을 이용하더라도 자격확인, 기준중위소득 150% 이하, 150% 초과 여부에 따라 정부지원금과 본인부담금이 크게 달라지기 때문에, 신청 전에 내 소득 구간을 먼저 파악해두는 것이 좋습니다.",
          "산모·신생아 건강관리 지원사업의 소득기준은 보통 건강보험료 본인부담금 기준표로 판단합니다. 월급이나 연봉만으로 단순하게 판단하기 어렵고, 직장가입자, 지역가입자, 혼합 세대에 따라 기준 보험료가 달라지기 때문에 가입 유형을 먼저 확인하는 절차가 필요합니다. 건강보험료 고지서를 미리 확인해두면 더 정확합니다.",
          "맞벌이 부부는 건강보험료 합산 방식도 중요합니다. 공개 안내 기준으로는 보험료가 낮은 배우자의 보험료를 50%만 합산하는 규칙이 있어, 단순 합산보다 결과가 달라질 수 있습니다. 다만 세대 구성과 가입 유형에 따라 예외가 있을 수 있으므로 최종 확인은 반드시 필요합니다.",
          "기준중위소득 150%를 초과한다고 해서 확인이 끝나는 것은 아닙니다. 둘째 이상 출산, 다태아, 미숙아, 희귀난치성질환 산모, 장애 산모·신생아, 결혼이민 산모, 미혼모 등은 지자체와 보건소 기준에 따라 예외지원 여부를 별도로 확인할 필요가 있으므로, 해당하는 경우라면 보건소에 직접 문의하는 것을 권장합니다."
        ]}
        inputPoints={[
          "가구원 수와 직장·지역·혼합 가입 유형을 선택하면 2026년 150% 기준 보험료를 보여줍니다.",
          "산모와 배우자 건강보험료를 입력하면 맞벌이 합산 규칙을 반영한 입력 보험료 합계가 계산됩니다.",
          "건강보험료를 모를 때는 월소득 보조 판정으로 대략적인 위치를 확인할 수 있습니다."
        ]}
        criteria={[
          "기준표의 건강보험료는 노인장기요양보험료 미포함 금액입니다.",
          "결과는 지원 확정이 아니라 소득기준 위치를 보여주는 참고 판정입니다.",
          "지원 가능성 확인 후에는 산후도우미 비용 계산기에서 실제 예상 본인부담금을 이어서 계산하는 흐름을 권장합니다."
        ]}
        faq={PNCEI_FAQ}
        related={PNCEI_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

