---
import { tools } from "../../data/tools";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import TrustPanel from "../../components/TrustPanel.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const orderedTools = [...tools].sort((a, b) => a.order - b.order);

const topicBySlug: Record<string, string> = {
  salary: "연봉·이직",
  retirement: "연봉·이직",
  negotiation: "연봉·이직",
  "household-income": "연봉·이직",
  "parental-leave": "육아휴직·출산",
  "bonus-simulator": "성과급 비교",
  "samsung-bonus": "성과급 비교",
  "sk-hynix-bonus": "성과급 비교",
  "hyundai-bonus": "성과급 비교",
  "birth-support-total": "육아휴직·출산",
  "single-parental-leave-total": "육아휴직·출산",
  "parental-leave-pay": "육아휴직·출산",
  "six-plus-six": "육아휴직·출산"
};

const topicOrder = ["전체", "연봉·이직", "성과급 비교", "육아휴직·출산"];
const categories = topicOrder.filter(
  (category) => category === "전체" || orderedTools.some((tool) => topicBySlug[tool.slug] === category)
);

const toolHighlights: Record<string, string> = {
  salary: "연봉 인상률별 월 실수령 차이와 연 총보상 흐름을 비교합니다.",
  retirement: "평균임금 기준 예상 퇴직금과 세후 추정액을 빠르게 확인합니다.",
  negotiation: "현재 연봉과 제안 연봉 차이를 세전 기준으로 한 번에 비교합니다.",
  "household-income": "가구 연 총소득, 월 체감, 평균·중위 대비 위치를 한 번에 계산합니다.",
  "parental-leave": "휴직 중 버틸 수 있는 현금흐름과 복직 후 변화를 같이 봅니다.",
  "bonus-simulator": "삼성전자, SK하이닉스, 현대차의 보상 시나리오를 나란히 정리합니다.",
  "samsung-bonus": "개인·부부 모드로 삼성전자 OPI, TAI, 월 체감 총보상을 바로 계산합니다.",
  "sk-hynix-bonus": "개인·부부 모드로 하이닉스 PS, PI, 월 체감 총보상을 바로 계산합니다.",
  "hyundai-bonus": "개인·부부 모드로 현대차 성과금 패키지와 월 체감 총보상을 바로 계산합니다.",
  "birth-support-total": "출산 직후부터 두 돌까지 받을 수 있는 지원금 총액을 계산합니다.",
  "single-parental-leave-total": "한 명만 육아휴직할 때 가구 총수령액을 합산해서 보여줍니다.",
  "parental-leave-pay": "일반 육아휴직 급여 기준으로 월별 급여와 총액을 정리합니다.",
  "six-plus-six": "6+6 특례와 일반 육아휴직 차이를 금액 기준으로 비교합니다."
};

const toolLibraryScript = `
  (() => {
    const searchInput = document.getElementById("toolSearchInput");
    const emptyState = document.getElementById("toolLibraryEmpty");
    const countNode = document.getElementById("toolLibraryCount");
    const cards = Array.from(document.querySelectorAll("[data-tool-card]"));
    const filters = Array.from(document.querySelectorAll("[data-filter]"));

    if (!searchInput || cards.length === 0) return;

    let activeFilter = "all";

    const render = () => {
      const query = String(searchInput.value || "").trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const category = card.getAttribute("data-category") || "";
        const text = String(card.textContent || "").toLowerCase();
        const slug = String(card.getAttribute("href") || "").toLowerCase();
        const matchesFilter = activeFilter === "all" || category === activeFilter;
        const matchesQuery = query.length === 0 || text.includes(query) || slug.includes(query);
        const visible = matchesFilter && matchesQuery;

        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (emptyState) emptyState.hidden = visibleCount > 0;
      if (countNode) countNode.textContent = visibleCount + "개 결과";
    };

    filters.forEach((button) => {
      button.addEventListener("click", () => {
        activeFilter = button.getAttribute("data-filter") || "all";
        filters.forEach((item) => item.classList.toggle("is-active", item === button));
        render();
      });
    });

    searchInput.addEventListener("input", render);
    searchInput.addEventListener("keyup", render);
    searchInput.addEventListener("search", render);
    searchInput.addEventListener("compositionend", render);
    render();
  })();
`;
---

<BaseLayout title="비교계산소 도구 목록" description="생활과 실무에서 자주 마주치는 숫자를 빠르게 계산하고 비교해볼 수 있는 도구 목록">
  <SiteHeader />

  <main class="container page-shell tool-library-page">
    <CalculatorHero
      eyebrow="도구 목록"
      title="필요한 계산기를 빠르게 찾고 바로 입력하세요"
      description="연봉, 성과급, 육아휴직, 출산 지원금처럼 자주 비교하는 계산기를 주제별로 묶어 모바일에서도 빠르게 찾을 수 있게 정리했습니다."
    />

    <section class="library-toolbar panel content-section content-section--tight">
      <div class="section-header">
        <p class="section-header__eyebrow">도구 찾기</p>
        <h2>주제와 키워드로 바로 찾기</h2>
        <p>찾고 싶은 계산기를 검색하거나, 지금 필요한 주제부터 눌러서 빠르게 이동해보세요.</p>
      </div>
      <div class="library-toolbar__search field">
        <span>검색</span>
        <input id="toolSearchInput" type="search" placeholder="예: 연봉, 육아휴직, 성과급" autocomplete="off" />
      </div>
      <div class="library-toolbar__filters">
        {
          categories.map((category, index) => (
            <button class={`tool-filter${index === 0 ? " is-active" : ""}`} type="button" data-filter={category === "전체" ? "all" : category}>{category}</button>
          ))
        }
      </div>
      <p class="library-count" id="toolLibraryCount" aria-live="polite">{orderedTools.length}개 결과</p>
    </section>

    <section class="content-section">
      <div class="section-header">
        <p class="section-header__eyebrow">전체 계산기</p>
        <h2>무엇을 바로 확인할 수 있는지 먼저 보이게</h2>
        <p>각 카드에서 이 페이지로 들어가면 어떤 결과를 바로 볼 수 있는지 한 줄씩 먼저 보여줍니다.</p>
      </div>
      <div class="tool-showcase tool-showcase--grid" id="toolLibraryGrid">
        {
          orderedTools.map((tool) => {
            const topic = topicBySlug[tool.slug] ?? "기타";
            return (
              <a
                class="tool-card tool-card--feature"
                href={withBase(`/tools/${tool.slug}/`)}
                data-tool-card
                data-category={topic}
              >
                <div class="tool-card__head">
                  <p class="tool-card__eyebrow">{topic}</p>
                  {
                    tool.badges && tool.badges.length > 0 && (
                      <div class="tool-badges">
                        {tool.badges.map((badge) => <span class="tool-badge">{badge}</span>)}
                      </div>
                    )
                  }
                </div>
                <h2>{tool.title}</h2>
                <p>{tool.description}</p>
                <span class="tool-card__meta">{toolHighlights[tool.slug] ?? "입력 후 결과를 바로 확인할 수 있게 구성했습니다."}</span>
              </a>
            );
          })
        }
      </div>
    </section>

    <TrustPanel
      eyebrow="신뢰 정보"
      title="검색 유입 사용자도 바로 확인할 수 있는 운영 안내"
      description="계산기만 모아둔 사이트가 아니라는 점이 한 번에 보이도록, 소개·문의·면책 정보를 도구 목록 하단에도 함께 배치했습니다."
    />

    <p class="library-empty" id="toolLibraryEmpty" hidden>검색 결과가 없습니다. 다른 키워드나 주제를 선택해보세요.</p>
  </main>

  <script is:inline set:html={toolLibraryScript}></script>
</BaseLayout>
