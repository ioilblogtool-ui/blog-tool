const toolLibraryScript = `
  (() => {
    const searchInput = document.getElementById("toolSearchInput");
    const emptyState = document.getElementById("toolLibraryEmpty");
    const countNode = document.getElementById("toolLibraryCount");
    const cards = Array.from(document.querySelectorAll("[data-tool-card]"));
    const filters = Array.from(document.querySelectorAll("[data-filter]"));

    if (!searchInput || cards.length === 0) return;

    let activeFilter = "all";

    const render = () => {
      const query = String(searchInput.value || "").trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const category = card.getAttribute("data-category") || "";
        const text = String(card.textContent || "").toLowerCase();
        const slug = String(card.getAttribute("href") || "").toLowerCase();
        const matchesFilter = activeFilter === "all" || category === activeFilter;
        const matchesQuery = query.length === 0 || text.includes(query) || slug.includes(query);
        const visible = matchesFilter && matchesQuery;

        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (emptyState) emptyState.hidden = visibleCount > 0;
      if (countNode) countNode.textContent = visibleCount + "개 결과";
    };

    filters.forEach((button) => {
      button.addEventListener("click", () => {
        activeFilter = button.getAttribute("data-filter") || "all";
        filters.forEach((item) => item.classList.toggle("is-active", item === button));
        render();
      });
    });

    searchInput.addEventListener("input", render);
    searchInput.addEventListener("keyup", render);
    searchInput.addEventListener("search", render);
    searchInput.addEventListener("compositionend", render);
    render();
  })();
`;
---

<BaseLayout
  title="비교계산소 도구 모음"
  description="연봉, 육아휴직, 출산, 투자, 부동산까지 자주 비교하는 계산기를 주제별로 묶어 빠르게 찾을 수 있게 정리했습니다."
>
  <SiteHeader />

  <main class="container page-shell tool-library-page">
    <section class="tl-hero">
      <p class="tl-hero__eyebrow">도구 목록</p>
      <h1 class="tl-hero__title">필요한 계산기부터<br />바로 찾아 시작하세요</h1>
      <p class="tl-hero__desc">연봉, 성과급, 출산, 육아, 투자, 집 마련까지 자주 비교하는 계산기를 주제별로 모아두었습니다.</p>
    </section>

    <section class="tl-guide">
      <div class="tl-guide__lead">
        <p class="tl-guide__eyebrow">시작 가이드</p>
        <h2 class="tl-guide__title">어떤 계산기부터 봐야 할지 모르겠다면</h2>
        <div class="tl-guide__copy">
          <p>비교계산소의 계산기는 숫자만 보여주는 도구가 아니라, 실제 선택 전에 빠르게 판단 기준을 잡기 위한 실전형 도구입니다. 연봉, 육아휴직, 출산비용, 부동산, 투자처럼 자주 비교하는 주제를 한 곳에 모아 두었습니다.</p>
          <p>처음 방문했다면 모든 계산기를 하나씩 볼 필요는 없습니다. 지금 내 상황과 가장 가까운 주제부터 시작하면 필요한 계산기 2~3개만으로도 충분히 방향을 잡을 수 있습니다.</p>
        </div>
        <div class="tl-guide__signals">
          <div class="tl-guide-signal">
            <span class="tl-guide-signal__label">추천 방식</span>
            <strong class="tl-guide-signal__value">지금 고민 1개부터</strong>
            <p class="tl-guide-signal__desc">모든 계산기를 훑기보다 현재 가장 급한 결정에 가까운 주제부터 시작하는 편이 훨씬 빠릅니다.</p>
          </div>
          <div class="tl-guide-signal">
            <span class="tl-guide-signal__label">권장 흐름</span>
            <strong class="tl-guide-signal__value">계산기 2~3개 조합</strong>
            <p class="tl-guide-signal__desc">한 페이지 결과만 보지 말고 관련 계산기를 이어서 보면 판단 기준이 더 선명해집니다.</p>
          </div>
        </div>
      </div>

      <div class="tl-guide-grid">
        {starterGuides.map((guide) => (
          <article class="tl-guide-card">
            <strong>{guide.title}</strong>
            <p>{guide.desc}</p>
            <div class="tl-guide-card__links">
              {guide.links.map((link) => (
                <a href={withBase(link.href)}>{link.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="tl-toolbar">
      <div class="tl-toolbar__search">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="4.5" stroke="#B4B2A9" stroke-width="1.2"></circle>
          <line x1="9.5" y1="9.5" x2="12.5" y2="12.5" stroke="#B4B2A9" stroke-width="1.2" stroke-linecap="round"></line>
        </svg>
        <input id="toolSearchInput" type="search" placeholder="예: 연봉, 육아휴직, 국민연금" autocomplete="off" />
      </div>
      <div class="tl-toolbar__filters">
        {categories.map((category, index) => (
          <button
            class={`tl-filter${index === 0 ? " is-active" : ""}`}
            type="button"
            data-filter={category === "전체" ? "all" : category}
          >
            {category}
          </button>
        ))}
      </div>
      <p class="tl-toolbar__count" id="toolLibraryCount" aria-live="polite">{orderedTools.length}개 결과</p>
    </section>

    <section class="tl-section">
      <div class="tl-section__head tl-section__head--stack">
        <div>
          <p class="tl-section__eyebrow">카테고리 안내</p>
          <h2>주제별로 보면 더 빨리 찾을 수 있습니다</h2>
        </div>
        <p class="tl-section__summary">같은 숫자라도 목적에 따라 먼저 봐야 하는 계산기가 다릅니다. 아래 설명을 보고 지금 필요한 주제부터 시작해 보세요.</p>
      </div>

      <div class="tl-category-grid">
        {categoryGuides.map((category) => (
          <article class="tl-category-card">
            <strong>{category.name}</strong>
            <p>{category.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="tl-section">
      <div class="tl-section__head">
        <h2>전체 계산기 <span class="tl-section__count">{orderedTools.length}개</span></h2>
      </div>

      <div class="tl-cards" id="toolLibraryGrid">
        {orderedTools.map((tool) => {
          const topic = topicBySlug[tool.slug] ?? "기타";
          return (
            <a class="tl-card" href={withBase(`/tools/${tool.slug}/`)} data-tool-card data-category={topic}>
              <div class="tl-card__head">
                <span class="tl-card__cat">{topic}</span>
                {tool.badges && tool.badges.length > 0 && (
                  <div class="tl-card__badges">
                    {tool.badges.map((badge) => (
                      <span class="tl-badge" data-badge={badge}>{badge}</span>
                    ))}
                  </div>
                )}
              </div>

              <p class="tl-card__title">{tool.title}</p>

              {tool.previewStats && tool.previewStats.length > 0 && (
                <div class="tl-card__stats">
                  {tool.previewStats.map((stat) => (
                    <div class="tl-stat">
                      <span class="tl-stat__label">{stat.label}</span>
                      <strong class="tl-stat__value">{stat.value}</strong>
                      {stat.context && <span class="tl-stat__ctx">{stat.context}</span>}
                    </div>
                  ))}
                </div>
              )}

              <p class="tl-card__desc">{tool.description}</p>
              <p class="tl-card__meta">
                {toolHighlights[tool.slug] ?? "입력값과 결과를 빠르게 확인할 수 있게 구성했습니다."}
              </p>
            </a>
          );
        })}
      </div>

      <p class="tl-empty" id="toolLibraryEmpty" hidden>
        검색 결과가 없습니다. 다른 키워드나 주제를 선택해 보세요.
      </p>
    </section>

    <section class="tl-section">
      <div class="tl-section__head">
        <h2>관련 리포트</h2>
      </div>

      <div class="tl-reports">
        {orderedReports.map((report) => (
          <a class="tl-report-card" href={withBase(`/reports/${report.slug}/`)}>
            <div class="tl-report-card__head">
              <span class="tl-report-badge">인터랙티브 리포트</span>
              {report.badges && (
                <div class="tl-card__badges">
                  {report.badges.map((badge) => (
                    <span class="tl-badge" data-badge={badge}>{badge}</span>
                  ))}
                </div>
              )}
            </div>
            <p class="tl-report-card__title">{report.title}</p>
            <p class="tl-report-card__desc">{report.description}</p>
            <p class="tl-report-card__meta">비교 기준과 배경 설명이 필요한 주제는 리포트로 먼저 읽어보면 더 이해가 쉽습니다.</p>
          </a>
        ))}
      </div>
    </section>

    <section class="tl-section">
      <div class="tl-section__head tl-section__head--stack">
        <div>
          <p class="tl-section__eyebrow">활용 팁</p>
          <h2>계산기 결과는 이렇게 활용하면 좋습니다</h2>
        </div>
        <p class="tl-section__summary">계산값 하나만 보는 것보다, 여러 시나리오를 비교하고 관련 리포트까지 이어서 읽는 편이 훨씬 실전적입니다.</p>
      </div>

      <div class="tl-principles">
        {usagePrinciples.map((item) => (
          <article class="tl-principle-card">
            <p>{item}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="tl-section">
      <div class="tl-section__head">
        <h2>운영 기준 보기</h2>
      </div>
      <div class="tl-trust">
        {trustLinks.map((link) => (
          <a class="tl-trust-card" href={link.href}>
            <p class="tl-trust-card__title">{link.title}</p>
            <p class="tl-trust-card__desc">{link.desc}</p>
          </a>
        ))}
      </div>
      <p class="tl-notice">
        계산 결과는 공개 기준과 입력값을 바탕으로 한 참고용 정보입니다. 중요한 신청, 계약, 구매 전에는 반드시 공식 기준과 최신 조건을 다시 확인해 주세요.
      </p>
    </section>
  </main>

  <script is:inline set:html={toolLibraryScript}></script>
</BaseLayout>
