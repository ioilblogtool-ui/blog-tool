---
import { tools } from "../../data/tools";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const orderedTools = [...tools].sort((a, b) => a.order - b.order);
const categories = Array.from(new Set(orderedTools.map((tool) => tool.category ?? "tool")));
const toolLibraryScript = `
  (() => {
    const searchInput = document.getElementById("toolSearchInput");
    const emptyState = document.getElementById("toolLibraryEmpty");
    const countNode = document.getElementById("toolLibraryCount");
    const cards = Array.from(document.querySelectorAll("[data-tool-card]"));
    const filters = Array.from(document.querySelectorAll("[data-filter]"));

    if (!searchInput || cards.length === 0) return;

    let activeFilter = "all";

    const render = () => {
      const query = String(searchInput.value || "").trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const category = card.getAttribute("data-category") || "";
        const text = String(card.textContent || "").toLowerCase();
        const slug = String(card.getAttribute("href") || "").toLowerCase();
        const matchesFilter = activeFilter === "all" || category === activeFilter;
        const matchesQuery = query.length === 0 || text.includes(query) || slug.includes(query);
        const visible = matchesFilter && matchesQuery;

        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }

      if (countNode) {
        countNode.textContent = visibleCount + "개 결과";
      }
    };

    filters.forEach((button) => {
      button.addEventListener("click", () => {
        activeFilter = button.getAttribute("data-filter") || "all";
        filters.forEach((item) => item.classList.toggle("is-active", item === button));
        render();
      });
    });

    searchInput.addEventListener("input", render);
    searchInput.addEventListener("keyup", render);
    searchInput.addEventListener("search", render);
    searchInput.addEventListener("compositionend", render);
    render();
  })();
`;
---

<BaseLayout title="ioil's Blog Tool" description="카드형 검색과 필터로 탐색하는 도구 목록">
  <SiteHeader />

  <main class="container page-shell tool-library-page">
    <CalculatorHero
      eyebrow="Tool Library"
      title="도구 목록"
      description="카드형 목록에서 검색과 필터로 원하는 계산기와 시뮬레이터를 빠르게 찾을 수 있습니다."
    />

    <section class="library-toolbar panel">
      <div class="library-toolbar__search field">
        <span>검색</span>
        <input id="toolSearchInput" type="search" placeholder="도구 이름 또는 설명 검색" autocomplete="off" />
      </div>
      <div class="library-toolbar__filters">
        <button class="tool-filter is-active" type="button" data-filter="all">전체</button>
        {
          categories.map((category) => (
            <button class="tool-filter" type="button" data-filter={category}>{category}</button>
          ))
        }
      </div>
      <p class="library-count" id="toolLibraryCount">{orderedTools.length}개 결과</p>
    </section>

    <section class="tool-showcase tool-showcase--grid" id="toolLibraryGrid">
      {
        orderedTools.map((tool) => (
          <a
            class="tool-card tool-card--feature"
            href={withBase(`/tools/${tool.slug}/`)}
            data-tool-card
            data-category={tool.category ?? "tool"}
          >
            <div class="tool-card__head">
              <p class="tool-card__eyebrow">{tool.category ?? "tool"}</p>
              {
                tool.badges && tool.badges.length > 0 && (
                  <div class="tool-badges">
                    {tool.badges.map((badge) => <span class="tool-badge">{badge}</span>)}
                  </div>
                )
              }
            </div>
            <h2>{tool.title}</h2>
            <p>{tool.description}</p>
            <span class="tool-card__meta">/{tool.slug}/</span>
          </a>
        ))
      }
    </section>

    <p class="library-empty" id="toolLibraryEmpty" hidden>검색 결과가 없습니다. 다른 키워드나 필터를 선택해보세요.</p>
  </main>

  <script is:inline set:html={toolLibraryScript}></script>
</BaseLayout>

