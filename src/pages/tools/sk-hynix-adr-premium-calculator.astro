---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  ADR_SPEC,
  defaultInputs,
  infoCards,
  presetScenarios,
  faq,
  relatedLinks,
  toolMeta,
} from "../../data/skHynixAdrPremium";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const config = {
  ADR_SPEC,
  DEFAULT_INPUT: defaultInputs,
  PRESETS: presetScenarios,
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: toolMeta.title,
      description: toolMeta.description,
      inLanguage: "ko-KR",
      dateModified: toolMeta.updatedAt,
      mainEntityOfPage: `https://bigyocalc.com/tools/${toolMeta.slug}/`,
      publisher: {
        "@type": "Organization",
        name: "비교계산소",
        url: "https://bigyocalc.com",
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: faq.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout
  title={toolMeta.title}
  description={toolMeta.description}
  ogImage="/og/tools/sk-hynix-adr-premium-calculator.png"
  jsonLd={jsonLd}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="sk-hynix-adr-premium" pageClass="skadr-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow={toolMeta.eyebrow}
        title={toolMeta.h1}
        description="국내 주가, 원/달러 환율, 나스닥 SKHY 주가를 입력하면 김치프리미엄(할증·할인) %를 바로 계산합니다. ADS 10주=보통주 1주 비율은 자동 반영됩니다."
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="skadrResetBtn" copyId="skadrCopyLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <div class="stack" id="skadr-inputs">
        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">입력</p>
              <h2 class="panel__title">국내 주가·환율·SKHY 주가</h2>
            </div>
            <p class="panel-heading__summary">
              실시간 시세는 자동 연동되지 않습니다. 증권사 앱·네이버페이증권 등에서 확인한 값을 직접 입력하세요.
            </p>
          </div>
          <div class="form-grid">
            <label class="field">
              <span>국내 주가(원)</span>
              <input id="skadrKrxPrice" type="number" inputmode="numeric" value={defaultInputs.krxPrice} />
            </label>
            <label class="field">
              <span>원/달러 환율</span>
              <input id="skadrFxRate" type="number" inputmode="decimal" value={defaultInputs.fxRate} step="0.1" />
            </label>
            <label class="field">
              <span>나스닥 SKHY 주가(달러)</span>
              <input id="skadrAdsPrice" type="number" inputmode="decimal" value={defaultInputs.adsPrice} step="0.01" />
            </label>
          </div>
          <p class="skadr-hint">
            ADR 비율(ADS 10주 = 보통주 1주)은 자동 반영됩니다. 공모가는 ADS 1주당 {ADR_SPEC.ipoPricePerAds}달러였습니다.
          </p>

          <div class="skadr-preset-divider">
            <span>빠른 예시로 체험하기</span>
          </div>
          <div class="skadr-preset-row">
            {presetScenarios.map((preset) => (
              <button type="button" class="skadr-preset-chip" data-preset={preset.id}>
                <span class="skadr-preset-chip__icon" aria-hidden="true"></span>
                {preset.label}
              </button>
            ))}
          </div>
        </article>
      </div>
    </Fragment>

    <article class="panel result-priority-panel skadr-result-panel" id="skadr-results" aria-live="polite">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">계산 결과</p>
          <h2 class="panel__title">국내 주가 대비 SKHY 프리미엄</h2>
        </div>
      </div>

      <div class="skadr-hero-result" id="skadrHeroResult" data-direction="neutral">
        <span class="skadr-direction-badge" id="skadrDirectionBadge">입력 대기</span>
        <strong class="skadr-hero-percent" id="skadrPremiumPercent">-</strong>
        <p class="skadr-hero-sentence" id="skadrDirectionLabel">값을 입력하면 계산됩니다</p>
      </div>

      <div class="skadr-compare-chart-wrap">
        <canvas id="skadr-compare-chart"></canvas>
      </div>

      <div class="skadr-stat-grid">
        <article class="skadr-stat-card skadr-stat-card--value" data-result="impliedShareValueKrw">
          <p class="skadr-stat-label">SKHY 보통주 환산가치</p>
          <strong id="skadrImpliedValue" class="skadr-stat-value">-</strong>
          <span class="skadr-stat-desc">ADS 주가 × 10 × 환율</span>
        </article>
        <article class="skadr-stat-card skadr-stat-card--diff" data-result="premiumAmount">
          <p class="skadr-stat-label">차액</p>
          <strong id="skadrPremiumAmount" class="skadr-stat-value">-</strong>
          <span class="skadr-stat-desc">환산가치 − 국내 주가</span>
        </article>
        <article class="skadr-stat-card skadr-stat-card--fx" data-result="fxApplied">
          <p class="skadr-stat-label">적용 환율</p>
          <strong id="skadrFxApplied" class="skadr-stat-value">-</strong>
          <span class="skadr-stat-desc">원/달러 매매기준율 기준</span>
        </article>
        <article class="skadr-stat-card skadr-stat-card--spread" id="skadrNetSpreadCard" data-result="netSpread">
          <p class="skadr-stat-label">재정거래 참고 순스프레드</p>
          <strong id="skadrNetSpread" class="skadr-stat-value">-</strong>
          <span class="skadr-stat-desc">왕복 환전비용 약 1.5%p 반영 추정치</span>
        </article>
      </div>
    </article>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">개념 정리</p>
        <h2>ADR·프리미엄·재정거래, 헷갈리는 용어 3가지</h2>
      </div>
      <div class="skadr-info-grid">
        {infoCards.map((card) => (
          <article class="skadr-info-card">
            <p>{card.label}</p>
            <strong>{card.value}</strong>
            <span>{card.description}</span>
          </article>
        ))}
      </div>
    </section>

    <InfoNotice
      title="재정거래 실행 전 확인하세요"
      lines={[
        "ADR과 국내 주식 간 실제 매매를 통한 재정거래는 계좌·세금·환전 비용·결제일 차이로 계산상 프리미엄만큼 수익이 나지 않을 수 있습니다.",
        "이 계산기는 가격 괴리를 파악하는 참고용이며 투자 실행을 권유하지 않습니다.",
        "SKHY 비율(ADS 10주=보통주 1주)은 2026-07-10 나스닥 상장 시 확정된 값입니다.",
      ]}
    />

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">다음 확인</p>
        <h2>ADR 상장 배경과 투자 비교도 함께 보세요</h2>
      </div>
      <div class="skadr-related-grid">
        {relatedLinks.map((item) => (
          <a class="skadr-related-card" href={withBase(item.href)}>
            <strong>{item.label}</strong>
            <span>{item.description}</span>
          </a>
        ))}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="SK하이닉스 ADR 프리미엄, 왜 확인해야 할까"
        intro={[
          "SK하이닉스는 2026년 7월 10일 미국 나스닥(Nasdaq Global Select Market)에 ADR(미국예탁증서)을 상장했습니다. 티커는 SKHY, 공모가는 ADS 1주당 149달러였고, 한국 보통주 약 1,779만 주 규모의 신주 발행을 기반으로 약 265억 달러 규모의 자금을 조달했습니다. 상장 이후 국내 투자자들 사이에서는 국내 상장 주가와 나스닥 SKHY 가격 사이의 차이, 이른바 \"김치프리미엄\"에 대한 관심이 커지고 있습니다.",
          "프리미엄(할증)은 SKHY 가격을 원화로 환산했을 때 국내 주가보다 비싼 상태를, 디스카운트(할인)는 반대로 더 싼 상태를 의미합니다. SK하이닉스 ADR은 ADS 10주가 한국 보통주 1주를 나타내는 구조로 확정되어, 이 계산기는 SKHY 주가에 이 비율을 자동 반영해 국내 주가와의 차이를 퍼센트와 금액으로 즉시 보여줍니다.",
          "프리미엄·디스카운트가 발생하는 이유는 다양합니다. 두 시장의 거래 시간이 달라 정보 반영 속도에 차이가 생기거나, 미국 기관투자자와 국내 투자자의 수급 구조가 다르거나, 원/달러 환율 변동성이 단기적으로 가격 괴리를 만들 수 있습니다. 실제로 상장 당시 기관 주문이 공모 물량의 7배 이상 몰릴 만큼 미국 기관 수요가 컸습니다.",
          "다만 계산상 프리미엄이 확인되더라도 실제로 국내 주식을 사서 ADR로 전환해 팔거나 그 반대로 차익을 실현하는 재정거래는 계좌 개설, 환전 수수료, 세금(양도소득세·배당소득세), 결제일 차이 때문에 계산된 퍼센트만큼 수익이 남지 않는 경우가 많습니다.",
          "이 계산기는 투자 실행을 권유하는 도구가 아니라, SK하이닉스 국내 주가와 SKHY 가격의 관계를 숫자로 이해하고 시장 상황을 참고하기 위한 용도입니다. ADR 상장 배경과 코리아 디스카운트 완화 기대, 국내 투자자에게 미치는 영향이 궁금하다면 하단의 관련 리포트를 함께 확인하세요.",
        ]}
        inputPoints={[
          "국내 주가·환율·나스닥 SKHY 주가 3개만 입력하면 프리미엄 %가 자동 계산됩니다.",
          "프리셋 버튼으로 할증·할인·등가 예시를 바로 체험할 수 있습니다.",
          "URL에 입력값이 저장되어 계산 결과를 링크로 공유할 수 있습니다.",
        ]}
        criteria={[
          "SKHY 보통주 환산가치 = SKHY 주가 × 10(ADS 10주=보통주 1주) × 원/달러 환율",
          "프리미엄(%) = (SKHY 환산가치 − 국내 주가) ÷ 국내 주가 × 100",
          "ADR 비율은 2026-07-10 나스닥 상장 시 확정된 고정값이며 사용자가 조정할 수 없습니다.",
        ]}
        faq={faq}
        related={relatedLinks.map((item) => ({ href: item.href, label: item.label }))}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="skadrConfig" type="application/json" set:html={JSON.stringify(config)}></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/sk-hynix-adr-premium-calculator.js")}></script>
</BaseLayout>
