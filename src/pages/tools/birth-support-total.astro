---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import CompareCta from "../../components/CompareCta.astro";
import SummaryCards from "../../components/SummaryCards.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import TimelineToolShell from "../../components/TimelineToolShell.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="출산~2세 총지원금 계산기"
  description="첫만남이용권, 부모급여, 아동수당을 합쳐 아이 두 돌 전까지 받을 수 있는 총액을 계산하는 도구"
  ogImage="/og/tools/birth-support-total.png">
  <SiteHeader />

  <TimelineToolShell calculatorId="birth-support-total" pageClass="birth-support-total-page">
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="지원금 합산"
        title="출산~2세 총지원금 계산기"
        description="첫만남이용권, 부모급여, 아동수당을 합쳐 아이 18개월 또는 두 돌 전까지 우리 집이 받을 수 있는 총지원금을 계산합니다."
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetBirthSupportBtn" copyId="copyBirthSupportLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">기본 정보 입력</h2>
          </div>
          <p class="panel-heading__summary">출생일과 자녀 순번만 넣으면 구간별 총액과 월별 현금흐름을 빠르게 확인할 수 있습니다.</p>
        </div>
        <div class="form-grid form-grid--compact">
          <label class="field">
            <span>출생일</span>
            <input id="birthDate" type="date" />
          </label>
          <label class="field">
            <span>자녀 순번</span>
            <select id="childOrder">
              <option value="FIRST">첫째</option>
              <option value="SECOND_PLUS">둘째 이상</option>
            </select>
          </label>
          <label class="field">
            <span>계산 구간</span>
            <select id="supportWindowMonths">
              <option value="18">출생~18개월</option>
              <option value="24" selected>출생~24개월</option>
            </select>
            <small class="is-placeholder">d</small>
            <small class="is-placeholder">d</small>
          </label>
          <label class="field">
            <span>현재 아이 개월 수</span>
            <input id="currentAgeMonths" type="number" min="0" max="24" value="0" />
            <small>출생일 기준으로 자동 계산되며 필요하면 직접 수정할 수 있습니다.</small>
          </label>
          <label class="field field-span-full">
            <span>비교용 월급</span>
            <input id="supportMonthlySalaryReference" type="number" value="3000000" />
            <small id="supportSalaryReferenceHint"></small>
          </label>
        </div>
        <button id="calcBirthSupportBtn" class="button button--primary" type="button">우리 집 총액 계산하기</button>
      </article>
    </Fragment>

    <SummaryCards
      columns={4}
      items={[
        { label: "선택 구간 총지원금", id: "supportTotalSummary" },
        { label: "월 평균 체감액", id: "supportMonthlyAverage" },
        { label: "월급 몇 개월치", id: "supportSalaryEquivalent" },
        { label: "월급 대비 보전율", id: "supportReplacementRate" }
      ]}
    />

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">지원금 분해</p>
          <h2 class="panel__title">항목별 지원금 분해</h2>
        </div>
        <p class="panel-heading__summary" id="supportSummaryNote">-</p>
      </div>
      <div class="breakdown-grid">
        <article class="breakdown-chip">
          <span>첫만남이용권</span>
          <strong id="firstMeetingVoucherValue">-</strong>
        </article>
        <article class="breakdown-chip">
          <span>부모급여 총액</span>
          <strong id="parentBenefitTotalValue">-</strong>
        </article>
        <article class="breakdown-chip">
          <span>아동수당 총액</span>
          <strong id="childAllowanceTotalValue">-</strong>
        </article>
        <article class="breakdown-chip">
          <span>현재까지 누적 추정</span>
          <strong id="supportCurrentAccumulated">-</strong>
        </article>
      </div>
    </article>

    <InfoNotice
      title="안내"
      lines={[
        "첫만남이용권은 첫째 200만 원, 둘째 이상 300만 원 기준으로 계산합니다.",
        "부모급여는 0세 월 100만 원, 1세 월 50만 원 기준이며 계산 구간에 맞춰 누적합니다.",
        "아동수당은 월 10만 원을 단순 반영하며, 비교용 월급은 총보수 감각을 보기 위한 참고값입니다."
      ]}
    />

    <Fragment slot="timeline">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">월별 흐름</p>
            <h2 class="panel__title">월별 현금흐름</h2>
          </div>
          <p class="panel-heading__summary">선택한 구간의 월별 수령 흐름을 보여줍니다.</p>
        </div>
        <div class="birth-support-chart-wrap">
          <canvas id="birth-support-timeline-chart"></canvas>
        </div>
        <div class="table-wrap">
          <table class="result-table">
            <thead>
              <tr>
                <th>개월</th>
                <th>첫만남이용권</th>
                <th>부모급여</th>
                <th>아동수당</th>
                <th>월 합계</th>
              </tr>
            </thead>
            <tbody id="birthSupportTimelineTable"></tbody>
          </table>
        </div>
      </article>
    </Fragment>

    <CompareCta
      variant="welfare"
      title="출산지원금 외에 받을 수 있는 지원금도 같이 보세요"
      description="첫만남이용권·부모급여를 계산한 뒤 청년 적금, 복지급여, 출산·육아 지원금 비교표로 다음 지원 가능성을 확인할 수 있습니다."
      links={[
        { href: "/compare/welfare/", label: "지원금 비교표 보기" },
        { href: "/tools/welfare-benefit-eligibility/", label: "복지급여 자격 계산" },
      ]}
    />

    <Fragment slot="seo">
      <SeoContent
        introTitle="출산~2세 총지원금 계산기를 보는 방법"
        intro={[
          "출산을 준비하는 가구는 제도 설명을 일일이 찾아 읽기보다 출생 후 두 돌까지 실제로 얼마를 받을 수 있는지 빠르게 감을 잡고 싶을 때가 많습니다. 첫째와 둘째 이상의 지원금 차이가 얼마나 나는지 궁금할 때, 출산 직후 초기 비용을 예상 지원금으로 어느 정도 충당할 수 있는지 가늠해야 할 때, 현재 받는 월급과 지원금을 비교해 출산 전후 가구 소득을 체감해보고 싶을 때 이 계산기가 적합합니다. 출생일과 자녀 순번만 입력하면 별도 제도 설명 없이 총액과 월별 흐름을 바로 확인할 수 있습니다.",
          "계산은 첫만남이용권 첫째 200만원·둘째 이상 300만원, 부모급여 0세 월 100만원·1세 월 50만원, 아동수당 월 10만원이라는 공개된 기준을 그대로 적용해 선택한 구간(18개월 또는 24개월) 동안 단순 누적하는 방식입니다. 출생 순번에 따라 첫만남이용권 금액이 달라지는 점을 반영해 첫째와 둘째 이상을 구분해서 계산하며, 비교용 월급을 입력하면 지원금 총액이 월급 몇 개월치에 해당하는지, 보전율은 어느 정도인지 참고로 환산해서 보여줍니다.",
          "결과를 볼 때는 선택 구간 총지원금이라는 한 숫자보다 항목별 분해와 월별 현금흐름을 같이 보는 것이 실제 가계 관리에 더 유용합니다. 첫만남이용권처럼 초기에 한 번 들어오는 일시금과 부모급여·아동수당처럼 매월 들어오는 지급분을 구분해서 봐야 출산 직후 단기 비용 대응과 이후 장기 육아 기간의 현금흐름을 따로 계획할 수 있습니다. 현재 아이 개월 수를 입력하면 이미 지나간 기간의 누적 추정액도 함께 확인할 수 있어 출생 이후 시점에 다시 계산할 때도 유용합니다.",
          "이 계산기는 첫만남이용권, 부모급여, 아동수당만 기본 포함하며 육아휴직 급여나 지역별 출산축하금, 산후조리비, 지자체 지원금은 포함하지 않으므로 실제 가구가 받는 총액은 이보다 더 클 수 있습니다. 첫만남이용권은 출생 후 일정 기간 내 신청해야 하고 부모급여는 신청 월 기준으로 지급이 시작되는 등 신청 시점을 놓치면 소급되지 않는 항목이 있으므로, 출생신고와 함께 복지로나 정부24의 행복출산 원스톱 서비스를 활용해 주요 항목을 빠짐없이 신청하는 것을 권장합니다.",
        ]}
        inputPoints={[
          "첫만남이용권, 부모급여, 아동수당을 합친 총액을 빠르게 계산할 수 있습니다.",
          "18개월 또는 24개월 구간으로 끊어서 월별 현금흐름을 볼 수 있습니다.",
          "월급 참고값을 넣으면 지원금이 월급 몇 개월치 느낌인지 가볍게 비교할 수 있습니다."
        ]}
        criteria={[
          "기준일은 2026년 현재 공개 제도 기준을 바탕으로 한 참고 계산입니다. 실제 지급 여부와 신청 방식은 거주지, 출생일, 제도 변경에 따라 달라질 수 있습니다.",
          "첫만남이용권은 첫째 200만 원, 둘째 이상 300만 원 기준으로 계산합니다.",
          "부모급여는 0세 월 100만 원, 1세 월 50만 원 구조를 기준으로 단순 누적합니다.",
          "아동수당은 0~24개월 구간만 반영하며 실제 제도 전체 기간과는 다를 수 있습니다.",
          "예시 1: 첫째, 출생~24개월 기준으로 계산하면 첫만남이용권과 부모급여, 아동수당이 각각 얼마씩 차지하는지 볼 수 있습니다.",
          "예시 2: 둘째 이상으로 바꿔 계산하면 첫만남이용권 차이 때문에 초기 지원금 총액이 얼마나 달라지는지 확인할 수 있습니다.",
          "지역별 출산축하금, 산후조리비, 임신·출산 바우처, 지자체 지원은 이 계산기에 기본 포함하지 않으므로 별도 확인이 필요합니다."
        ]}
        faq={[
          { question: "두 돌까지 총지원금에는 무엇이 포함되나요?", answer: "이 페이지에서는 첫만남이용권, 부모급여, 아동수당을 기본 포함 대상으로 봅니다." },
          { question: "출생월이 지나도 계산할 수 있나요?", answer: "네. 현재 아이 개월 수를 바탕으로 현재까지 누적 추정과 남은 흐름을 함께 볼 수 있습니다." },
          { question: "육아휴직 급여도 포함되나요?", answer: "아니요. 육아휴직 급여까지 포함한 가구 총액은 한 명만 육아휴직 총수령액 계산기에서 보는 편이 맞습니다." },
          { question: "지역별 출산지원금도 자동으로 포함되나요?", answer: "아니요. 지자체별 출산축하금, 산후조리비, 교통비 지원 등은 지역과 시점에 따라 차이가 커서 기본 계산에는 넣지 않았습니다. 거주지 주민센터나 복지로 안내를 함께 확인해야 합니다." },
          { question: "첫만남이용권은 현금으로 받는 금액인가요?", answer: "첫만남이용권은 일반 현금 지급과 다르게 바우처 성격으로 운영됩니다. 사용처와 지급 방식은 최신 정부 안내를 확인하는 것이 안전합니다." }
        ]}
        related={[
          { href: "/tools/single-parental-leave-total/", label: "한 명만 육아휴직 총수령액 계산기" },
          { href: "/tools/parental-leave-pay/", label: "육아휴직 급여 계산기" },
          { href: "/tools/six-plus-six/", label: "6+6 부모육아휴직제 계산기" },
          { href: "/reports/baby-cost-guide-first-year/", label: "첫해 육아비 가이드" }
        ]}
      />
    </Fragment>
  </TimelineToolShell>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/birth-support-total.js")}></script>
</BaseLayout>
