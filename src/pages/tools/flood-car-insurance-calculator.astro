---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  FCI_META,
  FCI_DEFAULT_INPUT,
  FCI_PRESETS,
  FCI_TIER_LABEL,
  FCI_COVERAGE_CASES,
  FCI_AFTER_FLOOD_CHECKLIST,
  FCI_PREMIUM_IMPACT,
  FCI_FAQ,
  FCI_RELATED_LINKS,
  FCI_EXTERNAL_LINKS,
  FCI_SOURCES,
  FCI_SEO_CONTENT,
  calcFloodCarInsurance,
  calcSensitivity,
} from "../../data/floodCarInsuranceCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${FCI_META.slug}/`;
const won = (value: number) => `${Math.round(value).toLocaleString("ko-KR")}원`;
const defaultResult = calcFloodCarInsurance(FCI_DEFAULT_INPUT);
const defaultSensitivity = calcSensitivity(FCI_DEFAULT_INPUT);
const pageData = {
  defaultInput: FCI_DEFAULT_INPUT,
  presets: FCI_PRESETS,
  tierLabel: FCI_TIER_LABEL,
};
---

<BaseLayout
  title={FCI_META.seoTitle}
  description={FCI_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: FCI_META.title,
      applicationCategory: "FinanceApplication",
      operatingSystem: "All",
      inLanguage: "ko-KR",
      isAccessibleForFree: true,
      url: pageUrl,
      description: FCI_META.seoDescription,
      provider: { "@type": "Organization", name: "비교계산소" },
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: FCI_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={FCI_META.slug} pageClass="fci-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="침수차 보험처리"
        title={FCI_META.title}
        description="차량가액과 예상 인정 손해액을 입력하면 전손·분손 가능성과 자기부담금을 반영한 예상 보험금을 추정합니다."
        badges={["장마·태풍", "자차보험", "전손·분손 추정", "2026"]}
      />
      <InfoNotice
        title="계산 기준 안내"
        lines={[
          FCI_META.dataNote,
          "침수 피해를 보상받으려면 자기차량손해담보와 차량단독사고(또는 침수) 보장 특약에 모두 가입돼 있어야 합니다.",
        ]}
      />
      <div class="fci-emergency-box">
        <strong>침수 후에는 다시 시동을 걸지 마세요</strong>
        <p>차량 침수 상태에서 시동을 반복하면 엔진과 전기장치 손상이 확대될 수 있습니다. 먼저 안전한 곳으로 대피한 뒤 보험회사에 사고를 접수하고 견인을 요청하세요.</p>
      </div>
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="fciResetBtn" copyId="fciCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 예시</p>
            <h2 class="panel__title">프리셋으로 바로 계산</h2>
          </div>
        </div>
        <div class="fci-preset-grid">
          {FCI_PRESETS.map((preset, index) => (
            <button type="button" class:list={["fci-preset-btn", index === 1 && "is-active"]} data-fci-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.summary}</span>
              {preset.note && <small>{preset.note}</small>}
            </button>
          ))}
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">① 보장 여부 확인</p>
            <h2 class="panel__title">자동차보험 보장 여부</h2>
          </div>
        </div>
        <div class="form-grid">
          <label class="field">
            <span>자기차량손해담보에 가입되어 있나요?</span>
            <select data-fci-input="collisionCoverage">
              <option value="yes" selected={FCI_DEFAULT_INPUT.collisionCoverage === "yes"}>가입</option>
              <option value="no" selected={FCI_DEFAULT_INPUT.collisionCoverage === "no"}>미가입</option>
              <option value="unsure" selected={FCI_DEFAULT_INPUT.collisionCoverage === "unsure"}>잘 모름</option>
            </select>
          </label>
          <label class="field">
            <span>침수·차량단독사고가 보장되는 특약에 가입되어 있나요?</span>
            <select data-fci-input="singleAccidentCoverage">
              <option value="yes" selected={FCI_DEFAULT_INPUT.singleAccidentCoverage === "yes"}>가입</option>
              <option value="no" selected={FCI_DEFAULT_INPUT.singleAccidentCoverage === "no"}>미가입</option>
              <option value="unsure" selected={FCI_DEFAULT_INPUT.singleAccidentCoverage === "unsure"}>잘 모름</option>
            </select>
            <small>자기차량손해담보가 있어도 차대차 사고만 보장하는 형태라면 침수가 보장되지 않을 수 있습니다.</small>
          </label>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">침수 상황</p>
            <h2 class="panel__title">어떤 상황이었나요?</h2>
          </div>
        </div>
        <div class="fci-scenario-group">
          <label class="fci-scenario-option">
            <input type="radio" name="fci-scenario" value="normal" data-fci-input="floodScenario" checked={FCI_DEFAULT_INPUT.floodScenario === "normal"} />
            <span>정상 주차·운행 중 침수</span>
          </label>
          <label class="fci-scenario-option">
            <input type="radio" name="fci-scenario" value="windowOpen" data-fci-input="floodScenario" checked={FCI_DEFAULT_INPUT.floodScenario === "windowOpen"} />
            <span>창문·선루프를 열어둔 상태에서 침수</span>
          </label>
          <label class="fci-scenario-option">
            <input type="radio" name="fci-scenario" value="restrictedArea" data-fci-input="floodScenario" checked={FCI_DEFAULT_INPUT.floodScenario === "restrictedArea"} />
            <span>통제구역 진입·대피명령 무시 중 침수</span>
          </label>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">② 손해액 입력</p>
            <h2 class="panel__title">사고 당시 차량가액 추정액</h2>
          </div>
          <p class="panel-heading__summary">보험개발원 차량기준가액 또는 보험사가 인정한 가액을 기준으로 입력하세요. 중고차 매물 가격과는 다를 수 있습니다.</p>
        </div>
        <div class="form-grid">
          <label class="field">
            <span>사고 당시 차량가액 추정액</span>
            <input type="text" inputmode="numeric" data-fci-input="vehicleValue" value={FCI_DEFAULT_INPUT.vehicleValue.toLocaleString("ko-KR")} />
          </label>
        </div>
        <a class="fci-external-link" href={FCI_EXTERNAL_LINKS.vehicleStandardValue.url} target="_blank" rel="noopener noreferrer">{FCI_EXTERNAL_LINKS.vehicleStandardValue.label}</a>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">예상 인정 손해액</p>
            <h2 class="panel__title">수리비·부대비용 입력</h2>
          </div>
        </div>
        <div class="form-grid">
          <label class="field">
            <span>정비업체 예상 수리비</span>
            <input type="text" inputmode="numeric" data-fci-input="repairCost" value={FCI_DEFAULT_INPUT.repairCost.toLocaleString("ko-KR")} />
            <small>엔진·변속기·전자장치·내장재 포함</small>
          </label>
          <label class="field">
            <span>견인비</span>
            <input type="text" inputmode="numeric" data-fci-input="towingCost" value={FCI_DEFAULT_INPUT.towingCost.toLocaleString("ko-KR")} />
          </label>
          <label class="field">
            <span>침수 세척·건조 비용</span>
            <input type="text" inputmode="numeric" data-fci-input="cleaningCost" value={FCI_DEFAULT_INPUT.cleaningCost.toLocaleString("ko-KR")} />
            <small>보험 인정 여부는 보험사별로 확인이 필요합니다.</small>
          </label>
          <label class="field">
            <span>추가 손상 예상액</span>
            <input type="text" inputmode="numeric" data-fci-input="additionalDamageEstimate" value={FCI_DEFAULT_INPUT.additionalDamageEstimate.toLocaleString("ko-KR")} />
            <small>분해 후 발견될 수 있는 추가 손상 여유분</small>
          </label>
        </div>
        <label class="fci-check-field">
          <input type="checkbox" data-fci-input="isFunctionUnrecoverable" checked={FCI_DEFAULT_INPUT.isFunctionUnrecoverable} />
          <span>수리해도 정상적인 자동차 기능 회복이 어려운 상태입니다 (절대전손 검토)</span>
        </label>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">자기부담금 설정</p>
            <h2 class="panel__title">직접 조정 (선택)</h2>
          </div>
          <p class="panel-heading__summary">본인 보험증권 기준으로 다르면 아래 값을 수정하세요.</p>
        </div>
        <div class="form-grid">
          <label class="field">
            <span>자기부담금 비율(%)</span>
            <input type="number" min="0" max="100" step="1" data-fci-input="deductibleRate" value={FCI_DEFAULT_INPUT.deductibleRate} />
          </label>
          <label class="field">
            <span>최소 자기부담금</span>
            <input type="text" inputmode="numeric" data-fci-input="deductibleMin" value={FCI_DEFAULT_INPUT.deductibleMin.toLocaleString("ko-KR")} />
          </label>
          <label class="field">
            <span>최대 자기부담금</span>
            <input type="text" inputmode="numeric" data-fci-input="deductibleMax" value={FCI_DEFAULT_INPUT.deductibleMax.toLocaleString("ko-KR")} />
          </label>
          <label class="field">
            <span>전손 시 자기부담금 처리</span>
            <select data-fci-input="deductibleWaiverOnTotalLoss">
              <option value="notWaived" selected={FCI_DEFAULT_INPUT.deductibleWaiverOnTotalLoss === "notWaived"}>공제하는 계약입니다</option>
              <option value="waived" selected={FCI_DEFAULT_INPUT.deductibleWaiverOnTotalLoss === "waived"}>공제하지 않는 계약입니다</option>
              <option value="unsure" selected={FCI_DEFAULT_INPUT.deductibleWaiverOnTotalLoss === "unsure"}>잘 모르겠습니다</option>
            </select>
            <small>전손 시 자기부담금 공제 여부는 보험사와 약관에 따라 다릅니다. 보험증권 또는 보상 담당자를 통해 확인하세요.</small>
          </label>
        </div>
      </article>
    </Fragment>

    <!-- 침수 상황 경고 -->
    <article class="panel fci-scenario-warning" data-fci-scenario-warning hidden>
      <strong data-fci-scenario-warning-title></strong>
      <p data-fci-scenario-warning-body></p>
    </article>

    <!-- 보장 미가입/확인 필요 안내 -->
    <article class="panel fci-warning-panel" data-fci-warning hidden>
      <strong data-fci-warning-title>자기차량손해담보 미가입 상태입니다</strong>
      <p data-fci-warning-body>책임보험만 가입한 경우 침수로 인한 내 차량 피해는 보상되지 않습니다. 보험증권에서 자기차량손해담보(또는 차량단독사고 특약) 가입 여부를 먼저 확인하세요.</p>
    </article>

    <!-- 계산 결과 -->
    <article class="panel fci-result-panel" aria-live="polite" data-fci-result-panel>
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">계산 결과</p>
          <h2 class="panel__title" data-fci-result="tierConclusion">{FCI_TIER_LABEL[defaultResult.tier]}</h2>
        </div>
      </div>
      <div class="table-wrap fci-table-wrap">
        <table class="fci-result-table">
          <tbody>
            <tr><th>사고 당시 차량가액</th><td data-fci-result="vehicleValue">{won(FCI_DEFAULT_INPUT.vehicleValue)}</td></tr>
            <tr><th>예상 인정 손해액</th><td data-fci-result="estimatedDamage">{won(defaultResult.estimatedDamage)}</td></tr>
            <tr><th>차량가액 대비 손해율</th><td data-fci-result="lossRatio">{defaultResult.lossRatio}%</td></tr>
            <tr><th>예상 자기부담금</th><td data-fci-result="deductibleAmount">{won(defaultResult.deductibleAmount)}</td></tr>
            <tr><th>예상 지급보험금</th><td data-fci-result="expectedPayout">{won(defaultResult.expectedPayout)}</td></tr>
          </tbody>
        </table>
      </div>
      <p class="fci-interpretation" data-fci-result="interpretation">
        현재 입력값에서는 예상 손해액이 차량가액보다 낮아 분손 가능성이 높습니다. 다만 정비 과정에서 엔진·변속기·전자제어장치의 추가 손상이 발견되면 수리비가 증가해 전손 검토 구간으로 변경될 수 있습니다.
      </p>
      <p class="fci-disclaimer">전손·분손 최종 판정은 수리 가능성, 주요 부품 손상, 잔존물 가치를 반영한 보험사 손해사정 결과가 우선합니다.</p>
    </article>

    <!-- 민감도 분석 -->
    <article class="panel" data-fci-sensitivity-panel>
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">민감도 분석</p>
          <h2 class="panel__title">추가 수리비가 늘어나면 판정이 어떻게 바뀔까</h2>
        </div>
      </div>
      <div class="table-wrap fci-table-wrap">
        <table class="fci-sensitivity-table">
          <thead>
            <tr><th>추가 수리비</th><th>총 손해액</th><th>손해율</th><th>예상 판정</th></tr>
          </thead>
          <tbody data-fci-sensitivity-body>
            {defaultSensitivity.map((row) => (
              <tr>
                <td>{won(row.extraCost)}</td>
                <td>{won(row.totalDamage)}</td>
                <td>{row.lossRatio}%</td>
                <td>{FCI_TIER_LABEL[row.tier]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>

    <!-- 전손·분손 판단 기준 -->
    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">판단 기준</p>
          <h2 class="panel__title">전손·분손, 어떻게 나뉘나요?</h2>
        </div>
      </div>
      <div class="fci-tier-grid">
        <article class="fci-tier-card"><strong>추정전손</strong><p>수리비가 사고 당시 차량가액을 초과하거나 근접해 경제성이 없는 경우</p></article>
        <article class="fci-tier-card"><strong>절대전손</strong><p>수리가 불가능하거나 수리 후에도 자동차 기능을 정상적으로 수행하기 어려운 경우</p></article>
        <article class="fci-tier-card"><strong>분손</strong><p>수리가 가능하고 인정 손해액이 차량가액 이내인 경우</p></article>
      </div>
      <p class="fci-table-note">위 4단계(분손 가능성 높음 / 고액 수리 구간 / 전손 검토 경계 / 추정전손 가능성 높음)는 법정 판정 기준이 아니라 사용자 이해를 돕기 위한 계산기 표시 구간입니다.</p>
    </article>

    <!-- 보상 가능·제외 사례 -->
    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">보상 가능·제외 사례</p>
          <h2 class="panel__title">내 상황은 보상 대상일까요?</h2>
        </div>
      </div>
      <div class="table-wrap fci-table-wrap">
        <table class="fci-coverage-table">
          <thead><tr><th>상황</th><th>일반적인 판단</th></tr></thead>
          <tbody>
            {FCI_COVERAGE_CASES.map((row) => (
              <tr><td>{row.situation}</td><td>{row.judgment}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>

    <!-- 보험료 할증 -->
    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">보험료 영향</p>
          <h2 class="panel__title">침수차 보험처리를 하면 보험료가 오를까?</h2>
        </div>
      </div>
      <div class="fci-premium-grid">
        <article class="fci-premium-card">
          <strong>운전자 과실 없음</strong>
          <p>{FCI_PREMIUM_IMPACT.noFault}</p>
        </article>
        <article class="fci-premium-card fci-premium-card--warn">
          <strong>통제구역 진입·대피명령 무시</strong>
          <p>{FCI_PREMIUM_IMPACT.atFault}</p>
        </article>
      </div>
    </article>

    <!-- 침수 직후 행동요령 -->
    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">사고 직후 체크리스트</p>
          <h2 class="panel__title">침수 직후 이렇게 행동하세요</h2>
        </div>
      </div>
      <ul class="fci-checklist">
        {FCI_AFTER_FLOOD_CHECKLIST.map((item) => (
          <li class="fci-checklist-item"><span class="fci-checklist-box" aria-hidden="true"></span>{item}</li>
        ))}
      </ul>
    </article>

    <!-- 침수 이력 조회 -->
    <article class="panel fci-lookup-panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">중고차 거래 예정이라면</p>
          <h2 class="panel__title">침수차 무료 이력 조회</h2>
        </div>
      </div>
      <p>보험개발원 카히스토리에서는 차량번호 또는 차대번호를 입력해 보험 처리된 침수사고 여부를 무료로 조회할 수 있습니다. 다만 보험사에 신고되지 않았거나 자동차보험으로 처리하지 않은 침수는 조회되지 않을 수 있습니다.</p>
      <a class="button button--primary" href={FCI_EXTERNAL_LINKS.floodHistoryCheck.url} target="_blank" rel="noopener noreferrer">{FCI_EXTERNAL_LINKS.floodHistoryCheck.label}</a>
    </article>

    <article class="panel fci-source-list">
      <h2>공식 자료</h2>
      <ul>
        {FCI_SOURCES.map((source) => (
          <li><a href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a></li>
        ))}
      </ul>
    </article>

    <Fragment slot="seo">
      <SeoContent
        introTitle={FCI_SEO_CONTENT.introTitle}
        intro={FCI_SEO_CONTENT.intro}
        inputPoints={FCI_SEO_CONTENT.inputPoints}
        criteria={FCI_SEO_CONTENT.criteria}
        faq={FCI_FAQ}
        related={FCI_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="fci-data" type="application/json" set:html={JSON.stringify(pageData)}></script>
  <script src={withBase("/scripts/flood-car-insurance-calculator.js")} defer></script>
</BaseLayout>
