---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import CompareCta from "../../components/CompareCta.astro";
import { SBFC_BROKERS, SBFC_META, SBFC_FAQS, SBFC_TRANSACTION_TAX } from "../../data/stockBrokerageFeeCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const configData = { brokers: SBFC_BROKERS };

const faqSchema = SBFC_FAQS.map((f) => ({
  "@type": "Question",
  name: f.question,
  acceptedAnswer: { "@type": "Answer", text: f.answer },
}));
---

<BaseLayout
  title={SBFC_META.title}
  description={SBFC_META.description}
  ogImage="/og/tools/stock-brokerage-fee-calculator.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "증권사 수수료 계산기 2026",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description: SBFC_META.description,
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/stock-brokerage-fee-calculator/`,
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  }}
>
  <SiteHeader />

  <script
    id="sbfcConfig"
    type="application/json"
    set:html={JSON.stringify(configData)}
  />

  <SimpleToolShell calculatorId="stock-brokerage-fee-calculator" pageClass="sbfc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="증권사 수수료"
        title="주식 수수료 계산기 2026"
        description="1회 거래금액과 월 거래 횟수를 입력하면 주요 증권사별 연간 수수료를 자동 계산합니다. 국내주식·미국주식 중 선택하고 나에게 가장 저렴한 증권사를 바로 확인하세요."
        stats={[
          { label: "비교 증권사", value: `${SBFC_BROKERS.length}곳` },
          { label: "업데이트", value: "2026.04" },
        ]}
      />
      <InfoNotice
        title="이 계산기는 참고용입니다"
        lines={[
          "수수료율은 2026년 4월 기준 각 증권사 이벤트·비대면 기준값입니다.",
          "이벤트 종료, 계좌 종류, 주문 채널에 따라 실제 수수료가 다를 수 있습니다.",
          "계좌 개설 전 각 증권사 공식 안내를 확인하세요.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="sbfcResetBtn" copyId="sbfcCopyLinkBtn" />
    </Fragment>

    <!-- 입력 패널 (aside) -->
    <Fragment slot="aside">
      <article class="panel sbfc-input-panel" data-sbfc-calculator>
        <!-- 투자 유형 -->
        <div class="sbfc-section">
          <h2 class="sbfc-section-title">투자 유형</h2>
          <div class="sbfc-toggle-group">
            <button class="sbfc-toggle active" data-sbfc-type="domestic">국내주식</button>
            <button class="sbfc-toggle" data-sbfc-type="overseas">미국주식</button>
          </div>
        </div>

        <!-- 거래 조건 -->
        <div class="sbfc-section">
          <h2 class="sbfc-section-title">거래 조건</h2>
          <div class="sbfc-field">
            <label class="sbfc-label" for="sbfcTradeAmount">1회 거래금액</label>
            <div class="sbfc-input-wrap">
              <input
                id="sbfcTradeAmount"
                type="text"
                class="sbfc-input"
                data-sbfc-trade-amount
                value="1,000,000"
                inputmode="numeric"
              />
              <span class="sbfc-unit">원</span>
            </div>
            <div class="sbfc-hint" data-sbfc-amount-hint></div>
          </div>
          <div class="sbfc-field">
            <label class="sbfc-label" for="sbfcMonthlyCount">월 거래 횟수</label>
            <div class="sbfc-input-wrap">
              <input
                id="sbfcMonthlyCount"
                type="number"
                class="sbfc-input"
                data-sbfc-monthly-count
                value="4"
                min="1"
                max="500"
              />
              <span class="sbfc-unit">회</span>
            </div>
          </div>
          <div class="sbfc-overseas-note" data-sbfc-overseas-note>
            <span>미국주식: 환전 스프레드 포함 총비용 기준</span>
          </div>
        </div>

        <!-- 증권사 선택 -->
        <div class="sbfc-section">
          <h2 class="sbfc-section-title">비교할 증권사</h2>
          <div class="sbfc-broker-list" data-sbfc-broker-list>
            {SBFC_BROKERS.map((broker) => (
              <label class="sbfc-broker-item" data-broker-id={broker.id}>
                <input
                  type="checkbox"
                  data-sbfc-broker-check={broker.id}
                  checked={broker.defaultSelected}
                />
                <span class="sbfc-broker-name">{broker.name}</span>
                {broker.badge && <span class="sbfc-broker-badge">{broker.badge}</span>}
              </label>
            ))}
          </div>
        </div>
      </article>
    </Fragment>

    <!-- 결과 영역 (기본 슬롯) -->
    <div class="sbfc-results">

      <!-- 1회 매도 수수료 빠른 계산 -->
      <div class="sbfc-sell-section">
        <h3 class="sbfc-sell-title">1회 매도 수수료 즉시 계산</h3>
        <p class="sbfc-sell-desc">입력한 거래금액 기준, 선택된 첫 번째 증권사로 1회 매도 시 발생하는 비용을 상세 분류합니다.</p>
        <div class="sbfc-sell-cards">
          <div class="sbfc-sell-card">
            <span class="sbfc-sell-label">매매수수료</span>
            <span class="sbfc-sell-value" data-sbfc-sell-commission>—</span>
          </div>
          <div class="sbfc-sell-card">
            <span class="sbfc-sell-label">유관기관 제비용</span>
            <span class="sbfc-sell-value" data-sbfc-sell-agency>—</span>
            <span class="sbfc-sell-note">약 0.004%</span>
          </div>
          <div class="sbfc-sell-card sbfc-sell-card--tax" data-sbfc-sell-tax-wrap>
            <span class="sbfc-sell-label">증권거래세 (매도)</span>
            <span class="sbfc-sell-value" data-sbfc-sell-tax>—</span>
            <span class="sbfc-sell-note">{SBFC_TRANSACTION_TAX.label} · {SBFC_TRANSACTION_TAX.note}</span>
          </div>
          <div class="sbfc-sell-card sbfc-sell-card--total">
            <span class="sbfc-sell-label">1회 매도 총비용</span>
            <span class="sbfc-sell-value" data-sbfc-sell-total>—</span>
            <span class="sbfc-sell-note" data-sbfc-sell-broker-name>—</span>
          </div>
        </div>
      </div>
      <!-- 요약 카드 -->
      <div class="sbfc-summary-cards">
        <div class="sbfc-card sbfc-card--best">
          <div class="sbfc-card-label">최저 수수료 증권사</div>
          <div class="sbfc-card-value" data-sbfc-best-broker>—</div>
          <div class="sbfc-card-sub" data-sbfc-best-fee>—</div>
        </div>
        <div class="sbfc-card">
          <div class="sbfc-card-label">연간 수수료 차이</div>
          <div class="sbfc-card-value" data-sbfc-max-gap>—</div>
          <div class="sbfc-card-sub">최저 vs 최고 증권사</div>
        </div>
        <div class="sbfc-card">
          <div class="sbfc-card-label">연간 총 거래금액</div>
          <div class="sbfc-card-value" data-sbfc-annual-volume>—</div>
          <div class="sbfc-card-sub" data-sbfc-volume-desc>—</div>
        </div>
      </div>

      <!-- 상세 테이블 -->
      <div class="sbfc-table-wrap">
        <h3 class="sbfc-table-title">증권사별 연간 수수료 상세</h3>
        <div class="sbfc-table-container">
          <table class="sbfc-table" data-sbfc-result-table>
            <thead>
              <tr>
                <th>증권사</th>
                <th>수수료율</th>
                <th>연간 수수료</th>
                <th data-sbfc-overseas-col>환전 포함</th>
                <th>비고</th>
              </tr>
            </thead>
            <tbody data-sbfc-table-body>
              <!-- JS로 채움 -->
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <!-- CTA 1: 연간 절세 → ISA -->
    <CompareCta
      eyebrow="절세 다음 단계"
      title="수수료보다 세금을 더 아끼려면?"
      description="ISA 계좌를 활용하면 ETF·예금 수익에서 연 200~400만원 비과세 혜택을 받을 수 있습니다. 내 투자 패턴으로 절세 효과를 계산해보세요."
      variant="hub"
      links={[
        { href: "/tools/isa-tax-calculator/", label: "ISA 절세 시뮬레이터", tone: "primary" },
        { href: "/tools/year-end-tax-refund-calculator/", label: "연말정산 환급 계산기", tone: "secondary" },
      ]}
    />

    <!-- CTA 2: 투자 수익 계산기 -->
    <CompareCta
      eyebrow="함께 쓰는 계산기"
      title="수수료 아낀 돈, 얼마나 불어날까?"
      description="적립식 투자나 배당주 계산기로 장기 수익도 함께 확인해보세요."
      variant="bonus"
      links={[
        { href: "/tools/dca-investment-calculator/", label: "적립식 투자 수익 계산기", tone: "primary" },
        { href: "/tools/dividend-monthly-income/", label: "배당주 월급 계산기", tone: "secondary" },
      ]}
    />
    <Fragment slot="seo">
      <SeoContent
        introTitle="증권사 수수료 계산기 사용법"
        intro={[
          "증권사를 처음 선택할 때는 거의 신경 쓰지 않지만, 거래가 잦아질수록 수수료 차이가 실수익에 영향을 미친다는 걸 체감하게 됩니다. 증권사 수수료는 거래금액과 거래 빈도에 따라 연간 차이가 수십만 원에 달할 수 있습니다. 특히 월 거래 횟수가 많거나 거래금액이 클수록 증권사 선택이 실질 수익에 미치는 영향이 커집니다.",
          "이 계산기는 1회 거래금액과 월 거래 횟수를 입력하면 주요 증권사별 연간 예상 수수료를 자동으로 계산합니다. 국내주식과 미국주식을 별도로 선택해 비교할 수 있으며, 미국주식은 환전 스프레드를 포함한 실질 총비용 기준으로 산출해 단순 수수료율 비교보다 더 정확한 결과를 보여줍니다.",
          "결과를 볼 때는 단순 수수료율만 보지 말고 본인의 실제 거래 패턴(1회 거래금액, 월 거래 횟수)을 반영한 연간 총비용을 기준으로 비교하는 것이 중요합니다. 거래 빈도가 적다면 수수료 차이가 크지 않을 수 있지만, 자주 거래하는 투자자라면 작은 수수료율 차이도 연간으로 누적되면 상당한 금액이 됩니다.",
          "수수료 외에도 ISA·연금 계좌 지원, 소수점 투자, 자동 투자 기능 등을 함께 고려하면 투자 스타일에 맞는 증권사를 선택하는 데 도움이 됩니다. 다만 증권사 수수료율은 이벤트나 프로모션에 따라 변동될 수 있으므로 가입 전 최신 수수료율을 다시 확인하는 것을 권장합니다.",
        ]}
        faq={SBFC_FAQS.map((f) => ({ question: f.question, answer: f.answer }))}
      />
    </Fragment>
  </SimpleToolShell>
</BaseLayout>

<script src={withBase("scripts/stock-brokerage-fee-calculator.js")} defer></script>
