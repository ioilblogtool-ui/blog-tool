---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  SCHOOL_LEVEL_DATA,
  REGION_OPTIONS,
  SUBJECT_OPTIONS,
  LEARNING_TYPE_OPTIONS,
  COMPARISON_TIERS,
  OPPORTUNITY_YEAR_PRESETS,
  RETURN_RATE_PRESETS,
  TUTORING_FAQ,
  TUTORING_RELATED_TOOLS,
} from "../../data/childTutoringData";

const config = {
  SCHOOL_LEVEL_DATA,
  REGION_OPTIONS,
  SUBJECT_OPTIONS,
  LEARNING_TYPE_OPTIONS,
  COMPARISON_TIERS,
  OPPORTUNITY_YEAR_PRESETS,
  RETURN_RATE_PRESETS,
};

const faqSchema = TUTORING_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: { "@type": "Answer", text: item.answer },
}));

const faqItems = TUTORING_FAQ.map((item) => ({
  question: item.question,
  answer: item.answer,
}));

const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="아이 사교육비 계산기 | 월 교육비·연간 학원비·누적 비용 한눈에"
  description="자녀 나이, 학교급, 과목, 지역을 입력하면 월 사교육비와 연간 교육비, 누적 학원비를 계산해주는 아이 사교육비 계산기. 또래 평균 비교와 기회비용 분석까지 한 번에 확인하세요."
  ogImage="/og/tools/child-tutoring-cost-calculator.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "아이 사교육비 계산기",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description:
      "자녀 수, 학교급, 과목, 지역을 입력하면 월·연간·누적 교육비와 또래 평균 대비 수준을 한 번에 계산. 기회비용 시뮬레이션 포함.",
    url: `${siteBase}/tools/child-tutoring-cost-calculator/`,
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="child-tutoring-cost-calculator" pageClass="tutoring-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="사교육비 계산기"
        title="아이 사교육비 계산기"
        description="자녀 수, 학교급, 과목, 지역만 입력하면 월·연간·누적 교육비와 평균 대비 수준을 한 번에 확인할 수 있어요."
      />
      <InfoNotice
        lines={[
          "이 계산기는 통계청 사교육비 조사(2024년 기준) 추정치를 활용한 참고용 도구입니다.",
          "실제 교육비는 학원·과외 종류, 지역 내 세부 편차, 개인 상황에 따라 크게 다를 수 있습니다.",
          "또래 평균 비교값과 기회비용 시뮬레이션은 참고·추정 수치이며 실제 투자 수익을 보장하지 않습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="tutoringResetBtn" copyId="tutoringCopyLinkBtn" />
    </Fragment>

    <!-- 입력 영역 -->
    <Fragment slot="aside">
      <section class="tutoring-input">
        <!-- 자녀 수 선택 -->
        <div class="tutoring-child-count">
          <label class="tutoring-field-label">자녀 수</label>
          <div class="tutoring-count-buttons" id="childCountButtons">
            <button class="tutoring-count-btn is-active" data-count="1" type="button">1명</button>
            <button class="tutoring-count-btn" data-count="2" type="button">2명</button>
            <button class="tutoring-count-btn" data-count="3" type="button">3명</button>
            <button class="tutoring-count-btn" data-count="4" type="button">4명</button>
          </div>
        </div>

        <!-- 자녀별 카드 컨테이너 (JS로 동적 렌더링) -->
        <div id="childCardsContainer"></div>

        <!-- 자녀 카드 템플릿 -->
        <template id="childCardTemplate">
          <div class="tutoring-child-card" data-child-index="">
            <div class="tutoring-child-card__header">
              <span class="tutoring-child-card__title">첫째</span>
              <button class="tutoring-child-card__toggle" type="button" aria-expanded="true">
                <span class="sr-only">접기/펼치기</span>
                <svg class="tutoring-toggle-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
            <div class="tutoring-child-card__body">
              <!-- 학교급 -->
              <div class="tutoring-field">
                <label class="tutoring-field-label">학교급</label>
                <div class="tutoring-level-buttons">
                  <button class="tutoring-level-btn" data-level="preschool" type="button">유아</button>
                  <button class="tutoring-level-btn is-active" data-level="elementary" type="button">초등</button>
                  <button class="tutoring-level-btn" data-level="middle" type="button">중등</button>
                  <button class="tutoring-level-btn" data-level="high" type="button">고등</button>
                </div>
              </div>
              <!-- 학년 -->
              <div class="tutoring-field tutoring-field--grade">
                <label class="tutoring-field-label">학년</label>
                <select class="tutoring-grade-select tutoring-select">
                  <!-- JS로 동적 생성 -->
                </select>
              </div>
              <!-- 지역 -->
              <div class="tutoring-field">
                <label class="tutoring-field-label">지역 <span class="tutoring-field-label--note">(또래 비교용)</span></label>
                <select class="tutoring-region-select tutoring-select">
                  <option value="">선택하세요</option>
                  <option value="seoul">서울</option>
                  <option value="metro">수도권</option>
                  <option value="city">광역시</option>
                  <option value="rural">지방</option>
                </select>
              </div>
              <!-- 과목 목록 -->
              <div class="tutoring-subjects">
                <div class="tutoring-subjects__header">
                  <span class="tutoring-field-label">과목별 월 비용</span>
                  <button class="tutoring-add-subject-btn" type="button">+ 과목 추가</button>
                </div>
                <div class="tutoring-subject-rows">
                  <!-- JS로 과목 행 동적 추가 -->
                </div>
              </div>
              <!-- 교재비 / 기타비용 -->
              <div class="tutoring-extra-costs">
                <div class="tutoring-field tutoring-field--inline">
                  <label class="tutoring-field-label">교재비 (월)</label>
                  <div class="tutoring-input-wrap">
                    <input type="number" class="tutoring-book-cost tutoring-number-input" placeholder="0" min="0" step="10000">
                    <span class="tutoring-input-unit">원</span>
                  </div>
                </div>
                <div class="tutoring-field tutoring-field--inline">
                  <label class="tutoring-field-label">기타비용 (월)</label>
                  <div class="tutoring-input-wrap">
                    <input type="number" class="tutoring-extra-cost tutoring-number-input" placeholder="0" min="0" step="10000">
                    <span class="tutoring-input-unit">원</span>
                  </div>
                </div>
              </div>
              <!-- 자녀 소계 -->
              <div class="tutoring-child-subtotal">
                월 소계: <strong class="tutoring-child-subtotal__value">0원</strong>
              </div>
            </div>
          </div>
        </template>

        <!-- 과목 행 템플릿 -->
        <template id="subjectRowTemplate">
          <div class="tutoring-subject-row">
            <select class="tutoring-subject-name tutoring-select">
              <option value="">과목 선택</option>
            </select>
            <select class="tutoring-learning-type tutoring-select">
              <!-- LEARNING_TYPE_OPTIONS로 채움 -->
            </select>
            <div class="tutoring-input-wrap">
              <input type="number" class="tutoring-subject-cost tutoring-number-input" placeholder="월 비용" min="0" step="10000">
              <span class="tutoring-input-unit">원</span>
            </div>
            <button class="tutoring-remove-subject-btn" type="button" aria-label="과목 삭제">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        </template>
      </section>
    </Fragment>

    <!-- 결과 영역 -->
    <section class="tutoring-result">
      <!-- KPI 카드 4종 -->
      <div class="tutoring-kpi-grid">
        <div class="tutoring-kpi-card">
          <div class="tutoring-kpi-card__label">월 사교육비</div>
          <div class="tutoring-kpi-card__value" id="kpiMonthly">-</div>
        </div>
        <div class="tutoring-kpi-card">
          <div class="tutoring-kpi-card__label">연간 사교육비</div>
          <div class="tutoring-kpi-card__value" id="kpiAnnual">-</div>
        </div>
        <div class="tutoring-kpi-card tutoring-kpi-card--accent">
          <div class="tutoring-kpi-card__label">누적 예상 비용</div>
          <div class="tutoring-kpi-card__value" id="kpiCumulative">-</div>
          <div class="tutoring-kpi-card__context" id="kpiCumulativeContext"></div>
        </div>
        <div class="tutoring-kpi-card">
          <div class="tutoring-kpi-card__label">형제자매 합산</div>
          <div class="tutoring-kpi-card__value" id="kpiTotal">-</div>
          <div class="tutoring-kpi-card__context" id="kpiTotalContext">전체 자녀 기준</div>
        </div>
      </div>

      <!-- 또래 비교 섹션 -->
      <div class="tutoring-comparison" id="comparisonSection">
        <h2 class="tutoring-section-title">우리 집 사교육비는 평균 대비 어느 수준일까?</h2>
        <p class="tutoring-section-note">지역 선택 시 또래 평균(추정)과 비교합니다.</p>
        <div id="comparisonCards">
          <!-- JS 동적 생성 -->
        </div>
      </div>

      <!-- 누적 비용 시뮬레이션 섹션 -->
      <div class="tutoring-simulation" id="simulationSection">
        <h2 class="tutoring-section-title">초등부터 고등까지 누적 교육비는 얼마일까?</h2>
        <p class="tutoring-section-note">첫째 자녀 기준. 학교급 전환 시 비용 변화를 시나리오별로 확인하세요.</p>
        <div class="tutoring-scenario-buttons">
          <button class="tutoring-scenario-btn is-active" data-growth="0" type="button">현재 수준 유지</button>
          <button class="tutoring-scenario-btn" data-growth="0.1" type="button">학교급 상승 시 +10%</button>
          <button class="tutoring-scenario-btn" data-growth="0.2" type="button">학교급 상승 시 +20%</button>
        </div>
        <div class="tutoring-simulation-table" id="simulationTable">
          <!-- JS로 동적 생성 -->
        </div>
      </div>

      <!-- 기회비용 섹션 -->
      <div class="tutoring-opportunity" id="opportunitySection">
        <h2 class="tutoring-section-title">이 돈을 투자했다면 얼마나 되었을까?</h2>
        <div class="tutoring-opportunity-params">
          <div class="tutoring-field">
            <label class="tutoring-field-label">기간</label>
            <div class="tutoring-tab-buttons" id="yearPresets">
              <button class="tutoring-tab-btn" data-years="5" type="button">5년</button>
              <button class="tutoring-tab-btn is-active" data-years="10" type="button">10년</button>
              <button class="tutoring-tab-btn" data-years="15" type="button">15년</button>
            </div>
          </div>
          <div class="tutoring-field">
            <label class="tutoring-field-label">기대수익률</label>
            <div class="tutoring-tab-buttons" id="ratePresets">
              <button class="tutoring-tab-btn" data-rate="0.03" type="button">3%</button>
              <button class="tutoring-tab-btn is-active" data-rate="0.05" type="button">5%</button>
              <button class="tutoring-tab-btn" data-rate="0.07" type="button">7%</button>
            </div>
          </div>
        </div>
        <div class="tutoring-opportunity-result" id="opportunityResult">
          <div class="tutoring-opportunity-card">
            <div class="tutoring-opportunity-card__label">
              월 <span id="opMonthly">-</span> 기준 <span id="opYears">10</span>년 후
            </div>
            <div class="tutoring-opportunity-card__value" id="opFutureValue">-</div>
            <div class="tutoring-opportunity-card__note">
              연 <span id="opRate">5</span>% 수익률 가정 시 참고값
            </div>
            <p class="tutoring-opportunity-card__disclaimer">
              * 실제 투자 수익을 보장하지 않습니다. 세금·수수료 미반영 참고용 시뮬레이션입니다.
            </p>
          </div>
        </div>
        <div class="tutoring-opportunity-links">
          <a href="/tools/dca-investment-calculator/" class="tutoring-link-btn">
            적립식 투자 계산기로 더 자세히 보기 →
          </a>
        </div>
      </div>

      <!-- 절감 팁 섹션 -->
      <div class="tutoring-tips">
        <h2 class="tutoring-section-title">사교육비를 줄이는 현실적인 방법</h2>
        <ul class="tutoring-tips-list">
          <li>과목 수보다 실제 학습 효과를 먼저 점검해보세요</li>
          <li>월 교육비 총액보다 연간 누적 부담을 같이 보세요</li>
          <li>오프라인 학원과 온라인 강의를 혼합하면 비용을 줄일 수 있어요</li>
          <li>학교급 전환 시점에 필수 과목 중심으로 재편해보세요</li>
          <li>형제자매가 있다면 자녀별이 아닌 가계 전체 기준으로 예산을 관리해보세요</li>
        </ul>
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="아이 사교육비 계산기 활용 가이드"
        intro={[
          "아이 한 명당 월 수십만 원의 사교육비는 가계에서 큰 비중을 차지합니다. 특히 학교급이 올라갈수록, 자녀 수가 늘어날수록 누적 부담은 상상 이상으로 커집니다. 이 계산기는 자녀별로 학교급·과목·지역을 입력하면 월 교육비부터 초등~고등 전 기간 누적 예상액까지 한눈에 보여주는 도구입니다.",
          "또래 평균과 비교해 내 지출이 어느 수준인지 확인하고, 같은 금액을 투자했을 때 얼마가 되는지 기회비용 시뮬레이션도 함께 제공합니다. 교육비 예산 계획을 세울 때 출발점으로 활용해보세요.",
        ]}
        inputPoints={[
          "자녀 수를 1~4명으로 선택하면 각 자녀별로 학교급·지역·과목을 따로 설정할 수 있습니다.",
          "과목 추가 버튼으로 영어·수학·코딩 등 각 과목별 월 비용과 학원 유형을 세분화해 입력할 수 있습니다.",
          "지역을 선택하면 해당 지역 또래 평균 추정값과 비교한 티어(절약형·평균권·적극 투자형·고지출형)를 확인할 수 있습니다.",
        ]}
        criteria={[
          "학교급별 평균값은 통계청 2024년 사교육비 조사 기준 추정치입니다. 실제 개인 상황과 다를 수 있습니다.",
          "누적 시뮬레이션은 학교급 전환 시 비용 변화 시나리오(0%, +10%, +20%)를 선택해 비교할 수 있습니다.",
          "기회비용은 적립식 투자 미래가치 공식(FV = PMT × ((1+r)^n − 1) / r) 기준 참고값입니다. 세금·수수료는 미반영입니다.",
        ]}
        faq={faqItems}
        related={TUTORING_RELATED_TOOLS.map((t) => ({
          href: `/tools/${t.slug}/`,
          label: t.label,
        }))}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="tutoringConfig" type="application/json" set:html={JSON.stringify(config)}></script>
  <script type="module" src={withBase("/scripts/child-tutoring-cost-calculator.js")}></script>
</BaseLayout>
