---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import CompareCta from "../../components/CompareCta.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  PSC_ALLOWANCES,
  PSC_CAREER_ROWS,
  PSC_DEFAULT_INPUT,
  PSC_FAQ,
  PSC_META,
  PSC_PRESETS,
  PSC_REGION_ROWS,
  PSC_RELATED_LINKS,
  PSC_WORK_TYPES,
} from "../../data/pharmacistSalaryCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const config = {
  workTypes: PSC_WORK_TYPES,
  careerRows: PSC_CAREER_ROWS,
  regionRows: PSC_REGION_ROWS,
  allowances: PSC_ALLOWANCES,
  defaultInput: PSC_DEFAULT_INPUT,
  presets: PSC_PRESETS,
};

const faqSchema = PSC_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: { "@type": "Answer", text: item.answer },
}));
---

<BaseLayout
  title={PSC_META.seoTitle}
  description={PSC_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: PSC_META.title,
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description: PSC_META.seoDescription,
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/pharmacist-salary-calculator/`,
    mainEntity: { "@type": "FAQPage", mainEntity: faqSchema },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="pharmacist-salary-calculator" pageClass="psc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="약사 연봉"
        title="약사 연봉·실수령 계산기"
        description="근무 형태(병원약사·약국약사·제약사·공공기관·개국약사)와 경력, 지역을 선택하면 2026년 기준 연봉과 월 실수령액 범위를 추정합니다."
        badges={["2026 추정", "근무처별 비교", "경력·지역별"]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          PSC_META.dataNote,
          "연봉·실수령액은 범위(최소~최대) 또는 단일 추정값으로 표시되며, 실제 금액은 근무처·지역·성과급 구조에 따라 달라질 수 있습니다.",
          "병원·약국 봉직약사는 경력별, 개국약사는 지역별 데이터를 기준으로 표시합니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="pscResetBtn" copyId="pscCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 입력</p>
            <h2 class="panel__title">자주 찾는 케이스</h2>
          </div>
          <p class="panel-heading__summary">대표 케이스를 먼저 선택한 뒤 근무 형태·경력·지역을 조정하세요.</p>
        </div>
        <div class="psc-preset-grid">
          {PSC_PRESETS.map((preset, index) => (
            <button
              type="button"
              class={`psc-preset-btn${index === 0 ? " is-active" : ""}`}
              data-preset={preset.id}
            >
              <strong>{preset.label}</strong>
              <span>{preset.description}</span>
            </button>
          ))}
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">기본 조건</p>
            <h2 class="panel__title">근무 형태·경력·지역 입력</h2>
          </div>
          <p class="panel-heading__summary">근무 형태에 따라 경력 또는 지역 선택이 활성화됩니다.</p>
        </div>

        <div class="psc-worktype-grid" role="group" aria-label="근무 형태 선택">
          {PSC_WORK_TYPES.map((type) => (
            <button type="button" class="psc-worktype-btn" data-work-type={type.id}>
              <strong>{type.name}</strong>
              <span>{type.badge}</span>
            </button>
          ))}
        </div>

        <label class="field" id="pscCareerField">
          <span>경력</span>
          <select data-psc="career" class="input-number">
            {PSC_CAREER_ROWS.map((row) => (
              <option value={row.years}>{row.label}</option>
            ))}
          </select>
        </label>

        <label class="field is-hidden" id="pscRegionField">
          <span>지역</span>
          <select data-psc="region" class="input-number">
            {PSC_REGION_ROWS.map((row) => (
              <option value={row.region}>{row.region}</option>
            ))}
          </select>
        </label>
      </article>
    </Fragment>

    <section class="psc-summary-panel panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">결과</p>
          <h2 class="panel__title"><strong id="pscWorkTypeLabel">약국 약사 (봉직)</strong> 연봉·실수령 추정</h2>
        </div>
        <p class="panel-heading__summary" id="pscSummaryText">근무 형태·경력·지역에 따른 연봉·월 실수령을 추정합니다.</p>
      </div>

      <div class="psc-result-grid" aria-live="polite">
        <article class="psc-result-card psc-result-card--main">
          <span>월 실수령 (추정)</span>
          <strong id="pscMonthlyValue">-</strong>
          <small>추정</small>
        </article>
        <article class="psc-result-card psc-result-card--main">
          <span>연봉 (세전, 추정)</span>
          <strong id="pscAnnualValue">-</strong>
          <small>추정</small>
        </article>
        <article class="psc-result-card">
          <span>상세 구분</span>
          <strong id="pscDetailLabel">-</strong>
        </article>
      </div>
      <p class="psc-detail-note" id="pscDetailNote"></p>
    </section>

    <section class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">수당 구조</p>
          <h2 class="panel__title">약사 수당·복리후생</h2>
        </div>
        <p class="panel-heading__summary">근무 형태에 따라 적용 여부와 금액이 달라질 수 있습니다.</p>
      </div>
      <ul class="psc-allowance-list" id="pscAllowanceNotes"></ul>
    </section>

    <section class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">경력별 비교</p>
          <h2 class="panel__title">경력별 병원·약국 약사 연봉</h2>
        </div>
        <p class="panel-heading__summary">선택한 경력을 기준으로 병원약사·약국약사 연봉 범위를 비교합니다.</p>
      </div>
      <div class="psc-table-wrap">
        <table class="psc-table">
          <thead>
            <tr>
              <th>경력</th>
              <th>병원약사 연봉 (추정)</th>
              <th>약국약사 연봉 (추정)</th>
            </tr>
          </thead>
          <tbody id="pscCareerRows"></tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">지역별 비교</p>
          <h2 class="panel__title">지역별 개국약사 연봉·개국비용</h2>
        </div>
        <p class="panel-heading__summary">개국약사를 선택하면 지역별 평균 연봉과 개국 비용을 비교할 수 있습니다.</p>
      </div>
      <div class="psc-table-wrap">
        <table class="psc-table">
          <thead>
            <tr>
              <th>지역</th>
              <th>평균 연봉 (추정)</th>
              <th>개국 비용</th>
              <th>수요</th>
            </tr>
          </thead>
          <tbody id="pscRegionRows"></tbody>
        </table>
      </div>
    </section>

    <CompareCta
      variant="hub"
      title="내 연봉이 전체 직장인 중 어느 위치인지 궁금하다면"
      description="계산된 연봉을 연봉 티어 계산기에 넣어보면 전체 직장인 분포에서 상위 몇 %인지 바로 확인할 수 있습니다."
      links={[
        { href: "/tools/salary-tier/", label: "연봉 티어 계산기" },
        { href: "/reports/pharmacist-salary-2026/", label: "약사 연봉 비교 리포트" },
      ]}
    />

    <Fragment slot="seo">
      <SeoContent
        introTitle="약사 연봉, 근무처마다 왜 이렇게 다를까?"
        intro={[
          "약대를 졸업하고 진로를 고민할 때 가장 헷갈리는 부분이 근무 형태별 연봉 차이입니다. 약사 연봉은 병원약사·약국 봉직약사·제약사·공공기관·개국약사 등 근무 형태에 따라 급여 구조와 수준이 크게 다릅니다. 같은 면허를 가지고도 선택한 진로에 따라 연봉이 2~5배 이상 차이 날 수 있습니다.",
          "이 계산기는 경력 5단계(신입~15년차+)별 병원·약국 봉직약사 연봉, 지역 5곳의 개국약사 평균 연봉·개국비용, 근무 형태별 연봉·실수령 범위를 기반으로 추정치를 보여줍니다. 봉직약사와 개국약사를 같은 화면에서 비교할 수 있게 구성해 진로 선택에 참고할 수 있습니다.",
          "병원·약국 봉직약사는 경력을 선택하면 해당 경력의 연봉 범위가, 개국약사는 지역을 선택하면 해당 지역의 평균 연봉과 개국 비용이 반영됩니다. 개국을 고려한다면 평균 연봉뿐 아니라 초기 개국 비용까지 함께 봐야 실제 순이익을 가늠할 수 있습니다.",
          "다만 이 계산기의 수치는 일반적인 시세를 기준으로 한 추정치이며, 실제 연봉은 근무 지역, 병원·약국의 규모, 개인의 협상력에 따라 크게 달라질 수 있습니다. 진로를 결정하기 전에는 실제 채용 공고나 업계 종사자의 정보를 함께 참고하는 것을 권장합니다.",
        ]}
        inputPoints={[
          "근무 형태(병원약사·약국약사·제약사·공공기관·개국약사)를 선택하면 해당 형태의 연봉 구조가 반영됩니다.",
          "병원약사·약국약사를 선택하면 경력(신입~15년차+) 5단계 중 하나를 선택할 수 있습니다.",
          "개국약사를 선택하면 지역 5곳 중 하나를 선택해 지역별 평균 연봉과 개국 비용이 반영됩니다.",
          "경력별 비교표와 지역별 비교표에서 선택한 조건이 다른 항목과 비교되어 강조 표시됩니다.",
        ]}
        criteria={[
          "연봉·실수령액은 대한약사회 실태조사, 병원약사회, 제약업계 공시 자료를 종합한 추정치입니다.",
          "병원약사 월 실수령은 연봉의 약 78%, 약국약사는 약 75%, 개국약사는 약 65%를 적용한 추정치이며 실제 세후 금액은 소득·세액공제에 따라 달라집니다.",
          "개국약사 연봉은 지역 평균 추정치(단일값)이며, 입지·처방전 수에 따라 실제 수입은 크게 달라질 수 있습니다.",
          "제약·바이오, 공공기관 약사는 직무·기관별 편차가 커 경력·지역 데이터를 별도 반영하지 않습니다.",
        ]}
        faq={PSC_FAQ}
        related={PSC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="pscConfig" type="application/json" set:html={JSON.stringify(config)} />
  <script type="module" src={withBase("/scripts/pharmacist-salary-calculator.js")}></script>
</BaseLayout>
