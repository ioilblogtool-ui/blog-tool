---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import ToolTabs from "../../components/ToolTabs.astro";
import SummaryCards from "../../components/SummaryCards.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout title="육아휴직 계산기" description="육아휴직 급여와 복직 후 수입을 비교하는 도구">
  <SiteHeader />

  <main class="container page-shell calculator-page" data-calculator="leave">
    <CalculatorHero
      eyebrow="Parental Leave Tool"
      title="육아휴직 계산기"
      description="휴직 중 월 수령액과 복직 후 연봉 기준 실수령을 비교해 필요한 생활비 버퍼를 계산합니다."
    />
    <ToolTabs />

    <ToolActionBar resetId="resetLeaveBtn" copyId="copyLeaveLinkBtn" />

    <section class="calculator-grid">
      <div class="stack">
        <article class="panel">
          <h2 class="panel__title">육아휴직 입력</h2>
          <div class="form-grid">
            <label class="field">
              <span>휴직 전 월 실수령</span>
              <input id="leaveBeforeNet" type="number" value="3200000" />
            </label>
            <label class="field">
              <span>복직 후 연봉</span>
              <input id="leaveAfterAnnual" type="number" value="52000000" />
              <small id="leaveAfterAnnualHint"></small>
            </label>
            <label class="field">
              <span>휴직 중 월 수령액</span>
              <input id="leaveMonthlyIncome" type="number" value="1500000" />
            </label>
            <label class="field">
              <span>휴직 개월 수</span>
              <input id="leaveMonths" type="number" value="12" />
            </label>
            <label class="field">
              <span>중간정산 금액</span>
              <input id="leaveRetirementPayout" type="number" value="12000000" />
              <small id="leaveRetirementPayoutHint"></small>
            </label>
            <label class="field">
              <span>보너스</span>
              <input id="leaveBonus" type="number" value="3000000" />
              <small id="leaveBonusHint"></small>
            </label>
            <label class="field">
              <span>연차수당</span>
              <input id="leaveAnnualLeavePay" type="number" value="1000000" />
              <small id="leaveAnnualLeavePayHint"></small>
            </label>
            <label class="check-field">
              <input id="leaveIncludeBonus" type="checkbox" checked />
              <span>복직 후 총보상에 보너스 포함</span>
            </label>
          </div>
          <button id="calcLeaveBtn" class="button button--primary" type="button">비교하기</button>
        </article>

        <InfoNotice
          title="안내"
          lines={[
            "실수령과 휴직 급여는 간이 추정 기준이며 실제 제도와 차이가 있을 수 있습니다.",
            "정책형 계산기는 연도별 제도 변경 여부를 함께 확인하는 것이 좋습니다.",
            "복직 후 총보상은 보너스 포함 여부에 따라 크게 달라질 수 있습니다."
          ]}
        />
      </div>

      <div class="stack">
        <SummaryCards
          columns={4}
          items={[
            { label: "휴직 중 월 수령", id: "leaveMonthlyIncomeCard" },
            { label: "복직 후 월 실수령", id: "leaveAfterMonthlyNet" },
            { label: "월 차이", id: "leaveMonthlyGap" },
            { label: "버퍼 가능 개월", id: "leaveBufferMonths" }
          ]}
        />

        <article class="panel">
          <h2 class="panel__title">비교 상세</h2>
          <div class="table-wrap">
            <table class="result-table">
              <thead>
                <tr>
                  <th>항목</th>
                  <th>값</th>
                </tr>
              </thead>
              <tbody id="leaveTable"></tbody>
            </table>
          </div>
        </article>
      </div>
    </section>
  </main>

  <script type="module" src={withBase("/scripts/tools.js")}></script>
</BaseLayout>
