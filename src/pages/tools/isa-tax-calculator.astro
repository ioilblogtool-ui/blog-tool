---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import CompareCta from "../../components/CompareCta.astro";
import {
  ISA_TYPES,
  ISA_PRODUCTS,
  ISA_LIMITS,
  ISA_META,
  ISA_FAQS,
  ISA_RELATED,
} from "../../data/isaCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const configData = { types: ISA_TYPES, products: ISA_PRODUCTS, limits: ISA_LIMITS };

const faqSchema = ISA_FAQS.map((f) => ({
  "@type": "Question",
  name: f.question,
  acceptedAnswer: { "@type": "Answer", text: f.answer },
}));
---

<BaseLayout
  title={ISA_META.title}
  description={ISA_META.description}
  ogImage="/og/tools/isa-tax-calculator.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "ISA 계좌 절세 시뮬레이터 2026",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description: ISA_META.description,
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/isa-tax-calculator/`,
    mainEntity: { "@type": "FAQPage", mainEntity: faqSchema },
  }}
>
  <SiteHeader />

  <script id="isacConfig" type="application/json" set:html={JSON.stringify(configData)} />

  <SimpleToolShell calculatorId="isa-tax-calculator" pageClass="isac-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="ISA 절세 시뮬레이터"
        title="ISA 계좌 절세 시뮬레이터 2026"
        description="투자 유형, 연간 납입액, 수익률, 기간을 입력하면 비과세 혜택과 절세액을 일반 계좌와 자동 비교합니다. 서민형이면 비과세 한도가 2배입니다."
        stats={[
          { label: "일반형 비과세", value: "200만원" },
          { label: "서민형 비과세", value: "400만원" },
          { label: "초과분 세율", value: "9.9%" },
        ]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          "이 시뮬레이터는 참고용 추정값입니다. 실제 세금은 개인 상황·상품 구성에 따라 다를 수 있습니다.",
          "ISA 의무 가입 기간 3년 미만 해지 시 비과세 혜택이 소멸됩니다.",
          "2026년 세법 기준. 세법 개정 시 수치가 달라질 수 있습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="isacResetBtn" copyId="isacCopyBtn" />
    </Fragment>

    <!-- 입력 패널 -->
    <Fragment slot="aside">
      <article class="panel isac-input-panel" data-isac-calculator>
        <!-- ISA 유형 -->
        <div class="isac-section">
          <h2 class="isac-section-title">ISA 유형</h2>
          <div class="isac-type-list">
            {ISA_TYPES.map((t, i) => (
              <label class={`isac-type-item${i === 0 ? " active" : ""}`} data-isac-type-label={t.id}>
                <input
                  type="radio"
                  name="isacType"
                  value={t.id}
                  data-isac-type
                  checked={i === 0}
                />
                <div class="isac-type-header">
                  <span class="isac-type-name">{t.label}</span>
                  {t.badge && <span class="isac-type-badge">{t.badge}</span>}
                  <span class="isac-type-limit">비과세 {(t.taxFreeLimit / 10000).toLocaleString("ko-KR")}만원</span>
                </div>
                <p class="isac-type-eligibility">{t.eligibility}</p>
              </label>
            ))}
          </div>
        </div>

        <!-- 납입·수익 입력 -->
        <div class="isac-section">
          <h2 class="isac-section-title">투자 조건</h2>
          <div class="isac-field">
            <label class="isac-label" for="isacAnnual">연간 납입액</label>
            <div class="isac-input-wrap">
              <input
                id="isacAnnual"
                type="text"
                class="isac-input"
                data-isac-annual
                value="1,200만원"
                inputmode="numeric"
              />
              <span class="isac-unit">원</span>
            </div>
            <div class="isac-hint">최대 {(ISA_LIMITS.annualMax / 10000).toLocaleString("ko-KR")}만원/년</div>
          </div>
          <div class="isac-field">
            <label class="isac-label" for="isacRate">연 수익률</label>
            <div class="isac-input-wrap">
              <input
                id="isacRate"
                type="number"
                class="isac-input"
                data-isac-rate
                value="5"
                min="0.1"
                max="30"
                step="0.1"
              />
              <span class="isac-unit">%</span>
            </div>
          </div>
          <div class="isac-field">
            <label class="isac-label" for="isacPeriod">투자 기간</label>
            <div class="isac-input-wrap">
              <input
                id="isacPeriod"
                type="number"
                class="isac-input"
                data-isac-period
                value="5"
                min="3"
                max="10"
              />
              <span class="isac-unit">년</span>
            </div>
            <div class="isac-hint">의무 가입 기간 최소 3년</div>
          </div>
        </div>

        <!-- 투자 상품 유형 -->
        <div class="isac-section">
          <h2 class="isac-section-title">투자 상품</h2>
          <div class="isac-product-list">
            {ISA_PRODUCTS.map((p, i) => (
              <label class={`isac-product-item${i === 1 ? " active" : ""}`} data-isac-product-label={p.id}>
                <input
                  type="radio"
                  name="isacProduct"
                  value={p.id}
                  data-isac-product
                  checked={i === 1}
                />
                <span class="isac-product-name">{p.label}</span>
                <span class="isac-product-note">{p.note}</span>
              </label>
            ))}
          </div>
        </div>
      </article>
    </Fragment>

    <!-- 결과 영역 -->
    <div class="isac-results">
      <!-- 핵심 요약 카드 -->
      <div class="isac-summary-cards">
        <div class="isac-card isac-card--hero">
          <div class="isac-card-label">ISA 절세 효과 (만기 기준)</div>
          <div class="isac-card-value" data-isac-tax-save>—</div>
          <div class="isac-card-sub" data-isac-tax-save-desc">일반 계좌 대비 절약</div>
        </div>
        <div class="isac-card">
          <div class="isac-card-label">만기 수령액 (ISA)</div>
          <div class="isac-card-value" data-isac-isa-final>—</div>
          <div class="isac-card-sub" data-isac-period-label>—</div>
        </div>
        <div class="isac-card isac-card--normal">
          <div class="isac-card-label">만기 수령액 (일반 계좌)</div>
          <div class="isac-card-value" data-isac-normal-final>—</div>
          <div class="isac-card-sub">동일 조건 일반 계좌</div>
        </div>
      </div>

      <!-- 세금 비교 상세 -->
      <div class="isac-detail-section">
        <h3 class="isac-detail-title">세금 상세 비교</h3>
        <div class="isac-compare-table">
          <div class="isac-compare-row isac-compare-row--head">
            <span></span>
            <span>ISA 계좌</span>
            <span>일반 계좌</span>
          </div>
          <div class="isac-compare-row">
            <span class="isac-compare-label">총 납입원금</span>
            <span data-isac-principal-isa>—</span>
            <span data-isac-principal-normal>—</span>
          </div>
          <div class="isac-compare-row">
            <span class="isac-compare-label">총 수익 (세전)</span>
            <span data-isac-profit-isa>—</span>
            <span data-isac-profit-normal>—</span>
          </div>
          <div class="isac-compare-row">
            <span class="isac-compare-label">비과세 금액</span>
            <span class="isac-compare-highlight" data-isac-taxfree>—</span>
            <span class="isac-compare-dim">해당 없음</span>
          </div>
          <div class="isac-compare-row">
            <span class="isac-compare-label">과세 금액</span>
            <span data-isac-taxable-isa>—</span>
            <span data-isac-taxable-normal>—</span>
          </div>
          <div class="isac-compare-row">
            <span class="isac-compare-label">세율</span>
            <span data-isac-rate-isa>—</span>
            <span data-isac-rate-normal>—</span>
          </div>
          <div class="isac-compare-row isac-compare-row--total">
            <span class="isac-compare-label">납부 세금</span>
            <span data-isac-tax-isa>—</span>
            <span data-isac-tax-normal>—</span>
          </div>
          <div class="isac-compare-row isac-compare-row--final">
            <span class="isac-compare-label">최종 수령액</span>
            <span class="isac-compare-highlight" data-isac-final-isa>—</span>
            <span data-isac-final-normal>—</span>
          </div>
        </div>
      </div>

      <!-- 연도별 누적 절세 -->
      <div class="isac-detail-section">
        <h3 class="isac-detail-title">연도별 누적 절세액</h3>
        <div class="isac-yearly-table-wrap">
          <table class="isac-yearly-table">
            <thead>
              <tr>
                <th>연차</th>
                <th>누적 납입</th>
                <th>누적 수익 (세전)</th>
                <th>절세액 누계</th>
              </tr>
            </thead>
            <tbody data-isac-yearly-body>
              <!-- JS로 채움 -->
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- CTA 1: ISA 만기 후 연금 이전 -->
    <CompareCta
      eyebrow="다음 단계"
      title="ISA 만기 후 연금 계좌로 이전하면?"
      description="ISA 만기 수령액을 IRP·연금저축으로 이전하면 전환금액의 10%(최대 300만원) 추가 세액공제를 받을 수 있습니다. 지금 바로 계산해보세요."
      variant="hub"
      links={[
        { href: "/tools/irp-pension-calculator/", label: "IRP 연금 계산기", tone: "primary" },
        { href: "/tools/year-end-tax-refund-calculator/", label: "연말정산 환급 계산기", tone: "secondary" },
      ]}
    />

    <!-- CTA 2: 세금·투자 관련 도구 -->
    <CompareCta
      eyebrow="함께 쓰는 계산기"
      title="ISA 계좌 개설 전 확인하세요"
      description="ISA를 개설할 증권사 수수료를 비교하거나, 국내주식 양도세 계산이 필요하다면 아래 계산기를 활용해보세요."
      variant="bonus"
      links={[
        { href: "/tools/stock-brokerage-fee-calculator/", label: "증권사 수수료 비교", tone: "primary" },
        { href: "/tools/domestic-stock-capital-gains-tax/", label: "국내주식 양도세 계산기", tone: "secondary" },
      ]}
    />
    <Fragment slot="seo">
      <SeoContent
        introTitle="ISA 계좌 절세 시뮬레이터 사용법"
        intro={[
          "ISA(개인종합자산관리계좌)는 하나의 계좌에서 예금, ETF, 펀드, 국내주식을 통합 운용하면서 비과세·분리과세 혜택을 받는 계좌입니다. 목돈을 3년 이상 묻어둘 수 있는 시점에 일반 계좌와 비교해 세금이 얼마나 줄어드는지 가늠하고 싶을 때, 일반형과 서민형 중 어느 유형이 본인 상황에 더 유리한지 따져볼 때, 또는 연간 납입액과 투자 기간을 바꿔보며 만기 수령액 차이를 미리 시뮬레이션하고 싶을 때 이 계산기가 필요합니다.",
          "계산은 연간 납입액, 연 수익률, 투자 기간을 기준으로 ISA 계좌와 일반 계좌 각각의 만기 수령액을 산출한 뒤 차이를 비교하는 방식입니다. ISA는 비과세 한도(일반형 200만원, 서민형·농어민형 400만원)까지는 세금이 없고, 한도를 넘는 수익에는 9.9% 분리과세가 적용됩니다. 일반 계좌는 이자·배당소득에 15.4% 세율이 그대로 적용되기 때문에, 같은 수익이라도 ISA 쪽의 세후 수령액이 더 많아지는 구조입니다. 또한 ISA는 계좌 내 여러 상품의 손익을 합산하는 손익통산이 적용되어, 일부 상품에서 손실이 나더라도 전체 순이익 기준으로 세금이 계산됩니다.",
          "결과에서는 ISA 절세 효과(일반 계좌 대비 절약액)가 핵심 지표입니다. 이 금액이 클수록 ISA를 활용하는 의미가 커지며, 투자 기간이 길어지고 수익률이 높아질수록 절세 효과도 함께 커지는 경향이 있습니다. 세금 상세 비교 표에서 비과세 금액과 과세 금액의 비율을 보면, 본인의 투자 규모가 비과세 한도를 얼마나 초과하는지 확인할 수 있고, 연도별 누적 절세액 표를 보면 의무 가입 기간 3년을 채우는 시점부터 절세 효과가 본격적으로 누적되는 흐름을 파악할 수 있습니다.",
          "이 시뮬레이터는 참고용 추정값이며 실제 세금은 가입 시점의 세법, 개인의 다른 금융소득 종합과세 여부, 상품 구성에 따라 달라질 수 있습니다. ISA는 의무 가입 기간 3년을 채우지 못하고 중도 해지하면 비과세·분리과세 혜택이 소멸되므로 자금 운용 계획을 먼저 세워야 합니다. 2026년 세법을 기준으로 계산했으며, 세법이 개정되면 비과세 한도나 세율이 달라질 수 있으니 실제 가입 전에는 금융사 상담과 국세청 안내를 함께 확인하시기 바랍니다.",
        ]}
        faq={ISA_FAQS.map((f) => ({ question: f.question, answer: f.answer }))}
        related={ISA_RELATED}
      />
    </Fragment>
  </SimpleToolShell>
</BaseLayout>

<script src={withBase("scripts/isa-tax-calculator.js")} defer></script>
