---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  UCC_META,
  UCC_FAQ,
  UCC_SEO_CONTENT,
  UCC_RELATED_LINKS,
  UCC_CONFIG,
  UCC_DEFAULT_INPUT,
} from "../../data/universityCostCalculator2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${UCC_META.slug}/`;
const man = (value: number) => `${Math.round(value / 10000).toLocaleString("ko-KR")}만원`;
---

<BaseLayout
  title={UCC_META.seoTitle}
  description={UCC_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: UCC_META.title,
      applicationCategory: "UtilityApplication",
      operatingSystem: "All",
      description: UCC_META.seoDescription,
      url: pageUrl,
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: UCC_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={UCC_META.slug} pageClass="ucc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="대학 등록금 계산"
        title={UCC_META.title}
        description="등록금·주거비·생활비·통학비를 입력하고 국가장학금을 빼면 대학 4년 실제 부담금을 바로 계산합니다."
        badges={["등록금", "대학생", "2026", "4년 총비용"]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          UCC_META.dataNote,
          "입력값은 브라우저에서만 계산되며 서버로 전송하지 않습니다.",
          "알바 등 학생 본인 소득은 포함하지 않은 계산입니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="uccResetBtn" copyId="uccCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel ucc-preset-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 설정</p>
            <h2 class="panel__title">등록금 프리셋</h2>
          </div>
          <p class="panel-heading__summary">2026학년도 실제 보도된 평균값을 바로 채웁니다.</p>
        </div>
        <div class="ucc-preset-grid">
          {UCC_CONFIG.tuitionPresets.map((preset) => (
            <button type="button" class="ucc-preset-btn" data-ucc-tuition-preset={preset.id} data-ucc-tuition-value={preset.annualTuition}>
              <strong>{preset.label}</strong>
              <span>{man(preset.annualTuition)}</span>
            </button>
          ))}
        </div>
      </article>

      <article class="panel ucc-input-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">등록금·주거·생활비</h2>
          </div>
        </div>

        <section class="ucc-input-section">
          <h3>연간 등록금</h3>
          <div class="form-grid">
            <label class="field">
              <span>연간 등록금</span>
              <input data-ucc="annualTuition" type="text" inputmode="numeric" class="input-number" value={UCC_DEFAULT_INPUT.annualTuition.toLocaleString("ko-KR")} />
              <small>기본값은 2026학년도 전체 평균입니다.</small>
            </label>
          </div>
          <div class="calc-slider-row">
            <input type="range" id="uccTuitionSlider" class="calc-slider" min="0" max="15000000" step="100000" value={UCC_DEFAULT_INPUT.annualTuition} />
            <span id="uccTuitionSliderVal" class="calc-slider-val">{man(UCC_DEFAULT_INPUT.annualTuition)}</span>
          </div>
        </section>

        <section class="ucc-input-section">
          <h3>거주 형태</h3>
          <div class="toggle-grid">
            {UCC_CONFIG.residencePresets.map((preset, i) => (
              <label class="mode-chip">
                <input type="radio" name="uccResidence" value={preset.type} checked={i === 0} />
                <span>{preset.label}</span>
              </label>
            ))}
          </div>
          <p class="ucc-note" data-ucc-residence-note>{UCC_CONFIG.residencePresets[0].note}</p>
        </section>

        <section class="ucc-input-section">
          <h3>월 주거비·생활비·통학비</h3>
          <div class="form-grid">
            <label class="field">
              <span>월 주거비</span>
              <input data-ucc="monthlyHousing" type="text" inputmode="numeric" class="input-number" value={UCC_DEFAULT_INPUT.monthlyHousing.toLocaleString("ko-KR")} />
            </label>
            <div class="calc-slider-row">
              <input type="range" id="uccHousingSlider" class="calc-slider" min="0" max="1500000" step="10000" value={UCC_DEFAULT_INPUT.monthlyHousing} />
              <span id="uccHousingSliderVal" class="calc-slider-val">{man(UCC_DEFAULT_INPUT.monthlyHousing)}</span>
            </div>

            <label class="field">
              <span>월 생활비</span>
              <input data-ucc="monthlyLiving" type="text" inputmode="numeric" class="input-number" value={UCC_DEFAULT_INPUT.monthlyLiving.toLocaleString("ko-KR")} />
            </label>
            <div class="calc-slider-row">
              <input type="range" id="uccLivingSlider" class="calc-slider" min="0" max="2000000" step="10000" value={UCC_DEFAULT_INPUT.monthlyLiving} />
              <span id="uccLivingSliderVal" class="calc-slider-val">{man(UCC_DEFAULT_INPUT.monthlyLiving)}</span>
            </div>

            <label class="field">
              <span>월 통학비</span>
              <input data-ucc="monthlyCommute" type="text" inputmode="numeric" class="input-number" value={UCC_DEFAULT_INPUT.monthlyCommute.toLocaleString("ko-KR")} />
            </label>
            <div class="calc-slider-row">
              <input type="range" id="uccCommuteSlider" class="calc-slider" min="0" max="500000" step="10000" value={UCC_DEFAULT_INPUT.monthlyCommute} />
              <span id="uccCommuteSliderVal" class="calc-slider-val">{man(UCC_DEFAULT_INPUT.monthlyCommute)}</span>
            </div>
          </div>
        </section>

        <section class="ucc-input-section">
          <h3>국가장학금·재학 기간</h3>
          <div class="form-grid">
            <label class="field">
              <span>연간 장학금</span>
              <input data-ucc="annualScholarship" type="text" inputmode="numeric" class="input-number" value={UCC_DEFAULT_INPUT.annualScholarship.toLocaleString("ko-KR")} />
              <small>국가장학금 계산기에서 확인한 예상 지원금을 입력하세요.</small>
            </label>
          </div>
          <div class="calc-slider-row">
            <input type="range" id="uccScholarshipSlider" class="calc-slider" min="0" max="10000000" step="100000" value={UCC_DEFAULT_INPUT.annualScholarship} />
            <span id="uccScholarshipSliderVal" class="calc-slider-val">{man(UCC_DEFAULT_INPUT.annualScholarship)}</span>
          </div>

          <div class="toggle-grid">
            <label class="mode-chip">
              <input type="radio" name="uccYears" value="4" checked />
              <span>4년</span>
            </label>
            <label class="mode-chip">
              <input type="radio" name="uccYears" value="6" />
              <span>6년(약학 등)</span>
            </label>
          </div>
        </section>
      </article>
    </Fragment>

    <section class="ucc-section ucc-result-section" aria-live="polite">
      <div class="section-header">
        <p class="section-header__eyebrow">계산 결과</p>
        <h2>대학 4년 실부담금</h2>
        <p>입력값을 바꾸면 등록금·주거생활비·장학금 반영 결과가 즉시 다시 계산됩니다.</p>
      </div>
      <div class="ucc-kpi-grid">
        <article class="ucc-kpi"><span>등록금 총액</span><strong data-ucc-result="tuitionTotal">-</strong></article>
        <article class="ucc-kpi"><span>주거·생활비 총액</span><strong data-ucc-result="livingTotal">-</strong></article>
        <article class="ucc-kpi"><span>장학금 총액</span><strong data-ucc-result="aidTotal">-</strong></article>
        <article class="ucc-kpi ucc-kpi--accent"><span>4년 실부담금</span><strong data-ucc-result="netBurden">-</strong></article>
      </div>
      <p class="ucc-summary">월평균 필요액 <strong data-ucc-result="monthlyAverage">-</strong> · 장학금이 총비용의 <strong data-ucc-result="aidCoverageRatio">0%</strong>를 충당합니다.</p>
    </section>

    <section class="ucc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">구성 보기</p>
        <h2>총비용 vs 실부담금</h2>
      </div>
      <div class="toggle-grid ucc-view-toggle">
        <label class="mode-chip">
          <input type="radio" name="uccViewMode" value="GROSS" checked />
          <span>총비용 보기</span>
        </label>
        <label class="mode-chip">
          <input type="radio" name="uccViewMode" value="NET" />
          <span>실부담금 보기</span>
        </label>
      </div>
      <div class="ucc-breakdown" data-ucc-breakdown></div>
    </section>

    <section class="ucc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">참고 데이터</p>
        <h2>설립유형·계열별 등록금, 거주형태별 월비용</h2>
      </div>
      <div class="ucc-table-wrap">
        <table class="ucc-table">
          <thead><tr><th>구분</th><th>연간 등록금</th></tr></thead>
          <tbody>
            {UCC_CONFIG.tuitionPresets.map((preset) => (
              <tr><td>{preset.label}</td><td>{man(preset.annualTuition)}</td></tr>
            ))}
          </tbody>
        </table>
        <table class="ucc-table">
          <thead><tr><th>거주 형태</th><th>월 주거비</th><th>월 생활비(참고)</th></tr></thead>
          <tbody>
            {UCC_CONFIG.residencePresets.map((preset) => (
              <tr><td>{preset.label}</td><td>{man(preset.monthlyHousingDefault)}</td><td>{man(preset.monthlyLivingDefault)}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="ucc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">추이</p>
        <h2>최근 5년 등록금 인상·동결 현황</h2>
      </div>
      <div class="ucc-table-wrap">
        <table class="ucc-table">
          <thead><tr><th>학년도</th><th>법정 인상 상한</th><th>실제 인상 대학 수</th></tr></thead>
          <tbody>
            {UCC_CONFIG.tuitionTrend.map((row) => (
              <tr><td>{row.year}</td><td>{row.legalCapRate}%</td><td>{row.raisedSchools}개교</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="ucc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">다음 확인</p>
        <h2>관련 계산기·리포트</h2>
      </div>
      <div class="ucc-cta-grid">
        {UCC_RELATED_LINKS.map((link) => (
          <a href={withBase(link.href)} class="ucc-cta-card">
            <strong>{link.label}</strong>
            <span>{link.description}</span>
          </a>
        ))}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle={UCC_SEO_CONTENT.introTitle}
        intro={UCC_SEO_CONTENT.intro}
        inputPoints={UCC_SEO_CONTENT.inputPoints}
        criteria={UCC_SEO_CONTENT.criteria}
        faq={UCC_FAQ}
        related={UCC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="ucc-data" type="application/json" set:html={JSON.stringify(UCC_CONFIG)} />
  <script type="module" src={withBase("/scripts/university-cost-calculator-2026.js")}></script>
</BaseLayout>
