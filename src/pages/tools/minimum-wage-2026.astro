---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  INCOME_TAX_BRACKETS,
  INSURANCE_RATES,
  MINIMUM_WAGE_2026,
  MONTHLY_WEEKS,
  MWC_FAQS,
  MWC_PRESETS,
  MWC_RELATED_CALCULATORS,
  NONTAX_MEAL,
  SEO_CRITERIA,
  SEO_INTRO,
  WEEKLY_HOLIDAY_MIN_HOURS,
  formatPercent,
  formatWon,
  minimumWageAnnual,
  minimumWageIncreaseAmount,
  minimumWageIncreaseRate,
  minimumWageMonthly,
} from "../../data/minimumWage2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");

const config = {
  minimumWage: MINIMUM_WAGE_2026,
  monthlyWeeks: MONTHLY_WEEKS,
  weeklyHolidayMinHours: WEEKLY_HOLIDAY_MIN_HOURS,
  nontaxMeal: NONTAX_MEAL,
  insuranceRates: INSURANCE_RATES,
  incomeTaxBrackets: INCOME_TAX_BRACKETS,
  presets: MWC_PRESETS,
};

const faqSchema = MWC_FAQS.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: { "@type": "Answer", text: item.answer },
}));
---

<BaseLayout
  title="2026 최저임금 계산기 — 시급 월급 환산·주휴수당·세후 실수령 한 번에"
  description="2026년 최저임금 기준으로 시급·주급·월급·연봉을 즉시 환산합니다. 주휴수당 포함 여부, 4대보험 공제 후 세후 실수령액까지 한 번에 확인하고 최저임금 미달 여부도 즉시 판단하세요."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "2026 최저임금 계산기",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    url: `${siteUrl}/tools/minimum-wage-2026/`,
    description: "2026년 최저임금 기준 시급·월급·주휴수당·세후 실수령액을 계산하는 도구",
    mainEntity: { "@type": "FAQPage", mainEntity: faqSchema },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="minimum-wage-2026" pageClass="mwc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="2026 최저임금 계산기"
        title="2026 최저임금 완전 계산기"
        description="2026 최저임금 기준으로 시급·주급·월급·연봉을 즉시 계산합니다. 주휴수당 포함 여부와 4대보험 공제 후 실수령액까지 한 번에 확인하세요."
      />
      <div class="mwc-official-strip">
        <article>
          <span>2026 시급</span>
          <strong>{formatWon(MINIMUM_WAGE_2026)}</strong>
          <small>전년 대비 +{formatWon(minimumWageIncreaseAmount)} · {formatPercent(minimumWageIncreaseRate)}</small>
        </article>
        <article>
          <span>월 환산액</span>
          <strong>{formatWon(minimumWageMonthly)}</strong>
          <small>주 40시간·유급주휴 포함 209시간</small>
        </article>
        <article>
          <span>연 환산액</span>
          <strong>{formatWon(minimumWageAnnual)}</strong>
          <small>세전 단순 환산</small>
        </article>
      </div>
      <InfoNotice
        title="계산 기준 안내"
        lines={[
          "2026년 적용 최저임금은 최저임금위원회 공개 기준 시간급 10,320원, 월 환산 2,156,880원을 사용했습니다.",
          "4대보험과 소득세는 간편 추정값이며 실제 원천징수와 다를 수 있습니다.",
          "주휴수당 발생 여부는 계약서상 소정근로시간 기준이며 실제 근무시간과 다를 수 있습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="mwcResetBtn" copyId="mwcCopyLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <div class="mwc-aside-stack" data-mwc-calculator>
        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">대표 예시</p>
              <h2 class="panel__title">근무 패턴 빠른 입력</h2>
            </div>
          </div>
          <div class="mwc-preset-grid">
            {MWC_PRESETS.map((preset, index) => (
              <button
                type="button"
                class={`mwc-preset-btn${index === 0 ? " is-active" : ""}`}
                data-mwc-preset={preset.id}
              >
                {preset.label}
              </button>
            ))}
          </div>
        </article>

        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">기본 입력</p>
              <h2 class="panel__title">근로 조건 입력</h2>
            </div>
            <p class="panel-heading__summary">시급과 주 소정근로시간을 기준으로 환산합니다.</p>
          </div>

          <div class="form-grid form-grid--compact">
            <label class="field">
              <span>시급 입력 방식</span>
              <select data-mwc-hourly-mode class="select">
                <option value="auto">2026 최저임금 자동 ({formatWon(MINIMUM_WAGE_2026)})</option>
                <option value="manual">직접 입력</option>
              </select>
            </label>

            <label class="field" data-mwc-hourly-field hidden>
              <span>시급 (원)</span>
              <input data-mwc-hourly-wage type="number" min="0" step="10" class="input-number" value={MINIMUM_WAGE_2026} />
              <small>최저임금 충족 여부를 즉시 확인합니다.</small>
            </label>

            <label class="field">
              <span>주 소정근로시간</span>
              <input data-mwc-weekly-hours type="number" min="1" max="40" step="0.5" value="40" class="input-number" />
            </label>

            <label class="field">
              <span>1일 근무시간</span>
              <input data-mwc-daily-hours type="number" min="1" max="12" step="0.5" value="8" class="input-number" />
            </label>

            <label class="field">
              <span>주 근무일수</span>
              <input data-mwc-weekly-days type="number" min="1" max="7" step="1" value="5" class="input-number" />
            </label>

            <label class="field field--toggle">
              <span>주휴수당 포함</span>
              <input type="checkbox" data-mwc-include-holiday checked />
              <small data-mwc-holiday-note>주 15시간 이상 시 자동 발생</small>
            </label>

            <label class="field">
              <span>4대보험·세금 공제</span>
              <select data-mwc-deduction-mode class="select">
                <option value="estimated">간편 추정</option>
                <option value="none">공제 없이 세전만</option>
                <option value="custom">직접 공제율 입력</option>
              </select>
            </label>

            <label class="field" data-mwc-custom-rate-field hidden>
              <span>공제율 (%)</span>
              <input data-mwc-custom-rate type="number" min="0" max="50" step="0.1" value="9.8" class="input-number" />
            </label>

            <label class="field field--toggle" data-mwc-trainee-field hidden>
              <span>수습 기간 90% 적용</span>
              <input type="checkbox" data-mwc-trainee />
              <small>예외 요건이 맞는 경우에만 참고하세요.</small>
            </label>
          </div>
        </article>
      </div>
    </Fragment>

    <section class="mwc-result-stack" aria-live="polite">
      <div class="mwc-kpi-grid">
        <article class="mwc-kpi-card mwc-kpi-card--main">
          <span>세후 실수령 (월)</span>
          <strong data-mwc-monthly-net>-</strong>
          <small>4대보험·소득세 공제 후 추정</small>
        </article>
        <article class="mwc-kpi-card">
          <span>월급 (세전)</span>
          <strong data-mwc-monthly-gross>-</strong>
          <small>주휴수당 포함 여부 반영</small>
        </article>
        <article class="mwc-kpi-card">
          <span>실질 시급</span>
          <strong data-mwc-effective-hourly>-</strong>
          <small>주휴수당 포함 환산</small>
        </article>
        <article class="mwc-kpi-card" data-mwc-compliance-section hidden>
          <span>최저임금 충족</span>
          <strong data-mwc-compliance-badge class="mwc-badge">-</strong>
          <small>세전 시급 기준</small>
        </article>
      </div>

      <div class="mwc-deficit-banner" data-mwc-deficit-banner hidden>
        <p>입력하신 시급은 2026 최저임금 미달입니다.</p>
        <p>월 미달 추정액: <strong data-mwc-deficit-amount>-</strong></p>
        <a href="https://minwon.moel.go.kr" target="_blank" rel="noopener">고용노동부 민원마당 보기</a>
      </div>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">환산 결과</p>
            <h2 class="panel__title">시급·일급·주급·월급·연봉 환산</h2>
          </div>
        </div>
        <div class="mwc-table-wrap">
          <table class="mwc-summary-table">
            <thead>
              <tr>
                <th scope="col">기간</th>
                <th scope="col">세전</th>
                <th scope="col">세후 추정</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">시간</th>
                <td data-mwc-effective-hourly>-</td>
                <td>-</td>
              </tr>
              <tr>
                <th scope="row">일</th>
                <td data-mwc-daily-gross>-</td>
                <td>-</td>
              </tr>
              <tr>
                <th scope="row">주</th>
                <td data-mwc-weekly-gross>-</td>
                <td>-</td>
              </tr>
              <tr class="is-highlight">
                <th scope="row">월</th>
                <td data-mwc-monthly-gross>-</td>
                <td data-mwc-monthly-net>-</td>
              </tr>
              <tr>
                <th scope="row">연</th>
                <td data-mwc-annual-gross>-</td>
                <td data-mwc-annual-net>-</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="mwc-disclaimer">예상 세후 금액은 간편 추정값입니다. 실제 통장 입금액은 부양가족, 비과세 항목, 연말정산 결과에 따라 달라질 수 있습니다.</p>
      </article>

      <div class="mwc-detail-grid">
        <article class="mwc-deduction-card">
          <h3>월 공제 상세</h3>
          <ul class="mwc-deduction-list">
            <li><span>국민연금</span><strong data-mwc-national-pension>-</strong></li>
            <li><span>건강보험</span><strong data-mwc-health-insurance>-</strong></li>
            <li><span>장기요양</span><strong data-mwc-long-term-care>-</strong></li>
            <li><span>고용보험</span><strong data-mwc-employment-insurance>-</strong></li>
            <li><span>소득세·지방세 추정</span><strong data-mwc-income-tax>-</strong></li>
            <li class="is-total"><span>공제 합계</span><strong data-mwc-total-deduction>-</strong></li>
          </ul>
        </article>

        <article class="mwc-holiday-guide">
          <h3>주휴수당 계산</h3>
          <ul class="mwc-deduction-list">
            <li><span>주 주휴수당</span><strong data-mwc-holiday-week>-</strong></li>
            <li><span>월 주휴수당</span><strong data-mwc-holiday-month>-</strong></li>
            <li class="is-total"><span>판단 기준</span><strong data-mwc-holiday-status>-</strong></li>
          </ul>
          <p>주 소정근로시간이 15시간 이상이면 주휴수당 발생 가능성이 있습니다. 근태, 결근, 계약 조건에 따라 실제 지급 여부는 달라질 수 있습니다.</p>
        </article>
      </div>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">공식 기준</p>
            <h2 class="panel__title">2026 최저임금 확인 포인트</h2>
          </div>
        </div>
        <div class="mwc-rule-grid">
          <article>
            <strong>세전 기준</strong>
            <p>최저임금 충족 여부는 4대보험과 세금을 뺀 통장 입금액이 아니라 세전 시급으로 판단합니다.</p>
          </article>
          <article>
            <strong>주휴수당</strong>
            <p>주 15시간 이상이면 주휴수당 발생 가능성이 있고, 주 40시간 기준 최대 8시간으로 계산합니다.</p>
          </article>
          <article>
            <strong>연장근로</strong>
            <p>주 40시간을 넘는 연장·야간·휴일근로는 최저임금 환산과 별개로 가산수당을 확인해야 합니다.</p>
          </article>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">다음 계산기</p>
            <h2 class="panel__title">같이 보면 좋은 계산기</h2>
          </div>
        </div>
        <div class="mwc-related-grid">
          {MWC_RELATED_CALCULATORS.map((item) => (
            <a href={withBase(item.href)} class="mwc-related-card">
              <strong>{item.label}</strong>
              <span>{item.description}</span>
            </a>
          ))}
        </div>
      </article>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="2026 최저임금과 월급 환산 기준"
        intro={SEO_INTRO}
        inputPoints={[
          "2026년 최저임금 시급과 월 209시간 환산액을 확인할 수 있습니다.",
          "주휴수당 포함 여부에 따라 주급·월급·실질 시급이 어떻게 달라지는지 볼 수 있습니다.",
          "직접 시급 입력 시 최저임금 미달 여부와 월 미달 추정액을 확인할 수 있습니다.",
        ]}
        criteria={SEO_CRITERIA}
        faq={MWC_FAQS}
        related={MWC_RELATED_CALCULATORS.map((item) => ({ href: item.href, label: item.label }))}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="mwcConfig" type="application/json" set:html={JSON.stringify(config)}></script>
  <script src={withBase("/scripts/minimum-wage-2026.js")} defer></script>
</BaseLayout>
