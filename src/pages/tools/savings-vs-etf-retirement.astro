---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  SVER_CRITERIA,
  SVER_DEFAULT_INPUT,
  SVER_FAQ,
  SVER_GUIDE_POINTS,
  SVER_META,
  SVER_MONTHLY_PRESETS,
  SVER_PRESETS,
  SVER_RELATED_LINKS,
} from "../../data/savingsVsEtfRetirement";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const config = {
  defaults: SVER_DEFAULT_INPUT,
  presets: SVER_PRESETS,
};

const faqSchema = SVER_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: {
    "@type": "Answer",
    text: item.answer,
  },
}));
---

<BaseLayout
  title={`${SVER_META.title} | 적금·ETF 은퇴자산 비교`}
  description={SVER_META.subtitle}
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: SVER_META.title,
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description: SVER_META.subtitle,
    url: `${siteUrl}/tools/${SVER_META.slug}/`,
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={SVER_META.slug} pageClass="sver-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="노후 준비 계산기"
        title={SVER_META.title}
        description={SVER_META.subtitle}
        badges={["적금", "ETF", "물가 반영", "자산 고갈 시점"]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          "ETF 수익률은 입력값 기반 기대수익률이며 확정 수익이 아닙니다.",
          "세금 반영은 단순 추정이며 실제 과세는 계좌, 상품, 보유 기간에 따라 달라집니다.",
          "의료비, 간병비, 주거비 급변, 연금 수령 조건은 별도로 검토해야 합니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetSverBtn" copyId="copySverLinkBtn" />
      <p class="sver-copy-status" id="sverCopyStatus" aria-live="polite"></p>
    </Fragment>

    <Fragment slot="aside">
      <article class="panel sver-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력 조건</p>
            <h2 class="panel__title">은퇴 전 납입 가정</h2>
          </div>
          <p class="panel-heading__summary">현재 나이와 은퇴 목표 나이, 매월 넣을 금액을 먼저 입력하세요.</p>
        </div>

        <div class="sver-form-grid">
          <label class="sver-field">
            <span>현재 나이</span>
            <input id="sverCurrentAge" type="number" inputmode="numeric" min="18" max="80" value={SVER_DEFAULT_INPUT.currentAge} />
          </label>
          <label class="sver-field">
            <span>은퇴 목표 나이</span>
            <input id="sverRetirementAge" type="number" inputmode="numeric" min="30" max="85" value={SVER_DEFAULT_INPUT.retirementAge} />
          </label>
          <label class="sver-field sver-field--full">
            <span>월 투자금</span>
            <input id="sverMonthlyAmount" type="text" inputmode="numeric" data-currency="true" value={SVER_DEFAULT_INPUT.monthlyAmount.toLocaleString("ko-KR")} />
          </label>
        </div>

        <div class="sver-chip-row" aria-label="월 투자금 빠른 선택">
          {SVER_MONTHLY_PRESETS.map((item) => (
            <button type="button" class="sver-mini-chip" data-sver-monthly={item.value}>{item.label}</button>
          ))}
        </div>
      </article>

      <article class="panel sver-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">수익률 가정</p>
            <h2 class="panel__title">적금과 ETF 조건</h2>
          </div>
          <p class="panel-heading__summary">프리셋을 누른 뒤 금리, 기대수익률, 보수율을 직접 조정할 수 있습니다.</p>
        </div>

        <div class="sver-preset-grid" aria-label="투자 성향 프리셋">
          {SVER_PRESETS.map((preset) => (
            <button class:list={["sver-preset", preset.id === "balanced" && "is-active"]} type="button" data-sver-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.description}</span>
            </button>
          ))}
        </div>

        <div class="sver-form-grid">
          <label class="sver-field">
            <span>적금 연 금리</span>
            <input id="sverSavingsRate" type="number" inputmode="decimal" min="-5" max="15" step="0.1" value={SVER_DEFAULT_INPUT.savingsAnnualRate} />
          </label>
          <label class="sver-field">
            <span>ETF 기대수익률</span>
            <input id="sverEtfReturn" type="number" inputmode="decimal" min="-20" max="30" step="0.1" value={SVER_DEFAULT_INPUT.etfAnnualReturn} />
          </label>
          <label class="sver-field">
            <span>ETF 연 보수</span>
            <input id="sverEtfFee" type="number" inputmode="decimal" min="0" max="3" step="0.01" value={SVER_DEFAULT_INPUT.etfFeeRate} />
          </label>
          <label class="sver-field">
            <span>물가상승률</span>
            <input id="sverInflationRate" type="number" inputmode="decimal" min="0" max="10" step="0.1" value={SVER_DEFAULT_INPUT.inflationRate} />
          </label>
        </div>

        <label class="sver-check">
          <input id="sverIncludeTax" type="checkbox" checked={SVER_DEFAULT_INPUT.includeTax} />
          <span>세금 15.4% 단순 반영</span>
        </label>
      </article>

      <article class="panel sver-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">은퇴 후</p>
            <h2 class="panel__title">생활비와 인출 방식</h2>
          </div>
          <p class="panel-heading__summary">은퇴 후 월 생활비와 연금 수입을 넣으면 커버 기간과 고갈 나이를 추정합니다.</p>
        </div>

        <div class="sver-form-grid">
          <label class="sver-field sver-field--full">
            <span>은퇴 후 월 생활비</span>
            <input id="sverMonthlyLivingCost" type="text" inputmode="numeric" data-currency="true" value={SVER_DEFAULT_INPUT.monthlyLivingCost.toLocaleString("ko-KR")} />
          </label>
          <label class="sver-field sver-field--full">
            <span>예상 월 연금 수입</span>
            <input id="sverExpectedPension" type="text" inputmode="numeric" data-currency="true" value={SVER_DEFAULT_INPUT.expectedMonthlyPension.toLocaleString("ko-KR")} />
          </label>
          <label class="sver-field">
            <span>은퇴 후 운용수익률</span>
            <input id="sverPostReturn" type="number" inputmode="decimal" min="-10" max="15" step="0.1" value={SVER_DEFAULT_INPUT.postRetirementReturn} />
          </label>
        </div>

        <fieldset class="sver-choice">
          <legend>납입 시점</legend>
          <label><input type="radio" name="sverContributionTiming" value="end" checked={SVER_DEFAULT_INPUT.contributionTiming === "end"} /> 매월 말</label>
          <label><input type="radio" name="sverContributionTiming" value="begin" checked={SVER_DEFAULT_INPUT.contributionTiming === "begin"} /> 매월 초</label>
        </fieldset>

        <fieldset class="sver-choice">
          <legend>은퇴 후 생활비</legend>
          <label><input type="radio" name="sverWithdrawalMode" value="fixed" checked={SVER_DEFAULT_INPUT.withdrawalMode === "fixed"} /> 고정</label>
          <label><input type="radio" name="sverWithdrawalMode" value="inflationAdjusted" checked={SVER_DEFAULT_INPUT.withdrawalMode === "inflationAdjusted"} /> 물가연동</label>
        </fieldset>
      </article>
    </Fragment>

    <section class="sver-section" aria-live="polite">
      <div class="sver-section__head">
        <p class="sver-section__eyebrow">비교 결과</p>
        <h2>은퇴 시점 자산과 현재 구매력 기준 차이를 봅니다</h2>
        <p>{SVER_META.caution}</p>
      </div>

      <div class="sver-verdict sver-verdict--similar" id="sverResultBox">
        <span id="sverStatusBadge">시뮬레이션</span>
        <p id="sverResultMessage">입력값 기준 계산 결과가 여기에 표시됩니다.</p>
      </div>

      <div class="sver-kpi-grid">
        <article class="sver-kpi-card sver-kpi-card--main">
          <p>ETF와 적금 명목 차이</p>
          <strong id="sverNominalGap">-</strong>
          <span>은퇴 시점 기준</span>
        </article>
        <article class="sver-kpi-card">
          <p>적금 예상 자산</p>
          <strong id="sverSavingsFutureValue">-</strong>
          <span>명목 금액</span>
        </article>
        <article class="sver-kpi-card">
          <p>ETF 예상 자산</p>
          <strong id="sverEtfFutureValue">-</strong>
          <span>명목 금액</span>
        </article>
        <article class="sver-kpi-card">
          <p>실질 구매력 차이</p>
          <strong id="sverRealGap">-</strong>
          <span>현재 가치 환산</span>
        </article>
      </div>
    </section>

    <section class="sver-section">
      <div class="sver-section__head">
        <p class="sver-section__eyebrow">은퇴 후 지속성</p>
        <h2>생활비를 몇 년 정도 커버할 수 있는지 확인합니다</h2>
      </div>

      <div class="sver-kpi-grid sver-kpi-grid--two">
        <article class="sver-kpi-card">
          <p>적금 생활비 커버</p>
          <strong id="sverSavingsCoverYears">-</strong>
          <span>연금 차감 후</span>
        </article>
        <article class="sver-kpi-card">
          <p>ETF 생활비 커버</p>
          <strong id="sverEtfCoverYears">-</strong>
          <span>연금 차감 후</span>
        </article>
        <article class="sver-kpi-card">
          <p>적금 고갈 예상 나이</p>
          <strong id="sverSavingsDepletionAge">-</strong>
          <span>월 단위 추정</span>
        </article>
        <article class="sver-kpi-card">
          <p>ETF 고갈 예상 나이</p>
          <strong id="sverEtfDepletionAge">-</strong>
          <span>월 단위 추정</span>
        </article>
      </div>
    </section>

    <section class="sver-section">
      <div class="sver-section__head">
        <p class="sver-section__eyebrow">차트</p>
        <h2>명목 자산, 실질 자산, 은퇴 후 잔액 흐름을 비교합니다</h2>
      </div>
      <div class="sver-chart-grid">
        <article class="sver-chart-panel">
          <h3>은퇴 시점 자산</h3>
          <div class="sver-chart-wrap">
            <canvas id="sverAssetChart" aria-label="적금과 ETF 은퇴 시점 자산 비교 차트"></canvas>
          </div>
          <p class="sver-chart-fallback">차트가 표시되지 않아도 아래 표에서 같은 값을 확인할 수 있습니다.</p>
        </article>
        <article class="sver-chart-panel">
          <h3>은퇴 후 잔액 흐름</h3>
          <div class="sver-chart-wrap">
            <canvas id="sverDepletionChart" aria-label="적금과 ETF 은퇴 후 잔액 흐름 차트"></canvas>
          </div>
          <p class="sver-chart-fallback">100세까지 월 단위로 계산한 연도별 잔액 흐름입니다.</p>
        </article>
      </div>
    </section>

    <section class="sver-section">
      <div class="sver-section__head">
        <p class="sver-section__eyebrow">상세 표</p>
        <h2>같은 입력값에서 적금과 ETF 결과를 나란히 비교합니다</h2>
      </div>
      <div class="sver-table-wrap">
        <table class="sver-table">
          <thead>
            <tr>
              <th scope="col">항목</th>
              <th scope="col">적금</th>
              <th scope="col">ETF</th>
            </tr>
          </thead>
          <tbody id="sverCompareBody"></tbody>
        </table>
      </div>
    </section>

    <section class="sver-section">
      <div class="sver-section__head">
        <p class="sver-section__eyebrow">해석 포인트</p>
        <h2>노후 준비에서는 수익률보다 현금흐름이 먼저입니다</h2>
      </div>
      <div class="sver-guide-grid">
        {SVER_GUIDE_POINTS.map((point) => (
          <article class="sver-guide-card">
            <p>{point}</p>
          </article>
        ))}
      </div>
    </section>

    <script id="savingsVsEtfRetirementData" type="application/json" set:html={JSON.stringify(config)} />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script type="module" src={withBase("/scripts/savings-vs-etf-retirement.js")}></script>

    <Fragment slot="seo">
      <SeoContent
        introTitle="월 적금과 ETF를 노후 자금 관점에서 비교하는 방법"
        intro={[
          "적금과 ETF는 단순히 수익률만 비교하면 결론이 빨리 나는 것처럼 보이지만, 노후 준비에서는 물가상승률, 은퇴 후 생활비, 연금 수입, 인출 방식까지 함께 봐야 합니다.",
          "이 계산기는 같은 월 납입액을 적금과 ETF에 넣는다고 가정하고 은퇴 시점의 명목 자산, 현재 구매력 환산 금액, 생활비 커버 기간, 자산 고갈 예상 나이를 나란히 보여줍니다.",
          "결과는 투자 권유가 아니라 입력한 가정에 따른 참고용 시뮬레이션입니다. 실제 실행 전에는 비상금, 부채, 세제 계좌, 위험 감수 성향을 함께 점검하세요.",
        ]}
        inputPoints={[...SVER_GUIDE_POINTS]}
        criteria={[...SVER_CRITERIA]}
        faq={SVER_FAQ}
        related={SVER_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>
</BaseLayout>
