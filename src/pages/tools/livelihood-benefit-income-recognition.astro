---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  LBIRC_CONFIG,
  LBIRC_FAQ,
  LBIRC_HOUSING_LABELS,
  LBIRC_META,
  LBIRC_PRESETS,
  LBIRC_REGION_LABELS,
  LBIRC_RELATED_LINKS,
  LBIRC_SEO_CONTENT,
} from "../../data/livelihoodBenefitIncomeRecognition";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${LBIRC_META.slug}/`;
const fourPerson = LBIRC_CONFIG.thresholds.find((item) => item.householdSize === 4)!;
const man = (value: number) => `${Math.round(value / 10000).toLocaleString("ko-KR")}만 원`;
---

<BaseLayout
  title={LBIRC_META.seoTitle}
  description={LBIRC_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: LBIRC_META.title,
      applicationCategory: "UtilityApplication",
      operatingSystem: "All",
      description: LBIRC_META.seoDescription,
      url: pageUrl,
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: LBIRC_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={LBIRC_META.slug} pageClass="lbirc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="생계급여 계산"
        title="생계급여 소득인정액 계산기"
        description="가구원 수와 월소득, 재산을 입력하면 2026년 생계급여 선정기준 대비 소득인정액과 예상 생계급여액을 빠르게 확인합니다."
        badges={["생계급여", "소득인정액", "2026", "자가 점검"]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          LBIRC_META.dataNote,
          "입력값은 브라우저에서만 계산되며 서버로 전송하지 않습니다.",
          "자동차, 부채, 재산 특례는 실제 조사에서 다르게 반영될 수 있어 확인 필요 항목으로 표시합니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="lbircResetBtn" copyId="lbircCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel lbirc-quick-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">2026 기준</p>
            <h2 class="panel__title">4인 생계급여 기준 {man(fourPerson.livelihood)}</h2>
          </div>
          <p class="panel-heading__summary">생계급여는 기준 중위소득 32% 이하 구간을 봅니다. 가구원 수를 바꾸면 기준선도 함께 바뀝니다.</p>
        </div>
        <div class="lbirc-threshold-mini">
          {LBIRC_CONFIG.thresholds.slice(0, 6).map((item) => (
            <p><span>{item.householdSize}인</span><strong>{man(item.livelihood)}</strong></p>
          ))}
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 예시</p>
            <h2 class="panel__title">상황을 골라 시작</h2>
          </div>
        </div>
        <div class="lbirc-preset-grid">
          {LBIRC_PRESETS.map((preset) => (
            <button type="button" class="lbirc-preset-btn" data-lbirc-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.summary}</span>
            </button>
          ))}
        </div>
      </article>

      <article class="panel lbirc-input-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">가구·소득·재산</h2>
          </div>
        </div>

        <section class="lbirc-input-section" aria-labelledby="lbirc-basic-title">
          <h3 id="lbirc-basic-title">기본 정보</h3>
          <div class="form-grid">
            <label class="field">
              <span>가구원 수</span>
              <select data-lbirc="householdSize">
                {LBIRC_CONFIG.thresholds.map((item) => <option value={item.householdSize}>{item.householdSize}인</option>)}
              </select>
            </label>
            <label class="field">
              <span>거주 지역</span>
              <select data-lbirc="region">
                {Object.entries(LBIRC_REGION_LABELS).map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
            <label class="field">
              <span>주거 형태</span>
              <select data-lbirc="housingType">
                {Object.entries(LBIRC_HOUSING_LABELS).map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
          </div>
        </section>

        <section class="lbirc-input-section" aria-labelledby="lbirc-income-title">
          <h3 id="lbirc-income-title">월 소득</h3>
          <div class="form-grid">
            <label class="field">
              <span>월 근로·사업소득</span>
              <input data-lbirc="earnedIncome" type="text" inputmode="numeric" class="input-number" value="1,500,000" />
            </label>
            <label class="field">
              <span>공적 이전소득</span>
              <input data-lbirc="publicTransferIncome" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
            <label class="field">
              <span>사적 이전·재산소득</span>
              <input data-lbirc="otherIncome" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
            <label class="checkbox-option">
              <input type="checkbox" data-lbirc="applyWorkDeduction" checked />
              <span>근로·사업소득 30% 간이 공제 적용</span>
            </label>
          </div>
        </section>

        <section class="lbirc-input-section" aria-labelledby="lbirc-asset-title">
          <h3 id="lbirc-asset-title">재산</h3>
          <div class="form-grid">
            <label class="field">
              <span>주거재산</span>
              <input data-lbirc="housingAsset" type="text" inputmode="numeric" class="input-number" value="50,000,000" />
              <small>전세보증금 또는 자가 주택가액을 입력합니다.</small>
            </label>
            <label class="field">
              <span>일반재산</span>
              <input data-lbirc="generalAsset" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
            <label class="field">
              <span>금융재산</span>
              <input data-lbirc="financialAsset" type="text" inputmode="numeric" class="input-number" value="5,000,000" />
            </label>
            <label class="field">
              <span>인정 가능 부채</span>
              <input data-lbirc="debt" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
            <label class="checkbox-option">
              <input type="checkbox" data-lbirc="hasCar" />
              <span>자동차가 있습니다</span>
            </label>
            <label class="field">
              <span>차량가액</span>
              <input data-lbirc="carValue" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
          </div>
        </section>

        <details class="lbirc-advanced">
          <summary>상세 확인 항목</summary>
          <div class="form-grid">
            <label class="checkbox-option">
              <input type="checkbox" data-lbirc="hasCrisisReason" />
              <span>실직·질병 등 최근 위기 사유가 있습니다</span>
            </label>
          </div>
        </details>
      </article>
    </Fragment>

    <section class="lbirc-section lbirc-result-section" aria-live="polite">
      <div class="section-header">
        <p class="section-header__eyebrow">계산 결과</p>
        <h2>생계급여 기준선과 예상 지급액</h2>
        <p>입력값을 바꾸면 소득인정액과 예상 생계급여액이 즉시 다시 계산됩니다.</p>
      </div>
      <div class="lbirc-kpi-grid">
        <article class="lbirc-kpi lbirc-kpi--main"><span>소득인정액 추정</span><strong data-lbirc-result="incomeRecognized">-</strong><small>자가 점검용 추정</small></article>
        <article class="lbirc-kpi"><span>생계급여 선정기준</span><strong data-lbirc-result="threshold">-</strong><small data-lbirc-result="thresholdMeta">2026년 기준</small></article>
        <article class="lbirc-kpi lbirc-kpi--accent"><span>예상 생계급여액</span><strong data-lbirc-result="benefit">-</strong><small>선정기준 - 소득인정액</small></article>
        <article class="lbirc-kpi"><span>기준까지 차이</span><strong data-lbirc-result="gap">-</strong><small data-lbirc-result="judgement">확인 중</small></article>
      </div>
      <p class="lbirc-summary" data-lbirc-summary></p>
    </section>

    <section class="lbirc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">기준선</p>
        <h2>내 소득인정액 위치</h2>
      </div>
      <div class="lbirc-gauge" aria-hidden="true">
        <span class="lbirc-gauge__bar"><i data-lbirc-gauge-fill></i></span>
        <div class="lbirc-gauge__labels"><span>0%</span><span>95%</span><span>100%</span><span>105%</span></div>
      </div>
    </section>

    <section class="lbirc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">분해</p>
        <h2>소득인정액 구성</h2>
      </div>
      <div class="lbirc-breakdown" data-lbirc-breakdown></div>
    </section>

    <section class="lbirc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">다음 확인</p>
        <h2>확인 필요 항목과 연결 계산기</h2>
      </div>
      <div class="lbirc-warning-grid" data-lbirc-warnings></div>
      <div class="lbirc-action-grid">
        <a href={withBase("/tools/welfare-benefit-eligibility/")}>4대 급여 전체 가능성 보기</a>
        <a href={withBase("/tools/basic-livelihood-recipient-asset-standard/")}>재산 기준 자세히 보기</a>
        <a href={withBase("/compare/welfare/")}>복지지원금 비교표 보기</a>
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle={LBIRC_SEO_CONTENT.introTitle}
        intro={LBIRC_SEO_CONTENT.intro}
        inputPoints={LBIRC_SEO_CONTENT.inputPoints}
        criteria={LBIRC_SEO_CONTENT.criteria}
        faq={LBIRC_FAQ}
        related={LBIRC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="lbirc-data" type="application/json" set:html={JSON.stringify(LBIRC_CONFIG)} />
  <script type="module" src={withBase("/scripts/livelihood-benefit-income-recognition.js")}></script>
</BaseLayout>
