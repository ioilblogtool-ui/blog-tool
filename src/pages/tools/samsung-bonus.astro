---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  averageCompensation,
  comparisonCards,
  defaultBenefits,
  divisions,
  factAnchors,
  operatingProfitScenarios,
  opiModes,
  rankPresets,
  scenarioPresets,
  unionDemandScenarios,
  yearOptions,
  SAMSUNG_NEXT_CALCULATOR,
  SAMSUNG_RELATED_CALCULATORS,
  SAMSUNG_EXTERNAL_REFERENCE_LINKS,
  SAMSUNG_AFFILIATE_PRODUCTS,
} from "../../data/samsungCompensation";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const config = {
  rankPresets,
  divisions,
  yearOptions,
  opiModes,
  scenarioPresets,
  operatingProfitScenarios,
  unionDemandScenarios,
  comparisonCards,
  defaultBenefits,
  averageCompensation
};
---

<BaseLayout
  title="삼성전자 성과급 협의안 계산기 | 2026 잠정합의안"
  description="2026년 삼성전자 임금협약 잠정합의안의 DS 특별경영성과급, 자사주 지급, 배분 구조를 개인·부부 총보상으로 환산하는 계산기"
  ogImage="/og/tools/samsung-bonus.png"
>
  <SiteHeader />

  <SimpleToolShell calculatorId="samsung-bonus" pageClass="samsung-bonus-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="Samsung Electronics Compensation"
        title="삼성전자 성과급 협의안 계산기"
        description="2026년 5월 20일 잠정합의안의 DS 특별경영성과급, 자사주 지급, 배분 구조를 내 연봉 기준으로 환산합니다."
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetSamsungBonusBtn" copyId="copySamsungBonusLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <div class="stack" id="samsung-bonus-inputs">
        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">계산 모드</p>
              <h2 class="panel__title">개인 또는 부부 선택</h2>
            </div>
            <p class="panel-heading__summary">개인과 부부 중 계산할 대상을 선택하세요.</p>
          </div>
          <div class="toggle-grid">
            <label class="mode-chip">
              <input id="modeSingle" name="householdMode" type="radio" value="SINGLE" checked />
              <span>개인 계산</span>
            </label>
            <label class="mode-chip">
              <input id="modeCouple" name="householdMode" type="radio" value="COUPLE" />
              <span>부부 계산</span>
            </label>
          </div>
        </article>

        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">빠른 입력</p>
              <h2 class="panel__title">직급·사업부·연봉 먼저 입력</h2>
            </div>
          </div>

          <div class="form-cluster form-cluster--nested">
            <div class="form-cluster__header">
              <strong>본인</strong>
              <span>직급별 연봉은 예시값이며 수정할 수 있습니다.</span>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>직급</span>
                <select id="selfRankSelect">
                  {rankPresets.map((rank) => <option value={rank.code}>{rank.label}</option>)}
                </select>
              </label>
              <label class="field">
                <span>사업부</span>
                <select id="selfDivisionSelect">
                  {divisions.map((division) => <option value={division.code}>{division.label}</option>)}
                </select>
              </label>
              <label class="field field-span-full">
                <span>연봉</span>
                <input id="selfSalaryInput" type="number" value="70000000" />
                <small id="selfSalaryHint"></small>
                <div class="calc-slider-row">
                  <input type="range" id="selfSalarySlider" class="calc-slider" min="30000000" max="300000000" step="1000000" value="70000000" />
                  <span id="selfSalarySliderVal" class="calc-slider-val">7,000만원</span>
                </div>
              </label>
            </div>
          </div>

          <div class="form-cluster form-cluster--nested" id="spouseBlock" hidden>
            <div class="form-cluster__header">
              <strong>배우자</strong>
              <span>부부 계산 모드일 때만 합산됩니다.</span>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>직급</span>
                <select id="spouseRankSelect">
                  {rankPresets.map((rank) => <option value={rank.code}>{rank.label}</option>)}
                </select>
              </label>
              <label class="field">
                <span>사업부</span>
                <select id="spouseDivisionSelect">
                  {divisions.map((division) => <option value={division.code}>{division.label}</option>)}
                </select>
              </label>
              <label class="field field-span-full">
                <span>연봉</span>
                <input id="spouseSalaryInput" type="number" value="90000000" />
                <small id="spouseSalaryHint"></small>
                <div class="calc-slider-row">
                  <input type="range" id="spouseSalarySlider" class="calc-slider" min="30000000" max="300000000" step="1000000" value="90000000" />
                  <span id="spouseSalarySliderVal" class="calc-slider-val">9,000만원</span>
                </div>
              </label>
            </div>
          </div>

          <div class="form-cluster form-cluster--nested">
            <div class="form-cluster__header">
              <strong>공통 가정</strong>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>연도</span>
                <select id="targetYearSelect">
                  {yearOptions.map((year) => <option value={year.code}>{year.label}</option>)}
                </select>
              </label>
              <div class="field field-span-full">
                <span>OPI 모드</span>
                <div class="toggle-grid">
                  <label class="mode-chip" id="opiActualChip">
                    <input type="radio" name="opiMode" value="ACTUAL" checked />
                    <span>기존 OPI</span>
                  </label>
                  <label class="mode-chip">
                    <input type="radio" name="opiMode" value="SCENARIO" />
                    <span>시나리오</span>
                  </label>
                  <label class="mode-chip mode-chip--highlight">
                    <input type="radio" name="opiMode" value="UNION_DEMAND" />
                    <span>잠정합의안</span>
                  </label>
                </div>
                <small id="opiModeHint"></small>
              </div>
              <label class="field">
                <span>시나리오</span>
                <select id="scenarioSelect">
                  {scenarioPresets.map((scenario) => <option value={scenario.code}>{scenario.label}</option>)}
                </select>
                <small id="scenarioHint"></small>
              </label>
              <label class="field">
                <span>복지 금액</span>
                <input id="benefitsInput" type="number" value={defaultBenefits} />
                <small id="benefitsHint"></small>
              </label>
              <label class="field">
                <span>영업이익 가정</span>
                <select id="operatingProfitScenarioSelect">
                  {operatingProfitScenarios.map((item) => <option value={item.code}>{item.label}</option>)}
                </select>
                <small id="operatingProfitHint"></small>
              </label>
              <label class="field">
                <span>협의안 비율</span>
                <select id="unionDemandScenarioSelect">
                  {unionDemandScenarios.map((item) => <option value={item.code}>{item.label}</option>)}
                </select>
                <small id="unionDemandHint"></small>
              </label>
              <label class="check-field">
                <input id="includeOpiToggle" type="checkbox" checked />
                <span>OPI 포함</span>
              </label>
              <label class="check-field">
                <input id="includeTaiToggle" type="checkbox" checked />
                <span>TAI 포함</span>
              </label>
              <label class="check-field">
                <input id="includeBenefitsToggle" type="checkbox" checked />
                <span>복지 포함</span>
              </label>
            </div>
          </div>

          <details class="detail-box detail-box--soft">
            <summary>고급 설정 열기</summary>
            <div class="detail-box__content detail-box__content--tight">
              <div class="form-grid form-grid--compact">
                <label class="field">
                  <span>OPI 비율 직접 입력</span>
                  <input id="customOpiRateInput" type="number" value="0" step="0.01" />
                  <small>0이면 사업부/시나리오 기본값 사용</small>
                </label>
                <label class="field">
                  <span>상반기 TAI</span>
                  <input id="taiFirstHalfInput" type="number" value="0.5" step="0.01" />
                </label>
                <label class="field">
                  <span>하반기 TAI</span>
                  <input id="taiSecondHalfInput" type="number" value="0.5" step="0.01" />
                </label>
                <label class="field">
                  <span>환산 직원 수</span>
                  <input id="eligibleEmployeesInput" type="number" value="120000" step="1000" />
                  <small>협의안 1인 환산용 추정값</small>
                </label>
                <label class="field">
                  <span>영업이익 직접 입력</span>
                  <input id="customOperatingProfitInput" type="number" value="0" step="1000000000000" />
                  <small>0이면 위 영업이익 가정 사용</small>
                </label>
                <label class="check-field field-span-full">
                  <input id="includeNetEstimateToggle" type="checkbox" checked />
                  <span>월 실수령 추정 같이 보기</span>
                </label>
              </div>
            </div>
          </details>

          <button id="calcSamsungBonusBtn" class="button button--primary" type="button">총보상 계산하기</button>
        </article>
      </div>
    </Fragment>

    <article class="panel result-priority-panel" id="samsung-bonus-results">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">결과 먼저 보기</p>
          <h2 class="panel__title">내 예상 성과급과 총보상</h2>
        </div>
      </div>
      <div class="result-priority-panel__actions">
        <a class="button button--secondary" href="#samsung-bonus-inputs">조건 다시 입력</a>
        <a class="button button--ghost" href="#samsung-bonus-details">세부 내역 보기</a>
      </div>
    </article>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">내 계산 결과</p>
        <h2 id="resultHeadline">개인 총보상 핵심 카드</h2>
        <p class="sb-section__sub" id="resultSubcopy">기존 OPI 기준 모드</p>
      </div>
      <div class="kpi-grid">
        <article class="kpi-card kpi-card--accent">
          <p id="salaryCardLabel">연봉</p>
          <strong id="salarySummary">-</strong>
          <span id="salarySummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>OPI</p>
          <strong id="opiSummary">-</strong>
          <span id="opiSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>TAI</p>
          <strong id="taiSummary">-</strong>
          <span id="taiSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>복지 포함 총보상</p>
          <strong id="totalSummary">-</strong>
          <span id="totalSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>월 체감 총액</p>
          <strong id="monthlySummary">-</strong>
          <span id="monthlySummaryNote">-</span>
        </article>
      </div>
    </section>

    <section class="content-section samsung-detail-grid" id="samsung-bonus-details">

      <article class="panel summary-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">연 · 월 요약</p>
            <h2 class="panel__title">핵심 금액</h2>
          </div>
        </div>
        <div class="samsung-donut-wrap">
          <canvas id="samsung-donut-chart"></canvas>
        </div>
        <div class="report-list" id="summaryReportList"></div>
      </article>

      <article class="panel net-panel" id="netPanel" hidden>
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">월 실수령 추정</p>
            <h2 class="panel__title">실수령 추정표</h2>
          </div>
        </div>
        <div class="report-list report-list--compact" id="netReportList"></div>
      </article>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">2026 잠정합의안</p>
        <h2>삼성전자 성과급 협의안 핵심</h2>
        <p class="sb-section__sub">아직 조합원 찬반투표 전이라 최종 확정은 아니며, 실제 지급액은 산식·사업부·직급·평가·주가에 따라 달라질 수 있습니다.</p>
      </div>
      <div class="logic-grid">
        <article class="logic-card">
          <strong>DS 특별경영성과급 신설</strong>
          <p>기존 OPI는 유지하고, DS부문에 사업성과 10.5% 수준의 특별경영성과급을 별도로 두는 구조입니다.</p>
        </article>
        <article class="logic-card">
          <strong>상한 없는 10년 제도화</strong>
          <p>2026~2035년 적용을 전제로 하되, 실제 지급은 합의 기준상 초과 성과 조건을 충족해야 합니다.</p>
        </article>
        <article class="logic-card">
          <strong>DS 공통 40%, 사업부 60%</strong>
          <p>공통 재원과 사업부별 차등 재원을 나누는 절충안입니다. 적자 사업부 적용 방식은 보도 기준 추정으로 봐야 합니다.</p>
        </article>
        <article class="logic-card">
          <strong>세후 전액 자사주 지급</strong>
          <p>현금 일시지급이 아니라 자사주 지급 방식이며, 일부는 즉시 매각 가능하고 일부는 1년·2년 매각 제한이 붙는 구조입니다.</p>
        </article>
        <article class="logic-card">
          <strong>DX·CSS 600만 원 보완</strong>
          <p>DS 중심 성과급 신설에 따른 형평성 보완으로 DX부문과 CSS사업팀에는 600만 원 상당 자사주 지급안이 포함됐습니다.</p>
        </article>
      </div>
    </section>

    <section class="sb-section sb-union-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">협의안 환산</p>
        <h2>영업이익 연동 성과급 재원 추정</h2>
        <p class="sb-section__sub">내 예상 성과급을 먼저 확인한 뒤, 보도된 잠정합의안 비율을 추정 비교선으로만 참고하세요.</p>
      </div>
      <div class="union-result-grid">
        <article class="union-result-card union-result-card--accent">
          <p>내 연봉 가중 환산</p>
          <strong id="unionWeightedSummary">-</strong>
          <span id="unionWeightedNote">평균 보수 대비 가중</span>
        </article>
        <article class="union-result-card">
          <p>1인 단순 환산</p>
          <strong id="unionPerHeadSummary">-</strong>
          <span id="unionPerHeadNote">환산 직원 수 기준</span>
        </article>
        <article class="union-result-card">
          <p>성과급 재원</p>
          <strong id="unionPoolSummary">-</strong>
          <span id="unionPoolNote">영업이익 × 요구 비율</span>
        </article>
      </div>
      <div class="union-comparison-panel">
        <div>
          <strong>현행 OPI 상한과 비교</strong>
          <p id="unionVsCurrentCopy">잠정합의안 모드를 선택하면 기존 OPI 50% 상한 대비 차이를 계산합니다.</p>
        </div>
        <span class="estimate-badge">보도·추정</span>
      </div>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">팩트 앵커</p>
        <h2>핵심 수치</h2>
      </div>
      <div class="fact-anchor-grid">
        {factAnchors.map((item) => (
          <article class="fact-anchor-card">
            <p>{item.label}</p>
            <strong>{item.value}</strong>
            <span>{item.note}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section">
      <article class="panel rank-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">직급별 예시</p>
            <h2 class="panel__title">추천 연봉 기준 비교</h2>
          </div>
        </div>
        <div class="samsung-rank-chart-wrap">
          <canvas id="samsung-rank-chart"></canvas>
        </div>
        <div class="matrix-list">
          <div class="matrix-list__head">
            <span>직급</span>
            <span>추천 연봉</span>
            <span>OPI</span>
            <span>총보상</span>
            <span>월 체감</span>
          </div>
          <div id="rankMatrixList"></div>
        </div>
      </article>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">연도 시나리오</p>
        <h2>2026~2028 비교</h2>
      </div>
      <div class="samsung-scenario-chart-wrap">
        <canvas id="samsung-scenario-chart"></canvas>
      </div>
      <div class="scenario-year-grid" id="scenarioYearGrid"></div>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">참고 비교</p>
        <h2>재미로 보는 비교</h2>
      </div>
      <div class="comparison-grid" id="comparisonGrid"></div>
    </section>

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">계산 기준</p>
          <h2 class="panel__title">계산 기준 요약</h2>
        </div>
      </div>
      <div class="logic-grid">
        <article class="logic-card">
          <strong>OPI = 연봉 × 사업부 비율</strong>
          <p>기존 OPI 기준은 공개 지급률, 미래 연도는 시나리오를 씁니다.</p>
        </article>
        <article class="logic-card">
          <strong>협의안 = 사업성과 × 합의 비율</strong>
          <p>직원 수와 평균 보수 대비 가중치로 1인 추정 환산합니다.</p>
        </article>
        <article class="logic-card">
          <strong>TAI = 연봉 ÷ 12 × (상반기 + 하반기)</strong>
          <p>TAI는 프리셋 또는 직접 입력값을 반영합니다.</p>
        </article>
        <article class="logic-card">
          <strong>총보상 = 연봉 + OPI + TAI + 복지</strong>
          <p>복지 포함 여부는 토글로 바꿀 수 있습니다.</p>
        </article>
        <article class="logic-card">
          <strong>실수령 추정은 참고값</strong>
          <p>세금과 공제 조건에 따라 달라질 수 있습니다.</p>
        </article>
      </div>
    </article>

    <InfoNotice
      title="안내"
      lines={[
        "직급별 연봉과 복지 금액은 공식 수치가 아니라 추천값(수정 가능)입니다.",
        "2026 잠정합의안은 조합원 찬반투표 전 보도 기준이며, 최종 타결 전까지 바뀔 수 있습니다.",
        "영업이익 컨센서스와 협의안 환산액은 보도·추정 기반이며 실제 지급액을 보장하지 않습니다.",
