---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import ToolTabs from "../../components/ToolTabs.astro";
import SummaryCards from "../../components/SummaryCards.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout title="이직 계산기" description="현재 연봉과 목표 연봉의 세전·실수령 차이를 비교하는 도구">
  <SiteHeader />

  <main class="container page-shell calculator-page" data-calculator="negotiation">
    <CalculatorHero
      eyebrow="Negotiation Tool"
      title="이직 계산기"
      description="현재 연봉과 목표 연봉을 비교해 월 세전, 월 실수령, 인상률 변화를 빠르게 확인합니다."
    />
    <ToolTabs />

    <ToolActionBar resetId="resetNegotiationBtn" copyId="copyNegotiationLinkBtn" />

    <section class="calculator-grid">
      <div class="stack">
        <article class="panel">
          <h2 class="panel__title">이직 입력</h2>
          <div class="form-grid">
            <label class="field">
              <span>현재 연봉</span>
              <input id="negCurrentAnnual" type="number" value="50000000" />
              <small id="negCurrentAnnualHint"></small>
            </label>
            <label class="field">
              <span>목표 연봉</span>
              <input id="negTargetAnnual" type="number" value="65000000" />
              <small id="negTargetAnnualHint"></small>
            </label>
          </div>
          <button id="calcNegotiationBtn" class="button button--primary" type="button">비교하기</button>
        </article>

        <InfoNotice
          title="안내"
          lines={[
            "실수령 증감은 간이 공제 기준으로 계산됩니다.",
            "보너스, 복지, RSU 같은 총보상 요소는 별도로 반영되지 않습니다.",
            "협상 기준을 잡을 때는 월 실수령 증가와 인상률을 함께 확인하세요."
          ]}
        />
      </div>

      <div class="stack">
        <SummaryCards
          columns={4}
          items={[
            { label: "연봉 인상액", id: "negRaiseAmount" },
            { label: "연봉 인상률", id: "negRaisePct" },
            { label: "월 세전 증가", id: "negMonthlyGrossIncrease" },
            { label: "월 실수령 증가", id: "negMonthlyNetIncrease" }
          ]}
        />

        <article class="panel">
          <h2 class="panel__title">비교 상세</h2>
          <div class="table-wrap">
            <table class="result-table">
              <thead>
                <tr>
                  <th>항목</th>
                  <th>값</th>
                </tr>
              </thead>
              <tbody id="negotiationTable"></tbody>
            </table>
          </div>
        </article>
      </div>
    </section>
  </main>

  <script type="module" src={withBase("/scripts/tools.js")}></script>
</BaseLayout>
