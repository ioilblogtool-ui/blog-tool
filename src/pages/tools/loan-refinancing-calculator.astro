---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  LRC_DEFAULT_INPUT,
  LRC_FAQ,
  LRC_INFO_LINES,
  LRC_LOAN_TYPE_PRESETS,
  LRC_META,
  LRC_PRESETS,
  LRC_RELATED_LINKS,
} from "../../data/loanRefinancingCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const defaultLoan =
  LRC_LOAN_TYPE_PRESETS.find((item) => item.id === LRC_DEFAULT_INPUT.loanType) ??
  LRC_LOAN_TYPE_PRESETS[0];
const faqItems = LRC_FAQ.map((item) => ({ question: item.question, answer: item.answer }));
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "대출 갈아타기 계산기",
      "url": `${import.meta.env.SITE}/tools/loan-refinancing-calculator/`,
      "description": LRC_META.description,
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "inLanguage": "ko-KR",
      "isAccessibleForFree": true,
      "provider": { "@type": "Organization", "name": "비교계산소" },
    },
    {
      "@type": "FAQPage",
      "mainEntity": LRC_FAQ.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": { "@type": "Answer", "text": item.answer },
      })),
    },
  ],
};
---

<BaseLayout
  title={LRC_META.title}
  description={LRC_META.description}
  ogImage="/og/tools/loan-refinancing-calculator.png"
  jsonLd={jsonLd}
>
  <SiteHeader />

  <SimpleToolShell
    calculatorId="loan-refinancing-calculator"
    pageClass="lrc-page"
    resultFirst={false}
  >
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="대환대출 계산기"
        title="대출 갈아타기, 수수료까지 빼고 진짜 이득인지 계산합니다"
        description="현재 대출과 신규 대출 조건을 입력하면 월 납입금 절감액, 총 이자 절감액, 중도상환수수료 회수 기간을 한 번에 확인할 수 있습니다."
        badges={["주담대", "전세대출", "신용대출", "손익분기"]}
      />
      <InfoNotice title="금융상품 예상 계산 안내" lines={LRC_INFO_LINES} />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="lrcResetBtn" copyId="lrcCopyLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">대출 종류</p>
            <h2 class="panel__title">어떤 대출을 갈아타나요?</h2>
          </div>
        </div>
        <div class="lrc-loan-tabs" id="lrcLoanTabs">
          {LRC_LOAN_TYPE_PRESETS.map((preset) => (
            <button
              type="button"
              class={`lrc-pill-btn${preset.id === LRC_DEFAULT_INPUT.loanType ? " is-active" : ""}`}
              data-loan-type={preset.id}
              aria-pressed={preset.id === LRC_DEFAULT_INPUT.loanType ? "true" : "false"}
            >
              {preset.label}
            </button>
          ))}
        </div>
        <p class="lrc-note" id="lrcLoanNote">{defaultLoan.note}</p>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">Step 1</p>
            <h2 class="panel__title">현재 대출 조건</h2>
          </div>
        </div>
        <div class="lrc-form-grid">
          <label class="lrc-field">
            <span>현재 대출 잔액</span>
            <input id="lrcCurrentBalance" type="text" inputmode="numeric" value="300,000,000" />
            <small>지금 남아 있는 원금</small>
          </label>
          <label class="lrc-field">
            <span>현재 금리</span>
            <input id="lrcCurrentRate" type="number" min="0" max="30" step="0.001" value="4.800" />
            <small>연 이율, 예: 4.8%</small>
          </label>
          <label class="lrc-field">
            <span>남은 기간</span>
            <input id="lrcRemainingMonths" type="number" min="1" max="600" step="1" value="240" />
            <small>개월 기준. 20년은 240개월</small>
          </label>
          <label class="lrc-field">
            <span>현재 상환 방식</span>
            <select id="lrcCurrentRepayment">
              <option value="annuity" selected>원리금균등</option>
              <option value="equalPrincipal">원금균등</option>
              <option value="bullet">만기일시</option>
            </select>
            <small>전세대출은 보통 만기일시</small>
          </label>
          <label class="lrc-field">
            <span>현재 금리 유형</span>
            <select id="lrcCurrentRateType">
              <option value="fixed">고정금리</option>
              <option value="variable" selected>변동금리</option>
              <option value="mixed">혼합형</option>
            </select>
          </label>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">Step 2</p>
            <h2 class="panel__title">신규 대출 조건</h2>
          </div>
        </div>
        <div class="lrc-form-grid">
          <label class="lrc-field">
            <span>신규 대출 금리</span>
            <input id="lrcNewRate" type="number" min="0" max="30" step="0.001" value="4.100" />
            <small>은행 앱에서 받은 예상 금리</small>
          </label>
          <label class="lrc-field">
            <span>신규 대출 기간</span>
            <input id="lrcNewTermMonths" type="number" min="1" max="600" step="1" value="240" />
            <small>기간을 늘리면 총이자가 늘 수 있음</small>
          </label>
          <button class="lrc-copy-term" id="lrcMatchTermBtn" type="button">기존 남은 기간과 맞추기</button>
          <label class="lrc-field">
            <span>신규 상환 방식</span>
            <select id="lrcNewRepayment">
              <option value="annuity" selected>원리금균등</option>
              <option value="equalPrincipal">원금균등</option>
              <option value="bullet">만기일시</option>
            </select>
          </label>
          <label class="lrc-field">
            <span>신규 금리 유형</span>
            <select id="lrcNewRateType">
              <option value="fixed" selected>고정금리</option>
              <option value="variable">변동금리</option>
              <option value="mixed">혼합형</option>
            </select>
          </label>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">Step 3</p>
            <h2 class="panel__title">수수료와 부대비용</h2>
          </div>
        </div>
        <div class="lrc-form-grid">
          <label class="lrc-field">
            <span>중도상환수수료율</span>
            <input id="lrcPenaltyRate" type="number" min="0" max="10" step="0.001" value="1.200" />
            <small>예: 1.2%는 1.200 입력</small>
          </label>
          <label class="lrc-field">
            <span>수수료 남은 기간</span>
            <input id="lrcPenaltyRemainingMonths" type="number" min="0" max="120" step="1" value="12" />
            <small>개월 기준</small>
          </label>
          <label class="lrc-field">
            <span>전체 수수료 부과 기간</span>
            <input id="lrcPenaltyTotalMonths" type="number" min="1" max="120" step="1" value="36" />
          </label>
          <label class="lrc-field">
            <span>수수료 면제 금액</span>
            <input id="lrcPenaltyExemptAmount" type="text" inputmode="numeric" value="0" />
          </label>
          <label class="lrc-field">
            <span>신규 대출 부대비용</span>
            <input id="lrcNewLoanCosts" type="text" inputmode="numeric" value="0" />
            <small>인지세, 보증료, 플랫폼 비용 등</small>
          </label>
          <label class="lrc-field">
            <span>금리 시나리오 폭</span>
            <input id="lrcScenarioDelta" type="number" min="0" max="5" step="0.1" value="0.5" />
            <small>0.5%p 상승/하락 기준</small>
          </label>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 선택</p>
            <h2 class="panel__title">시나리오 프리셋</h2>
          </div>
        </div>
        <div class="lrc-presets" id="lrcPresets">
          {LRC_PRESETS.map((preset) => (
            <button class="lrc-preset-btn" type="button" data-preset-id={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.description}</span>
            </button>
          ))}
        </div>
      </article>
    </Fragment>

    <section class="lrc-section">
      <div class="lrc-section__head">
        <p class="lrc-section__eyebrow">계산 결과</p>
        <h2>갈아타기 비용을 회수할 수 있는지 봅니다</h2>
        <p id="lrcResultSummary">조건을 입력하면 대출 갈아타기 손익이 표시됩니다.</p>
      </div>
      <div class="lrc-kpi-grid">
        <article class="lrc-kpi-card lrc-kpi-card--main">
          <p>월 납입금 절감액</p>
          <strong id="lrcMonthlySaving">-</strong>
          <span>현재 월 납입금 - 신규 월 납입금</span>
        </article>
        <article class="lrc-kpi-card">
          <p>총 이자 절감액</p>
          <strong id="lrcInterestSaving">-</strong>
          <span>잔여 기간 기준</span>
        </article>
        <article class="lrc-kpi-card">
          <p>갈아타기 순절감액</p>
          <strong id="lrcNetSaving">-</strong>
          <span>이자 절감 - 수수료 - 비용</span>
        </article>
        <article class="lrc-kpi-card lrc-kpi-card--accent">
          <p>수수료 회수 기간</p>
          <strong id="lrcBreakEvenMonths">-</strong>
          <span>총 비용 ÷ 월 절감액</span>
        </article>
      </div>
    </section>

    <section class="lrc-section">
      <div class="lrc-decision-box" id="lrcDecisionBox">
        <span class="lrc-decision-badge" id="lrcDecisionBadge">-</span>
        <p id="lrcDecisionMessage">조건을 입력하면 판단 메시지가 표시됩니다.</p>
      </div>
      <ul class="lrc-warning-list" id="lrcWarningList" aria-live="polite"></ul>
    </section>

    <section class="lrc-section">
      <div class="lrc-section__head">
        <p class="lrc-section__eyebrow">비용 분해</p>
        <h2>월 납입금과 총이자를 함께 비교합니다</h2>
      </div>
      <div class="table-wrap">
        <table class="lrc-table">
          <thead>
            <tr>
              <th>항목</th>
              <th>현재 대출</th>
              <th>신규 대출</th>
              <th>차이</th>
            </tr>
          </thead>
          <tbody id="lrcBreakdownBody"></tbody>
        </table>
      </div>
    </section>

    <section class="lrc-section">
      <div class="lrc-section__head">
        <p class="lrc-section__eyebrow">손익분기</p>
        <h2>수수료를 몇 개월 만에 회수하나요?</h2>
      </div>
      <div class="lrc-timeline" id="lrcTimeline"></div>
    </section>

    <section class="lrc-section">
      <div class="lrc-section__head">
        <p class="lrc-section__eyebrow">금리 시나리오</p>
        <h2>고정금리와 변동금리 리스크를 같이 봅니다</h2>
      </div>
      <div class="table-wrap">
        <table class="lrc-table">
          <thead>
            <tr>
              <th>시나리오</th>
              <th>신규 금리</th>
              <th>월 납입금</th>
              <th>총이자</th>
              <th>순절감액</th>
            </tr>
          </thead>
          <tbody id="lrcScenarioBody"></tbody>
        </table>
      </div>
    </section>

    <section class="lrc-section">
      <div class="lrc-section__head">
        <p class="lrc-section__eyebrow">체크포인트</p>
        <h2>대환 신청 전 확인할 것</h2>
      </div>
      <div class="lrc-checklist">
        <article><strong>기존 약정서</strong><span>중도상환수수료율과 면제 시점 확인</span></article>
        <article><strong>신규 실제 금리</strong><span>우대금리 조건을 충족해야 하는지 확인</span></article>
        <article><strong>부대비용</strong><span>인지세, 보증료, 설정 관련 비용 확인</span></article>
        <article><strong>DSR/LTV</strong><span>대환 승인 가능성과 한도 확인</span></article>
      </div>
    </section>

    <section class="lrc-section">
      <div class="lrc-related-grid">
        {LRC_RELATED_LINKS.map((item) => (
          <a class="lrc-related-card" href={withBase(item.href)}>
            <strong>{item.label}</strong>
            <span>{item.description}</span>
          </a>
        ))}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="대출 갈아타기 계산기 — 결과 읽는 법"
        intro={[
          "대출 갈아타기는 신규 금리가 낮다고 항상 유리한 것은 아닙니다. 중도상환수수료, 신규 대출 부대비용, 대출 기간 변화까지 함께 비교해야 실제 손익을 알 수 있습니다.",
          "이 계산기는 기존 대출과 신규 대출 조건을 입력해 월 납입금 절감액, 총 이자 절감액, 수수료 회수 기간을 계산합니다.",
        ]}
        inputPoints={[
          "현재 대출 잔액, 금리, 남은 기간을 입력합니다.",
          "신규 대출 금리와 상환 기간을 입력해 월 납입금을 비교합니다.",
          "중도상환수수료와 부대비용을 차감해 손익분기 시점을 확인합니다.",
        ]}
        criteria={[
          "입력값을 바탕으로 한 참고용 예상 계산입니다.",
          "실제 대환 가능 여부와 금리는 금융회사 심사, DSR, LTV, 신용점수, 소득에 따라 달라질 수 있습니다.",
          "신규 대출 기간을 늘리면 월 납입금은 줄어도 총이자가 증가할 수 있습니다.",
          "제휴 링크가 포함되는 경우 별도 고지를 표시합니다.",
        ]}
        formulaTitle="계산 공식"
        formula={[
          "월 납입금은 상환 방식별로 원리금균등, 원금균등, 만기일시 공식을 적용합니다.",
          "순절감액 = 기존 잔여 총이자 - 신규 총이자 - 중도상환수수료 - 신규 부대비용입니다.",
          "수수료 회수 기간 = 갈아타기 비용 ÷ 월 납입금 절감액입니다.",
        ]}
        faqTitle="자주 묻는 질문"
        faqItems={faqItems}
      />
    </Fragment>
  </SimpleToolShell>

  <script
    id="lrcConfig"
    type="application/json"
    set:html={JSON.stringify({
      defaultInput: LRC_DEFAULT_INPUT,
      loanTypePresets: LRC_LOAN_TYPE_PRESETS,
      presets: LRC_PRESETS,
    })}
  />
  <script type="module" src={withBase("/scripts/loan-refinancing-calculator.js")}></script>
</BaseLayout>
