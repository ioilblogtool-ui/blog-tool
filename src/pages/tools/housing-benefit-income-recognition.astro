---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  HBIRC_CONFIG,
  HBIRC_FAQ,
  HBIRC_HOUSING_LABELS,
  HBIRC_META,
  HBIRC_PRESETS,
  HBIRC_REGION_LABELS,
  HBIRC_RELATED_LINKS,
  HBIRC_REPAIR_GRADE_LABELS,
  HBIRC_SEO_CONTENT,
  HBIRC_ZONE_LABELS,
} from "../../data/housingBenefitIncomeRecognition";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${HBIRC_META.slug}/`;
const fourPerson = HBIRC_CONFIG.thresholds.find((item) => item.householdSize === 4)!;
const man = (value: number) => `${Math.round(value / 10000).toLocaleString("ko-KR")}만 원`;
---

<BaseLayout
  title={HBIRC_META.seoTitle}
  description={HBIRC_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: HBIRC_META.title,
      applicationCategory: "UtilityApplication",
      operatingSystem: "All",
      description: HBIRC_META.seoDescription,
      url: pageUrl,
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: HBIRC_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={HBIRC_META.slug} pageClass="hbirc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="주거급여 계산"
        title="주거급여 계산기"
        description="가구원 수와 월소득, 재산, 거주 형태를 입력하면 주거급여 선정기준 통과 여부와 예상 기준임대료·수선비용을 함께 확인합니다."
        badges={["신규", "주거급여", "기준임대료", "2026"]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          HBIRC_META.dataNote,
          "입력값은 브라우저에서만 계산되며 서버로 전송하지 않습니다.",
          "기준임대료는 고시값을 단순화한 추정이라 실제 신청 전 최신 고시값 확인이 필요합니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="hbircResetBtn" copyId="hbircCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel hbirc-quick-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">2026 기준</p>
            <h2 class="panel__title">4인 주거급여 기준 {man(fourPerson.housing)}</h2>
          </div>
          <p class="panel-heading__summary">주거급여는 기준 중위소득 48% 이하 구간을 봅니다. 가구원 수를 바꾸면 기준선도 함께 바뀝니다.</p>
        </div>
        <div class="hbirc-threshold-mini">
          {HBIRC_CONFIG.thresholds.slice(0, 6).map((item) => (
            <p><span>{item.householdSize}인</span><strong>{man(item.housing)}</strong></p>
          ))}
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 예시</p>
            <h2 class="panel__title">상황을 골라 시작</h2>
          </div>
        </div>
        <div class="hbirc-preset-grid">
          {HBIRC_PRESETS.map((preset) => (
            <button type="button" class="hbirc-preset-btn" data-hbirc-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.summary}</span>
            </button>
          ))}
        </div>
      </article>

      <article class="panel hbirc-input-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">가구·소득·재산·거주 형태</h2>
          </div>
        </div>

        <section class="hbirc-input-section" aria-labelledby="hbirc-basic-title">
          <h3 id="hbirc-basic-title">기본 정보</h3>
          <div class="form-grid">
            <label class="field">
              <span>가구원 수</span>
              <select data-hbirc="householdSize">
                {HBIRC_CONFIG.thresholds.map((item) => <option value={item.householdSize}>{item.householdSize}인</option>)}
              </select>
            </label>
            <label class="field">
              <span>기본재산액 지역</span>
              <select data-hbirc="region">
                {Object.entries(HBIRC_REGION_LABELS).map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
            <label class="field">
              <span>거주 지역(급지)</span>
              <select data-hbirc="zone">
                {Object.entries(HBIRC_ZONE_LABELS).map(([value, label]) => <option value={value} selected={value === "zone2"}>{label}</option>)}
              </select>
              <small>임차가구 기준임대료 산정용입니다.</small>
            </label>
          </div>
        </section>

        <section class="hbirc-input-section" aria-labelledby="hbirc-housing-title">
          <h3 id="hbirc-housing-title">거주 형태</h3>
          <div class="hbirc-segment" role="group" aria-label="거주 형태">
            {Object.entries(HBIRC_HOUSING_LABELS).map(([value, label]) => (
              <button type="button" data-hbirc-housing={value} aria-pressed={value === "rent" ? "true" : "false"}>{label}</button>
            ))}
          </div>

          <div class="hbirc-branch-panel" data-hbirc-branch="rent">
            <label class="field">
              <span>실제 월 임차료</span>
              <input data-hbirc="monthlyRent" type="text" inputmode="numeric" class="input-number" value="450,000" />
            </label>
          </div>

          <div class="hbirc-branch-panel" data-hbirc-branch="jeonse" hidden>
            <label class="field">
              <span>전세보증금</span>
              <input data-hbirc="jeonseDeposit" type="text" inputmode="numeric" class="input-number" value="150,000,000" />
              <small>전월세 전환율을 적용해 월세로 환산합니다.</small>
            </label>
          </div>

          <div class="hbirc-branch-panel" data-hbirc-branch="own" hidden>
            <div class="form-grid">
              <label class="field">
                <span>주택 사용연수</span>
                <input data-hbirc="houseAge" type="text" inputmode="numeric" class="input-number" value="15" />
              </label>
              <label class="field">
                <span>보수 등급</span>
                <select data-hbirc="repairGrade">
                  <option value="auto">자동(연수 기준 추정)</option>
                  {Object.entries(HBIRC_REPAIR_GRADE_LABELS).map(([value, label]) => <option value={value}>{label}</option>)}
                </select>
              </label>
            </div>
          </div>

          <div class="hbirc-branch-panel" data-hbirc-branch="free" hidden>
            <p class="hbirc-branch-note">무상거주는 별도 임대료·수선비 계산 없이 소득인정액 기준 통과 여부만 확인합니다.</p>
          </div>
        </section>

        <section class="hbirc-input-section" aria-labelledby="hbirc-income-title">
          <h3 id="hbirc-income-title">월 소득</h3>
          <div class="form-grid">
            <label class="field">
              <span>월 근로·사업소득</span>
              <input data-hbirc="earnedIncome" type="text" inputmode="numeric" class="input-number" value="1,500,000" />
            </label>
            <label class="field">
              <span>공적 이전소득</span>
              <input data-hbirc="publicTransferIncome" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
            <label class="field">
              <span>사적 이전·재산소득</span>
              <input data-hbirc="otherIncome" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
            <label class="checkbox-option">
              <input type="checkbox" data-hbirc="applyWorkDeduction" checked />
              <span>근로·사업소득 30% 간이 공제 적용</span>
            </label>
          </div>
        </section>

        <section class="hbirc-input-section" aria-labelledby="hbirc-asset-title">
          <h3 id="hbirc-asset-title">재산</h3>
          <div class="form-grid">
            <label class="field">
              <span>주거재산</span>
              <input data-hbirc="housingAsset" type="text" inputmode="numeric" class="input-number" value="50,000,000" />
              <small>전세보증금 또는 자가 주택가액을 입력합니다.</small>
            </label>
            <label class="field">
              <span>일반재산</span>
              <input data-hbirc="generalAsset" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
            <label class="field">
              <span>금융재산</span>
              <input data-hbirc="financialAsset" type="text" inputmode="numeric" class="input-number" value="5,000,000" />
            </label>
            <label class="field">
              <span>인정 가능 부채</span>
              <input data-hbirc="debt" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
            <label class="checkbox-option">
              <input type="checkbox" data-hbirc="hasCar" />
              <span>자동차가 있습니다</span>
            </label>
            <label class="field">
              <span>차량가액</span>
              <input data-hbirc="carValue" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
          </div>
        </section>
      </article>
    </Fragment>

    <section class="hbirc-section hbirc-result-section" aria-live="polite">
      <div class="section-header">
        <p class="section-header__eyebrow">계산 결과</p>
        <h2>주거급여 기준선과 예상 지급액</h2>
        <p>입력값을 바꾸면 소득인정액과 거주 형태별 예상 지급액이 즉시 다시 계산됩니다.</p>
      </div>
      <div class="hbirc-kpi-grid">
        <article class="hbirc-kpi hbirc-kpi--main"><span>소득인정액 추정</span><strong data-hbirc-result="incomeRecognized">-</strong><small>자가 점검용 추정</small></article>
        <article class="hbirc-kpi"><span>주거급여 선정기준</span><strong data-hbirc-result="threshold">-</strong><small data-hbirc-result="thresholdMeta">2026년 기준</small></article>
        <article class="hbirc-kpi"><span>기준까지 차이</span><strong data-hbirc-result="gap">-</strong><small data-hbirc-result="judgement">확인 중</small></article>
      </div>

      <div class="hbirc-kpi-grid hbirc-kpi-grid--branch" data-hbirc-branch-result="rent" hidden>
        <article class="hbirc-kpi"><span>기준임대료(<span data-hbirc-result="zoneLabel"></span>)</span><strong data-hbirc-result="standardRent">-</strong></article>
        <article class="hbirc-kpi"><span>실제 임차료 반영액</span><strong data-hbirc-result="effectiveRent">-</strong></article>
        <article class="hbirc-kpi hbirc-kpi--accent"><span>예상 주거급여</span><strong data-hbirc-result="estimatedRentBenefit">-</strong></article>
      </div>

      <div class="hbirc-kpi-grid hbirc-kpi-grid--branch" data-hbirc-branch-result="own" hidden>
        <article class="hbirc-kpi"><span>수선 등급</span><strong data-hbirc-result="repairGradeLabel">-</strong></article>
        <article class="hbirc-kpi"><span>기준 지원금액</span><strong data-hbirc-result="repairBaseAmount">-</strong></article>
        <article class="hbirc-kpi hbirc-kpi--accent"><span>예상 지원금액</span><strong data-hbirc-result="estimatedRepairAmount">-</strong></article>
      </div>

      <p class="hbirc-branch-note" data-hbirc-branch-result="free" hidden>무상거주는 임대료·수선비 지원 항목이 없습니다.</p>

      <p class="hbirc-summary" data-hbirc-summary></p>
    </section>

    <section class="hbirc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">기준선</p>
        <h2>내 소득인정액 위치</h2>
      </div>
      <div class="hbirc-gauge" aria-hidden="true">
        <span class="hbirc-gauge__bar"><i data-hbirc-gauge-fill></i></span>
        <div class="hbirc-gauge__labels"><span>0%</span><span>95%</span><span>100%</span><span>105%</span></div>
      </div>
    </section>

    <section class="hbirc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">분해</p>
        <h2>소득인정액 구성</h2>
      </div>
      <div class="hbirc-breakdown" data-hbirc-breakdown></div>
    </section>

    <section class="hbirc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">참고표</p>
        <h2>2026년 급지별 기준임대료(가구원 수별)</h2>
      </div>
      <div class="hbirc-table-wrap">
        <table class="hbirc-rent-table">
          <thead>
            <tr>
              <th>가구원 수</th>
              {Object.entries(HBIRC_ZONE_LABELS).map(([, label]) => <th>{label}</th>)}
            </tr>
          </thead>
          <tbody>
            {[1, 2, 3, 4, 5, 6].map((size) => (
              <tr>
                <td>{size}인</td>
                {Object.keys(HBIRC_ZONE_LABELS).map((zone) => (
                  <td>{man(HBIRC_CONFIG.standardRent[zone][size])}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="hbirc-table-note">2026년 국토교통부 주거급여 기준임대료 고시 단순화. 실제 신청 전 LH 주거급여 콜센터(1600-0777) 또는 복지로 최신 고시값을 확인하세요.</p>
    </section>

    <section class="hbirc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">다음 확인</p>
        <h2>확인 필요 항목과 연결 계산기</h2>
      </div>
      <div class="hbirc-warning-grid" data-hbirc-warnings></div>
      <div class="hbirc-action-grid">
        <a href={withBase("/tools/livelihood-benefit-income-recognition/")}>생계급여 소득인정액 계산기 보기</a>
        <a href={withBase("/tools/welfare-benefit-eligibility/")}>4대 급여 전체 가능성 보기</a>
        <a href={withBase("/compare/welfare/")}>복지지원금 비교표 보기</a>
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle={HBIRC_SEO_CONTENT.introTitle}
        intro={HBIRC_SEO_CONTENT.intro}
        inputPoints={HBIRC_SEO_CONTENT.inputPoints}
        criteria={HBIRC_SEO_CONTENT.criteria}
        faq={HBIRC_FAQ}
        related={HBIRC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="hbirc-data" type="application/json" set:html={JSON.stringify(HBIRC_CONFIG)} />
  <script type="module" src={withBase("/scripts/housing-benefit-income-recognition.js")}></script>
</BaseLayout>
