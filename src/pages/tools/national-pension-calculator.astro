---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  NPC_DEFAULT_INPUT,
  NPC_FAQ,
  NPC_GUIDE_POINTS,
  NPC_INCOME_PRESETS,
  NPC_LIFE_EXPECTANCY_PRESETS,
  NPC_NEXT_CONTENT,
  NPC_REFERENCE_CARDS,
  NPC_RELATED_LINKS,
  NPC_RULES,
} from "../../data/nationalPensionCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const config = {
  defaults: NPC_DEFAULT_INPUT,
  rules: NPC_RULES,
  incomePresets: NPC_INCOME_PRESETS,
};

const faqSchema = NPC_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: {
    "@type": "Answer",
    text: item.answer,
  },
}));
---

<BaseLayout
  title="국민연금 예상수령액 계산기 2026 | 조기·정상·연기 수령 비교"
  description="현재 나이, 가입 시작 연도, 소득 또는 보험료를 입력하면 국민연금 예상 수령액, 총 납입액, 손익분기 연령, 생활비 부족분을 빠르게 비교합니다."
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "국민연금 예상수령액 계산기 2026",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description:
      "현재 나이, 소득, 가입기간과 수령 방식을 기준으로 국민연금 예상 수령액과 손익분기를 비교하는 계산기",
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/national-pension-calculator/`,
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="national-pension-calculator" pageClass="npc-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="연금 계산기"
        title="국민연금 예상수령액을 조기·정상·연기로 바로 비교합니다"
        description="가입 시작 연도, 소득, 납입 종료 나이만 입력하면 예상 월 연금, 총 납입액, 손익분기 연령과 노후 생활비 부족분까지 한 화면에서 확인할 수 있습니다."
      />
      <InfoNotice
        title="안내"
        lines={[
          "이 계산기는 국민연금공단 공식 조회를 대체하지 않는 추정 도구입니다.",
          "실제 수령액은 개인별 가입 이력, 소득 재평가, 수급 시점 제도 변화에 따라 달라질 수 있습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetNpcBtn" copyId="copyNpcLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">기본 입력</p>
            <h2 class="panel__title">가입 조건 입력</h2>
          </div>
          <p class="panel-heading__summary">소득 기준으로 볼지, 내가 실제 내는 보험료 기준으로 볼지 먼저 선택합니다.</p>
        </div>

        <div class="form-grid">
          <label class="field">
            <span>현재 나이</span>
            <input id="npcCurrentAge" type="number" min="20" max="64" value={NPC_DEFAULT_INPUT.currentAge} />
          </label>

          <label class="field">
            <span>국민연금 가입 시작 연도</span>
            <input id="npcStartYear" type="number" min="1988" max="2026" value={NPC_DEFAULT_INPUT.startYear} />
          </label>

          <div class="field field-span-full">
            <span class="field__label">입력 기준</span>
            <div class="npc-income-mode-tabs">
              <button id="npcModeIncome" class="npc-mode-tab is-active" type="button" data-mode="income">월소득 기준</button>
              <button id="npcModePremium" class="npc-mode-tab" type="button" data-mode="premium">보험료 직접 입력</button>
            </div>
          </div>

          <label class="field" id="npcIncomeField">
            <span>월소득</span>
            <input id="npcMonthlyIncome" type="number" min="37" max="650" step="10" value={NPC_DEFAULT_INPUT.monthlyIncome} />
            <div class="npc-presets">
              {NPC_INCOME_PRESETS.map((preset) => (
                <button class="npc-preset-btn" type="button" data-value={preset.value}>{preset.label}</button>
              ))}
            </div>
          </label>

          <label class="field is-hidden" id="npcPremiumField">
            <span>본인 월 보험료</span>
            <input id="npcMonthlyPremium" type="number" min="1" max="100" step="1" value={NPC_DEFAULT_INPUT.monthlyPremium} />
            <small>직장가입자는 본인 부담분, 지역가입자는 전액 기준</small>
          </label>

          <label class="field field-span-full">
            <span>예상 납입 종료 나이 <strong id="npcEndAgeDisplay">60세</strong></span>
            <input id="npcEndAge" type="range" min="30" max="60" step="1" value={NPC_DEFAULT_INPUT.endAge} />
          </label>

          <fieldset class="field field-span-full npc-radio-group">
            <legend>가입자 유형</legend>
            <label><input type="radio" name="npcSubscriberType" value="employee" checked /> 직장가입자</label>
            <label><input type="radio" name="npcSubscriberType" value="regional" /> 지역가입자</label>
          </fieldset>

          <label class="field">
            <span>기본 기대수명</span>
            <select id="npcLifeExpectancy">
              {NPC_LIFE_EXPECTANCY_PRESETS.map((item) => (
                <option value={item.value} selected={item.value === NPC_DEFAULT_INPUT.lifeExpectancy}>{item.label}</option>
              ))}
            </select>
          </label>

          <label class="field">
            <span>목표 노후 생활비</span>
            <input id="npcTargetExpense" type="number" min="50" max="1000" step="10" value={NPC_DEFAULT_INPUT.targetMonthlyExpense} />
          </label>
        </div>

        <button id="npcAdvancedToggle" class="npc-advanced-toggle" type="button" aria-expanded="false">고급 설정 열기</button>
        <div id="npcAdvancedPanel" class="npc-advanced-panel" hidden>
          <div class="form-grid">
            <label class="field">
              <span>납입 공백 연수</span>
              <input id="npcGapYears" type="number" min="0" max="20" step="1" value={NPC_DEFAULT_INPUT.contributionGapYears} />
              <small>이직, 휴직, 경력 단절 구간을 단순 반영</small>
            </label>
            <label class="field">
              <span>물가상승률 가정</span>
              <input id="npcInflationRate" type="number" min="0" max="10" step="0.5" value={NPC_DEFAULT_INPUT.inflationRate} />
              <small>실질가치 계산에 사용</small>
            </label>
          </div>
        </div>
      </article>
    </Fragment>

    <section class="npc-section">
      <div class="npc-section__head">
        <p class="npc-section__eyebrow">핵심 결과</p>
        <h2>조기·정상·연기 수령 중 현재 선택 기준을 먼저 봅니다</h2>
        <p class="npc-section__sub">국민연금 계산기는 복잡한 제도 설명보다 예상 월 연금과 손익분기 시점을 먼저 확인하는 흐름에 맞춰 구성했습니다.</p>
      </div>

      <div class="npc-claim-tabs" id="npcClaimTabs">
        <button class="npc-claim-tab" type="button" data-claim="early">조기 수령<small>60세</small></button>
        <button class="npc-claim-tab is-active" type="button" data-claim="normal">정상 수령<small>65세</small></button>
        <button class="npc-claim-tab" type="button" data-claim="deferred">연기 수령<small id="npcDeferredLabel">68세</small></button>
      </div>

      <div class="npc-defer-ctrl" id="npcDeferControl" hidden>
        <label class="field">
          <span>연기 연수</span>
          <select id="npcDeferYears">
            <option value="1">1년</option>
            <option value="2">2년</option>
            <option value="3" selected>3년</option>
            <option value="4">4년</option>
            <option value="5">5년</option>
          </select>
        </label>
      </div>

      <div class="npc-ineligible-notice" id="npcIneligibleNotice" hidden>
        <strong>가입기간 10년 미만 추정</strong>
        <p>현재 입력값 기준으로는 노령연금 수급 조건에 아직 도달하지 못했을 수 있습니다. 납입 종료 나이나 가입 시작 연도를 다시 확인해보세요.</p>
      </div>

      <div class="npc-result-cards">
        <article class="npc-result-card npc-result-card--main">
          <p class="npc-result-label">예상 월 연금</p>
          <strong class="npc-result-value npc-result-value--hl" id="npcMonthlyPension">-</strong>
          <p class="npc-result-note"><span class="npc-badge npc-badge--est">추정</span> <span id="npcClaimLabel">정상 수령 65세 기준</span></p>
        </article>
        <article class="npc-result-card">
          <p class="npc-result-label">실질가치 월 연금</p>
          <strong class="npc-result-value" id="npcRealPension">-</strong>
          <p class="npc-result-note">현재 가치로 환산한 금액</p>
        </article>
        <article class="npc-result-card">
          <p class="npc-result-label">총 납입액</p>
          <strong class="npc-result-value" id="npcTotalContribution">-</strong>
          <p class="npc-result-note"><span id="npcContributionYears">-</span>년 가입 기준</p>
        </article>
        <article class="npc-result-card npc-result-card--breakeven">
          <p class="npc-result-label">손익분기 연령</p>
          <strong class="npc-result-value" id="npcBreakevenAge">-</strong>
          <p class="npc-result-note">총 납입액을 회수하는 시점</p>
        </article>
        <article class="npc-result-card">
          <p class="npc-result-label">평생 총 수령액</p>
          <strong class="npc-result-value" id="npcTotalPayout">-</strong>
          <p class="npc-result-note"><span id="npcLifeLabel">85세</span>까지 수령 가정</p>
        </article>
      </div>
    </section>

    <section class="npc-section">
      <div class="npc-section__head">
        <p class="npc-section__eyebrow">생활비 비교</p>
        <h2>국민연금만으로 부족한 금액을 바로 확인합니다</h2>
      </div>
      <article class="npc-shortfall-box">
        <p class="npc-shortfall-title">목표 생활비 대비 부족분</p>
        <div class="npc-shortfall-row">
          <span>목표 생활비</span>
          <strong id="npcTargetDisplay">-</strong>
        </div>
        <div class="npc-shortfall-row">
          <span>예상 월 연금</span>
          <strong id="npcPensionDisplay">-</strong>
        </div>
        <div class="npc-shortfall-row npc-shortfall-row--gap">
          <span>추가로 준비할 금액</span>
          <strong id="npcShortfallDisplay">-</strong>
        </div>
        <p class="npc-shortfall-cta-text">부족분이 크다면 퇴직연금, IRP, 개인연금, 장기 적립식 투자까지 같이 보는 흐름이 현실적입니다.</p>
      </article>
    </section>

    <section class="npc-section">
      <div class="npc-section__head">
        <p class="npc-section__eyebrow">보조 차트</p>
        <h2>수령 방식과 손익 구조를 차트로 다시 확인합니다</h2>
        <p class="npc-section__sub">이 페이지는 Simple Calculator를 기준으로 두되, 수급 방식 차이는 차트 2개로 보조 확인할 수 있게 유지합니다.</p>
      </div>
      <div class="npc-chart-grid">
        <article class="panel npc-chart-card">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">차트 1</p>
              <h2 class="panel__title">수령 방식별 월 연금 비교</h2>
            </div>
            <p class="panel-heading__summary">조기·정상·연기 시나리오를 같은 축에서 비교합니다.</p>
          </div>
          <div class="npc-chart-wrap">
            <canvas id="npcCompareChart"></canvas>
          </div>
        </article>

        <article class="panel npc-chart-card">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">차트 2</p>
              <h2 class="panel__title">총 납입액과 평생 수령액 비교</h2>
            </div>
            <p class="panel-heading__summary">내가 내는 금액과 받을 가능성이 있는 총액을 단순 비교합니다.</p>
          </div>
          <div class="npc-chart-wrap">
            <canvas id="npcFlowChart"></canvas>
          </div>
        </article>
      </div>
    </section>

    <section class="npc-section">
      <div class="npc-section__head">
        <p class="npc-section__eyebrow">해석 가이드</p>
        <h2>입력값 기준으로 먼저 봐야 할 포인트</h2>
      </div>
      <ul class="npc-guide-list" id="npcGuideList">
        {NPC_GUIDE_POINTS.map((item) => <li class="npc-guide-item">{item}</li>)}
      </ul>
    </section>

    <section class="content-section npc-next-section">
      <div class="panel npc-next-main">
        <div class="npc-next-main__badges">
          {NPC_NEXT_CONTENT.badges.map((badge) => (
            <span class="npc-next-main__badge">{badge}</span>
          ))}
        </div>
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">{NPC_NEXT_CONTENT.eyebrow}</p>
            <h2 class="panel__title">{NPC_NEXT_CONTENT.title}</h2>
          </div>
          <p class="panel-heading__summary">{NPC_NEXT_CONTENT.desc}</p>
        </div>
        <a href={withBase(NPC_NEXT_CONTENT.href)} class="button button--secondary">{NPC_NEXT_CONTENT.cta}</a>
      </div>
      <div class="npc-next-grid">
        {NPC_NEXT_CONTENT.sub.map((item) => (
          <a href={withBase(item.href)} class="npc-next-card">
            <div class="npc-next-card__badges">
              {item.badges.map((badge) => (
                <span class="npc-next-card__badge">{badge}</span>
              ))}
            </div>
            <strong>{item.title}</strong>
            <span>{item.desc}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="content-section npc-reference-section">
      <div class="panel npc-reference-links">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">외부 참고 링크</p>
            <h2 class="panel__title">공식 조회와 제도 안내 같이 보기</h2>
          </div>
          <p class="panel-heading__summary">이 계산기는 추정 도구이므로 실제 수급 판단 전에는 공단 공식 조회와 제도 안내를 함께 보는 편이 안전합니다.</p>
        </div>
        <div class="npc-link-grid">
          {NPC_REFERENCE_CARDS.map((item) => (
            <a class="npc-reference-link" href={item.href} target="_blank" rel="noopener noreferrer">
              <span class="npc-reference-link__source">{item.source}</span>
              <strong class="npc-reference-link__title">{item.title}</strong>
              <span class="npc-reference-link__desc">{item.desc}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="국민연금 예상수령액 계산기를 이렇게 읽으면 됩니다"
        intro={[
          "국민연금을 몇 살부터 받을지, 조기 수령과 연기 수령 중 어느 쪽이 유리한지 고민하는 시기가 누구에게나 옵니다. 국민연금 예상수령액 계산기는 국민연금공단 공식 조회를 대신하는 서비스가 아니라, 현재 나이와 소득, 가입기간을 기준으로 조기·정상·연기 수령 차이를 빠르게 비교하는 추정 도구입니다.",
          "조기 수령은 정상 연령보다 일찍 받는 대신 매월 수령액이 줄어들고, 연기 수령은 늦게 받는 대신 수령액이 늘어나는 구조입니다. 이 계산기는 예상 월 연금, 총 납입액, 손익분기 연령, 목표 생활비 대비 부족분을 함께 보여줘서 노후 자금 흐름을 감으로 보지 않고 숫자로 확인할 수 있게 합니다.",
          "결과에서 가장 중요하게 볼 지표는 손익분기 연령입니다. 손익분기 연령보다 더 오래 살 것으로 예상한다면 연기 수령이 총수령액 기준으로 유리하고, 그보다 일찍 자금이 필요하다면 조기 수령이 더 합리적인 선택일 수 있습니다. 은퇴 전후 현금흐름을 처음 점검하거나 개인연금·IRP를 얼마나 추가로 준비할지 가늠할 때도 유용하게 활용할 수 있습니다.",
          "다만 이 계산기는 현재 소득과 가입기간을 기준으로 한 추정치이며, 실제 수령액은 향후 소득 변동, 연금 개혁, 물가 변동률에 따라 달라질 수 있습니다. 정확한 예상 수령액은 국민연금공단 홈페이지나 '내 연금' 앱에서 공식 조회로 다시 확인하는 것을 권장합니다.",
        ]}
        inputPoints={[
          "현재 나이, 가입 시작 연도, 월소득 또는 보험료를 입력해 예상 월 연금과 총 납입액을 확인할 수 있습니다.",
          "조기 수령, 정상 수령, 연기 수령을 같은 기준에서 비교해 월 수령액과 손익분기 연령 차이를 볼 수 있습니다.",
          "목표 노후 생활비를 넣으면 국민연금만으로 부족한 월 금액을 바로 확인할 수 있습니다.",
        ]}
        criteria={[
          "기준일은 2026년 가정이며 보험료율 9.5%, 소득대체율 43%, A값 319.4만원을 추정 모델에 반영했습니다.",
