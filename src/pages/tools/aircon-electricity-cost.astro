---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  ELECTRICITY_RATES,
  AIRCON_PRESETS,
  INVERTER_RATIO,
  ACC_FAQS,
  ACC_SEO_INTRO,
  ACC_SEO_CRITERIA,
  ACC_RELATED,
} from "../../data/airconElectricityCost";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteUrl = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");

const config = {
  rates: ELECTRICITY_RATES,
  presets: AIRCON_PRESETS,
  inverterRatio: INVERTER_RATIO,
};

const faqSchema = ACC_FAQS.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: { "@type": "Answer", text: item.answer },
}));
---

<BaseLayout
  title="에어컨 전기요금 계산기 2026 — 누진세 반영 월 추가 요금"
  description="에어컨 소비전력과 하루 사용 시간을 입력하면 월 전기요금 추가분을 누진세 구간까지 반영해 정확하게 계산합니다. 인버터 보정, 여름 완화 구간 자동 적용."
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "에어컨 전기요금 계산기",
    applicationCategory: "UtilitiesApplication",
    operatingSystem: "All",
    url: `${siteUrl}/tools/aircon-electricity-cost/`,
    description: "에어컨 소비전력과 하루 사용 시간으로 월 전기요금 추가분을 누진세 구간까지 반영해 계산하는 도구",
    mainEntity: { "@type": "FAQPage", mainEntity: faqSchema },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="aircon-electricity-cost" pageClass="acc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="에어컨 전기요금 계산기"
        title="에어컨 켜면 전기요금 얼마나 오를까?"
        description="소비전력과 사용 시간을 입력하면 가정 기존 사용량에 에어컨 추가분을 더해 누진 구간 교차 효과까지 반영한 정확한 추가 요금을 계산합니다."
      />
      <InfoNotice
        title="계산 기준 안내"
        lines={ACC_SEO_CRITERIA}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="accResetBtn" copyId="accCopyLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <div class="acc-aside-stack" data-acc-calculator>

        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">에어컨 종류 선택</p>
              <h2 class="panel__title">빠른 프리셋</h2>
            </div>
          </div>
          <div class="acc-preset-grid">
            {AIRCON_PRESETS.map((preset, i) => (
              <button
                type="button"
                class={`acc-preset-btn${i === 1 ? " is-active" : ""}`}
                data-acc-preset={preset.id}
                data-acc-preset-watt={preset.watt}
              >
                {preset.label}
              </button>
            ))}
          </div>
        </article>

        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">에어컨 설정</p>
              <h2 class="panel__title">사용 조건 입력</h2>
            </div>
          </div>

          <div class="form-grid form-grid--compact">
            <label class="field" data-acc-watt-field>
              <span>소비전력 (W)</span>
              <input data-acc-watt type="number" min="100" max="5000" step="50" value="1200" class="input-number" />
            </label>

            <label class="field field--toggle">
              <span>인버터 에어컨</span>
              <input type="checkbox" data-acc-inverter checked />
              <small>정격 소비전력의 60% 실소비 추정</small>
            </label>

            <label class="field">
              <span>하루 사용 시간 <strong data-acc-hours-display>8</strong>시간</span>
              <input
                type="range"
                data-acc-hours
                min="0.5"
                max="24"
                step="0.5"
                value="8"
                class="range-slider"
              />
              <div class="range-labels"><span>0.5h</span><span>24h</span></div>
            </label>

            <label class="field">
              <span>월 사용 일수 <strong data-acc-days-display>25</strong>일</span>
              <input
                type="range"
                data-acc-days
                min="1"
                max="31"
                step="1"
                value="25"
                class="range-slider"
              />
              <div class="range-labels"><span>1일</span><span>31일</span></div>
            </label>
          </div>
        </article>

        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">가정 기본 사용량</p>
              <h2 class="panel__title">에어컨 제외 월 전력 소비</h2>
            </div>
          </div>
          <div class="form-grid form-grid--compact">
            <label class="field">
              <span>기본 월 사용량 <strong data-acc-base-display>200</strong>kWh</span>
              <input
                type="range"
                data-acc-base
                min="50"
                max="400"
                step="10"
                value="200"
                class="range-slider"
              />
              <div class="range-labels"><span>50kWh</span><span>400kWh</span></div>
            </label>

            <label class="field">
              <span>계절</span>
              <select data-acc-season class="select">
                <option value="summer" selected>여름 (7~8월 완화 구간 적용)</option>
                <option value="normal">일반 (그 외 계절)</option>
              </select>
            </label>
          </div>
        </article>

      </div>
    </Fragment>

    <section class="acc-result-stack" aria-live="polite">

      <div class="acc-kpi-grid">
        <article class="acc-kpi-card acc-kpi-card--main">
          <span>에어컨 추가 월 요금</span>
          <strong data-acc-extra>-</strong>
          <small>기존 요금 대비 추가분</small>
        </article>
        <article class="acc-kpi-card">
          <span>전체 예상 전기요금</span>
          <strong data-acc-total>-</strong>
          <small>기존 + 에어컨 합산</small>
        </article>
        <article class="acc-kpi-card">
          <span>에어컨 월 전력 소비</span>
          <strong data-acc-kwh>-</strong>
          <small>실소비전력 기준</small>
        </article>
        <article class="acc-kpi-card">
          <span>누진 구간</span>
          <strong><span class="acc-tier-badge" data-acc-tier-badge>-</span></strong>
          <small data-acc-total-kwh-label>총 - kWh</small>
        </article>
      </div>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">누진 구간 위치</p>
            <h2 class="panel__title">현재 사용량 구간 시각화</h2>
          </div>
        </div>
        <div class="acc-tier-bar-wrap">
          <div class="acc-tier-bar">
            <div class="acc-tier-bar__fill" data-acc-tier-fill style="width:0%"></div>
            <div class="acc-tier-bar__marker" data-acc-marker-1 style="left:0%">
              <span class="acc-tier-bar__marker-label" data-acc-marker-1-label>200</span>
            </div>
            <div class="acc-tier-bar__marker acc-tier-bar__marker--2" data-acc-marker-2 style="left:0%">
              <span class="acc-tier-bar__marker-label" data-acc-marker-2-label>400</span>
            </div>
          </div>
          <div class="acc-tier-labels">
            <span class="acc-tier-label acc-tier-label--1">1단계</span>
            <span class="acc-tier-label acc-tier-label--2">2단계</span>
            <span class="acc-tier-label acc-tier-label--3">3단계</span>
          </div>
          <p class="acc-tier-desc" data-acc-tier-desc>-</p>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">사용량 구성</p>
            <h2 class="panel__title">기존 vs 에어컨 추가</h2>
          </div>
        </div>
        <div class="acc-donut-wrap">
          <canvas id="aircon-usage-donut"></canvas>
        </div>
        <div class="acc-donut-legend">
          <span class="acc-legend-dot acc-legend-dot--base"></span>기존 사용량 <strong data-acc-base-kwh-label>-</strong>
          <span class="acc-legend-dot acc-legend-dot--aircon"></span>에어컨 추가 <strong data-acc-aircon-kwh-label>-</strong>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">요금 상세</p>
            <h2 class="panel__title">항목별 전기요금 내역</h2>
          </div>
        </div>
        <div class="acc-table-wrap">
          <table class="acc-detail-table">
            <thead>
              <tr>
                <th>항목</th>
                <th>기존만</th>
                <th>에어컨 포함</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>기본요금</td>
                <td data-acc-base-basic>-</td>
                <td data-acc-total-basic>-</td>
              </tr>
              <tr>
                <td>전력량요금</td>
                <td data-acc-base-energy>-</td>
                <td data-acc-total-energy>-</td>
              </tr>
              <tr>
                <td>기후환경요금</td>
                <td data-acc-base-climate>-</td>
                <td data-acc-total-climate>-</td>
              </tr>
              <tr>
                <td>연료비조정액</td>
                <td data-acc-base-fuel>-</td>
                <td data-acc-total-fuel>-</td>
              </tr>
              <tr>
                <td>부가세 + 기반기금</td>
                <td data-acc-base-tax>-</td>
                <td data-acc-total-tax>-</td>
              </tr>
              <tr class="is-highlight">
                <td><strong>합계</strong></td>
                <td><strong data-acc-base-bill>-</strong></td>
                <td><strong data-acc-total-bill>-</strong></td>
              </tr>
              <tr class="acc-extra-row">
                <td colspan="2"><strong>에어컨 추가 요금</strong></td>
                <td><strong data-acc-extra-cell>-</strong></td>
              </tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">절약 팁</p>
            <h2 class="panel__title">이렇게 하면 절약됩니다</h2>
          </div>
        </div>
        <div class="acc-tip-grid">
          <article class="acc-tip-card">
            <strong>하루 1시간 줄이면</strong>
            <p data-acc-tip-1h>계산 중...</p>
          </article>
          <article class="acc-tip-card">
            <strong>26°C → 28°C 설정</strong>
            <p>소비전력 약 15~20% 감소. 체감 온도 차이는 크지 않습니다.</p>
          </article>
          <article class="acc-tip-card">
            <strong>인버터 vs 일반</strong>
            <p data-acc-tip-inverter>인버터 에어컨은 정격 대비 약 40% 전기요금을 절약합니다.</p>
          </article>
          <article class="acc-tip-card">
            <strong>여름 누진 완화</strong>
            <p>7~8월에는 1단계 구간이 300kWh로 확대됩니다. 절약 효과가 큽니다.</p>
          </article>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">관련 계산기</p>
            <h2 class="panel__title">같이 보면 좋은 계산기</h2>
          </div>
        </div>
        <div class="acc-related-grid">
          {ACC_RELATED.map((item) => (
            <a href={withBase(item.href)} class="acc-related-card">
              <strong>{item.label}</strong>
              <span>{item.description}</span>
            </a>
          ))}
        </div>
      </article>

    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="에어컨 전기요금 누진세 완전 계산법"
        intro={[ACC_SEO_INTRO]}
        inputPoints={[
          "에어컨 소비전력과 하루 사용 시간·월 사용 일수를 입력하면 월 추가 전기요금을 즉시 계산합니다.",
          "인버터 에어컨은 정격 소비전력의 60% 수준을 실소비전력으로 자동 적용합니다.",
          "가정 기본 사용량과 합산한 누진 구간(1~3단계)을 시각적으로 확인할 수 있습니다.",
          "7~8월 여름 완화 구간(1단계 300kWh)을 선택하면 실제 여름철 요금에 가깝게 계산됩니다.",
        ]}
        criteria={ACC_SEO_CRITERIA}
        faq={ACC_FAQS}
        related={ACC_RELATED.map((item) => ({ href: item.href, label: item.label }))}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="accConfig" type="application/json" set:html={JSON.stringify(config)}></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/aircon-electricity-cost.js")}></script>
</BaseLayout>
