---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  BPEC_CONFIG,
  BPEC_FAQ,
  BPEC_HOUSEHOLD_LABELS,
  BPEC_META,
  BPEC_PRESETS,
  BPEC_REGION_LABELS,
  BPEC_RELATED_LINKS,
  BPEC_SEO_CONTENT,
  BPEC_SELECTION_THRESHOLD,
} from "../../data/basicPensionEligibilityCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${BPEC_META.slug}/`;
const man = (value: number) => `${Math.round(value / 10000).toLocaleString("ko-KR")}만 원`;
---

<BaseLayout
  title={BPEC_META.seoTitle}
  description={BPEC_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: BPEC_META.title,
      applicationCategory: "UtilityApplication",
      operatingSystem: "All",
      description: BPEC_META.seoDescription,
      url: pageUrl,
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: BPEC_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={BPEC_META.slug} pageClass="bpec-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="기초연금 계산"
        title="기초연금 수급 가능성 계산기"
        description="가구 형태와 소득, 재산을 입력하면 2026년 기초연금 선정기준 대비 소득인정액과 수급 가능성을 빠르게 확인합니다."
        badges={["기초연금", "소득인정액", "2026", "자가 점검"]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          BPEC_META.dataNote,
          "입력값은 브라우저에서만 계산되며 서버로 전송하지 않습니다.",
          "국민연금 연계 감액·소득역전방지 감액은 반영하지 않았습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="bpecResetBtn" copyId="bpecCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel bpec-quick-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">2026 기준</p>
            <h2 class="panel__title">단독 {man(BPEC_SELECTION_THRESHOLD.single)} · 부부 {man(BPEC_SELECTION_THRESHOLD.couple)}</h2>
          </div>
          <p class="panel-heading__summary">기초연금은 소득인정액이 선정기준액보다 낮아야 수급 가능 구간으로 봅니다.</p>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 예시</p>
            <h2 class="panel__title">상황을 골라 시작</h2>
          </div>
        </div>
        <div class="bpec-preset-grid">
          {BPEC_PRESETS.map((preset) => (
            <button type="button" class="bpec-preset-btn" data-bpec-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.summary}</span>
            </button>
          ))}
        </div>
      </article>

      <article class="panel bpec-input-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">가구·소득·재산</h2>
          </div>
        </div>

        <section class="bpec-input-section" aria-labelledby="bpec-basic-title">
          <h3 id="bpec-basic-title">기본 정보</h3>
          <div class="form-grid">
            <label class="field">
              <span>가구 형태</span>
              <select data-bpec="householdType">
                {Object.entries(BPEC_HOUSEHOLD_LABELS).map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
            <label class="field">
              <span>거주 지역</span>
              <select data-bpec="region">
                {Object.entries(BPEC_REGION_LABELS).map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
          </div>
        </section>

        <section class="bpec-input-section" aria-labelledby="bpec-income-title">
          <h3 id="bpec-income-title">월 소득</h3>
          <div class="form-grid">
            <label class="field">
              <span>월 근로·사업소득</span>
              <input data-bpec="earnedIncome" type="text" inputmode="numeric" class="input-number" value="0" />
              <small>116만원까지는 소득평가액에 반영되지 않습니다.</small>
            </label>
            <label class="field">
              <span>공적연금 등 기타소득</span>
              <input data-bpec="publicPensionIncome" type="text" inputmode="numeric" class="input-number" value="300,000" />
              <small>국민연금, 공무원연금 등 수령액을 그대로 입력합니다.</small>
            </label>
          </div>
        </section>

        <section class="bpec-input-section" aria-labelledby="bpec-asset-title">
          <h3 id="bpec-asset-title">재산</h3>
          <div class="form-grid">
            <label class="field">
              <span>일반재산(부동산 등)</span>
              <input data-bpec="generalAsset" type="text" inputmode="numeric" class="input-number" value="150,000,000" />
            </label>
            <label class="field">
              <span>금융재산</span>
              <input data-bpec="financialAsset" type="text" inputmode="numeric" class="input-number" value="10,000,000" />
            </label>
            <label class="field">
              <span>인정 가능 부채</span>
              <input data-bpec="debt" type="text" inputmode="numeric" class="input-number" value="0" />
            </label>
            <label class="checkbox-option">
              <input type="checkbox" data-bpec="hasLuxuryAsset" />
              <span>고급자동차 또는 회원권이 있습니다</span>
            </label>
          </div>
        </section>
      </article>
    </Fragment>

    <section class="bpec-section bpec-result-section" aria-live="polite">
      <div class="section-header">
        <p class="section-header__eyebrow">계산 결과</p>
        <h2>기초연금 선정기준과 예상 수급액</h2>
        <p>입력값을 바꾸면 소득인정액과 예상 기초연금액이 즉시 다시 계산됩니다.</p>
      </div>
      <div class="bpec-kpi-grid">
        <article class="bpec-kpi bpec-kpi--main"><span>소득인정액 추정</span><strong data-bpec-result="incomeRecognized">-</strong><small>자가 점검용 추정</small></article>
        <article class="bpec-kpi"><span>선정기준액</span><strong data-bpec-result="threshold">-</strong><small>2026년 기준</small></article>
        <article class="bpec-kpi bpec-kpi--accent"><span>예상 기초연금액</span><strong data-bpec-result="benefit">-</strong><small>국민연금 연계 감액 미반영</small></article>
        <article class="bpec-kpi"><span>기준까지 차이</span><strong data-bpec-result="gap">-</strong><small data-bpec-result="judgement">확인 중</small></article>
      </div>
    </section>

    <section class="bpec-section">
      <div class="section-header">
        <p class="section-header__eyebrow">기준선</p>
        <h2>내 소득인정액 위치</h2>
      </div>
      <div class="bpec-gauge" aria-hidden="true">
        <span class="bpec-gauge__bar"><i data-bpec-gauge-fill></i></span>
        <div class="bpec-gauge__labels"><span>0%</span><span>90%</span><span>100%</span></div>
      </div>
    </section>

    <section class="bpec-section">
      <div class="section-header">
        <p class="section-header__eyebrow">분해</p>
        <h2>소득인정액 구성</h2>
      </div>
      <div class="bpec-breakdown" data-bpec-breakdown></div>
    </section>

    <section class="bpec-section">
      <div class="section-header">
        <p class="section-header__eyebrow">다음 확인</p>
        <h2>확인 필요 항목과 연결 계산기</h2>
      </div>
      <div class="bpec-warning-grid" data-bpec-warnings></div>
      <div class="bpec-action-grid">
        {BPEC_RELATED_LINKS.map((link) => <a href={withBase(link.href)}>{link.label}</a>)}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle={BPEC_SEO_CONTENT.introTitle}
        intro={BPEC_SEO_CONTENT.intro}
        inputPoints={BPEC_SEO_CONTENT.inputPoints}
        criteria={BPEC_SEO_CONTENT.criteria}
        faq={BPEC_FAQ}
        related={BPEC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="bpec-data" type="application/json" set:html={JSON.stringify(BPEC_CONFIG)} />
  <script type="module" src={withBase("/scripts/basic-pension-eligibility-calculator.js")}></script>
</BaseLayout>
