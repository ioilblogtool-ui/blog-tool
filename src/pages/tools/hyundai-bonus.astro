---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  actualBonusMultiplier,
  actualFixedCash,
  actualGiftValue,
  actualStockShares,
  comparisonCards,
  defaultBenefits,
  defaultStockPrice,
  factAnchors,
  packageModes,
  rankPresets,
  scenarioPresets,
  yearOptions
} from "../../data/hyundaiCompensation";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const config = {
  rankPresets,
  yearOptions,
  packageModes,
  scenarioPresets,
  comparisonCards,
  defaultBenefits,
  defaultStockPrice,
  actualBonusMultiplier,
  actualFixedCash,
  actualStockShares,
  actualGiftValue
};
---

<BaseLayout
  title="현대자동차 성과금 계산기 | 개인·부부 총보상 시뮬레이터"
  description="현대자동차 2025 임단협 패키지 공개값과 2027·2028 시나리오를 바탕으로 개인·부부 총보상과 월 체감액을 계산하는 페이지"
  ogImage="/og/tools/hyundai-bonus.svg"
>
  <SiteHeader />

  <SimpleToolShell calculatorId="hyundai-bonus" pageClass="hyundai-bonus-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="현대자동차 총보상 시뮬레이터"
        title="현대자동차 성과금 계산기"
        description="월급 450% + 1,580만 원 + 자사주 30주 패키지를 기준으로 개인·부부 총보상과 월 체감값을 한 번에 확인합니다."
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetHyundaiBonusBtn" copyId="copyHyundaiBonusLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <div class="stack" id="hyundai-bonus-inputs">
        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">계산 모드</p>
              <h2 class="panel__title">개인 또는 부부 선택</h2>
            </div>
            <p class="panel-heading__summary">개인과 부부 중 계산할 대상을 선택하세요.</p>
          </div>
          <div class="toggle-grid">
            <label class="mode-chip">
              <input id="modeSingle" name="householdMode" type="radio" value="SINGLE" checked />
              <span>개인 계산</span>
            </label>
            <label class="mode-chip">
              <input id="modeCouple" name="householdMode" type="radio" value="COUPLE" />
              <span>부부 계산</span>
            </label>
          </div>
        </article>

        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">빠른 입력</p>
              <h2 class="panel__title">직급·연봉·월 기본급 먼저 입력</h2>
            </div>
          </div>

          <div class="form-cluster form-cluster--nested">
            <div class="form-cluster__header">
              <strong>본인</strong>
              <span>연봉과 월 기본급은 예시값이며 수정할 수 있습니다.</span>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>직급</span>
                <select id="selfRankSelect">
                  {rankPresets.map((rank) => <option value={rank.code}>{rank.label}</option>)}
                </select>
              </label>
              <label class="field">
                <span>연봉</span>
                <input id="selfSalaryInput" type="number" value="65000000" />
                <small id="selfSalaryHint"></small>
              </label>
              <label class="field field-span-full">
                <span>월 기본급</span>
                <input id="selfMonthlyBaseInput" type="number" value="4200000" />
                <small id="selfMonthlyBaseHint"></small>
              </label>
            </div>
            <div class="calc-slider-row">
              <input type="range" id="selfSalarySlider" class="calc-slider" min="20000000" max="300000000" step="1000000" value="65000000" />
              <span id="selfSalarySliderVal" class="calc-slider-val">6,500만원</span>
            </div>
          </div>

          <div class="form-cluster form-cluster--nested" id="spouseBlock" hidden>
            <div class="form-cluster__header">
              <strong>배우자</strong>
              <span>부부 계산 모드일 때만 합산됩니다.</span>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>직급</span>
                <select id="spouseRankSelect">
                  {rankPresets.map((rank) => <option value={rank.code}>{rank.label}</option>)}
                </select>
              </label>
              <label class="field">
                <span>연봉</span>
                <input id="spouseSalaryInput" type="number" value="82000000" />
                <small id="spouseSalaryHint"></small>
              </label>
              <label class="field field-span-full">
                <span>월 기본급</span>
                <input id="spouseMonthlyBaseInput" type="number" value="5100000" />
                <small id="spouseMonthlyBaseHint"></small>
              </label>
            </div>
            <div class="calc-slider-row">
              <input type="range" id="spouseSalarySlider" class="calc-slider" min="20000000" max="300000000" step="1000000" value="82000000" />
              <span id="spouseSalarySliderVal" class="calc-slider-val">8,200만원</span>
            </div>
          </div>

          <div class="form-cluster form-cluster--nested">
            <div class="form-cluster__header">
              <strong>공통 가정</strong>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>연도</span>
                <select id="targetYearSelect">
                  {yearOptions.map((year) => <option value={year.code}>{year.label}</option>)}
                </select>
              </label>
              <div class="field field-span-full">
                <span>패키지 모드</span>
                <div class="toggle-grid">
                  <label class="mode-chip" id="packageActualChip">
                    <input type="radio" name="packageMode" value="ACTUAL" checked />
                    <span>2026 실제값</span>
                  </label>
                  <label class="mode-chip">
                    <input type="radio" name="packageMode" value="SCENARIO" />
                    <span>시나리오</span>
                  </label>
                </div>
                <small id="packageModeHint"></small>
              </div>
              <label class="field">
                <span>시나리오</span>
                <select id="scenarioSelect">
                  {scenarioPresets.map((scenario) => <option value={scenario.code}>{scenario.label}</option>)}
                </select>
                <small id="scenarioHint"></small>
              </label>
              <label class="field">
                <span>주가 입력</span>
                <input id="stockPriceInput" type="number" value={defaultStockPrice} />
                <small id="stockPriceHint"></small>
              </label>
              <label class="field">
                <span>복지 금액</span>
                <input id="benefitsInput" type="number" value={defaultBenefits} />
                <small id="benefitsHint"></small>
              </label>
              <label class="check-field">
                <input id="includeBonusToggle" type="checkbox" checked />
                <span>성과금 포함</span>
              </label>
              <label class="check-field">
                <input id="includeStockToggle" type="checkbox" checked />
                <span>자사주 포함</span>
              </label>
              <label class="check-field">
                <input id="includeBenefitsToggle" type="checkbox" checked />
                <span>복지 포함</span>
              </label>
            </div>
          </div>

          <details class="detail-box detail-box--soft">
            <summary>고급 설정 열기</summary>
            <div class="detail-box__content detail-box__content--tight">
              <div class="form-grid form-grid--compact">
                <label class="field">
                  <span>성과금 배수</span>
                  <input id="bonusMultiplierInput" type="number" value="4.5" step="0.1" />
                </label>
                <label class="field">
                  <span>정액 현금</span>
                  <input id="fixedCashInput" type="number" value={actualFixedCash} />
                </label>
                <label class="field">
                  <span>자사주 수</span>
                  <input id="stockSharesInput" type="number" value={actualStockShares} />
                </label>
                <label class="check-field field-span-full">
                  <input id="includeNetEstimateToggle" type="checkbox" checked />
                  <span>월 실수령 추정 같이 보기</span>
                </label>
              </div>
            </div>
          </details>

          <button id="calcHyundaiBonusBtn" class="button button--primary" type="button">총보상 계산하기</button>
        </article>
      </div>
    </Fragment>

    <article class="panel result-priority-panel" id="hyundai-bonus-results">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">결과 먼저 보기</p>
          <h2 class="panel__title">연 총액과 월 체감값</h2>
        </div>
      </div>
      <div class="result-priority-panel__actions">
        <a class="button button--secondary" href="#hyundai-bonus-inputs">조건 다시 입력</a>
        <a class="button button--ghost" href="#hyundai-bonus-details">세부 보기</a>
      </div>
    </article>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">팩트 앵커</p>
        <h2>핵심 수치</h2>
      </div>
      <div class="fact-anchor-grid">
        {factAnchors.map((item) => (
          <article class="fact-anchor-card">
            <p>{item.label}</p>
            <strong>{item.value}</strong>
            <span>{item.note}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">핵심 KPI</p>
        <h2 id="resultHeadline">개인 총보상 핵심 카드</h2>
        <p class="sb-section__sub" id="resultSubcopy">2026 실제 패키지 기준</p>
      </div>
      <div class="kpi-grid">
        <article class="kpi-card kpi-card--accent">
          <p id="salaryCardLabel">연봉</p>
          <strong id="salarySummary">-</strong>
          <span id="salarySummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>성과금</p>
          <strong id="bonusSummary">-</strong>
          <span id="bonusSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>정액 현금</p>
          <strong id="fixedCashSummary">-</strong>
          <span id="fixedCashSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>자사주 가치</p>
          <strong id="stockSummary">-</strong>
          <span id="stockSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>복지 포함 총보상</p>
          <strong id="totalSummary">-</strong>
          <span id="totalSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>월 체감 총액</p>
          <strong id="monthlySummary">-</strong>
          <span id="monthlySummaryNote">-</span>
        </article>
      </div>
    </section>

    <section class="content-section hyundai-detail-grid" id="hyundai-bonus-details">
      <article class="panel summary-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">연 · 월 요약</p>
            <h2 class="panel__title">핵심 금액</h2>
          </div>
        </div>
        <div class="hyundai-donut-wrap">
          <canvas id="hyundai-donut-chart"></canvas>
        </div>
        <div class="report-list" id="summaryReportList"></div>
      </article>

      <article class="panel net-panel" id="netPanel" hidden>
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">월 실수령 추정</p>
            <h2 class="panel__title">실수령 추정표</h2>
          </div>
        </div>
        <div class="report-list report-list--compact" id="netReportList"></div>
      </article>
    </section>

    <section class="content-section">
      <article class="panel rank-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">직급별 예시</p>
            <h2 class="panel__title">추천 연봉 기준 비교</h2>
          </div>
        </div>
        <div class="hyundai-rank-chart-wrap">
          <canvas id="hyundai-rank-chart"></canvas>
        </div>
        <div class="matrix-list">
          <div class="matrix-list__head">
            <span>직급</span>
            <span>추천 연봉</span>
            <span>월 기본급</span>
            <span>성과금</span>
            <span>자사주 포함 총보상</span>
            <span>월 체감</span>
          </div>
          <div id="rankMatrixList"></div>
        </div>
      </article>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">연도 시나리오</p>
        <h2>2026~2028 비교</h2>
      </div>
      <div class="hyundai-scenario-chart-wrap">
        <canvas id="hyundai-scenario-chart"></canvas>
      </div>
      <div class="scenario-year-grid" id="scenarioYearGrid"></div>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">참고 비교</p>
        <h2>재미로 보는 비교</h2>
      </div>
      <div class="comparison-grid" id="comparisonGrid"></div>
    </section>

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">계산 기준</p>
          <h2 class="panel__title">계산 기준 요약</h2>
        </div>
      </div>
      <div class="logic-grid">
        <article class="logic-card">
          <strong>성과금 = 월 기본급 × 배수</strong>
          <p>2026은 실제 기준, 이후는 시나리오 배수로 계산합니다.</p>
        </article>
        <article class="logic-card">
          <strong>정액 현금 = 1,580만 원</strong>
          <p>실제 기준 모드에서는 공개값을 사용합니다.</p>
        </article>
        <article class="logic-card">
          <strong>자사주 가치 = 주가 × 주식 수</strong>
          <p>주가와 주식 수는 수정할 수 있습니다.</p>
        </article>
        <article class="logic-card">
          <strong>총보상 = 연봉 + 성과금 + 정액 현금 + 자사주 + 상품권 + 복지</strong>
          <p>실수령 추정은 참고용입니다.</p>
        </article>
      </div>
    </article>

    <InfoNotice
      title="안내"
      lines={[
        "직급별 연봉과 월 기본급은 공식 수치가 아니라 예시값(수정 가능)입니다.",
        "2026은 2025 임단협 패키지 공개값, 2027·2028은 시나리오 시뮬레이션입니다.",
        "실수령 추정은 세금, 공제, 가족 구성, 상여금 과세 처리 방식에 따라 달라질 수 있습니다."
      ]}
    />

    <Fragment slot="seo">
      <SeoContent
        introTitle="현대자동차 성과금 계산기 활용 가이드"
        intro={[
          "이 페이지는 현대자동차 2025 임단협 패키지를 기준으로 개인 또는 부부 총보상을 계산하는 계산기형 랜딩입니다. 연봉, 월 기본급, 주가를 입력하면 성과금과 자사주 가치까지 포함한 총액을 빠르게 볼 수 있습니다.",
          "핵심은 2026 실제 참고 패키지와 2027·2028 시나리오를 분리해서 보여주는 것입니다. 공개값이 있는 항목은 팩트 앵커로 두고, 연봉·월 기본급·주가·복지는 수정 가능한 가정값으로 다룹니다."
        ]}
        inputPoints={[
          "개인·부부 토글에 따라 입력 폼과 결과 문구가 함께 바뀝니다.",
          "월급 450% 성과금, 1,580만 원 정액 현금, 자사주 30주 구조를 기본값으로 반영합니다.",
          "연 총보상, 월 체감액, 실수령 추정, 직급별 예시 비교까지 한 화면에서 이어서 확인할 수 있습니다."
        ]}
        criteria={[
          "2026 실제 기준 모드는 월급 450%, 정액 1,580만 원, 자사주 30주, 상품권 20만 원, 월 기본급 10만 원 인상 합의안 공개값을 참고합니다.",
          "2027·2028은 보수적·기준·공격적 패키지 시나리오이며, 보너스 배수·정액 현금·자사주 수를 직접 수정할 수 있습니다.",
          "직급별 추천 연봉과 월 기본급, 복지 금액, 주가 입력값은 모두 예시 또는 운영 가정값입니다."
        ]}
        faq={[
          { question: "현대자동차 성과금은 어떻게 계산하나요?", answer: "이 페이지에서는 월 기본급에 성과금 배수를 곱해 계산합니다. 2026 실제 기준은 4.5배, 이후 연도는 시나리오 배수 또는 직접 입력값을 반영합니다." },
          { question: "1,580만 원과 자사주 30주도 포함되나요?", answer: "포함됩니다. 실제 기준 모드에서는 정액 현금 1,580만 원, 자사주 30주, 상품권 20만 원을 기본값으로 반영합니다." },
          { question: "직급별 연봉과 월 기본급은 공식표인가요?", answer: "아닙니다. 추천값(수정 가능)이며, 사용자가 자신의 상황에 맞게 연봉과 월 기본급을 직접 수정해서 보는 구조입니다." },
          { question: "부부 계산은 어떤 값을 합산하나요?", answer: "두 사람의 연봉, 성과금, 정액 현금, 자사주 가치, 상품권, 복지, 총보상을 모두 합산해서 보여줍니다." },
          { question: "실수령 추정은 정확한가요?", answer: "실수령 추정은 참고용입니다. 세금, 공제, 가족 구성, 상여금 과세 처리 방식에 따라 실제 수령액은 달라질 수 있습니다." },
          { question: "2027·2028은 왜 공식 전망이 아닌가요?", answer: "미래 연도는 확정 공개 합의안이 없어서 시나리오 시뮬레이션으로만 보여줘야 안전합니다." }
        ]}
        related={[
          { href: "/tools/bonus-simulator/", label: "대기업 성과급 시뮬레이터" },
          { href: "/tools/samsung-bonus/", label: "삼성전자 성과급 계산기" },
          { href: "/tools/sk-hynix-bonus/", label: "SK하이닉스 성과급 계산기" }
        ]}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="hyundaiCompensationConfig" type="application/json" set:html={JSON.stringify(config)}></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/hyundai-bonus.js")}></script>
</BaseLayout>


