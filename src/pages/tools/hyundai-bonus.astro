---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import CompareCta from "../../components/CompareCta.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  actualBonusMultiplier,
  actualFixedCash,
  actualGiftValue,
  actualStockShares,
  comparisonCards,
  defaultEmployeeCount,
  defaultBenefits,
  defaultStockPrice,
  demandVerificationSteps,
  factAnchors,
  operatingProfitConsensus,
  operatingProfitSensitivityRates,
  packageModes,
  rankPresets,
  scenarioPresets,
  unionDemandHighlights,
  yearOptions
} from "../../data/hyundaiCompensation";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const config = {
  rankPresets,
  yearOptions,
  packageModes,
  scenarioPresets,
  comparisonCards,
  defaultBenefits,
  defaultStockPrice,
  actualBonusMultiplier,
  actualFixedCash,
  actualStockShares,
  actualGiftValue,
  operatingProfitConsensus,
  operatingProfitSensitivityRates,
  defaultEmployeeCount
};
---

<BaseLayout
  title="현대자동차 성과급 계산기 2026 | OPI·격려금 세후 실수령액 계산"
  description="현대차 2026 임단협 기준 정액 1,580만원, 자사주 30주를 포함한 직급별 성과급 총액과 월 실수령액을 1분 만에 계산합니다. 부부 합산도 바로 확인하세요."
  ogImage="/og/tools/hyundai-bonus.png"
>
  <SiteHeader />

  <SimpleToolShell calculatorId="hyundai-bonus" pageClass="hyundai-bonus-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="현대자동차 총보상 시뮬레이터"
        title="현대차 성과급 계산기 2026"
        description="현대자동차 임단협 패키지와 2026년 노조 요구안, 2026·2027 영업이익 컨센서스까지 함께 보며 개인·부부 총보상과 월 체감값을 확인합니다."
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetHyundaiBonusBtn" copyId="copyHyundaiBonusLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <div class="stack" id="hyundai-bonus-inputs">
        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">계산 모드</p>
              <h2 class="panel__title">개인 또는 부부 선택</h2>
            </div>
            <p class="panel-heading__summary">개인과 부부 중 계산할 대상을 선택하세요.</p>
          </div>
          <div class="toggle-grid">
            <label class="mode-chip">
              <input id="modeSingle" name="householdMode" type="radio" value="SINGLE" checked />
              <span>개인 계산</span>
            </label>
            <label class="mode-chip">
              <input id="modeCouple" name="householdMode" type="radio" value="COUPLE" />
              <span>부부 계산</span>
            </label>
          </div>
        </article>

        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">빠른 입력</p>
              <h2 class="panel__title">직급·연봉·월 기본급 먼저 입력</h2>
            </div>
          </div>

          <div class="form-cluster form-cluster--nested">
            <div class="form-cluster__header">
              <strong>본인</strong>
              <span>연봉과 월 기본급은 예시값이며 수정할 수 있습니다.</span>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>직급</span>
                <select id="selfRankSelect">
                  {rankPresets.map((rank) => <option value={rank.code}>{rank.label}</option>)}
                </select>
                <small class="is-placeholder">d</small>
              </label>
              <label class="field">
                <span>연봉</span>
                <input id="selfSalaryInput" type="number" value="65000000" />
                <small id="selfSalaryHint"></small>
              </label>
              <label class="field field-span-full">
                <span>월 기본급</span>
                <input id="selfMonthlyBaseInput" type="number" value="4200000" />
                <small id="selfMonthlyBaseHint"></small>
              </label>
            </div>
            <div class="calc-slider-row">
              <input type="range" id="selfSalarySlider" class="calc-slider" min="20000000" max="300000000" step="1000000" value="65000000" />
              <span id="selfSalarySliderVal" class="calc-slider-val">6,500만원</span>
            </div>
          </div>

          <div class="form-cluster form-cluster--nested" id="spouseBlock" hidden>
            <div class="form-cluster__header">
              <strong>배우자</strong>
              <span>부부 계산 모드일 때만 합산됩니다.</span>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>직급</span>
                <select id="spouseRankSelect">
                  {rankPresets.map((rank) => <option value={rank.code}>{rank.label}</option>)}
                </select>
              </label>
              <label class="field">
                <span>연봉</span>
                <input id="spouseSalaryInput" type="number" value="82000000" />
                <small id="spouseSalaryHint"></small>
              </label>
              <label class="field field-span-full">
                <span>월 기본급</span>
                <input id="spouseMonthlyBaseInput" type="number" value="5100000" />
                <small id="spouseMonthlyBaseHint"></small>
              </label>
            </div>
            <div class="calc-slider-row">
              <input type="range" id="spouseSalarySlider" class="calc-slider" min="20000000" max="300000000" step="1000000" value="82000000" />
              <span id="spouseSalarySliderVal" class="calc-slider-val">8,200만원</span>
            </div>
          </div>

          <div class="form-cluster form-cluster--nested">
            <div class="form-cluster__header">
              <strong>공통 가정</strong>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>연도</span>
                <select id="targetYearSelect">
                  {yearOptions.map((year) => <option value={year.code}>{year.label}</option>)}
                </select>
              </label>
              <div class="field field-span-full">
                <span>패키지 모드</span>
                <div class="toggle-grid">
                  <label class="mode-chip" id="packageActualChip">
                    <input type="radio" name="packageMode" value="ACTUAL" checked />
                    <span>2026 실제값</span>
                  </label>
                  <label class="mode-chip">
                    <input type="radio" name="packageMode" value="SCENARIO" />
                    <span>시나리오</span>
                  </label>
                </div>
                <small id="packageModeHint"></small>
              </div>
              <label class="field">
                <span>시나리오</span>
                <select id="scenarioSelect">
                  {scenarioPresets.map((scenario) => <option value={scenario.code}>{scenario.label}</option>)}
                </select>
                <small id="scenarioHint"></small>
              </label>
              <label class="field">
                <span>주가 입력</span>
                <input id="stockPriceInput" type="number" value={defaultStockPrice} />
                <small id="stockPriceHint"></small>
              </label>
              <label class="field">
                <span>복지 금액</span>
                <input id="benefitsInput" type="number" value={defaultBenefits} />
                <small id="benefitsHint"></small>
              </label>
              <label class="check-field">
                <input id="includeBonusToggle" type="checkbox" checked />
                <span>성과급 포함</span>
              </label>
              <label class="check-field">
                <input id="includeStockToggle" type="checkbox" checked />
                <span>자사주 포함</span>
              </label>
              <label class="check-field">
                <input id="includeBenefitsToggle" type="checkbox" checked />
                <span>복지 포함</span>
              </label>
            </div>
          </div>

          <details class="detail-box detail-box--soft">
            <summary>고급 설정 열기</summary>
            <div class="detail-box__content detail-box__content--tight">
              <div class="form-grid form-grid--compact">
                <label class="field">
                  <span>성과급 배수</span>
                  <input id="bonusMultiplierInput" type="number" value="4.5" step="0.1" />
                </label>
                <label class="field">
                  <span>정액 현금</span>
                  <input id="fixedCashInput" type="number" value={actualFixedCash} />
                </label>
                <label class="field">
                  <span>자사주 수</span>
                  <input id="stockSharesInput" type="number" value={actualStockShares} />
                </label>
                <label class="check-field field-span-full">
                  <input id="includeNetEstimateToggle" type="checkbox" checked />
                  <span>월 실수령 추정 같이 보기</span>
                </label>
              </div>
            </div>
          </details>

          <button id="calcHyundaiBonusBtn" class="button button--primary" type="button">총보상 계산하기</button>
        </article>
      </div>
    </Fragment>

    <article class="panel result-priority-panel" id="hyundai-bonus-results">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">결과 먼저 보기</p>
          <h2 class="panel__title">연 총액과 월 체감값</h2>
        </div>
      </div>
      <div class="result-priority-panel__actions">
        <a class="button button--secondary" href="#hyundai-bonus-inputs">조건 다시 입력</a>
        <a class="button button--ghost" href="#hyundai-bonus-details">세부 보기</a>
      </div>
      <div class="bonus-next-step" aria-label="계산 결과 다음 단계">
        <p class="bonus-next-step__eyebrow">지금 바로 이어서</p>
        <div class="bonus-next-step__actions">
          <a id="hyundaiAfterTaxCta" class="button button--primary" href={withBase("/tools/bonus-after-tax-calculator/?company=hyundai")}>세후 실수령 계산하기 →</a>
          <a id="hyundaiDcaCta" class="button button--secondary" href={withBase("/tools/dca-investment-calculator/?m=300000&p=10&a=SP500,NASDAQ100,QQQ&fx=1&div=1")}>이 금액 투자하면? →</a>
        </div>
        <p class="bonus-next-step__note" id="hyundaiNextStepNote">성과급 패키지 세전 금액을 기준으로 다음 계산기에 자동 반영합니다.</p>
      </div>
    </article>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">팩트 앵커</p>
        <h2>핵심 수치</h2>
        <p class="sb-section__sub">상세 요구안과 컨센서스 민감도는 결과표 아래에서 확인할 수 있습니다.</p>
      </div>
      <div class="fact-anchor-grid">
        {factAnchors.map((item) => (
          <article class="fact-anchor-card">
            <p>{item.label}</p>
            <strong>{item.value}</strong>
            <span>{item.note}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">핵심 KPI</p>
        <h2 id="resultHeadline">개인 총보상 핵심 카드</h2>
        <p class="sb-section__sub" id="resultSubcopy">2026 실제 패키지 기준</p>
      </div>
      <div class="kpi-grid">
        <article class="kpi-card kpi-card--accent">
          <p id="salaryCardLabel">연봉</p>
          <strong id="salarySummary">-</strong>
          <span id="salarySummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>성과급</p>
          <strong id="bonusSummary">-</strong>
          <span id="bonusSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>정액 현금</p>
          <strong id="fixedCashSummary">-</strong>
          <span id="fixedCashSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>자사주 가치</p>
          <strong id="stockSummary">-</strong>
          <span id="stockSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>복지 포함 총보상</p>
          <strong id="totalSummary">-</strong>
          <span id="totalSummaryNote">-</span>
        </article>
        <article class="kpi-card">
          <p>월 체감 총액</p>
          <strong id="monthlySummary">-</strong>
          <span id="monthlySummaryNote">-</span>
        </article>
      </div>
    </section>

    <section class="content-section hyundai-detail-grid" id="hyundai-bonus-details">
      <article class="panel summary-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">연 · 월 요약</p>
            <h2 class="panel__title">핵심 금액</h2>
          </div>
        </div>
        <div class="hyundai-donut-wrap">
          <canvas id="hyundai-donut-chart"></canvas>
        </div>
        <div class="report-list" id="summaryReportList"></div>
      </article>

      <article class="panel net-panel" id="netPanel" hidden>
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">월 실수령 추정</p>
            <h2 class="panel__title">실수령 추정표</h2>
          </div>
        </div>
        <div class="report-list report-list--compact" id="netReportList"></div>
      </article>
    </section>

    <section class="content-section">
      <article class="panel rank-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">직급별 예시</p>
            <h2 class="panel__title">추천 연봉 기준 비교</h2>
          </div>
        </div>
        <div class="hyundai-rank-chart-wrap">
          <canvas id="hyundai-rank-chart"></canvas>
        </div>
        <div class="matrix-list">
          <div class="matrix-list__head">
            <span>직급</span>
            <span>추천 연봉</span>
            <span>월 기본급</span>
            <span>성과급</span>
            <span>자사주 포함 총보상</span>
            <span>월 체감</span>
          </div>
          <div id="rankMatrixList"></div>
        </div>
      </article>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">연도 시나리오</p>
        <h2>2026~2028 비교</h2>
      </div>
      <div class="hyundai-scenario-chart-wrap">
        <canvas id="hyundai-scenario-chart"></canvas>
      </div>
      <div class="scenario-year-grid" id="scenarioYearGrid"></div>
    </section>

    <section class="sb-section hyundai-reference-section">
      <details class="hyundai-reference-details">
        <summary>
          <span>
            <em>참고 정보</em>
            2026 임협 요구안과 2026·2027 영업이익 컨센서스 보기
          </span>
        </summary>
        <div class="hyundai-reference-body">
          <section class="hyundai-demand-section">
            <div class="sb-section__head">
              <p class="sb-section__eyebrow">2026 임협 요구안</p>
              <h2>최근 노조 요구안 확인 포인트</h2>
              <p class="sb-section__sub">아래 수치는 확정 지급안이 아니라 2026년 임금협상 요구안입니다.</p>
            </div>
            <div class="hyundai-demand-grid">
              {unionDemandHighlights.map((item) => (
                <article class="hyundai-demand-card">
                  <p>{item.label}</p>
                  <strong>{item.value}</strong>
                  <span>{item.note}</span>
                </article>
              ))}
            </div>
            <article class="panel hyundai-verification-panel">
              <div class="panel-heading">
                <div>
                  <p class="panel-heading__eyebrow">확인 방법</p>
                  <h2 class="panel__title">요구안·제시안·합의안 구분하기</h2>
                </div>
              </div>
              <ol class="hyundai-check-list">
                {demandVerificationSteps.map((step) => <li>{step}</li>)}
              </ol>
            </article>
          </section>

          <section class="hyundai-consensus-section">
            <div class="sb-section__head">
              <p class="sb-section__eyebrow">컨센서스 반영</p>
              <h2>2026·2027 영업이익 기준 성과급 재원</h2>
              <p class="sb-section__sub">FnGuide 컨센서스 인용치를 기준으로 영업이익 배분율을 단순 계산합니다. 노조 요구안의 기준은 순이익 30%라서 직접 비교는 주의가 필요합니다.</p>
            </div>
            <div class="hyundai-consensus-grid">
              {operatingProfitConsensus.map((item) => (
                <article class="hyundai-consensus-card">
                  <p>{item.label} 영업이익 컨센서스</p>
                  <strong>{Math.round(item.operatingProfit / 100000000000) / 10}조 원</strong>
                  <span>{item.note}</span>
                </article>
              ))}
            </div>
            <article class="panel hyundai-profit-tool">
              <div class="panel-heading">
                <div>
                  <p class="panel-heading__eyebrow">민감도 계산</p>
                  <h2 class="panel__title">영업이익 배분율별 1인당 참고 재원</h2>
                </div>
                <p class="panel-heading__summary">배분율과 인원 수를 바꿔 요구안 체감 규모를 확인합니다.</p>
              </div>
              <div class="hyundai-profit-controls">
                <label class="field">
                  <span>기준 연도</span>
                  <select id="profitConsensusYear">
                    {operatingProfitConsensus.map((item) => <option value={item.year}>{item.label}</option>)}
                  </select>
                </label>
                <label class="field">
                  <span>배분율</span>
                  <select id="profitShareRate">
                    {operatingProfitSensitivityRates.map((item) => <option value={item.rate}>{item.label} · {(item.rate * 100).toFixed(0)}%</option>)}
                  </select>
                </label>
                <label class="field">
                  <span>대상 인원</span>
                  <input id="profitEmployeeCount" type="number" value={defaultEmployeeCount} min="1" step="100" />
                  <small>계산 편의를 위한 입력값입니다.</small>
                </label>
              </div>
              <div class="hyundai-profit-result" id="profitPoolResult"></div>
            </article>
          </section>
        </div>
      </details>
    </section>

    <section class="sb-section">
      <div class="sb-section__head">
        <p class="sb-section__eyebrow">참고 비교</p>
        <h2>재미로 보는 비교</h2>
      </div>
      <div class="comparison-grid" id="comparisonGrid"></div>
    </section>

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">계산 기준</p>
          <h2 class="panel__title">계산 기준 요약</h2>
        </div>
      </div>
      <div class="logic-grid">
        <article class="logic-card">
          <strong>성과급 = 월 기본급 × 배수</strong>
          <p>2026은 실제 기준, 이후는 시나리오 배수로 계산합니다.</p>
        </article>
        <article class="logic-card">
          <strong>정액 현금 = 1,580만 원</strong>
          <p>실제 기준 모드에서는 공개값을 사용합니다.</p>
        </article>
        <article class="logic-card">
          <strong>자사주 가치 = 주가 × 주식 수</strong>
          <p>주가와 주식 수는 수정할 수 있습니다.</p>
        </article>
        <article class="logic-card">
          <strong>총보상 = 연봉 + 성과급 + 정액 현금 + 자사주 + 상품권 + 복지</strong>
          <p>실수령 추정은 참고용입니다.</p>
        </article>
        <article class="logic-card">
          <strong>컨센서스 재원 = 영업이익 × 배분율</strong>
          <p>요구안의 순이익 30%와는 기준 계정이 다르므로 비교용으로만 봅니다.</p>
        </article>
      </div>
    </article>

    <InfoNotice
      title="안내"
      lines={[
        "직급별 연봉과 월 기본급은 공식 수치가 아니라 예시값(수정 가능)입니다.",
        "2026은 2025 임단협 패키지 공개값, 2027·2028은 시나리오 시뮬레이션입니다.",
