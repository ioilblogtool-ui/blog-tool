---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import ToolTabs from "../../components/ToolTabs.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout title="퇴직금 계산기" description="평균임금 기준 퇴직금과 세후 추정액을 계산하는 도구">
  <SiteHeader />

  <main class="container page-shell calculator-page" data-calculator="retirement">
    <CalculatorHero
      eyebrow="Retirement Tool"
      title="퇴직금 계산기"
      description="연봉과 근속연수, 보너스 반영 여부를 기준으로 평균임금과 퇴직금 실수령 추정액을 계산합니다."
    />
    <ToolTabs />

    <section class="calculator-grid">
      <div class="stack">
        <article class="panel">
          <h2 class="panel__title">퇴직금 입력</h2>
          <div class="form-grid">
            <label class="field">
              <span>현재 연봉</span>
              <input id="retirementAnnualSalary" type="number" value="50000000" />
              <small id="retirementAnnualSalaryHint"></small>
            </label>
            <label class="field">
              <span>근속연수</span>
              <input id="yearsOfService" type="number" step="0.1" value="5" />
            </label>
            <label class="field">
              <span>정기 보너스</span>
              <input id="retirementBonus" type="number" value="3000000" />
              <small id="retirementBonusHint"></small>
            </label>
            <label class="field">
              <span>연차수당</span>
              <input id="retirementLeavePay" type="number" value="1000000" />
              <small id="retirementLeavePayHint"></small>
            </label>
            <label class="check-field">
              <input id="retirementIncludeBonus" type="checkbox" checked />
              <span>평균임금에 보너스 반영</span>
            </label>
            <label class="field">
              <span>퇴직소득세 추정 비율 (%)</span>
              <input id="retirementTaxRate" type="number" step="0.1" value="6" />
            </label>
          </div>
          <button id="calcRetirementBtn" class="button button--primary" type="button">퇴직금 계산</button>
        </article>
      </div>

      <div class="stack">
        <section class="metrics metrics--three">
          <article class="metric-card">
            <p>평균임금 추정</p>
            <strong id="retirementAvgMonthlyWage">-</strong>
          </article>
          <article class="metric-card">
            <p>퇴직금 세전</p>
            <strong id="retirementGross">-</strong>
          </article>
          <article class="metric-card">
            <p>퇴직금 세후</p>
            <strong id="retirementNet">-</strong>
          </article>
        </section>

        <article class="panel">
          <h2 class="panel__title">계산 상세</h2>
          <div class="table-wrap">
            <table class="result-table">
              <thead>
                <tr>
                  <th>항목</th>
                  <th>금액</th>
                </tr>
              </thead>
              <tbody id="retirementTable"></tbody>
            </table>
          </div>
        </article>
      </div>
    </section>
  </main>

  <script type="module" src={withBase("/scripts/tools.js")}></script>
</BaseLayout>

