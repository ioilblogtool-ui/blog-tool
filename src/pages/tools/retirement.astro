---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import SummaryCards from "../../components/SummaryCards.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="퇴직금 계산기 2026 | 근속연수별 세후 실수령액 바로 계산"
  description="근속연수와 평균임금 입력하면 퇴직소득세 공제 후 실수령액 바로 계산. 1년·3년·10년 시뮬레이션 포함."
  ogImage="/og/tools/retirement.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "퇴직금 계산기",
    "url": `${import.meta.env.SITE}/tools/retirement/`,
    "description": "근속연수와 평균임금 입력하면 퇴직소득세 공제 후 실수령액 바로 계산. 1년·3년·10년 시뮬레이션 포함.",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "All",
    "inLanguage": "ko-KR",
    "isAccessibleForFree": true,
    "provider": { "@type": "Organization", "name": "비교계산소" },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="retirement" pageClass="retirement-page">
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="퇴직 준비"
        title="퇴직금 계산기 - 세전·세후"
        description="연봉과 근속연수, 보너스 반영 여부를 기준으로 평균임금과 퇴직금 세전·세후 실수령 추정액을 계산합니다."
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetRetirementBtn" copyId="copyRetirementLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">퇴직금 계산 기준 입력</h2>
          </div>
          <p class="panel-heading__summary">근속연수와 상여 반영 여부에 따라 평균임금과 퇴직금 규모가 얼마나 달라지는지 빠르게 확인합니다.</p>
        </div>
        <div class="form-grid form-grid--compact">
          <label class="field field-span-full">
            <span>현재 연봉</span>
            <input id="retirementAnnualSalary" type="number" value="50000000" />
            <small id="retirementAnnualSalaryHint"></small>
            <div class="calc-slider-row">
              <input type="range" id="retirementAnnualSlider" class="calc-slider"
                min="20000000" max="300000000" step="1000000" value="50000000" />
              <span id="retirementAnnualSliderVal" class="calc-slider-val">5,000만원</span>
            </div>
          </label>
          <label class="field field-span-full">
            <span>근속연수</span>
            <input id="yearsOfService" type="number" step="0.1" value="5" />
            <div class="calc-slider-row">
              <input type="range" id="yearsOfServiceSlider" class="calc-slider"
                min="1" max="40" step="0.5" value="5" />
              <span id="yearsOfServiceSliderVal" class="calc-slider-val">5.0년</span>
            </div>
          </label>
          <label class="field">
            <span>정기 보너스</span>
            <input id="retirementBonus" type="number" value="3000000" />
            <small id="retirementBonusHint"></small>
          </label>
          <label class="field">
            <span>연차수당</span>
            <input id="retirementLeavePay" type="number" value="1000000" />
            <small id="retirementLeavePayHint"></small>
          </label>
          <label class="check-field field-span-full">
            <input id="retirementIncludeBonus" type="checkbox" checked />
            <span>평균임금에 보너스 반영</span>
          </label>
          <label class="field field-span-full">
            <span>퇴직소득세 추정 비율 (%)</span>
            <input id="retirementTaxRate" type="number" step="0.1" value="6" />
          </label>
        </div>
        <button id="calcRetirementBtn" class="button button--primary" type="button">퇴직금 계산</button>
      </article>
    </Fragment>

    <SummaryCards
      columns={3}
      items={[
        { label: "평균임금 추정", id: "retirementAvgMonthlyWage" },
        { label: "퇴직금 세전", id: "retirementGross" },
        { label: "퇴직금 세후", id: "retirementNet" }
      ]}
    />

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">구성 비율</p>
          <h2 class="panel__title">세전 대비 세후 비율</h2>
        </div>
        <p class="panel-heading__summary">퇴직금에서 세금이 차지하는 비중을 한눈에 확인합니다.</p>
      </div>
      <div class="retirement-donut-wrap">
        <div class="retirement-donut-canvas-wrap">
          <canvas id="retirement-donut-chart"></canvas>
        </div>
        <div class="retirement-donut-legend">
          <div class="retirement-donut-legend__item">
            <span class="retirement-donut-legend__dot retirement-donut-legend__dot--net"></span>
            <div>
              <div class="retirement-donut-legend__label">세후 실수령</div>
              <div class="retirement-donut-legend__value" id="retirementNetLegend">-</div>
            </div>
          </div>
          <div class="retirement-donut-legend__item">
            <span class="retirement-donut-legend__dot retirement-donut-legend__dot--tax"></span>
            <div>
              <div class="retirement-donut-legend__label">세금 추정</div>
              <div class="retirement-donut-legend__value" id="retirementTaxLegend">-</div>
            </div>
          </div>
        </div>
      </div>
    </article>

    <article class="panel">
      <div class="panel-heading">
        <div>
          <p class="panel-heading__eyebrow">상세 계산</p>
          <h2 class="panel__title">계산 상세</h2>
        </div>
      </div>
      <div class="table-wrap">
        <table class="result-table">
          <thead>
            <tr>
              <th>항목</th>
              <th>금액</th>
            </tr>
          </thead>
          <tbody id="retirementTable"></tbody>
        </table>
      </div>
    </article>

    <InfoNotice
      title="안내"
      lines={[
        "퇴직소득세는 간이 추정 비율이며 실제 정산과 다를 수 있습니다.",
        "평균임금 반영 방식은 회사 제도와 지급 항목에 따라 달라질 수 있습니다.",
        "근속연수와 상여 반영 여부를 함께 점검해보는 것이 좋습니다."
      ]}
    />

    <Fragment slot="seo">
      <SeoContent
        introTitle="퇴직금 계산기에서 확인해야 하는 핵심"
        intro={[
          "퇴직금 계산기는 연봉과 근속연수, 상여 반영 여부를 기준으로 평균임금과 예상 퇴직금을 빠르게 확인하는 페이지입니다. 퇴사 시점 점검, 희망퇴직 비교, 커리어 이동 계획을 세울 때 가장 먼저 보는 숫자를 정리하는 데 맞춰져 있습니다.",
          "실무에서는 퇴직금 세전 금액만 보는 경우가 많은데, 실제 체감은 세후 추정액과 근속연수 변화에 따라 꽤 달라집니다. 이 페이지는 그런 차이를 빠르게 확인할 수 있게 구성했습니다.",
          "퇴직금은 이직 여부뿐 아니라 퇴사 시점, 보너스 지급 시점, 연차수당 정산, 퇴직소득세 추정에 따라 달라질 수 있습니다. 그래서 단일 결과보다 상여 포함/제외와 세율 가정을 바꿔 보는 방식이 더 실전적입니다."
        ]}
        inputPoints={[
          "현재 연봉과 근속연수로 기본 퇴직금 규모를 계산할 수 있습니다.",
          "정기 보너스와 연차수당을 반영해 평균임금 기준이 얼마나 달라지는지 확인할 수 있습니다.",
          "퇴직소득세 추정 비율을 직접 넣어 세후 감각도 함께 볼 수 있습니다."
        ]}
        criteria={[
          "기준일은 2026년 현재 사이트의 간이 계산 기준이며, 실제 퇴직금 산정은 근로기준법상 평균임금, 회사 취업규칙, 임금 항목 성격에 따라 달라질 수 있습니다.",
          "평균임금 반영 범위는 회사의 상여금 지급 방식과 취업규칙에 따라 달라질 수 있습니다.",
          "세후 금액은 단순 추정치이므로 실제 정산 결과와 차이가 날 수 있습니다.",
          "예시 1: 연봉 5,000만원, 근속 5년, 정기 보너스 300만원을 넣어 보너스 포함 여부에 따른 퇴직금 차이를 볼 수 있습니다.",
          "예시 2: 근속연수를 9.5년과 10년으로 나눠 넣어 퇴사 시점이 몇 개월 달라질 때 예상 금액이 얼마나 바뀌는지 확인할 수 있습니다.",
          "퇴직 직전 연봉 협상이나 이직 결정 전에는 연봉 계산기와 함께 보는 것이 좋습니다."
        ]}
        faq={[
          { question: "보너스를 평균임금에 항상 넣어야 하나요?", answer: "항상 그런 것은 아닙니다. 지급 주기와 회사 규정에 따라 평균임금 반영 여부가 달라질 수 있어서, 비교용으로 포함/제외를 둘 다 보는 것이 좋습니다." },
          { question: "근속연수는 소수점으로 넣어도 되나요?", answer: "네. 실제 퇴사 시점이 딱 정수 연수가 아닐 수 있으므로 대략적인 개월 수를 반영해 소수점으로 넣어볼 수 있습니다." },
          { question: "세후 추정은 왜 대략치인가요?", answer: "퇴직소득세는 다양한 공제와 계산 단계가 있어서 페이지에서는 빠른 판단용 비율 입력 방식으로 단순화했습니다." },
          { question: "퇴직금은 연봉을 12로 나눈 월급으로 계산하면 되나요?", answer: "간단한 추정은 가능하지만 실제 퇴직금은 평균임금과 임금 항목 성격을 기준으로 계산합니다. 정기 상여, 연차수당, 비정기 수당의 반영 여부를 회사 기준과 함께 확인해야 합니다." },
          { question: "퇴사 시점을 늦추면 퇴직금이 많이 달라지나요?", answer: "근속연수가 늘면 퇴직금도 커질 수 있습니다. 특히 정기 상여 지급 직후인지, 근속연수 경계에 가까운지에 따라 체감 차이가 생길 수 있어 여러 시점을 비교해보는 것이 좋습니다." }
        ]}
        related={[
          { href: "/tools/salary/", label: "연봉 인상 계산기" },
          { href: "/tools/negotiation/", label: "이직 계산기" },
          { href: "/tools/bonus-simulator/", label: "대기업 성과급 시뮬레이터" },
          { href: "/tools/health-insurance-premium-calculator/", label: "건강보험료 계산기" },
          { href: "/tools/retirement-fund-depletion/", label: "은퇴자금 고갈 계산기" }
        ]}
      />
    </Fragment>
  </SimpleToolShell>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/retirement.js")}></script>
</BaseLayout>
