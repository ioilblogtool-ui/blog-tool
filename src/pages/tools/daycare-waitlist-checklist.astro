---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import {
  DWC_META,
  DWC_DEFAULTS,
  DWC_FAQS,
  DWC_TIPS,
  AGE_GROUP_LABELS,
  URGENCY_LABELS,
} from "../../data/daycareWaitlistChecklist";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const faqSchema = DWC_FAQS.map((f) => ({
  "@type": "Question",
  name: f.question,
  acceptedAnswer: { "@type": "Answer", text: f.answer },
}));
---

<BaseLayout
  title={DWC_META.seoTitle}
  description={DWC_META.description}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: DWC_META.title,
    applicationCategory: "LifestyleApplication",
    operatingSystem: "All",
    description: DWC_META.description,
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/daycare-waitlist-checklist/`,
    mainEntity: { "@type": "FAQPage", mainEntity: faqSchema },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="daycare-waitlist" pageClass="dwc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="육아 · 보육"
        title="어린이집 대기순번 입소 가능성 체크리스트"
        description="대기순번·월령·맞벌이·형제 여부를 선택하면 입소 가능성을 즉시 판정합니다. 전화 문의 멘트도 자동 생성됩니다."
        stats={[
          { label: "판정 기준", value: "4가지 조건" },
          { label: "전화 멘트", value: "자동 생성" },
        ]}
      />

      <InfoNotice
        title="이 체크리스트는 참고용입니다"
        lines={[
          "입소 가능성은 어린이집 상황(퇴소·전원 빈도), 지역별 수요, 가중치 점수 등에 따라 실제와 다를 수 있습니다.",
          "우선순위 점수 기준은 아이사랑 시스템을 참고했으며, 어린이집 유형(국공립·민간·직장)에 따라 다를 수 있습니다.",
          "정확한 현황은 해당 어린이집 또는 관할 구청 보육담당팀에 직접 문의하세요.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="dwcResetBtn" copyId="dwcCopyLinkBtn" />
    </Fragment>

    <!-- 입력 패널 -->
    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">대기 조건 입력</h2>
          </div>
          <p class="panel-heading__summary">조건을 입력하면 입소 가능성이 자동으로 업데이트됩니다.</p>
        </div>

        <div class="form-grid form-grid--compact">
          <!-- 대기순번 슬라이더 -->
          <label class="field field-span-full">
            <span>현재 대기순번</span>
            <div class="dwc-rank-row">
              <input
                type="range"
                id="dwcRankSlider"
                class="dwc-rank-slider"
                min="1"
                max="20"
                step="1"
                value={DWC_DEFAULTS.rank}
              />
              <span id="dwcRankVal" class="dwc-rank-badge">{DWC_DEFAULTS.rank}번</span>
            </div>
            <small style="color:var(--color-text-muted,#667085);font-size:0.8rem;">순번을 모르면 10 이상으로 설정하세요</small>
          </label>

          <!-- 자녀 월령 -->
          <div class="field field-span-full">
            <span class="field-label">자녀 월령</span>
            <div class="dwc-btn-group">
              {Object.entries(AGE_GROUP_LABELS).map(([key, label]) => (
                <button
                  class={`dwc-btn${key === DWC_DEFAULTS.ageGroup ? ' dwc-btn--active' : ''}`}
                  data-dwc-age={key}
                  type="button"
                >
                  {label}
                </button>
              ))}
            </div>
          </div>

          <!-- 맞벌이 여부 -->
          <div class="field field-span-full" style="padding: 0.25rem 0;">
            <div class="dwc-toggle-row">
              <label for="dwcDualIncome" style="cursor:pointer;">맞벌이 가정 (부모 모두 취업)</label>
              <input
                type="checkbox"
                id="dwcDualIncome"
                checked={DWC_DEFAULTS.isDualIncome}
              />
            </div>
            <div class="dwc-toggle-row">
              <label for="dwcSibling" style="cursor:pointer;">형제·자매 해당 어린이집 재원 중</label>
              <input
                type="checkbox"
                id="dwcSibling"
                checked={DWC_DEFAULTS.hasSibling}
              />
            </div>
          </div>

          <!-- 희망 입소 시점 -->
          <div class="field field-span-full">
            <span class="field-label">희망 입소 시점</span>
            <div class="dwc-btn-group">
              {Object.entries(URGENCY_LABELS).map(([key, label]) => (
                <button
                  class={`dwc-btn${key === DWC_DEFAULTS.urgency ? ' dwc-btn--active' : ''}`}
                  data-dwc-urgency={key}
                  type="button"
                >
                  {label}
                </button>
              ))}
            </div>
          </div>
        </div>
      </article>
    </Fragment>

    <!-- 결과 영역 -->
    <div style="display:grid;gap:1rem;">

      <!-- 판정 결과 카드 -->
      <div id="dwcResultCard" class="dwc-result-card dwc-result-card--medium">
        <p class="dwc-result-score" id="dwcScore">—</p>
        <p class="dwc-result-level" id="dwcLevel">계산 중...</p>
        <p class="dwc-result-prob"  id="dwcProbability"></p>
      </div>

      <!-- 체크리스트 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">체크리스트</p>
            <h2 class="panel__title">조건별 해당 여부</h2>
          </div>
        </div>
        <ul id="dwcChecklist" class="dwc-checklist"></ul>
      </article>

      <!-- 전화 문의 멘트 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">전화 가이드</p>
            <h2 class="panel__title">📞 이렇게 전화하세요</h2>
          </div>
        </div>
        <div class="dwc-phone-box">
          <div class="dwc-phone-header">
            <strong>문의 멘트 (복사해서 사용하세요)</strong>
            <button id="dwcCopyBtn" class="dwc-copy-btn" type="button">복사</button>
          </div>
          <p id="dwcPhoneMent" class="dwc-phone-ment"></p>
        </div>
        <ul class="dwc-phone-meta">
          <li><span>📌</span><span>전화 타이밍: 매월 초 1~5일 (전달 퇴소·전원 집계 후)</span></li>
          <li><span>📌</span><span>아이사랑 앱에서 현재 순번 수시 확인 가능</span></li>
          <li><span>📌</span><span>맞벌이 확인 서류(재직증명서·건강보험료 납부확인서) 미리 준비</span></li>
        </ul>
      </article>

      <!-- 대기 단축 꿀팁 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">꿀팁</p>
            <h2 class="panel__title">대기 단축 방법 3가지</h2>
          </div>
        </div>
        <div class="dwc-tips-grid">
          {DWC_TIPS.map((tip) => (
            <div class="dwc-tip-card">
              <strong>{tip.title}</strong>
              <p>{tip.body}</p>
            </div>
          ))}
        </div>
      </article>

    </div>

    <Fragment slot="seo">
      <SeoContent
        introTitle="어린이집 대기순번, 입소 가능성을 높이는 방법"
        intro={[
          "어린이집 대기순번을 받은 부모라면 '이 순번으로 언제 입소할 수 있을까?'가 가장 큰 고민일 것입니다. 대기순번 1번이라도 반드시 빠른 입소가 보장되지는 않으며, 우선순위 점수와 해당 반의 자리 회전율이 실제 입소 시점을 결정하는 더 중요한 변수이기 때문에 순번 숫자만으로는 정확한 예측이 어렵습니다. 이 체크리스트는 그 변수들을 종합해 입소 가능성을 미리 가늠해보도록 만든 도구입니다.",
          "아이사랑 시스템에서 어린이집 입소 우선순위는 법령으로 정해진 1순위(기초수급·한부모·장애·다문화 가정)와 2순위(맞벌이·형제 재원)로 나뉘고, 같은 순위 안에서는 대기 등록일 순서로 배정됩니다. 같은 대기순번이어도 맞벌이 가정이 비맞벌이보다 먼저 배정될 수 있는 이유가 여기에 있으며, 우선순위 항목에 해당하는지 먼저 확인하는 것이 입소 시점을 가늠하는 첫 단계입니다.",
          "반별 정원도 입소 속도에 큰 영향을 줍니다. 0세반은 정원이 3명에 불과해 회전율이 낮은 대신 한 자리만 나도 순번 진행이 빠르게 이루어지고, 2세반 이상은 정원이 7명 이상으로 많아 상대적으로 자리가 나는 빈도 자체는 높지만 대기자 수도 함께 많은 편입니다. 같은 대기순번이라도 어떤 반에 대기하고 있는지에 따라 체감 대기 기간이 달라질 수 있습니다.",
          "복직을 앞두고 시간이 촉박한 경우 한 곳에만 대기하는 것은 위험합니다. 아이사랑 앱에서는 최대 3곳까지 동시 대기가 가능하므로 통학 가능한 거리의 여러 어린이집에 함께 등록해두는 것이 안전하고, 신규 개원 어린이집은 대기 없이 바로 입소할 수 있는 경우가 많으니 구청 보육담당팀에 미리 문의해보는 것도 좋은 방법입니다.",
          "매월 초(1~5일)는 전화 문의 타이밍으로 가장 적합합니다. 전달 말일 기준으로 퇴소·전원이 집계된 후 당월 자리 상황이 확정되기 때문에, 그 직후에 문의하면 가장 최신 정보를 얻을 수 있습니다. 전화 시 아이 생년월일과 대기 등록일을 먼저 말씀드리면 어린이집에서도 빠르게 순번을 확인해드릴 수 있습니다.",
          "이 체크리스트는 대기순번, 월령, 맞벌이 여부, 형제 재원 여부, 희망 입소 시점을 종합해 입소 가능성 점수를 산출하는 자가 점검용 도구입니다. 점수는 어디까지나 참고용 추정이며 실제 입소 시점은 해당 시점의 퇴소·전원 상황에 따라 크게 달라질 수 있으므로, 정확한 입소 가능 시점은 해당 어린이집에 직접 문의해 확인하는 것이 가장 정확합니다.",
        ]}
        faq={DWC_FAQS.map((f) => ({ question: f.question, answer: f.answer }))}
        related={[
          { href: "/tools/daycare-kindergarten-cost-2026/", label: "어린이집 vs 유치원 비용 비교" },
          { href: "/tools/baby-cost-guide-first-year/", label: "0~12개월 육아 비용 가이드" },
          { href: "/tools/parental-leave-short-work-calculator/", label: "육아기 단축근무 급여 계산기" },
        ]}
      />
    </Fragment>
  </SimpleToolShell>
</BaseLayout>

<script src={withBase("scripts/daycare-waitlist-checklist.js")} defer></script>
