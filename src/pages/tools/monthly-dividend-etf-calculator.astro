---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  ETF_PRESETS,
  INVESTMENT_SCENARIOS,
  GOAL_SCENARIOS,
  calcMonthlyDist,
  calcRequiredInvestment,
  fmtManwon,
} from "../../data/monthlyDividendEtfCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const TITLE       = "월배당 ETF 배당금 계산기 — 투자금별 월 배당금 바로 계산";
const DESCRIPTION = "투자금과 ETF를 선택하면 월 예상 배당금·세후 실수령액을 바로 계산합니다. CONY·JEPI·SCHD·나스닥100커버드콜 등 14개 ETF 프리셋 제공.";

// 기본값으로 JEPI 선택
const defaultEtf = ETF_PRESETS.find(e => e.id === "jepi")!;

const faqItems = [
  { question: "월배당 ETF 배당금 계산기는 어떻게 사용하나요?",
    answer: "ETF를 선택하거나 연 분배율을 직접 입력하고, 투자금액을 입력하면 월 예상 배당금(세전·세후)이 자동 계산됩니다. 목표 월배당 역산 탭에서는 원하는 월 배당금을 받으려면 얼마를 투자해야 하는지도 확인할 수 있습니다." },
  { question: "국내 ETF와 미국 ETF의 세율 차이는?",
    answer: "국내 상장 ETF 분배금은 배당소득세 15.4%(소득세 14% + 지방소득세 1.4%)가 원천징수됩니다. 미국 상장 ETF는 배당소득에 대해 15% 원천징수 후 국내에서 추가 과세되어 실질 세율이 22% 수준입니다. 다만 금융소득종합과세 대상(연 2,000만원 초과)은 별도 처리됩니다." },
  { question: "커버드콜 ETF 분배율이 높은 이유는?",
    answer: "커버드콜 전략은 보유 주식에 콜옵션을 매도해 옵션 프리미엄을 수익으로 지급합니다. 분배율이 높지만 주가 상승 시 수익이 제한되고, 주가 하락 시 원금 손실은 그대로 발생합니다. CONY·AMDY처럼 단일 종목 기반은 변동성이 특히 큽니다." },
  { question: "월배당 100만원 만들려면 얼마 필요한가요?",
    answer: "연 분배율 12%, 세율 15.4% 기준으로 약 1억 180만원이 필요합니다. 연 분배율 8%, 세율 22% 기준(미국 ETF)은 약 1억 9,300만원이 필요합니다. 목표 월배당 탭에서 ETF별로 직접 확인해보세요." },
  { question: "분배율은 매년 바뀌나요?",
    answer: "네, ETF 분배율은 시장 상황에 따라 변동됩니다. 특히 커버드콜 ETF는 변동성이 낮아지면 분배율도 함께 낮아지는 경향이 있습니다. 이 계산기의 분배율은 최근 실적 기반 추정치이며 미래 분배를 보장하지 않습니다." },
];
---

<BaseLayout title={TITLE} description={DESCRIPTION}>
  <SiteHeader />
  <main class="container page-shell calc-page mdec-page">

    <!-- Hero -->
    <section class="mdec-hero">
      <p class="mdec-hero__eyebrow">투자·재테크 계산기</p>
      <h1 class="mdec-hero__title">월배당 ETF 배당금 계산기</h1>
      <p class="mdec-hero__sub">
        ETF 선택 → 투자금 입력 → 월 배당금 즉시 계산<br/>
        <span class="mdec-hero__sub-note">CONY · JEPI · JEPQ · SCHD · 나스닥100커버드콜 등 14개 ETF 프리셋</span>
      </p>
    </section>

    <!-- 탭 -->
    <div class="mdec-tabs" role="tablist">
      <button class="mdec-tab mdec-tab--active" data-tab="calc" role="tab" aria-selected="true">💰 배당금 계산</button>
      <button class="mdec-tab" data-tab="goal" role="tab" aria-selected="false">🎯 목표 월배당 역산</button>
      <button class="mdec-tab" data-tab="compare" role="tab" aria-selected="false">📊 ETF 비교표</button>
    </div>

    <!-- ── 탭 1: 배당금 계산 ─────────────────────────────── -->
    <section id="mdec-tab-calc" class="mdec-section content-section">

      <!-- ETF 프리셋 선택 -->
      <div class="mdec-etf-picker">
        <p class="mdec-label">ETF 선택 (선택 시 자동 입력)</p>
        <div class="mdec-etf-grid">
          {ETF_PRESETS.map((etf) => (
            <button
              type="button"
              class={`mdec-etf-btn mdec-etf-btn--${etf.market}`}
              data-etf-id={etf.id}
              data-rate={etf.annualDistRate}
              data-tax={etf.taxRate}
              data-market={etf.market}
              title={etf.description}
            >
              <span class="mdec-etf-btn__name">{etf.ticker}</span>
              <span class="mdec-etf-btn__rate">{etf.annualDistRate}%</span>
              {etf.remark && <span class="mdec-etf-btn__warn">⚠</span>}
            </button>
          ))}
        </div>
        <p class="mdec-etf-note">
          <span class="mdec-badge mdec-badge--domestic">국내</span> 분배금 세율 15.4%
          <span class="mdec-badge mdec-badge--us">미국</span> 배당 세율 22%
          · 분배율은 최근 실적 기반 추정치로 변동될 수 있습니다.
        </p>
      </div>

      <!-- 입력 -->
      <div class="mdec-inputs">
        <div class="mdec-input-group">
          <label class="mdec-input-label" for="mdec-investment">투자금액</label>
          <div class="mdec-input-wrap">
            <input id="mdec-investment" type="number" class="mdec-input" value="10000" min="1" step="100" />
            <span class="mdec-input-unit">만원</span>
          </div>
          <div class="mdec-quick-btns">
            {[1000, 3000, 5000, 10000, 20000, 30000].map(v => (
              <button type="button" class="mdec-quick-btn" data-val={v}>{fmtManwon(v)}</button>
            ))}
          </div>
        </div>

        <div class="mdec-input-group">
          <label class="mdec-input-label" for="mdec-rate">연 분배율</label>
          <div class="mdec-input-wrap">
            <input id="mdec-rate" type="number" class="mdec-input" value={defaultEtf.annualDistRate} min="0.1" max="100" step="0.1" />
            <span class="mdec-input-unit">%</span>
          </div>
          <p class="mdec-input-hint">직접 입력하거나 위 ETF 버튼 클릭 시 자동 입력</p>
        </div>

        <div class="mdec-input-group">
          <label class="mdec-input-label" for="mdec-tax">배당소득세율</label>
          <div class="mdec-input-wrap">
            <input id="mdec-tax" type="number" class="mdec-input" value={defaultEtf.taxRate} min="0" max="50" step="0.1" />
            <span class="mdec-input-unit">%</span>
          </div>
          <div class="mdec-tax-btns">
            <button type="button" class="mdec-tax-btn" data-tax="15.4">국내 15.4%</button>
            <button type="button" class="mdec-tax-btn" data-tax="22">미국 22%</button>
            <button type="button" class="mdec-tax-btn" data-tax="0">세금 없음</button>
          </div>
        </div>
      </div>

      <!-- 결과 카드 -->
      <div class="mdec-result-cards" id="mdec-results">
        <div class="mdec-result-card mdec-result-card--main">
          <p class="mdec-result-card__label">월 세후 배당금</p>
          <p class="mdec-result-card__value" id="mdec-monthly-net">—</p>
          <p class="mdec-result-card__sub" id="mdec-monthly-net-sub"></p>
        </div>
        <div class="mdec-result-card">
          <p class="mdec-result-card__label">월 세전 배당금</p>
          <p class="mdec-result-card__value" id="mdec-monthly-gross">—</p>
        </div>
        <div class="mdec-result-card">
          <p class="mdec-result-card__label">월 세금</p>
          <p class="mdec-result-card__value" id="mdec-monthly-tax">—</p>
          <p class="mdec-result-card__sub" id="mdec-tax-rate-display"></p>
        </div>
        <div class="mdec-result-card">
          <p class="mdec-result-card__label">연 세후 배당금</p>
          <p class="mdec-result-card__value" id="mdec-annual-net">—</p>
        </div>
      </div>

      <!-- 투자금별 시나리오 표 -->
      <div class="mdec-scenario-section">
        <h2 class="mdec-section-title">투자금별 월 배당금 비교 <span class="mdec-scenario-rate-display" id="mdec-scenario-rate-display"></span></h2>
        <div class="mdec-table-wrap">
          <table class="mdec-table" id="mdec-scenario-table">
            <thead>
              <tr>
                <th>투자금</th>
                <th>월 세전</th>
                <th>세금</th>
                <th>월 세후</th>
                <th>연 세후</th>
              </tr>
            </thead>
            <tbody id="mdec-scenario-tbody">
              {INVESTMENT_SCENARIOS.map(s => {
                const r = calcMonthlyDist(s.investmentManwon, defaultEtf.annualDistRate, defaultEtf.taxRate);
                return (
                  <tr class={s.investmentManwon === 10000 ? "mdec-row--highlight" : ""}>
                    <td><strong>{s.label}</strong></td>
                    <td>{fmtManwon(r.grossMonthly)}만</td>
                    <td class="mdec-cell--muted">{fmtManwon(r.tax)}만</td>
                    <td><strong>{fmtManwon(r.netMonthly)}만</strong></td>
                    <td>{fmtManwon(r.netMonthly * 12)}만</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      <!-- 선택 ETF 설명 -->
      <div class="mdec-etf-info" id="mdec-etf-info" hidden>
        <p class="mdec-etf-info__name" id="mdec-etf-info-name"></p>
        <p class="mdec-etf-info__desc" id="mdec-etf-info-desc"></p>
        <p class="mdec-etf-info__remark" id="mdec-etf-info-remark"></p>
      </div>
    </section>

    <!-- ── 탭 2: 목표 월배당 역산 ─────────────────────────── -->
    <section id="mdec-tab-goal" class="mdec-section content-section" hidden>
      <h2 class="mdec-section-title">목표 월배당 받으려면 얼마 투자해야 할까?</h2>
      <p class="mdec-section-desc">세후 월 배당금 목표를 입력하면 필요한 투자금을 역산합니다.</p>

      <div class="mdec-inputs">
        <div class="mdec-input-group">
          <label class="mdec-input-label" for="mdec-goal-target">목표 월 배당금 (세후)</label>
          <div class="mdec-input-wrap">
            <input id="mdec-goal-target" type="number" class="mdec-input" value="100" min="1" step="10" />
            <span class="mdec-input-unit">만원</span>
          </div>
          <div class="mdec-quick-btns">
            {[10, 30, 50, 100, 200, 300].map(v => (
              <button type="button" class="mdec-quick-btn mdec-goal-preset" data-val={v}>{v}만원</button>
            ))}
          </div>
        </div>
        <div class="mdec-input-group">
          <label class="mdec-input-label" for="mdec-goal-rate">연 분배율</label>
          <div class="mdec-input-wrap">
            <input id="mdec-goal-rate" type="number" class="mdec-input" value="10" min="0.1" max="100" step="0.1" />
            <span class="mdec-input-unit">%</span>
          </div>
        </div>
        <div class="mdec-input-group">
          <label class="mdec-input-label" for="mdec-goal-tax">세율</label>
          <div class="mdec-input-wrap">
            <input id="mdec-goal-tax" type="number" class="mdec-input" value="15.4" min="0" max="50" step="0.1" />
            <span class="mdec-input-unit">%</span>
          </div>
        </div>
      </div>

      <div class="mdec-goal-result" id="mdec-goal-result">
        <p class="mdec-goal-result__label">필요 투자금</p>
        <p class="mdec-goal-result__value" id="mdec-goal-value">—</p>
        <p class="mdec-goal-result__sub" id="mdec-goal-sub"></p>
      </div>

      <!-- 목표별 × 분배율별 표 -->
      <h3 class="mdec-section-title" style="margin-top:2rem">목표 월배당별 필요 투자금 비교</h3>
      <div class="mdec-table-wrap">
        <table class="mdec-table">
          <thead>
            <tr>
              <th>목표 월배당</th>
              <th>분배율 8%</th>
              <th>분배율 10%</th>
              <th>분배율 12%</th>
              <th>분배율 15%</th>
            </tr>
          </thead>
          <tbody>
            {GOAL_SCENARIOS.map(g => (
              <tr class={g.monthlyGoalManwon === 100 ? "mdec-row--highlight" : ""}>
                <td><strong>{g.label}</strong></td>
                {[8, 10, 12, 15].map(rate => {
                  const req = calcRequiredInvestment(g.monthlyGoalManwon, rate, 15.4);
                  return <td>{fmtManwon(req)}만</td>;
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mdec-table-note">※ 세율 15.4%(국내 기준) 적용. 미국 ETF는 22% 적용 시 투자금이 더 필요.</p>
    </section>

    <!-- ── 탭 3: ETF 비교표 ──────────────────────────────── -->
    <section id="mdec-tab-compare" class="mdec-section content-section" hidden>
      <h2 class="mdec-section-title">월배당 ETF 분배율 비교표</h2>
      <p class="mdec-section-desc">1억원 투자 기준 월 예상 배당금 비교 (세후)</p>

      <div class="mdec-compare-filter">
        <button class="mdec-compare-btn mdec-compare-btn--active" data-filter="all">전체</button>
        <button class="mdec-compare-btn" data-filter="domestic">국내 상장</button>
        <button class="mdec-compare-btn" data-filter="us">미국 상장</button>
        <button class="mdec-compare-btn" data-filter="covered-call">커버드콜</button>
        <button class="mdec-compare-btn" data-filter="dividend">배당주</button>
      </div>

      <div class="mdec-table-wrap">
        <table class="mdec-table mdec-compare-table">
          <thead>
            <tr>
              <th>ETF</th>
              <th>시장</th>
              <th>연 분배율</th>
              <th>세율</th>
              <th>1억 기준 월 세후</th>
              <th>1억 기준 연 세후</th>
              <th>비고</th>
            </tr>
          </thead>
          <tbody>
            {ETF_PRESETS
              .sort((a, b) => b.annualDistRate - a.annualDistRate)
              .map(etf => {
                const r = calcMonthlyDist(10000, etf.annualDistRate, etf.taxRate);
                return (
                  <tr data-etf-market={etf.market} data-etf-category={etf.category}>
                    <td>
                      <strong>{etf.ticker}</strong>
                      <p class="mdec-etf-name-sub">{etf.name}</p>
                    </td>
                    <td>
                      <span class={`mdec-badge mdec-badge--${etf.market}`}>
                        {etf.market === "domestic" ? "국내" : "미국"}
                      </span>
                    </td>
                    <td class="mdec-cell--rate"><strong>{etf.annualDistRate}%</strong></td>
                    <td class="mdec-cell--muted">{etf.taxRate}%</td>
                    <td><strong class="mdec-cell--highlight">{fmtManwon(r.netMonthly)}만</strong></td>
                    <td>{fmtManwon(r.netMonthly * 12)}만</td>
                    <td class="mdec-cell--remark">{etf.remark ?? "—"}</td>
                  </tr>
                );
              })}
          </tbody>
        </table>
      </div>
      <p class="mdec-table-note">※ 분배율은 최근 실적 기반 추정치. 투자 판단에 참고만 하세요.</p>
    </section>

    <!-- 주의사항 -->
    <div class="mdec-caution content-section">
      <h3 class="mdec-caution__title">⚠️ 투자 유의사항</h3>
      <ul class="mdec-caution__list">
        <li>이 계산기는 참고용이며 실제 투자 결과를 보장하지 않습니다.</li>
        <li>ETF 분배금은 시장 상황에 따라 감소하거나 없어질 수 있습니다.</li>
        <li>커버드콜 ETF는 주가 상승 시 수익이 제한되며 원금 손실이 발생할 수 있습니다.</li>
        <li>CONY·AMDY 등 단일 종목 커버드콜 ETF는 변동성이 매우 높습니다.</li>
        <li>금융소득이 연 2,000만원을 초과하면 금융소득종합과세 대상이 됩니다.</li>
        <li>투자 전 반드시 본인의 투자 성향과 재무 상황을 고려하세요.</li>
      </ul>
    </div>

    <!-- 관련 계산기 -->
    <section class="mdec-related content-section" aria-labelledby="mdec-related-title">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">관련 계산기</p>
        <h2 id="mdec-related-title">같이 사용하면 좋은 계산기</h2>
      </div>
      <div class="ts-link-grid">
        <a class="ts-link-card" href={withBase("/tools/dividend-monthly-income/")}>
          <span class="ts-link-card__eyebrow">배당 계산기</span>
          <strong>배당주 월급 계산기</strong>
          <p>배당 재투자 복리 20년 시뮬레이션 포함.</p>
        </a>
        <a class="ts-link-card" href={withBase("/tools/dca-investment-calculator/")}>
          <span class="ts-link-card__eyebrow">적립식 투자</span>
          <strong>적립식 투자 수익 비교 계산기</strong>
          <p>매달 투자 시 장기 수익 시뮬레이션.</p>
        </a>
        <a class="ts-link-card" href={withBase("/tools/us-stock-exchange-profit-calculator/")}>
          <span class="ts-link-card__eyebrow">미국주식</span>
          <strong>미국주식 환차손익 계산기</strong>
          <p>달러 배당금의 원화 환산 수익 계산.</p>
        </a>
        <a class="ts-link-card" href={withBase("/tools/bonus-after-tax-calculator/")}>
          <span class="ts-link-card__eyebrow">성과급 활용</span>
          <strong>성과급 세후 실수령액 계산기</strong>
          <p>성과급 세후 금액으로 ETF 투자 시뮬레이션.</p>
        </a>
      </div>
    </section>

    <SeoContent
      introTitle="월배당 ETF 배당금 계산기 — 비교계산소"
      intro={[
