---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import SummaryCards from "../../components/SummaryCards.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import TimelineToolShell from "../../components/TimelineToolShell.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title="육아휴직 급여 계산기"
  description="월 통상임금 기준으로 일반 육아휴직 사용 시 월별 급여와 총액을 계산하는 도구"
  ogImage="/og/tools/parental-leave-pay.png">
  <SiteHeader />

  <TimelineToolShell calculatorId="parental-leave-pay" pageClass="parental-leave-pay-page">
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="급여 계산"
        title="육아휴직 급여 계산기"
        description="월 통상임금을 기준으로 일반 육아휴직 18개월까지의 급여와 월급 대비 보전율을 계산합니다."
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetLeavePayBtn" copyId="copyLeavePayLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">육아휴직 정보 입력</h2>
          </div>
          <p class="panel-heading__summary">월 통상임금과 사용 개월 수를 넣으면 월별 급여 구간과 상한 적용 여부를 바로 확인할 수 있습니다.</p>
        </div>
        <div class="form-grid form-grid--compact">
          <label class="field">
            <span>월 통상임금</span>
            <input id="leavePayMonthlyWage" type="number" value="2500000" />
            <small id="leavePayMonthlyWageHint"></small>
          </label>
          <label class="field">
            <span>사용 개월 수</span>
            <select id="leavePayMonths">
              <option value="1">1개월</option>
              <option value="3">3개월</option>
              <option value="6">6개월</option>
              <option value="9">9개월</option>
              <option value="12" selected>12개월</option>
              <option value="15">15개월</option>
              <option value="18">18개월</option>
            </select>
          </label>
          <label class="field">
            <span>18개월 연장 조건</span>
            <select id="leavePayExtensionType">
              <option value="NONE" selected>기본 12개월</option>
              <option value="SHARED_PARENT">부모 모두 3개월 이상 사용</option>
              <option value="SINGLE_PARENT">한부모 가정</option>
              <option value="DISABLED_CHILD">중증장애아동 양육</option>
            </select>
          </label>
          <label class="field">
            <span>사용자</span>
            <select id="leavePayUser">
              <option value="MOTHER">엄마</option>
              <option value="FATHER">아빠</option>
            </select>
          </label>
          <label class="field field-span-full">
            <span>시작 시점</span>
            <select id="leavePayStartMonth">
              <option value="0" selected>출생 직후</option>
              <option value="1">1개월차</option>
              <option value="3">3개월차</option>
              <option value="6">6개월차</option>
              <option value="12">12개월차</option>
            </select>
          </label>
        </div>
        <button id="calcLeavePayBtn" class="button button--primary" type="button">육아휴직 급여 계산하기</button>
      </article>
    </Fragment>

    <SummaryCards
      columns={4}
      items={[
        { label: "총 육아휴직 급여", id: "leavePayTotalSummary" },
        { label: "월 평균 급여", id: "leavePayAverageSummary" },
        { label: "월급 대비 보전율", id: "leavePayReplacementSummary" },
        { label: "허용 한도", id: "leavePayAllowanceSummary" }
      ]}
    />

    <!-- ④ 구간별 급여 구조 바 -->
    <div class="plp-phase-bar">
      <p class="plp-phase-bar__title">구간별 급여 구조</p>
      <div class="plp-phase-bar__track">
        <div class="plp-phase plp-phase--1" id="phase1Bar">
          <span>1~3개월</span>
          <strong id="phase1Label">100% · 상한 250만</strong>
        </div>
        <div class="plp-phase plp-phase--2" id="phase2Bar">
          <span>4~6개월</span>
          <strong id="phase2Label">100% · 상한 200만</strong>
        </div>
        <div class="plp-phase plp-phase--3" id="phase3Bar">
          <span>7개월~</span>
          <strong id="phase3Label">80% · 상한 160만</strong>
        </div>
      </div>
      <div class="plp-phase-bar__legend">
        <span class="plp-legend-item plp-legend-item--1">1~3개월 (100%, 상한 250만)</span>
        <span class="plp-legend-item plp-legend-item--2">4~6개월 (100%, 상한 200만)</span>
        <span class="plp-legend-item plp-legend-item--3">7개월~ (80%, 상한 160만)</span>
      </div>
    </div>

    <!-- ⑤ 월별 급여 바 차트 -->
    <div class="plp-chart-wrap">
      <canvas id="plp-monthly-chart"></canvas>
    </div>

    <!-- ⑥ 상한 적용 뱃지 -->
    <div class="plp-limit-summary" id="plpLimitSummary">
      <div class="plp-limit-row" id="limitRow1">
        <span class="plp-limit-label">1~3개월</span>
        <span class="plp-limit-badge" id="limitBadge1">—</span>
        <span class="plp-limit-note" id="limitNote1"></span>
      </div>
      <div class="plp-limit-row" id="limitRow2">
        <span class="plp-limit-label">4~6개월</span>
        <span class="plp-limit-badge" id="limitBadge2">—</span>
        <span class="plp-limit-note" id="limitNote2"></span>
      </div>
      <div class="plp-limit-row" id="limitRow3">
        <span class="plp-limit-label">7개월~</span>
        <span class="plp-limit-badge" id="limitBadge3">—</span>
        <span class="plp-limit-note" id="limitNote3"></span>
      </div>
    </div>

    <InfoNotice
      title="안내"
      lines={[
        "육아휴직 1년 6개월 연장은 2025년 2월 23일 시행 기준으로 단순화한 조건 입력입니다.",
        "1~3개월은 통상임금 100% 상한 250만 원, 4~6개월은 100% 상한 200만 원, 이후는 80% 상한 160만 원 기준으로 계산합니다.",
        "13~18개월 구간은 공개 안내 흐름을 기준으로 7~12개월과 같은 상한 구조를 이어서 적용한 추정값입니다."
      ]}
    />

    <Fragment slot="timeline">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">월별 급여</p>
            <h2 class="panel__title">월별 육아휴직 급여</h2>
          </div>
          <p class="panel-heading__summary" id="leavePaySummaryNote">-</p>
        </div>
        <div class="table-wrap">
          <table class="result-table">
            <thead>
              <tr>
                <th>개월</th>
                <th>적용 비율</th>
                <th>상한</th>
                <th>월 급여</th>
                <th>상한 적용</th>
              </tr>
            </thead>
            <tbody id="leavePayTable"></tbody>
          </table>
        </div>
      </article>
    </Fragment>

    <Fragment slot="seo">
      <SeoContent
        introTitle="육아휴직 급여 계산기에서 봐야 할 포인트"
        intro={[
          "육아휴직 급여 계산기는 월 통상임금을 기준으로 육아휴직 기간 동안 실제로 받을 수 있는 급여 구간을 월별로 계산하는 페이지입니다. 육아휴직을 3개월, 6개월, 12개월, 18개월까지 사용할 때 총액이 어떻게 달라지는지 빠르게 비교할 수 있습니다.",
          "특히 1~3개월, 4~6개월, 7개월 이후 구간마다 상한이 달라지기 때문에, 내 월급이 어느 시점부터 상한에 걸리는지 확인하는 것이 중요합니다."
        ]}
        inputPoints={[
          "월 통상임금과 사용 개월 수를 바탕으로 총 육아휴직 급여를 계산합니다.",
          "18개월 연장 조건을 선택해 확장 구간까지 가정 비교할 수 있습니다.",
          "월별 급여표를 통해 어느 시점에 상한이 적용되는지 바로 확인할 수 있습니다."
        ]}
        criteria={[
          "1~3개월, 4~6개월, 7개월 이후 구간의 상한 구조를 기준으로 단순 계산합니다.",
          "18개월 연장은 2025년 2월 23일 시행 기준을 단순화해 입력받고 있습니다.",
          "13~18개월 구간은 공개 안내 흐름을 바탕으로 7~12개월 구조를 이어 적용한 비교용 추정입니다."
        ]}
        faq={[
          { question: "육아휴직 18개월까지 모두 정확히 반영되나요?", answer: "현재 페이지는 제도 확장 흐름을 비교용으로 반영한 버전입니다. 13~18개월 구간은 공개 안내를 바탕으로 단순화한 추정 구조를 사용합니다." },
          { question: "상한 적용 여부를 왜 봐야 하나요?", answer: "월 통상임금이 높을수록 계산상 비율보다 상한 금액에 먼저 걸릴 수 있어서, 실제 수령 체감이 달라지기 때문입니다." },
          { question: "가구 전체 기준으로도 볼 수 있나요?", answer: "가구 총액은 배우자 월급과 부모급여까지 합산하는 한 명만 육아휴직 총수령액 계산기에서 확인하는 것이 맞습니다." }
        ]}
        related={[
          { href: "/tools/single-parental-leave-total/", label: "한 명만 육아휴직 총수령액 계산기" },
          { href: "/tools/six-plus-six/", label: "6+6 부모육아휴직제 계산기" },
          { href: "/tools/birth-support-total/", label: "출산~2세 총지원금 계산기" }
        ]}
      />
    </Fragment>
  </TimelineToolShell>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/parental-leave-pay.js")}></script>
</BaseLayout>
