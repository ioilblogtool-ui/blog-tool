---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";

import {
  DTC_META,
  DTC_TREATMENTS,
  DTC_FAQS,
  DTC_INSURANCE_TABLE,
} from "../../data/dentalTreatmentCost";

const relatedLinks = [
  { href: "/tools/health-checkup-cost-comparison-2026/", label: "건강검진 비용 비교 2026" },
  { href: "/tools/fetal-insurance-calculator/",          label: "태아보험 계산기" },
  { href: "/tools/year-end-tax-refund-calculator/",     label: "연말정산 환급 계산기" },
  { href: "/tools/four-insurance-calculator/",          label: "4대보험 계산기" },
];
---

<BaseLayout
  title={DTC_META.seoTitle}
  description={DTC_META.description}
  ogType="website"
>
  <SiteHeader slot="header" />

  <script id="dtcConfig" type="application/json" set:html={JSON.stringify({ treatments: DTC_TREATMENTS, insuranceTable: DTC_INSURANCE_TABLE })} />

  <div class="dtc-page">
    <SimpleToolShell calculatorId="dental-treatment-cost-calculator">

      <!-- hero 슬롯 -->
      <div slot="hero">
        <CalculatorHero
          title={DTC_META.title}
          description="임플란트·크라운·충치 등 견적을 입력하면 전국 평균 대비 낮음·보통·높음을 즉시 판단합니다."
          eyebrow="의료비 판단"
          badges={["생활", "의료비"]}
        />
      </div>

      <!-- aside 슬롯: 입력 영역 -->
      <div slot="aside">
        <!-- 치료 탭 -->
        <div class="dtc-tab-list">
          {DTC_TREATMENTS.map((t) => (
            <button
              class={"dtc-tab-btn" + (t.id === "implant" ? " is-active" : "")}
              data-treatment={t.id}
              type="button"
            >
              {t.label}
            </button>
          ))}
        </div>

        <!-- 옵션 선택 -->
        <div class="dtc-option-row">
          <label for="dtc-option-select">치료 옵션</label>
          <select id="dtc-option-select">
            {DTC_TREATMENTS[0].options.map((o) => (
              <option value={o.id}>{o.label}</option>
            ))}
          </select>
        </div>

        <!-- 치아 수 (perTooth=true일 때만 표시) -->
        <div class="dtc-count-row is-visible">
          <label for="dtc-count">치아 수</label>
          <input id="dtc-count" type="number" min="1" max="28" value="1" />
        </div>

        <!-- 보험 배너 -->
        <div class="dtc-insurance-banner is-visible">
          <span class="dtc-banner-icon">ℹ️</span>
          <span class="dtc-banner-text">만 65세 이상은 건강보험 적용 (본인부담 30%, 평생 2개 한도)</span>
        </div>

        <!-- 견적 입력 -->
        <div class="dtc-price-row">
          <label for="dtc-price">받은 견적 (만원 단위)</label>
          <input
            id="dtc-price"
            type="number"
            min="0"
            step="1"
            placeholder="예: 100"
          />
        </div>

        <ToolActionBar copyLinkId="dtc-copy-link" resetId="dtc-reset" />
      </div>

      <!-- 기본 슬롯: 결과 영역 -->
      <div>
        <!-- 판정 카드 -->
        <div class="dtc-kpi-grid">
          <div class="dtc-kpi-card dtc-kpi-card--verdict">
            <div class="dtc-verdict-body">
              <div class="dtc-kpi-label">견적 판정</div>
              <span class="dtc-verdict-badge dtc-verdict-badge--empty">—</span>
              <div class="dtc-verdict-msg">견적을 입력하면 판정이 표시됩니다.</div>
            </div>
          </div>

          <div class="dtc-kpi-card">
            <div class="dtc-kpi-label">전국 최저 수준</div>
            <div class="dtc-kpi-value" id="dtc-kv-low">—</div>
          </div>
          <div class="dtc-kpi-card">
            <div class="dtc-kpi-label">전국 평균</div>
            <div class="dtc-kpi-value" id="dtc-kv-avg">—</div>
          </div>
          <div class="dtc-kpi-card">
            <div class="dtc-kpi-label">전국 최고 수준</div>
            <div class="dtc-kpi-value" id="dtc-kv-high">—</div>
          </div>
        </div>

        <!-- 게이지 바 -->
        <div class="dtc-gauge-wrap">
          <div class="dtc-gauge-labels">
            <span>낮음</span>
            <span class="dtc-gauge-user-label"></span>
            <span>높음</span>
          </div>
          <div class="dtc-gauge-track">
            <div class="dtc-gauge-marker" style="left:50%"></div>
          </div>
        </div>

        <!-- 참고 범위 표 -->
        <h3 style="font-size:0.9rem;font-weight:600;margin:1rem 0 0.5rem;">옵션별 참고 비용 범위 (만원)</h3>
        <div class="dtc-range-table-wrap">
          <table class="dtc-range-table">
            <thead>
              <tr>
                <th>옵션</th>
                <th class="dtc-col-low">최저</th>
                <th class="dtc-col-avg">평균</th>
                <th class="dtc-col-high">최고</th>
                <th>보험 적용 시</th>
              </tr>
            </thead>
            <tbody id="dtc-range-tbody">
            </tbody>
          </table>
        </div>

        <InfoNotice
          title="참고 안내"
          lines={[
            "이 계산기의 비용 범위는 전국 치과 조사를 바탕으로 한 추정치입니다.",
            "지역·병원·재료에 따라 실제 비용이 크게 다를 수 있으며, 정확한 금액은 해당 치과에서 확인하세요.",
          ]}
        />

        <!-- 건강보험 적용 안내 -->
        <h3 style="font-size:0.9rem;font-weight:600;margin:1.5rem 0 0.5rem;">건강보험 적용 항목 안내</h3>
        <div class="dtc-ins-table-wrap">
          <table class="dtc-ins-table">
            <thead>
              <tr>
                <th>치료 항목</th>
                <th>적용 조건</th>
                <th>본인부담률</th>
              </tr>
            </thead>
            <tbody>
              {DTC_INSURANCE_TABLE.map((row) => (
                <tr>
                  <td>{row.treatment}</td>
                  <td>{row.condition}</td>
                  <td style="text-align:center">{row.rate}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="dtc-notice">
          💡 <strong>연말정산 팁:</strong> 임플란트·크라운·교정 등 비보험 치과 치료비도 의료비 세액공제 대상입니다. 총급여의 3% 초과분에 대해 15% 세액공제를 받을 수 있으니 영수증을 꼭 보관하세요.
        </div>
      </div>

      <!-- seo 슬롯 -->
      <div slot="seo">
        <SeoContent
          intro={[
            "치과 치료는 종류에 따라 수십만원에서 수백만원까지 비용이 크게 다릅니다. 같은 임플란트라도 국산·수입 픽스처, 크라운 재료, 뼈이식 여부에 따라 병원마다 견적 차이가 납니다.",
            "이 계산기는 임플란트·크라운·인레이·충치·신경치료·스케일링·교정·틀니 8가지 치료에 대해 전국 참고 비용 범위를 제공합니다. 받은 견적이 낮음·보통·높음 중 어디에 해당하는지 즉시 확인할 수 있습니다.",
            "건강보험 적용 항목(임플란트 만 65세 이상, 스케일링 연 1회, 충치·신경치료 등)과 연말정산 의료비 공제 정보도 함께 안내합니다.",
          ]}
          criteria={[
            "비용 범위는 국내 다수 치과의 공개 가격 및 소비자 조사를 바탕으로 한 추정치입니다.",
            "건강보험 적용 조건 및 본인부담률은 2026년 기준이며, 정책 변경에 따라 달라질 수 있습니다.",
            "치과 치료비는 지역(서울·수도권이 지방보다 높음), 재료, 술식 난이도에 따라 실제 차이가 발생할 수 있습니다.",
          ]}
          faqs={DTC_FAQS}
          relatedLinks={relatedLinks}
        />
      </div>

    </SimpleToolShell>
  </div>

  <SiteFooter slot="footer" />

  <script is:inline src="/scripts/dental-treatment-cost-calculator.js"></script>
</BaseLayout>
