---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";

import {
  DTC_META,
  DTC_TREATMENTS,
  DTC_FAQS,
  DTC_INSURANCE_TABLE,
} from "../../data/dentalTreatmentCost";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title={DTC_META.seoTitle}
  description={DTC_META.description}
  ogType="website"
>
  <SiteHeader />

  <script
    id="dtcConfig"
    type="application/json"
    set:html={JSON.stringify({ treatments: DTC_TREATMENTS, insuranceTable: DTC_INSURANCE_TABLE })}
  />

  <SimpleToolShell calculatorId="dental-treatment-cost-calculator" pageClass="dtc-page">

    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="의료비 판단"
        title={DTC_META.title}
        description="임플란트·크라운·충치 등 견적을 입력하면 전국 평균 대비 낮음·보통·높음을 즉시 판단합니다."
        stats={[
          { label: "치료 항목", value: "8종" },
          { label: "판정 기준", value: "전국 평균" },
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="dtcResetBtn" copyId="dtcCopyLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">치료 조건 입력</h2>
          </div>
          <p class="panel-heading__summary">치료 종류와 받은 견적을 입력하면 전국 평균 대비 적정성을 즉시 확인합니다.</p>
        </div>

        <div class="form-grid form-grid--compact">
          <!-- 치료 탭 -->
          <div class="field field-span-full">
            <span>치료 종류</span>
            <div class="dtc-tab-list">
              {DTC_TREATMENTS.map((t) => (
                <button
                  class={"dtc-tab-btn" + (t.id === "implant" ? " is-active" : "")}
                  data-treatment={t.id}
                  type="button"
                >
                  {t.label}
                </button>
              ))}
            </div>
          </div>

          <!-- 옵션 선택 -->
          <label class="field field-span-full">
            <span>치료 옵션</span>
            <select id="dtc-option-select" class="select">
              {DTC_TREATMENTS[0].options.map((o) => (
                <option value={o.id}>{o.label}</option>
              ))}
            </select>
          </label>

          <!-- 치아 수 -->
          <label class="field field-span-full dtc-count-row is-visible">
            <span>치아 수</span>
            <input id="dtc-count" type="number" class="input-number" min="1" max="28" value="1" />
          </label>

          <!-- 견적 입력 -->
          <label class="field field-span-full">
            <span>받은 견적 (만원 단위)</span>
            <input
              id="dtc-price"
              type="number"
              class="input-number"
              min="0"
              step="1"
              placeholder="예: 100"
            />
          </label>
        </div>

        <!-- 보험 배너 -->
        <div class="dtc-insurance-banner is-visible">
          <span class="dtc-banner-icon">ℹ️</span>
          <span class="dtc-banner-text">만 65세 이상은 건강보험 적용 (본인부담 30%, 평생 2개 한도)</span>
        </div>
      </article>
    </Fragment>

    <!-- 결과 영역 (기본 슬롯) -->
    <div style="display: grid; gap: 1rem;">

      <!-- 판정 카드 -->
      <div class="dtc-kpi-grid">
        <div class="dtc-kpi-card dtc-kpi-card--verdict">
          <div class="dtc-verdict-body">
            <div class="dtc-kpi-label">견적 판정</div>
            <span class="dtc-verdict-badge dtc-verdict-badge--empty">—</span>
            <div class="dtc-verdict-msg">견적을 입력하면 판정이 표시됩니다.</div>
          </div>
        </div>
        <div class="dtc-kpi-card">
          <div class="dtc-kpi-label">전국 최저 수준</div>
          <div class="dtc-kpi-value" id="dtc-kv-low">—</div>
        </div>
        <div class="dtc-kpi-card">
          <div class="dtc-kpi-label">전국 평균</div>
          <div class="dtc-kpi-value" id="dtc-kv-avg">—</div>
        </div>
        <div class="dtc-kpi-card">
          <div class="dtc-kpi-label">전국 최고 수준</div>
          <div class="dtc-kpi-value" id="dtc-kv-high">—</div>
        </div>
      </div>

      <!-- 게이지 바 -->
      <div class="dtc-gauge-wrap">
        <div class="dtc-gauge-labels">
          <span>낮음</span>
          <span class="dtc-gauge-user-label"></span>
          <span>높음</span>
        </div>
        <div class="dtc-gauge-track">
          <div class="dtc-gauge-marker" style="left:50%"></div>
        </div>
      </div>

      <!-- 참고 범위 표 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">비용 범위</p>
            <h2 class="panel__title">옵션별 참고 비용 (만원)</h2>
          </div>
        </div>
        <div class="dtc-range-table-wrap">
          <table class="dtc-range-table">
            <thead>
              <tr>
                <th>옵션</th>
                <th class="dtc-col-low">최저</th>
                <th class="dtc-col-avg">평균</th>
                <th class="dtc-col-high">최고</th>
                <th>보험 적용 시</th>
              </tr>
            </thead>
            <tbody id="dtc-range-tbody"></tbody>
          </table>
        </div>
      </article>

      <!-- 건강보험 적용 안내 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">건강보험</p>
            <h2 class="panel__title">건강보험 적용 항목 안내</h2>
          </div>
        </div>
        <div class="dtc-ins-table-wrap">
          <table class="dtc-ins-table">
            <thead>
              <tr>
                <th>치료 항목</th>
                <th>적용 조건</th>
                <th>본인부담률</th>
              </tr>
            </thead>
            <tbody>
              {DTC_INSURANCE_TABLE.map((row) => (
                <tr>
                  <td>{row.treatment}</td>
                  <td>{row.condition}</td>
                  <td style="text-align:center">{row.rate}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="dtc-notice">
          💡 <strong>연말정산 팁:</strong> 임플란트·크라운·교정 등 비보험 치과 치료비도 의료비 세액공제 대상입니다. 총급여의 3% 초과분에 대해 15% 세액공제를 받을 수 있으니 영수증을 꼭 보관하세요.
        </div>
      </article>

      <InfoNotice
        title="참고 안내"
        lines={[
          "이 계산기의 비용 범위는 전국 치과 조사를 바탕으로 한 추정치입니다.",
          "지역·병원·재료에 따라 실제 비용이 크게 다를 수 있으며, 정확한 금액은 해당 치과에서 확인하세요.",
        ]}
      />
    </div>

    <Fragment slot="seo">
      <SeoContent
        introTitle="치과 치료비, 받은 견적이 적정한지 바로 확인"
        intro={[
          "치과에서 임플란트나 크라운 견적을 받고 나면 '이 가격이 적정한가, 비싸게 부른 건 아닌가' 판단이 어려운 경우가 많습니다. 병원마다 같은 치료라도 가격이 수십만원에서 수백만원까지 차이가 나기 때문에, 첫 상담에서 받은 견적 하나만으로는 비교 기준을 잡기 어렵습니다. 이 계산기는 치료 종류와 받은 견적을 입력하면 전국 참고 비용 범위와 즉시 비교해 적정성을 판단할 수 있도록 만들어졌습니다.",
          "비용 범위는 임플란트·크라운·인레이·충치·신경치료·스케일링·교정·틀니 8가지 치료 항목별로 국내 다수 치과의 공개 가격과 소비자 조사를 바탕으로 전국 최저·평균·최고 수준을 산출했습니다. 임플란트·크라운처럼 치아 1개당 비용이 책정되는 항목은 치아 수를 곱해 총비용 범위로 환산하며, 스케일링·교정처럼 시술 단위로 가격이 책정되는 항목은 그대로 비교합니다.",
          "받은 견적이 전국 최저 수준보다 낮으면 '낮음', 평균 범위 안에 들면 '보통', 최고 수준을 넘으면 '높음'으로 판정됩니다. 게이지 바의 마커 위치가 오른쪽에 가까울수록 평균보다 비싼 견적이라는 의미이며, '높음' 판정을 받았다면 동일 치료를 다른 치과 2~3곳에서 추가 상담받아 비교해보는 것이 좋습니다.",
          "다만 이 계산기의 비용 범위는 추정치이며, 실제 가격은 재료 브랜드, 의사 경력, 병원 위치(서울·수도권이 지방보다 높은 경향), 뼈이식 등 부가 시술 여부에 따라 크게 달라질 수 있습니다. '낮음' 판정이라고 무조건 좋은 선택은 아니며, 재료 품질과 시술 방법도 함께 확인한 뒤 최종 결정을 내리는 것을 권장합니다.",
        ]}
        criteria={[
          "비용 범위는 국내 다수 치과의 공개 가격 및 소비자 조사를 바탕으로 한 추정치입니다.",
          "건강보험 적용 조건 및 본인부담률은 2026년 기준이며, 정책 변경에 따라 달라질 수 있습니다.",
          "치과 치료비는 지역(서울·수도권이 지방보다 높음), 재료, 술식 난이도에 따라 실제 차이가 발생할 수 있습니다.",
        ]}
        faq={DTC_FAQS}
        related={[
          { href: "/tools/health-checkup-cost-comparison-2026/", label: "건강검진 비용 비교 2026" },
          { href: "/tools/fetal-insurance-calculator/",          label: "태아보험 계산기" },
          { href: "/tools/year-end-tax-refund-calculator/",     label: "연말정산 환급 계산기" },
          { href: "/tools/four-insurance-calculator/",          label: "4대보험 계산기" },
        ]}
      />
    </Fragment>

  </SimpleToolShell>
</BaseLayout>

<script src={withBase("scripts/dental-treatment-cost-calculator.js")} defer></script>
