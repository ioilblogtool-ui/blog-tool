---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import { NUC_DEFAULTS, NUC_META, NUC_FAQ, NUC_PRESETS } from "../../data/newVsUsedCar5YearCost";

const config = { defaults: NUC_DEFAULTS, presets: NUC_PRESETS };
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: NUC_META.title,
  description: NUC_META.description,
  applicationCategory: "FinanceApplication",
  operatingSystem: "All",
  url: `https://bigyocalc.com/tools/${NUC_META.slug}/`,
};
---

<BaseLayout title={NUC_META.title} description={NUC_META.description} jsonLd={jsonLd}>
  <SiteHeader />

  <SimpleToolShell calculatorId={NUC_META.slug} pageClass="nuc-page">
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="자동차 구매 비교"
        title="신차 vs 중고차, 5년 동안 실제로 어떤 게 더 싸?"
        description="구매가·보험·유지비·감가를 모두 반영한 5년 총보유비용을 비교합니다."
      />
      <InfoNotice title="추정 계산 안내" lines={[NUC_META.caution, `업데이트 기준: ${NUC_META.updatedAt}`]} />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="nucResetBtn" copyId="nucCopyLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <script id="nucConfig" type="application/json" set:html={JSON.stringify(config)} />

      <div class="nuc-presets">
        <button class="nuc-preset-btn is-active" data-preset="small">소형차 (아반떼급)</button>
        <button class="nuc-preset-btn" data-preset="mid">준중형 (K5급)</button>
        <button class="nuc-preset-btn" data-preset="suv">SUV (투싼급)</button>
      </div>

      <section class="nuc-section">
        <h3>신차 조건</h3>
        <div class="nuc-field">
          <label>차량 가격</label>
          <div class="nuc-input-row"><input data-nuc="newPrice" type="number" min="500" max="20000" step="100" /><span>만원</span></div>
        </div>
        <div class="nuc-field">
          <label>첫해 보험료</label>
          <div class="nuc-input-row"><input data-nuc="newInsurance" type="number" min="30" max="500" step="10" /><span>만원/년</span></div>
        </div>
        <div class="nuc-field">
          <label>월 유지비</label>
          <div class="nuc-input-row"><input data-nuc="newMonthly" type="number" min="5" max="200" step="1" /><span>만원/월</span></div>
        </div>
        <div class="nuc-field">
          <label>5년 후 잔존가치</label>
          <div class="nuc-input-row"><input data-nuc="newResidual" type="number" min="0" max="80" step="1" /><span>%</span></div>
        </div>
      </section>

      <section class="nuc-section">
        <h3>중고차 조건</h3>
        <div class="nuc-field">
          <label>차량 가격</label>
          <div class="nuc-input-row"><input data-nuc="usedPrice" type="number" min="200" max="15000" step="100" /><span>만원</span></div>
        </div>
        <div class="nuc-field">
          <label>현재 연식</label>
          <div class="nuc-input-row"><input data-nuc="usedAge" type="number" min="1" max="15" step="1" /><span>년</span></div>
        </div>
        <div class="nuc-field">
          <label>첫해 보험료</label>
          <div class="nuc-input-row"><input data-nuc="usedInsurance" type="number" min="30" max="500" step="10" /><span>만원/년</span></div>
        </div>
        <div class="nuc-field">
          <label>월 유지비</label>
          <div class="nuc-input-row"><input data-nuc="usedMonthly" type="number" min="5" max="200" step="1" /><span>만원/월</span></div>
        </div>
        <div class="nuc-field">
          <label>5년 후 잔존가치</label>
          <div class="nuc-input-row"><input data-nuc="usedResidual" type="number" min="0" max="80" step="1" /><span>%</span></div>
        </div>
      </section>
    </Fragment>

    <!-- 결과 영역 -->
    <div class="nuc-kpi-grid">
      <div class="nuc-kpi-card nuc-kpi-card--new">
        <span class="nuc-kpi__label">신차 5년 총비용</span>
        <span class="nuc-kpi__value" id="nucNewTotal">—</span>
        <span class="nuc-kpi__sub" id="nucNewSub"></span>
      </div>
      <div class="nuc-kpi-card nuc-kpi-card--used">
        <span class="nuc-kpi__label">중고차 5년 총비용</span>
        <span class="nuc-kpi__value" id="nucUsedTotal">—</span>
        <span class="nuc-kpi__sub" id="nucUsedSub"></span>
      </div>
      <div class="nuc-kpi-card nuc-kpi-card--diff">
        <span class="nuc-kpi__label">차액</span>
        <span class="nuc-kpi__value" id="nucDiff">—</span>
        <span class="nuc-kpi__sub" id="nucDiffSub"></span>
      </div>
      <div class="nuc-kpi-card">
        <span class="nuc-kpi__label">손익분기점</span>
        <span class="nuc-kpi__value" id="nucBreakEven">—</span>
        <span class="nuc-kpi__sub">신차가 더 유리해지는 시점</span>
      </div>
    </div>

    <div id="nucConclusion" class="nuc-conclusion"></div>

    <div class="nuc-chart-wrap">
      <canvas id="nucChart"></canvas>
    </div>

    <h3 class="nuc-table-title">비용 항목별 상세</h3>
    <div class="nuc-table-wrap">
      <table class="nuc-table">
        <thead>
          <tr><th>항목</th><th>신차</th><th>중고차</th></tr>
        </thead>
        <tbody>
          <tr><td>구매가</td><td id="nucNewPriceRow">—</td><td id="nucUsedPriceRow">—</td></tr>
          <tr><td>취득세 (7%)</td><td id="nucNewTaxRow">—</td><td id="nucUsedTaxRow">—</td></tr>
          <tr><td>5년 보험료</td><td id="nucNewInsRow">—</td><td id="nucUsedInsRow">—</td></tr>
          <tr><td>5년 유지비</td><td id="nucNewMaintRow">—</td><td id="nucUsedMaintRow">—</td></tr>
          <tr><td>감가 손실</td><td id="nucNewDeprRow">—</td><td id="nucUsedDeprRow">—</td></tr>
        </tbody>
        <tfoot>
          <tr><td>합계</td><td id="nucNewTotalRow">—</td><td id="nucUsedTotalRow">—</td></tr>
        </tfoot>
      </table>
    </div>

    <!-- 관련 계산기 CTA -->
    <section class="nuc-related-section">
      <p class="nuc-related__eyebrow">자동차 관련 계산기</p>
      <h2 class="nuc-related__title">이어서 확인하면 좋은 계산기</h2>
      <div class="nuc-related-grid">
        <a href="/tools/car-purchase-method-comparison/" class="nuc-related-card">
          <strong>리스 vs 할부 vs 현금 비교</strong>
          <span>어떤 방법으로 사야 총비용이 가장 적을까?</span>
        </a>
        <a href="/tools/ev-vs-ice-10year-cost/" class="nuc-related-card">
          <strong>전기차 vs 내연기관 10년 유지비</strong>
          <span>보조금 포함 10년 총비용과 손익분기점 계산</span>
        </a>
        <a href="/tools/ev-vs-ice-cost-calculator/" class="nuc-related-card">
          <strong>전기차 연간 유지비 비교</strong>
          <span>연간 충전비·유지비 기준 빠른 비교</span>
        </a>
      </div>
    </section>

    <!-- SEO 콘텐츠 -->
    <SeoContent
      introTitle="신차 vs 중고차, 단순 가격만 보면 안 됩니다"
      intro={[
        "자동차 구매 시 많은 사람이 '신차 가격 vs 중고차 가격'만 비교합니다. 하지만 실제 5년 보유 비용은 구매가 외에도 취득세(7%), 보험료, 월 유지비, 감가(잔존가치 하락)까지 포함해야 합니다.",
        "3년식 중고차는 구매가가 신차 대비 40~50% 낮지만, 유지비와 보험료가 더 높고 추가 감가도 크기 때문에 5년 총비용 기준으로는 생각보다 차이가 적을 수 있습니다. 차종과 이용 조건에 따라 신차가 유리한 경우도 있습니다.",
      ]}
      inputPoints={[
        "차량 구매가와 연식 — 중고차는 3년식 기준이 일반적",
        "첫해 보험료 — 신차 대비 중고차는 10~30% 낮음",
        "월 유지비 — 연식이 오래될수록 소모품 교체 빈도 증가",
        "잔존가치 — 5년 후 중고차 시세 예상치 (신차 40%, 중고차 25% 기준)",
      ]}
      criteria={[
        "취득세: 승용차 7%, 경차 4% 기준으로 자동 계산",
        "감가: 구매가 × (1 - 잔존가치%) 로 계산 (선형 분산)",
        "보험료: 5년 합산 기준, 연도별 변동은 미반영",
        "유지비: 주유·주차·소모품 월 평균 합산 기준",
      ]}
      faq={NUC_FAQ}
      related={[
        { href: "/tools/car-purchase-method-comparison/", label: "리스 vs 할부 vs 현금 비교 계산기" },
        { href: "/tools/ev-vs-ice-10year-cost/", label: "전기차 vs 내연기관 10년 유지비 계산기" },
      ]}
    />
  </SimpleToolShell>
</BaseLayout>

<script src="/scripts/new-vs-used-car-5year-cost.js" defer></script>
