---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  DC_SCENARIOS,
  SALARY_GROWTH_PRESETS,
  FAQ,
  calcDbRetirement,
  calcDcRetirement,
  fmtManwon,
} from "../../data/retirementDcDbCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const TITLE = "퇴직연금 DB형 DC형 전환 계산기 — 내게 유리한 유형은?";
const DESC  = "현재 연봉·근속연수·ETF 수익률을 입력하면 DB형 vs DC형 퇴직금을 자동 비교합니다. 임금 피크제·이직 계획별 시뮬레이션 제공.";

// 기본값으로 결과 미리 계산 (SSR 테이블용)
const defaultSalary = 6000;
const defaultYears  = 20;
const defaultGrowth = 3.5;
const defaultDb     = calcDbRetirement(defaultSalary, defaultYears, defaultGrowth);
---

<BaseLayout title={TITLE} description={DESC}>
  <SiteHeader />
  <main class="container page-shell calc-page rddc-page">

    <!-- Hero -->
    <section class="rddc-hero">
      <p class="rddc-hero__eyebrow">퇴직연금 계산기</p>
      <h1 class="rddc-hero__title">DB형 vs DC형 전환 계산기</h1>
      <p class="rddc-hero__sub">
        연봉·근속연수·ETF 수익률 입력 → DB·DC 퇴직금 자동 비교<br/>
        <span class="rddc-hero__note">임금 피크제·이직 계획·투자 성향별 시뮬레이션</span>
      </p>
    </section>

    <!-- 입력 -->
    <section class="rddc-input-section content-section">
      <h2 class="rddc-section-title">내 조건 입력</h2>

      <div class="rddc-inputs">
        <div class="rddc-input-group">
          <label class="rddc-label" for="rddc-salary">현재 연봉</label>
          <div class="rddc-input-wrap">
            <input id="rddc-salary" type="number" class="rddc-input" value="6000" min="1000" step="100" />
            <span class="rddc-unit">만원</span>
          </div>
          <div class="rddc-quick-btns">
            {[4000,5000,6000,7000,8000,10000].map(v => (
              <button type="button" class="rddc-quick-btn" data-val={v}>{fmtManwon(v)}</button>
            ))}
          </div>
        </div>

        <div class="rddc-input-group">
          <label class="rddc-label" for="rddc-years">남은 근속 기간</label>
          <div class="rddc-input-wrap">
            <input id="rddc-years" type="number" class="rddc-input" value="20" min="1" max="40" step="1" />
            <span class="rddc-unit">년</span>
          </div>
          <div class="rddc-quick-btns">
            {[5,10,15,20,25,30].map(v => (
              <button type="button" class="rddc-years-btn" data-val={v}>{v}년</button>
            ))}
          </div>
        </div>

        <div class="rddc-input-group rddc-input-group--full">
          <label class="rddc-label">연봉 인상률 (연평균)</label>
          <div class="rddc-preset-btns" id="rddc-growth-presets">
            {SALARY_GROWTH_PRESETS.map((p, i) => (
              <button
                type="button"
                class={`rddc-preset-btn${i === 1 ? " is-active" : ""}`}
                data-val={p.annualGrowthRate}
                data-id={p.id}
                title={p.description}
              >
                {p.label}
              </button>
            ))}
          </div>
          <div class="rddc-input-wrap rddc-input-wrap--sm">
            <input id="rddc-growth" type="number" class="rddc-input" value="3.5" min="0" max="20" step="0.5" />
            <span class="rddc-unit">%</span>
          </div>
        </div>

        <div class="rddc-input-group rddc-input-group--full">
          <label class="rddc-label">DC형 운용 수익률 (연평균)</label>
          <div class="rddc-preset-btns" id="rddc-dc-presets">
            {DC_SCENARIOS.map((s, i) => (
              <button
                type="button"
                class={`rddc-preset-btn rddc-preset-btn--dc${i === 2 ? " is-active" : ""}`}
                data-val={s.dcReturnRate}
                title={s.description}
                style={`--btn-color: ${s.color}`}
              >
                {s.label} {s.dcReturnRate}%
              </button>
            ))}
          </div>
          <div class="rddc-input-wrap rddc-input-wrap--sm">
            <input id="rddc-dc-rate" type="number" class="rddc-input" value="8" min="0" max="30" step="0.5" />
            <span class="rddc-unit">%</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 결과 -->
    <section class="rddc-result-section content-section">
      <h2 class="rddc-section-title">비교 결과</h2>

      <!-- 승자 배너 -->
      <div class="rddc-winner-banner" id="rddc-winner-banner">
        <span class="rddc-winner-banner__label" id="rddc-winner-label">계산 중...</span>
        <span class="rddc-winner-banner__diff" id="rddc-winner-diff"></span>
      </div>

      <!-- 결과 카드 2개 -->
      <div class="rddc-result-cards">
        <div class="rddc-result-card rddc-result-card--db" id="rddc-db-card">
          <div class="rddc-result-card__header">
            <span class="rddc-result-card__type">DB형</span>
            <span class="rddc-result-card__badge">확정급여형</span>
          </div>
          <p class="rddc-result-card__label">예상 퇴직금</p>
          <p class="rddc-result-card__value" id="rddc-db-amount">—</p>
          <p class="rddc-result-card__sub">퇴직 직전 임금 기준</p>
          <ul class="rddc-result-card__pros">
            <li>연봉이 꾸준히 오를수록 유리</li>
            <li>운용 위험은 회사 부담</li>
            <li>장기 근속 시 유리</li>
          </ul>
        </div>

        <div class="rddc-result-card rddc-result-card--dc" id="rddc-dc-card">
          <div class="rddc-result-card__header">
            <span class="rddc-result-card__type">DC형</span>
            <span class="rddc-result-card__badge">확정기여형</span>
          </div>
          <p class="rddc-result-card__label">예상 퇴직금</p>
          <p class="rddc-result-card__value" id="rddc-dc-amount">—</p>
          <p class="rddc-result-card__sub" id="rddc-dc-rate-display">ETF 운용 기준</p>
          <ul class="rddc-result-card__pros">
            <li>직접 ETF 투자로 수익 극대화</li>
            <li>이직해도 계좌 유지</li>
            <li>임금 피크제 적용 시 유리</li>
          </ul>
        </div>
      </div>

      <!-- 바 비교 -->
      <div class="rddc-bar-section">
        <div class="rddc-bar-row">
          <span class="rddc-bar-label">DB형</span>
          <div class="rddc-bar-track">
            <div class="rddc-bar rddc-bar--db" id="rddc-bar-db" style="width:50%"></div>
          </div>
          <span class="rddc-bar-value" id="rddc-bar-db-val">—</span>
        </div>
        <div class="rddc-bar-row">
          <span class="rddc-bar-label">DC형</span>
          <div class="rddc-bar-track">
            <div class="rddc-bar rddc-bar--dc" id="rddc-bar-dc" style="width:50%"></div>
          </div>
          <span class="rddc-bar-value" id="rddc-bar-dc-val">—</span>
        </div>
      </div>

      <!-- 이유 -->
      <div class="rddc-reason" id="rddc-reason"></div>
    </section>

    <!-- 수익률별 시나리오 표 -->
    <section class="rddc-scenario-section content-section">
      <h2 class="rddc-section-title">
        DC 운용 수익률별 퇴직금 비교
        <span class="rddc-scenario-meta" id="rddc-scenario-meta"></span>
      </h2>
      <div class="rddc-table-wrap">
        <table class="rddc-table">
          <thead>
            <tr>
              <th>DC 운용 전략</th>
              <th>수익률</th>
              <th>DC 예상 퇴직금</th>
              <th>DB 대비</th>
              <th>결과</th>
            </tr>
          </thead>
          <tbody id="rddc-scenario-tbody">
            {DC_SCENARIOS.map(s => {
              const dc = calcDcRetirement(defaultSalary, defaultYears, defaultGrowth, s.dcReturnRate);
              const diff = dc - defaultDb;
              const win = diff > 0 ? "DC 유리" : "DB 유리";
              return (
                <tr>
                  <td><strong>{s.label}</strong><br/><span class="rddc-cell-sub">{s.description}</span></td>
                  <td style={`color:${s.color};font-weight:700`}>{s.dcReturnRate}%</td>
                  <td><strong>{fmtManwon(dc)}만</strong></td>
                  <td class={diff > 0 ? "rddc-cell--pos" : "rddc-cell--neg"}>
                    {diff > 0 ? "+" : ""}{fmtManwon(diff)}만
                  </td>
                  <td>
                    <span class={`rddc-result-badge rddc-result-badge--${diff > 0 ? "dc" : "db"}`}>
                      {win}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <p class="rddc-table-note">※ 연봉 {fmtManwon(defaultSalary)}만원, 근속 {defaultYears}년, 연봉 인상률 {defaultGrowth}% 기준. 입력 변경 시 자동 업데이트.</p>
    </section>

    <!-- DC형 ETF 활용 가이드 -->
    <section class="rddc-guide content-section">
      <h2 class="rddc-section-title">DC형 전환 후 ETF 투자 가이드</h2>
      <div class="rddc-guide-grid">
        <div class="rddc-guide-card">
          <p class="rddc-guide-card__icon">📋</p>
          <h3 class="rddc-guide-card__title">편입 가능한 ETF</h3>
          <ul class="rddc-guide-card__list">
            <li>TIGER 미국S&P500</li>
            <li>TIGER 미국나스닥100</li>
            <li>KODEX 미국S&P500</li>
            <li>국내 배당·채권 ETF</li>
          </ul>
          <p class="rddc-guide-card__note">레버리지·인버스 ETF는 편입 불가</p>
        </div>
        <div class="rddc-guide-card">
          <p class="rddc-guide-card__icon">⚠️</p>
          <h3 class="rddc-guide-card__title">주의사항</h3>
          <ul class="rddc-guide-card__list">
            <li>DC → DB 재전환 불가 (일반적)</li>
            <li>투자 손실 시 퇴직금 감소</li>
            <li>본인이 직접 리밸런싱 필요</li>
            <li>연금저축·IRP와 별도 계좌</li>
          </ul>
        </div>
        <div class="rddc-guide-card">
          <p class="rddc-guide-card__icon">✅</p>
          <h3 class="rddc-guide-card__title">DC 전환 권장 케이스</h3>
          <ul class="rddc-guide-card__list">
            <li>이직 계획 있는 직장인</li>
            <li>임금 피크제 적용 예정</li>
            <li>장기 ETF 투자에 관심</li>
            <li>연봉 인상률이 낮은 경우</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="rddc-faq content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">자주 묻는 질문</p>
        <h2>DB·DC 퇴직연금 전환 FAQ</h2>
      </div>
      <div class="rddc-faq-list" itemscope itemtype="https://schema.org/FAQPage">
        {FAQ.map(item => (
          <div class="rddc-faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <button class="rddc-faq-q" itemprop="name" aria-expanded="false">
              {item.q}<span class="rddc-faq-icon">▼</span>
            </button>
            <div class="rddc-faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer" hidden>
              <p itemprop="text">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 관련 계산기 -->
    <section class="rddc-related content-section">
      <div class="section-header--compact">
        <p class="section-header__eyebrow">연결된 계산기</p>
        <h2>DC형 전환 후 이 계산기도 활용해보세요</h2>
      </div>
      <div class="ts-link-grid">
        <a class="ts-link-card" href={withBase("/tools/monthly-dividend-etf-calculator/")}>
          <span class="ts-link-card__eyebrow">투자 계산기</span>
          <strong>월배당 ETF 배당금 계산기</strong>
          <p>DC형으로 ETF 투자 시 월 배당금 시뮬레이션.</p>
        </a>
        <a class="ts-link-card" href={withBase("/tools/retirement/")}>
          <span class="ts-link-card__eyebrow">퇴직금 계산기</span>
          <strong>퇴직금 계산기</strong>
          <p>평균임금 기준 퇴직금 세후 실수령 계산.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/retirement-pension-dc-db-irp-2026/")}>
          <span class="ts-link-card__eyebrow">리포트</span>
          <strong>퇴직연금 DC·DB·IRP 비교 2026</strong>
          <p>세 가지 유형 완전 비교 리포트.</p>
        </a>
        <a class="ts-link-card" href={withBase("/reports/retirement-pension-db-to-dc-peak-wage-2026/")}>
          <span class="ts-link-card__eyebrow">전환 가이드</span>
          <strong>임금피크제 전 DB에서 DC로 바꿔야 할까</strong>
          <p>급여가 낮아지기 전 전환 시점과 체크리스트를 함께 확인하세요.</p>
        </a>
        <a class="ts-link-card" href={withBase("/tools/dca-investment-calculator/")}>
          <span class="ts-link-card__eyebrow">적립식 투자</span>
          <strong>적립식 투자 수익 계산기</strong>
          <p>DC형 매월 납입 시 장기 수익 시뮬레이션.</p>
        </a>
      </div>
    </section>

    <SeoContent
      introTitle="퇴직연금 DB형 DC형 전환 계산기 — 비교계산소"
      intro={[
        "DB형(확정급여형)은 퇴직 직전 임금을 기준으로 퇴직금이 결정되어 연봉이 꾸준히 오르는 장기 근속자에게 유리합니다. 반면 DC형(확정기여형)은 매년 연봉의 1/12이 내 계좌에 납입되고 ETF 등으로 직접 운용하므로 운용 수익률이 높을수록 유리합니다.",
        "최근 S&P500·나스닥100 ETF의 장기 수익률이 연봉 인상률을 크게 웃돌면서 DC형으로 전환하는 직장인이 늘고 있습니다. 특히 임금 피크제 적용 예정자, 이직 계획이 있는 직장인은 DC 전환을 적극 검토해볼 만합니다.",
        "단, DC형 전환 후 DB형으로 재전환은 일반적으로 불가능합니다. 충분한 시뮬레이션과 장기 계획을 세운 후 결정하세요.",
      ]}
      criteria={[
        "DB형: 퇴직 직전 3개월 평균임금 × 근속연수 간이 계산",
        "DC형: 매년 연봉/12 납입 + 복리 운용 수익 시뮬레이션",
        "이 계산기는 참고용이며 실제 퇴직금은 회사 규정에 따라 다를 수 있음",
        "ETF 수익률은 과거 실적 기반 추정치 — 미래 수익 보장 없음",
      ]}
      faq={FAQ.map(f => ({ question: f.q, answer: f.a }))}
      related={[
        { href: "/tools/monthly-dividend-etf-calculator/", label: "월배당 ETF 배당금 계산기" },
        { href: "/tools/retirement/",                       label: "퇴직금 계산기" },
        { href: "/reports/retirement-pension-dc-db-irp-2026/", label: "퇴직연금 DC·DB·IRP 비교 2026" },
        { href: "/reports/retirement-pension-db-to-dc-peak-wage-2026/", label: "임금피크제 전 DB에서 DC로 바꿔야 할까" },
      ]}
    />

  </main>

  <script define:vars={{ dcScenarios: DC_SCENARIOS, salaryGrowthPresets: SALARY_GROWTH_PRESETS }}>
    window.RDDC_DC_SCENARIOS = dcScenarios;
    window.RDDC_SALARY_GROWTH_PRESETS = salaryGrowthPresets;
  </script>
  <script src={withBase("scripts/retirement-dc-db-calculator.js")} defer></script>
</BaseLayout>
