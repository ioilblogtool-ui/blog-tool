---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import SummaryCards from "../../components/SummaryCards.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import { companyConfigs, growthModeOptions, rankOptions, scenarioOptions } from "../../data/bonusSimulator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const initialCompany = companyConfigs[0];
---

<BaseLayout
  title="대기업 성과급 시뮬레이터 | 삼성전자·SK하이닉스·현대차 비교"
  description="삼성전자, SK하이닉스, 현대자동차의 직급별 성과급과 2026~2028 총보상 시나리오를 빠르게 비교하는 정적 계산기"
>
  <SiteHeader />

  <main class="container page-shell calculator-page bonus-dashboard-page bonus-page" data-calculator="bonus-simulator">
    <CalculatorHero
      eyebrow="보상 비교"
      title="대기업 성과급 시뮬레이터"
      description="삼성전자, SK하이닉스, 현대자동차의 직급별 보상 감각을 빠르게 비교하고 2026~2028 총보상 흐름을 확인해보세요."
    />

    <ToolActionBar resetId="resetBonusBtn" copyId="copyBonusLinkBtn" />

    <section class="bonus-dashboard-layout bonus-dashboard-layout--result-first">
      <aside class="bonus-dashboard-layout__aside" id="bonus-inputs">
        <article class="panel bonus-input-panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">입력</p>
              <h2 class="panel__title">핵심 조건 먼저 입력</h2>
            </div>
            <p class="panel-heading__summary">회사, 직급, 연봉만 먼저 잡고 올해 총보상과 3사 비교를 바로 확인한 뒤 필요하면 상세 옵션을 여세요.</p>
          </div>

          <div class="form-cluster">
            <div class="form-cluster__header">
              <strong>빠른 설정</strong>
              <span>검색 유입 사용자도 이 5개만 먼저 보도록 구성합니다.</span>
            </div>
            <div class="form-grid form-grid--compact">
              <label class="field">
                <span>회사</span>
                <select id="companySelect">
                  {
                    companyConfigs.map((company) => (
                      <option value={company.companyCode}>{company.companyName}</option>
                    ))
                  }
                </select>
              </label>

              <label class="field">
                <span>직급</span>
                <select id="rankSelect">
                  {
                    rankOptions.map((rank) => (
                      <option value={rank.code} selected={rank.code === initialCompany.defaultRank}>{rank.label}</option>
                    ))
                  }
                </select>
              </label>

              <label class="field">
                <span>추천 연봉</span>
                <input id="annualSalaryInput" type="number" value={initialCompany.baseSalaryByRank[initialCompany.defaultRank]} />
                <small id="annualSalaryHint"></small>
              </label>

              <label class="field">
                <span>시나리오</span>
                <select id="scenarioSelect">
                  {
                    scenarioOptions.map((scenario) => (
                      <option value={scenario.code} selected={scenario.code === "BASE"}>{scenario.label}</option>
                    ))
                  }
                </select>
                <small id="scenarioHint">최근 공개 흐름의 평균적 가정</small>
              </label>

              <label class="field field-span-full">
                <span id="presetHeading">{initialCompany.presetHeading}</span>
                <select id="presetSelect"></select>
                <small id="presetHint"></small>
              </label>
            </div>
          </div>

          <details class="detail-box detail-box--soft">
            <summary>고급 설정 열기</summary>
            <div class="detail-box__content detail-box__content--tight">
              <div class="form-cluster form-cluster--nested">
                <div class="form-cluster__header">
                  <strong>세부 가정</strong>
                  <span>통상임금, 3개년 성장 기대, 현대차 주식 포함 여부를 더 조정할 수 있습니다.</span>
                </div>
                <div class="form-grid form-grid--compact">
                  <label class="field">
                    <span>월 기준급/통상임금</span>
                    <input id="monthlyBaseInput" type="number" value="0" />
                    <small id="monthlyBaseHint"></small>
                  </label>

                  <label class="field">
                    <span>2026~2028 성장 기대</span>
                    <select id="growthModeSelect">
                      {
                        growthModeOptions.map((mode) => (
                          <option value={mode.code} selected={mode.code === "NORMAL"}>{mode.label}</option>
                        ))
                      }
                    </select>
                    <small id="growthModeHint">기준 시나리오에 가까운 증가</small>
                  </label>

                  <label class="check-field check-field--vertical field-span-full">
                    <input id="includeStockToggle" type="checkbox" />
                    <span>현대차 주식 포함 총보상 보기</span>
                    <small>현대차 선택 시 참고용 주식 가치를 합산합니다.</small>
                  </label>
                </div>
              </div>
            </div>
          </details>

          <button id="calcBonusBtn" class="button button--primary" type="button">올해 보상 먼저 보기</button>
        </article>
      </aside>

      <div class="bonus-dashboard-layout__main">
        <article class="panel result-priority-panel" id="bonus-results">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">결과 먼저 보기</p>
              <h2 class="panel__title">회사·직급·연봉만 입력해도 바로 읽히는 결과</h2>
            </div>
            <p class="panel-heading__summary">모바일에서는 올해 총보상, 3년 누적 흐름, 같은 직급 기준 3사 비교를 먼저 보여주고 세부 항목은 아래에서 이어서 펼쳐보게 했습니다.</p>
          </div>
          <div class="result-priority-panel__actions">
            <a class="button button--secondary" href="#bonus-inputs">조건 다시 입력</a>
            <a class="button button--ghost" href="#bonus-details">세부 항목 보기</a>
          </div>
        </article>

        <section class="bonus-primary-strip content-section">
          <SummaryCards
            columns={4}
            items={[
              { label: "2026 예상 성과급", id: "bonusSummary" },
              { label: "2026 예상 총보상", id: "totalCompSummary" },
              { label: "2026~2028 누적 총보상", id: "threeYearSummary" },
              { label: "회사 내 체감 포지션", id: "positionSummary" }
            ]}
          />
        </section>

        <section class="bonus-main-grid content-section">
          <article class="panel bonus-overview-panel">
            <div class="panel-heading">
              <div>
                <p class="panel-heading__eyebrow">선택 회사 요약</p>
                <h2 class="panel__title">올해 총보상과 해석</h2>
              </div>
              <p class="panel-heading__summary" id="shareCopy">-</p>
            </div>
            <div class="breakdown-grid">
              <article class="breakdown-chip">
                <span>올해 예상 성과급</span>
                <strong id="bonusSummaryMirror">-</strong>
              </article>
              <article class="breakdown-chip">
                <span>올해 예상 총보상</span>
                <strong id="totalCompSummaryMirror">-</strong>
              </article>
              <article class="breakdown-chip">
                <span>3개년 누적 총보상</span>
                <strong id="threeYearSummaryMirror">-</strong>
              </article>
              <article class="breakdown-chip">
                <span>보상 포지션</span>
                <strong id="positionSummaryMirror">-</strong>
              </article>
            </div>
            <p class="insight-text" id="insightText">-</p>
          </article>

          <article class="panel bonus-company-compare-panel">
            <div class="panel-heading">
              <div>
                <p class="panel-heading__eyebrow">회사 비교</p>
                <h2 class="panel__title">같은 직급 기준 3사 비교</h2>
              </div>
              <p class="panel-heading__summary">추천 연봉 기준으로 올해 총보상과 3년 누적 흐름을 함께 봅니다.</p>
            </div>

            {/*
              [STEP 3] Chart.js 3사 비교 가로 바 차트 삽입 위치
              canvas id: 'bonus-compare-chart'
              높이 120px 고정 → .bonus-compare-chart-wrap { height: 120px }
              렌더링: public/scripts/bonus-simulator.js > renderCompareChart()
              색상: 삼성(teal #1D9E75) / SK하이닉스(보라 #534AB7) / 현대차(amber #BA7517)
            */}
            <div class="bonus-compare-chart-wrap">
              <canvas id="bonus-compare-chart"></canvas>
            </div>

            <div class="compare-list" id="companyCompareList"></div>
          </article>
        </section>

        <section class="bonus-projection-grid content-section">
          <article class="metric-card bonus-focus-card">
            <p>2026 예상 총보상</p>
            <strong id="year2026Total">-</strong>
            <span class="metric-sub" id="year2026Note">-</span>
          </article>
          <article class="metric-card bonus-focus-card">
            <p>2027 예상 총보상</p>
            <strong id="year2027Total">-</strong>
            <span class="metric-sub" id="year2027Note">-</span>
          </article>
          <article class="metric-card bonus-focus-card">
            <p>2028 예상 총보상</p>
            <strong id="year2028Total">-</strong>
            <span class="metric-sub" id="year2028Note">-</span>
          </article>
        </section>

        <details class="detail-box detail-box--soft detail-box--inline" id="bonus-details">
          <summary>시나리오·세부 항목 이어서 보기</summary>
          <div class="detail-box__content detail-box__content--tight">
            <section class="bonus-secondary-grid content-section">
              <article class="panel scenario-panel">
                <div class="panel-heading">
                  <div>
                    <p class="panel-heading__eyebrow">시나리오 비교</p>
                    <h2 class="panel__title">보수적 · 기준 · 공격적 비교</h2>
                  </div>
                  <p class="panel-heading__summary">같은 회사, 같은 직급에서 업황 가정만 바꿨을 때의 차이입니다.</p>
                </div>
                <div class="scenario-grid">
                  <article class="scenario-card" data-scenario-card="CONSERVATIVE">
                    <p class="scenario-card__label">보수적</p>
                    <strong id="scenarioBonusConservative">-</strong>
                    <span id="scenarioTotalConservative">-</span>
                  </article>
                  <article class="scenario-card" data-scenario-card="BASE">
                    <p class="scenario-card__label">기준</p>
                    <strong id="scenarioBonusBase">-</strong>
                    <span id="scenarioTotalBase">-</span>
                  </article>
                  <article class="scenario-card" data-scenario-card="AGGRESSIVE">
                    <p class="scenario-card__label">공격적</p>
                    <strong id="scenarioBonusAggressive">-</strong>
                    <span id="scenarioTotalAggressive">-</span>
                  </article>
                </div>
              </article>

              <article class="panel bonus-breakdown-panel">
                <div class="panel-heading">
                  <div>
                    <p class="panel-heading__eyebrow">성과급 분해</p>
                    <h2 class="panel__title">보상 구조 세부 항목</h2>
                  </div>
                  <p class="panel-heading__summary" id="companyTagline">-</p>
                </div>
                <div class="breakdown-grid">
                  <article class="breakdown-chip">
                    <span id="payoutLabel1">항목 1</span>
                    <strong id="payoutValue1">-</strong>
                  </article>
                  <article class="breakdown-chip">
                    <span id="payoutLabel2">항목 2</span>
                    <strong id="payoutValue2">-</strong>
                  </article>
                  <article class="breakdown-chip">
                    <span>기본 연봉</span>
                    <strong id="baseAnnualValue">-</strong>
                  </article>
                  <article class="breakdown-chip">
                    <span>주식/기타 보상</span>
                    <strong id="extrasValue">-</strong>
                  </article>
                </div>
              </article>
            </section>

            <section class="bonus-detail-grid content-section">
              <details class="detail-box detail-box--soft bonus-detail-box" open>
                <summary>세부 표 보기</summary>
                <div class="detail-box__content detail-box__content--tight">
                  <div class="table-wrap">
                    <table class="result-table">
                      <thead>
                        <tr>
                          <th>항목</th>
                          <th>값</th>
                        </tr>
                      </thead>
                      <tbody id="bonusBreakdownTable"></tbody>
                    </table>
                  </div>
                </div>
              </details>

              <div class="compare-tool-card-stack">
                <InfoNotice
                  title="안내"
                  lines={[
                    "공개 자료와 보도 내용을 바탕으로 단순화한 시뮬레이션입니다.",
                    "실제 지급액은 사업부, 평가, 재직기간, 노사합의, 연도별 정책에 따라 달라질 수 있습니다.",
                    "2027~2028 값은 예측이 아니라 가정 기반 시나리오입니다."
                  ]}
                />

                <details class="detail-box detail-box--soft bonus-notes-box">
                  <summary>기준값 메모 보기</summary>
                  <div class="detail-box__content">
                    <div class="note-stack note-stack--compact">
                      <p class="note-chip">삼성전자: 2026년 1월 16일 기준 2025년분 OPI가 사업부별로 11%~50% 수준까지 공지된 보도 흐름을 반영했습니다.</p>
                      <p class="note-chip">SK하이닉스: 2026년 1월 28일 FY2025 매출 97.1467조 원, 영업이익 47.2063조 원과 2026년 2월 PS 2964% 사례를 기준점으로 잡았습니다.</p>
                      <p class="note-chip">현대자동차: 2025년 9월 9일 잠정합의안 기준 성과금 450% + 1,580만 원, 주식 30주, 상품권 20만 원 패키지를 반영했습니다.</p>
                    </div>
                  </div>
                </details>

                <article class="panel bonus-source-panel">
                  <div class="panel-heading">
                    <div>
                      <p class="panel-heading__eyebrow">회사 메모</p>
                      <h2 class="panel__title">공개 자료 기반 해석</h2>
                    </div>
                  </div>
                  <div class="note-stack" id="companyNotes"></div>
                </article>
              </div>
            </section>
          </div>
        </details>
      </div>
    </section>

    <SeoContent
      introTitle="대기업 성과급 시뮬레이터를 보는 관점"
      intro={[
        "대기업 성과급 시뮬레이터는 삼성전자, SK하이닉스, 현대자동차의 직급별 성과급 구조를 단순화해서 올해 예상 성과급과 2026~2028 총보상 흐름을 비교하는 페이지입니다. 취업 준비, 이직 고민, 같은 직급 비교처럼 보상 감각이 궁금할 때 빠르게 돌려보는 용도로 설계했습니다.",
        "실제 회사 제도는 사업부, 평가, 업황, 노사합의에 따라 달라지기 때문에 이 페이지는 공개 자료 기반의 시나리오형 비교 도구로 보는 것이 맞습니다. 핵심은 정확한 지급명세서가 아니라 회사별 보상 성격을 직관적으로 파악하는 데 있습니다."
      ]}
      inputPoints={[
        "회사, 직급, 연봉, 시나리오만으로 올해 성과급과 총보상을 빠르게 비교할 수 있습니다.",
        "2026~2028 3개년 흐름과 누적 총보상까지 함께 볼 수 있습니다.",
        "같은 직급 기준 3사 비교로 어느 회사가 업황 민감도가 큰지 감각적으로 확인할 수 있습니다."
      ]}
      criteria={[
        "삼성전자는 TAI와 OPI, SK하이닉스는 PI와 PS, 현대차는 패키지형 보상 구조를 단순화해 반영했습니다.",
        "2027~2028 값은 예측이 아니라 시나리오 기반 가정값입니다.",
        "실제 지급액은 사업부, 평가, 재직기간, 연도별 정책에 따라 달라질 수 있습니다."
      ]}
      faq={[
        { question: "이 계산기는 실제 회사 성과급을 정확히 맞추나요?", answer: "아니요. 공개 자료와 보도 내용을 바탕으로 단순화한 시뮬레이션입니다. 실제 지급액은 회사 내부 정책과 개인 조건에 따라 달라집니다." },
        { question: "왜 3개년 예상 기능이 있나요?", answer: "사용자가 궁금한 것은 단순히 올해 한 번의 성과급이 아니라 업황이 좋거나 나쁠 때 총보상이 얼마나 달라지는지이기 때문입니다." },
        { question: "어느 회사가 가장 유리한지 판단할 수 있나요?", answer: "가능하지만 정답처럼 보기보다는 보상 구조의 성격 차이를 보는 용도로 활용하는 것이 좋습니다. 안정성, 업황 민감도, 패키지 보상 구조가 서로 다릅니다." }
      ]}
      related={[
        { href: "/tools/salary/", label: "연봉 인상 계산기" },
        { href: "/tools/negotiation/", label: "이직 계산기" },
        { href: "/tools/retirement/", label: "퇴직금 계산기" }
      ]}
    />
  </main>

  <script id="bonusSimulatorConfig" type="application/json" set:html={JSON.stringify({ companyConfigs, rankOptions, scenarioOptions, growthModeOptions })}></script>
  <!-- Chart.js UMD: window.Chart 으로 노출 → bonus-simulator.js 보다 먼저 로드 -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/bonus-simulator.js")}></script>
</BaseLayout>
