---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  FOUR_INSURANCE_CONFIG,
  FOUR_INSURANCE_DEFAULT_INPUT,
  FOUR_INSURANCE_FAQ,
  FOUR_INSURANCE_GUIDES,
  FOUR_INSURANCE_PRESETS,
  FOUR_INSURANCE_RELATED,
} from "../../data/fourInsuranceCalculator";

const site = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const faqSchema = FOUR_INSURANCE_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: {
    "@type": "Answer",
    text: item.answer,
  },
}));

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: "4대보험 계산기 2026",
      applicationCategory: "FinanceApplication",
      operatingSystem: "All",
      inLanguage: "ko-KR",
      isAccessibleForFree: true,
      url: `${site}/tools/four-insurance-calculator/`,
      description: "월급과 비과세 금액을 입력해 2026년 기준 4대보험 공제액과 예상 실수령액을 계산합니다.",
      provider: { "@type": "Organization", name: "비교계산소" },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "홈", item: `${site}/` },
        { "@type": "ListItem", position: 2, name: "계산기", item: `${site}/tools/` },
        { "@type": "ListItem", position: 3, name: "4대보험 계산기 2026", item: `${site}/tools/four-insurance-calculator/` },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  ],
};
---

<BaseLayout
  title="4대보험 계산기 2026 | 월급 국민연금·건강보험·고용보험 공제액"
  description="월급과 비과세 금액을 입력해 2026년 기준 국민연금, 건강보험, 장기요양보험, 고용보험 공제액과 예상 실수령액을 계산합니다."
  jsonLd={jsonLd}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="four-insurance-calculator" pageClass="fic-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="급여 공제 계산"
        title="4대보험 계산기 2026"
        description="월급과 비과세 금액을 입력하면 국민연금, 건강보험, 장기요양보험, 고용보험, 간이 세금과 예상 실수령액을 한 번에 계산합니다."
      />
      <InfoNotice
        title="계산 기준 안내"
        lines={[
          "4대보험은 2026년 공개 요율 기준 모의 계산입니다.",
          "소득세는 급여명세서 이해를 돕기 위한 간이 추정이며 실제 원천징수액과 다를 수 있습니다.",
          "산재보험은 근로자 부담 공제 항목이 아니므로 실수령액 차감액에 포함하지 않습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetFicBtn" copyId="copyFicLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">월급 정보 입력</h2>
          </div>
          <p class="panel-heading__summary">월 급여와 비과세 금액만 넣어도 4대보험 공제액을 바로 볼 수 있습니다.</p>
        </div>

        <div class="fic-preset-grid">
          {FOUR_INSURANCE_PRESETS.map((preset) => (
            <button class="fic-preset-btn" type="button">{preset.label}</button>
          ))}
        </div>

        <div class="form-grid form-grid--compact">
          <label class="field field-span-full">
            <span>월 급여</span>
            <input id="ficMonthlySalary" type="number" min="0" step="10000" value={FOUR_INSURANCE_DEFAULT_INPUT.monthlySalary} />
            <small>세전 월급 기준입니다. 성과급은 별도 지급월에는 실제 공제액이 달라질 수 있습니다.</small>
          </label>

          <label class="field">
            <span>비과세 금액</span>
            <input id="ficTaxFreeAmount" type="number" min="0" step="10000" value={FOUR_INSURANCE_DEFAULT_INPUT.taxFreeAmount} />
            <small>예: 식대 20만원</small>
          </label>

          <label class="field">
            <span>부양가족 수</span>
            <input id="ficDependents" type="number" min="1" max="11" step="1" value={FOUR_INSURANCE_DEFAULT_INPUT.dependents} />
          </label>

          <label class="field">
            <span>20세 이하 자녀 수</span>
            <input id="ficChildrenUnder20" type="number" min="0" max="8" step="1" value={FOUR_INSURANCE_DEFAULT_INPUT.childrenUnder20} />
          </label>

          <label class="check-field field-span-full">
            <input id="ficApplyNationalPension" type="checkbox" checked={FOUR_INSURANCE_DEFAULT_INPUT.applyNationalPension} />
            <span>국민연금 적용</span>
          </label>

          <label class="check-field field-span-full">
            <input id="ficApplyEmploymentInsurance" type="checkbox" checked={FOUR_INSURANCE_DEFAULT_INPUT.applyEmploymentInsurance} />
            <span>고용보험 적용</span>
          </label>

          <label class="check-field field-span-full">
            <input id="ficShowEmployerShare" type="checkbox" checked={FOUR_INSURANCE_DEFAULT_INPUT.showEmployerShare} />
            <span>회사 부담 참고액 표시</span>
          </label>
        </div>
      </article>
    </Fragment>

    <section class="content-section content-section--tight">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">핵심 결과</p>
        <h2>월급에서 빠지는 금액을 먼저 봅니다</h2>
        <p id="ficSummaryText">입력값을 기준으로 예상 공제액을 계산합니다.</p>
      </div>

      <div class="fic-kpi-grid">
        <article class="fic-kpi-card fic-kpi-card--main">
          <p>예상 실수령액</p>
          <strong id="ficNetPay">-</strong>
          <span>총 공제 후 월 수령 추정</span>
        </article>
        <article class="fic-kpi-card">
          <p>4대보험 합계</p>
          <strong id="ficTotalInsurance">-</strong>
          <span>근로자 부담 기준</span>
        </article>
        <article class="fic-kpi-card">
          <p>간이 세금 합계</p>
          <strong id="ficTaxTotal">-</strong>
          <span>소득세 + 지방소득세</span>
        </article>
        <article class="fic-kpi-card">
          <p>총 공제액</p>
          <strong id="ficTotalDeduction">-</strong>
          <span>보험료 + 세금</span>
        </article>
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">상세 공제</p>
        <h2>공제 항목별 금액</h2>
      </div>

      <div class="fic-detail-grid">
        <article class="fic-detail-card">
          <p>과세 기준 월급</p>
          <strong id="ficTaxablePay">-</strong>
        </article>
        <article class="fic-detail-card">
          <p>국민연금</p>
          <strong id="ficNationalPension">-</strong>
        </article>
        <article class="fic-detail-card">
          <p>건강보험</p>
          <strong id="ficHealthInsurance">-</strong>
        </article>
        <article class="fic-detail-card">
          <p>장기요양보험</p>
          <strong id="ficLongTermCare">-</strong>
        </article>
        <article class="fic-detail-card">
          <p>고용보험</p>
          <strong id="ficEmploymentInsurance">-</strong>
        </article>
        <article class="fic-detail-card">
          <p>회사 부담 참고액</p>
          <strong id="ficEmployerShare">-</strong>
        </article>
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">급여명세서 표</p>
        <h2>공제 항목별 계산 기준</h2>
      </div>
      <div class="fic-table-wrap">
        <table class="fic-table">
          <thead>
            <tr>
              <th>항목</th>
              <th>예상 금액</th>
              <th>계산 기준</th>
            </tr>
          </thead>
          <tbody id="ficBreakdownBody"></tbody>
        </table>
      </div>
    </section>

    <section class="content-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">해석 가이드</p>
        <h2>이 결과를 읽는 방법</h2>
      </div>
      <div class="fic-guide-grid">
        {FOUR_INSURANCE_GUIDES.map((item) => (
          <article class="fic-guide-card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="content-section fic-report-cta">
      <div>
        <p class="fic-eyebrow">요율표와 함께 보기</p>
        <h2>2026 직장인 세금·4대보험 요율표</h2>
        <p>급여명세서 공제 항목이 왜 이렇게 계산되는지 리포트에서 표와 예시로 다시 확인할 수 있습니다.</p>
      </div>
      <a class="button button--secondary" href={withBase("/reports/employee-tax-insurance-rates-2026/")}>요율표 리포트 보기</a>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="4대보험 계산기 2026 사용법"
        intro={[
          "4대보험 계산기는 월급에서 빠지는 국민연금, 건강보험, 장기요양보험, 고용보험을 먼저 계산하고, 급여명세서 이해를 돕기 위해 근로소득세와 지방소득세를 간이 추정합니다.",
          "2026년에는 국민연금 보험료율 단계 인상과 건강보험료율 변화가 실수령액에 영향을 줄 수 있습니다. 월급이 같아도 비과세 금액과 부양가족 수에 따라 세금 추정액은 달라집니다.",
          "산재보험은 회사 부담이므로 예상 실수령액 차감 항목에는 넣지 않았습니다. 회사 부담 참고액은 인건비 구조를 이해하기 위한 보조 정보로만 확인하면 됩니다.",
        ]}
        inputPoints={[
          "월 급여와 비과세 금액을 입력하면 근로자 부담 4대보험을 계산합니다.",
          "부양가족 수와 자녀 수를 반영해 소득세를 간이 추정합니다.",
          "회사 부담 참고액을 켜면 근로자 부담과 회사 부담을 같이 볼 수 있습니다.",
        ]}
        criteria={[
          "국민연금은 기준소득월액 상한·하한을 적용합니다.",
          "장기요양보험은 건강보험료에 13.14%를 곱해 계산합니다.",
          "소득세는 실제 국세청 간이세액표 원천징수액과 다를 수 있는 추정값입니다.",
        ]}
        faq={FOUR_INSURANCE_FAQ}
        related={FOUR_INSURANCE_RELATED}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="ficConfig" type="application/json" set:html={JSON.stringify(FOUR_INSURANCE_CONFIG)} />
  <script src={withBase("/scripts/four-insurance-calculator.js")} defer></script>
</BaseLayout>

