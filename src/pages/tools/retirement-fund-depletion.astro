---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import SeoContent from "../../components/SeoContent.astro";
import {
  RFD_ASSET_PRESETS,
  RFD_DEFAULT_INPUT,
  RFD_FAQ,
  RFD_GUIDE_POINTS,
  RFD_LIFE_EXPECTANCY_PRESETS,
  RFD_LIVING_COST_PRESETS,
  RFD_OTHER_INCOME_PRESETS,
  RFD_PENSION_PRESETS,
  RFD_PRESETS,
  RFD_RATE_PRESETS,
  RFD_RELATED_LINKS,
  RFD_RULES,
  RFD_SCENARIOS,
} from "../../data/retirementFundDepletion";

const config = {
  defaults: RFD_DEFAULT_INPUT,
  rules: RFD_RULES,
  presets: RFD_PRESETS,
  scenarios: RFD_SCENARIOS,
};

const faqSchema = RFD_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: {
    "@type": "Answer",
    text: item.answer,
  },
}));
---

<BaseLayout
  title="노후 자금 고갈 계산기 | 은퇴 준비 자금·부족 금액·고갈 시점 계산"
  description="현재 나이, 은퇴 나이, 생활비, 자산, 국민연금, 수익률을 입력하면 노후 필요 자산과 부족 금액, 월 추가 적립액, 자산 고갈 예상 시점을 계산합니다."
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "노후 자금 고갈 계산기",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description:
      "현재 자산, 생활비, 국민연금, 물가상승률, 운용수익률을 기준으로 은퇴 준비 자금과 자산 고갈 시점을 추정하는 계산기",
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/retirement-fund-depletion/`,
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="retirement-fund-depletion" pageClass="rfd-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="은퇴·노후 계산기"
        title="노후 자금 고갈 시점을 지금 입력값으로 확인합니다"
        description="현재 자산, 생활비, 국민연금, 수익률을 입력하면 은퇴 시점 필요 자산과 부족 금액, 월 추가 적립액, 자산 고갈 예상 나이를 추정합니다."
      />
      <InfoNotice
        title="안내"
        lines={[
          "이 계산기는 입력값을 바탕으로 한 참고용 시뮬레이션입니다.",
          "국민연금 수령액은 사용자가 입력한 예상치이며, 실제 수령액과 다를 수 있습니다.",
          "세금, 건강보험료, 의료비, 간병비, 주거비 급변은 별도로 반영하지 않았습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetRfdBtn" copyId="copyRfdLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel rfd-panel" data-rfd-root>
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력 조건</p>
            <h2 class="panel__title">은퇴 준비 시나리오</h2>
          </div>
          <p class="panel-heading__summary">기본 시나리오를 고른 뒤 생활비, 자산, 연금액을 조정해보세요.</p>
        </div>

        <div class="rfd-preset-row" aria-label="시나리오 프리셋">
          {RFD_PRESETS.map((preset) => (
            <button class="rfd-chip" type="button" data-rfd-preset={preset.id}>{preset.label}</button>
          ))}
        </div>

        <div class="form-grid">
          <label class="field">
            <span>현재 나이</span>
            <input id="rfdCurrentAge" type="number" inputmode="numeric" min="20" max="80" value={RFD_DEFAULT_INPUT.currentAge} data-rfd-input="currentAge" />
          </label>

          <label class="field">
            <span>목표 은퇴 나이</span>
            <input id="rfdRetirementAge" type="number" inputmode="numeric" min="35" max="80" value={RFD_DEFAULT_INPUT.retirementAge} data-rfd-input="retirementAge" />
          </label>

          <label class="field field-span-full">
            <span>기대수명</span>
            <input id="rfdLifeExpectancy" type="number" inputmode="numeric" min="50" max="110" value={RFD_DEFAULT_INPUT.lifeExpectancy} data-rfd-input="lifeExpectancy" />
            <div class="rfd-chip-row">
              {RFD_LIFE_EXPECTANCY_PRESETS.map((item) => (
                <button class="rfd-mini-chip" type="button" data-rfd-set="lifeExpectancy" data-rfd-value={item.value}>{item.label}</button>
              ))}
            </div>
          </label>

          <label class="field field-span-full">
            <span>월 생활비</span>
            <input id="rfdMonthlyLivingCost" type="text" inputmode="numeric" data-currency="true" value={RFD_DEFAULT_INPUT.monthlyLivingCost} data-rfd-input="monthlyLivingCost" />
            <div class="rfd-chip-row">
              {RFD_LIVING_COST_PRESETS.map((item) => (
                <button class="rfd-mini-chip" type="button" data-rfd-set="monthlyLivingCost" data-rfd-value={item.value}>{item.label}</button>
              ))}
            </div>
          </label>

          <label class="field field-span-full">
            <span>현재 보유 자산</span>
            <input id="rfdCurrentAssets" type="text" inputmode="numeric" data-currency="true" value={RFD_DEFAULT_INPUT.currentAssets} data-rfd-input="currentAssets" />
            <div class="rfd-chip-row">
              {RFD_ASSET_PRESETS.map((item) => (
                <button class="rfd-mini-chip" type="button" data-rfd-set="currentAssets" data-rfd-value={item.value}>{item.label}</button>
              ))}
            </div>
          </label>

          <label class="field">
            <span>현재 월 적립액</span>
            <input id="rfdMonthlyContribution" type="text" inputmode="numeric" data-currency="true" value={RFD_DEFAULT_INPUT.monthlyContribution} data-rfd-input="monthlyContribution" />
          </label>

          <label class="field">
            <span>국민연금 예상 월 수령액</span>
            <input id="rfdMonthlyPension" type="text" inputmode="numeric" data-currency="true" value={RFD_DEFAULT_INPUT.monthlyPension} data-rfd-input="monthlyPension" />
            <div class="rfd-chip-row">
              {RFD_PENSION_PRESETS.map((item) => (
                <button class="rfd-mini-chip" type="button" data-rfd-set="monthlyPension" data-rfd-value={item.value}>{item.label}</button>
              ))}
            </div>
          </label>

          <label class="field">
            <span>기타 은퇴 후 월 소득</span>
            <input id="rfdOtherIncome" type="text" inputmode="numeric" data-currency="true" value={RFD_DEFAULT_INPUT.otherRetirementIncome} data-rfd-input="otherRetirementIncome" />
            <div class="rfd-chip-row">
              {RFD_OTHER_INCOME_PRESETS.map((item) => (
                <button class="rfd-mini-chip" type="button" data-rfd-set="otherRetirementIncome" data-rfd-value={item.value}>{item.label}</button>
              ))}
            </div>
          </label>

          <label class="field">
            <span>예상 물가상승률</span>
            <input id="rfdInflationRate" type="number" inputmode="decimal" min="0" max="10" step="0.1" value={RFD_DEFAULT_INPUT.inflationRate * 100} data-rfd-input="inflationRate" />
            <div class="rfd-chip-row">
              {RFD_RATE_PRESETS.inflation.map((item) => (
                <button class="rfd-mini-chip" type="button" data-rfd-rate="inflationRate" data-rfd-value={item.value}>{item.label}</button>
              ))}
            </div>
          </label>

          <label class="field">
            <span>예상 운용수익률</span>
            <input id="rfdAnnualReturnRate" type="number" inputmode="decimal" min="-10" max="15" step="0.1" value={RFD_DEFAULT_INPUT.annualReturnRate * 100} data-rfd-input="annualReturnRate" />
            <div class="rfd-chip-row">
              {RFD_RATE_PRESETS.returns.map((item) => (
                <button class="rfd-mini-chip" type="button" data-rfd-rate="annualReturnRate" data-rfd-value={item.value}>{item.label}</button>
              ))}
            </div>
          </label>
        </div>
      </article>
    </Fragment>

    <section class="rfd-section" aria-live="polite">
      <div class="rfd-section__head">
        <p class="rfd-section__eyebrow">핵심 결과</p>
        <h2>현재 계획 기준 노후 자금이 언제까지 버티는지 봅니다</h2>
        <p class="rfd-section__sub" id="rfdSummaryMessage">입력값 기준 시뮬레이션 결과가 여기에 표시됩니다.</p>
      </div>

      <div class="rfd-status-line">
        <span class="rfd-status-badge" id="rfdStatusBadge">시뮬레이션</span>
        <span id="rfdStatusDetail">물가상승률과 운용수익률을 함께 반영합니다.</span>
      </div>

      <div class="rfd-kpi-grid">
        <article class="rfd-kpi-card rfd-kpi-card--main">
          <p>자산 고갈 예상 나이</p>
          <strong id="rfdDepletionAge">-</strong>
          <span>시뮬레이션</span>
        </article>
        <article class="rfd-kpi-card">
          <p>은퇴 시점 필요 자산</p>
          <strong id="rfdRequiredAssets">-</strong>
          <span>추정</span>
        </article>
        <article class="rfd-kpi-card">
          <p>은퇴 시점 예상 자산</p>
          <strong id="rfdProjectedAssets">-</strong>
          <span>추정</span>
        </article>
        <article class="rfd-kpi-card">
          <p>현재 계획 기준 부족 금액</p>
          <strong id="rfdShortfall">-</strong>
          <span>추정</span>
        </article>
        <article class="rfd-kpi-card">
          <p>월 추가 적립 필요액</p>
          <strong id="rfdAdditionalMonthly">-</strong>
          <span>추정</span>
        </article>
      </div>
    </section>

    <section class="rfd-section">
      <div class="rfd-section__head">
        <p class="rfd-section__eyebrow">잔액 추이</p>
        <h2>은퇴 후 자산 잔액이 어떻게 줄어드는지 확인합니다</h2>
        <p class="rfd-section__sub">차트가 표시되지 않아도 위 핵심 결과와 아래 시나리오 표는 그대로 확인할 수 있습니다.</p>
      </div>
      <div class="rfd-chart-panel">
        <div class="rfd-chart-wrap">
          <canvas id="rfdBalanceChart" aria-label="은퇴 후 자산 잔액 추이 차트"></canvas>
        </div>
        <p class="rfd-chart-note">입력값 기준 시뮬레이션 · 실제 투자 성과와 지출은 달라질 수 있습니다.</p>
      </div>
    </section>

    <section class="rfd-section">
      <div class="rfd-section__head">
        <p class="rfd-section__eyebrow">시나리오 비교</p>
        <h2>낙관·기본·보수 조건을 함께 비교합니다</h2>
      </div>
      <div class="rfd-table-wrap">
        <table class="rfd-table">
          <thead>
            <tr>
              <th scope="col">시나리오</th>
              <th scope="col">고갈 예상</th>
              <th scope="col">부족 금액</th>
              <th scope="col">월 추가 적립</th>
            </tr>
          </thead>
          <tbody id="rfdScenarioBody"></tbody>
        </table>
      </div>
    </section>

    <section class="rfd-section">
      <div class="rfd-section__head">
        <p class="rfd-section__eyebrow">조정 효과</p>
        <h2>월 적립액, 은퇴 나이, 생활비를 바꾸면 결과가 어떻게 달라질까요?</h2>
      </div>
      <div class="rfd-sensitivity-grid" id="rfdSensitivityGrid"></div>
    </section>

    <section class="rfd-section">
      <div class="rfd-section__head">
        <p class="rfd-section__eyebrow">관련 계산기</p>
        <h2>부족 금액을 줄이는 다음 입력값을 확인하세요</h2>
      </div>
      <div class="rfd-link-grid">
        {RFD_RELATED_LINKS.slice(0, 3).map((item) => (
          <a class="rfd-link-card" href={item.href}>
            <strong>{item.label}</strong>
            <span>새 입력값으로 노후 현금흐름을 다시 점검하기</span>
          </a>
        ))}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="노후자금은 단순히 몇 억 원으로 고정해 말하기 어렵습니다"
        intro={[
          "은퇴 후 필요한 자금은 현재 생활비, 은퇴까지 남은 기간, 국민연금, 기대수명, 물가상승률, 운용수익률에 따라 크게 달라집니다.",
          "이 계산기는 현재 가치의 월 생활비를 은퇴 시점 가치로 환산하고, 은퇴 후 매년 자산 잔액을 시뮬레이션해 자산 고갈 예상 나이와 부족 금액을 추정합니다.",
          "결과가 부족하게 나온다면 월 적립액을 늘리거나 은퇴 시점을 늦추거나, 생활비와 연금성 현금흐름을 다시 조정해 여러 번 비교해보는 방식이 적합합니다.",
        ]}
        inputPoints={[
          "현재 계획 기준 은퇴 시점 필요 자산과 예상 자산을 비교할 수 있습니다.",
          "국민연금과 기타 소득을 넣어 은퇴 후 순지출을 추정할 수 있습니다.",
          "자산 고갈 예상 나이와 월 추가 적립 필요액을 함께 확인할 수 있습니다.",
        ]}
        criteria={RFD_GUIDE_POINTS}
        faq={RFD_FAQ}
        related={RFD_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="rfdConfig" type="application/json" set:html={JSON.stringify(config)} />
  <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
  <script src="/scripts/retirement-fund-depletion.js" defer></script>
</BaseLayout>
