---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import CompareCta from "../../components/CompareCta.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import { EDTC_ETF_TYPES, EDTC_META, EDTC_FAQS } from "../../data/etfDistributionTaxCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title={EDTC_META.title}
  description={EDTC_META.description}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "ETF 분배금 세후 계산기 2026",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description: EDTC_META.description,
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/etf-distribution-tax-calculator/`,
  }}
>
  <SiteHeader />
  <script id="edtcConfig" type="application/json" set:html={JSON.stringify({ types: EDTC_ETF_TYPES })} />

  <SimpleToolShell calculatorId="etf-distribution-tax-calculator" pageClass="edtc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="ETF 분배금 세후"
        title="ETF 분배금 세후 계산기 2026"
        description="국내 ETF(15.4%), 미국 상장 ETF(15%), ISA 계좌(비과세) 조건별로 분배금 세후 실수령과 절세 효과를 비교합니다."
        stats={[
          { label: "국내 ETF 세율", value: "15.4%" },
          { label: "미국 ETF 세율", value: "15%" },
          { label: "ISA 초과분", value: "9.9%" },
        ]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          "분배금 세율은 계좌 유형과 ETF 종류에 따라 다릅니다.",
          "ISA 계좌는 국내 상장 ETF만 편입 가능합니다 (미국 상장 ETF 불가).",
          "금융소득 연 2,000만원 초과 시 종합소득세 신고 대상이 될 수 있습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="edtcResetBtn" copyId="edtcCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel edtc-input-panel" data-edtc-calculator>
        <!-- 분배금 입력 -->
        <div class="edtc-section">
          <h2 class="edtc-section-title">월 분배금 (세전)</h2>
          <div class="edtc-field">
            <div class="edtc-input-wrap">
              <input id="edtcDistribution" type="text" class="edtc-input" data-edtc-distribution value="500,000" inputmode="numeric" />
              <span class="edtc-unit">원</span>
            </div>
          </div>
        </div>

        <!-- ETF 유형 -->
        <div class="edtc-section">
          <h2 class="edtc-section-title">ETF 유형</h2>
          <div class="edtc-type-list">
            {EDTC_ETF_TYPES.map((t, i) => (
              <label class={`edtc-type-item${i === 1 ? " active" : ""}`} data-edtc-type-label={t.id}>
                <input type="radio" name="edtcType" value={t.id} data-edtc-type checked={i === 1} />
                <div class="edtc-type-info">
                  <span class="edtc-type-name">{t.label}</span>
                  <span class="edtc-type-desc">{t.desc}</span>
                  <span class="edtc-type-rate">세율 {(t.taxRate * 100).toFixed(1)}%</span>
                </div>
              </label>
            ))}
          </div>
        </div>

        <!-- ISA 비교 -->
        <div class="edtc-section">
          <h2 class="edtc-section-title">ISA 계좌 비교</h2>
          <div class="edtc-toggle-group">
            <button class="edtc-toggle active" data-edtc-isa="off">일반 계좌</button>
            <button class="edtc-toggle" data-edtc-isa="general">ISA 일반형</button>
            <button class="edtc-toggle" data-edtc-isa="seomin">ISA 서민형</button>
          </div>
          <p class="edtc-isa-note" data-edtc-isa-note>ISA는 국내 상장 ETF만 편입 가능합니다.</p>
        </div>
      </article>
    </Fragment>

    <!-- 결과 -->
    <div class="edtc-results">
      <div class="edtc-summary-cards">
        <div class="edtc-card edtc-card--main">
          <div class="edtc-card-label">세후 실수령 (월)</div>
          <div class="edtc-card-value" data-edtc-net-monthly>—</div>
          <div class="edtc-card-sub" data-edtc-net-annual>연간 —</div>
        </div>
        <div class="edtc-card">
          <div class="edtc-card-label">납부 세금 (월)</div>
          <div class="edtc-card-value" data-edtc-tax-monthly>—</div>
          <div class="edtc-card-sub" data-edtc-tax-rate-label>—</div>
        </div>
        <div class="edtc-card edtc-card--isa" data-edtc-isa-card>
          <div class="edtc-card-label">ISA 절세 효과 (연간)</div>
          <div class="edtc-card-value" data-edtc-isa-saving>—</div>
          <div class="edtc-card-sub">일반 계좌 대비 절약</div>
        </div>
      </div>

      <!-- 3가지 계좌 비교 -->
      <div class="edtc-compare-section">
        <h3 class="edtc-compare-title">계좌별 세후 비교 (월 분배금 기준)</h3>
        <div class="edtc-compare-table" data-edtc-compare-table>
          <!-- JS로 채움 -->
        </div>
      </div>
    </div>

    <CompareCta
      eyebrow="함께 쓰는 계산기"
      title="ISA로 절세하면 얼마나 달라지나요?"
      description="ISA 계좌 절세 시뮬레이터로 비과세 혜택과 만기 수령액을 직접 계산해보세요."
      variant="hub"
      links={[
        { href: "/tools/isa-tax-calculator/", label: "ISA 절세 시뮬레이터", tone: "primary" },
        { href: "/tools/us-dividend-tax-calculator/", label: "미국주식 배당소득세 계산기", tone: "secondary" },
      ]}
    />

    <Fragment slot="seo">
      <section class="seo-content stack">
        <article class="panel seo-panel">
          <div class="panel-heading">
            <div><p class="panel-heading__eyebrow">상세 안내</p><h2 class="panel__title">ETF 분배금 세금, 계좌별로 얼마나 다를까?</h2></div>
          </div>
          <div class="seo-copy">
            <p>ETF 분배금의 세후 실수령은 어떤 계좌에서 투자하느냐에 따라 크게 달라집니다. 같은 월 50만원 분배금이라도 일반 계좌, ISA 계좌, 미국 상장 ETF 여부에 따라 세후 수령액 차이가 연간 수십만원에 달할 수 있습니다.</p>
            <p>국내 상장 ETF(TIGER·ACE·SOL 다우존스 등)를 일반 계좌에서 보유하면 분배금에 15.4%가 원천징수됩니다. 월 50만원 분배금이라면 세후 약 42만3,000원이 입금됩니다. 연간으로는 약 92,400원의 세금이 납부됩니다.</p>
            <p>같은 ETF를 ISA 일반형 계좌에서 보유하면 연간 순이익 200만원까지 비과세, 초과분은 9.9% 분리과세입니다. 일반 계좌(15.4%)보다 최대 5.5%p 낮은 세율이 적용되어 장기 보유 시 절세 효과가 커집니다.</p>
            <p>미국 상장 ETF(CONY·YMAX·SCHD 등)는 미국에서 15%가 원천징수되고 국내 ISA에는 편입할 수 없습니다. 국내 상장 ETF(15.4%)와 세율 차이는 0.4%p로 크지 않지만, ISA 혜택 적용 여부가 핵심 차이입니다.</p>
            <p>배당 투자를 ISA 계좌로 운용하면 금융소득종합과세(연 2,000만원 기준) 부담에서도 자유로워집니다. ISA 계좌 내 수익은 종합과세 합산에서 제외되기 때문입니다. 장기적으로 배당 투자 규모가 커질수록 ISA 활용이 중요해집니다.</p>
          </div>
        </article>
        <article class="panel seo-panel" id="faq">
          <h2 class="panel__title">자주 묻는 질문</h2>
          <div class="faq-list">
            {EDTC_FAQS.map((f, i) => (
              <details class="faq-item" open={i === 0}>
                <summary>{f.question}</summary>
                <p>{f.answer}</p>
              </details>
            ))}
          </div>
        </article>
      </section>
    </Fragment>
  </SimpleToolShell>
</BaseLayout>

<script src={withBase("scripts/etf-distribution-tax-calculator.js")} defer></script>
