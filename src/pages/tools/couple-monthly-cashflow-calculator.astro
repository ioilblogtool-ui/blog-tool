---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  CMC_CONFIG,
  CMC_FAQ,
  CMC_HOUSING_TYPE_LABELS,
  CMC_META,
  CMC_RELATED_LINKS,
  CMC_SEO_CONTENT,
} from "../../data/coupleMonthlyCashflowCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${CMC_META.slug}/`;
const moneyValue = (value: number) => value.toLocaleString("ko-KR");
---

<BaseLayout
  title={CMC_META.seoTitle}
  description={CMC_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: CMC_META.title,
      applicationCategory: "FinanceApplication",
      operatingSystem: "All",
      description: CMC_META.seoDescription,
      url: pageUrl,
      inLanguage: "ko-KR",
      isAccessibleForFree: true,
      provider: { "@type": "Organization", name: "비교계산소" },
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: CMC_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={CMC_META.slug} pageClass="cmc-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="부부 생활비 · 저축률 계산"
        title="부부 월 현금흐름 계산기"
        description="연봉, 대출, 육아비, 생활비, 투자금을 넣으면 우리 집 월 실수령 합계와 잉여현금, 저축률, 10억 도달 예상 기간을 계산합니다."
        badges={["신규", "맞벌이", "생활비", "저축률"]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          CMC_META.dataNote,
          "세후소득, 대출이자, 목표자산 도달 기간은 입력값 기반 추정값입니다. 실제 급여명세서와 투자 성과를 보장하지 않습니다.",
          "입력값은 브라우저에서만 계산되며 서버로 전송되지 않습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="cmcResetBtn" copyId="cmcCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel cmc-preset-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 시작</p>
            <h2 class="panel__title">우리 집과 비슷한 상황 선택</h2>
          </div>
          <p class="panel-heading__summary">프리셋을 누른 뒤 금액만 조금 바꾸면 더 빠르게 계산할 수 있습니다.</p>
        </div>
        <div class="cmc-preset-grid">
          {CMC_CONFIG.presets.map((preset, index) => (
            <button type="button" class="cmc-preset-btn" data-cmc-preset={preset.id} aria-pressed={index === 1 ? "true" : "false"}>
              <strong>{preset.label}</strong>
              <span>{preset.summary}</span>
            </button>
          ))}
        </div>
      </article>

      <article class="panel cmc-input-panel" id="cmc-inputs">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">소득부터 투자 목표까지</h2>
          </div>
        </div>

        <section class="cmc-input-section" aria-labelledby="cmc-income-title">
          <h3 id="cmc-income-title">소득</h3>
          <div class="form-grid">
            <label class="field">
              <span>남편 연봉(세전)</span>
              <input data-cmc="husbandSalary" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.husbandSalary)} />
            </label>
            <label class="field">
              <span>아내 연봉(세전)</span>
              <input data-cmc="wifeSalary" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.wifeSalary)} />
            </label>
            <label class="field">
              <span>남편 연간 성과급</span>
              <input data-cmc="husbandBonus" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.husbandBonus)} />
            </label>
            <label class="field">
              <span>아내 연간 성과급</span>
              <input data-cmc="wifeBonus" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.wifeBonus)} />
            </label>
            <label class="field field-span-full">
              <span>기타 월 소득</span>
              <input data-cmc="otherMonthlyIncome" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.otherMonthlyIncome)} />
              <small>부업, 월세수입, 육아휴직 급여 등을 월 단위로 넣을 수 있습니다.</small>
            </label>
          </div>
        </section>

        <section class="cmc-input-section" aria-labelledby="cmc-housing-title">
          <h3 id="cmc-housing-title">주거</h3>
          <div class="form-grid">
            <label class="field">
              <span>주거 형태</span>
              <select data-cmc="housingType">
                {Object.entries(CMC_HOUSING_TYPE_LABELS).map(([value, label]) => (
                  <option value={value} selected={value === CMC_CONFIG.defaultInput.housingType}>{label}</option>
                ))}
              </select>
            </label>
            <label class="field">
              <span>대출 잔액</span>
              <input data-cmc="loanBalance" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.loanBalance)} />
            </label>
            <label class="field">
              <span>대출 금리(연 %)</span>
              <input data-cmc="loanRate" type="number" min="0" max="20" step="0.1" value={CMC_CONFIG.defaultInput.loanRate} />
            </label>
            <label class="field">
              <span>월 원리금 직접 입력</span>
              <input data-cmc="manualMonthlyPayment" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.manualMonthlyPayment)} />
            </label>
            <label class="field">
              <span>월세</span>
              <input data-cmc="rent" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.rent)} />
            </label>
            <label class="field">
              <span>관리비</span>
              <input data-cmc="maintenanceFee" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.maintenanceFee)} />
            </label>
          </div>
        </section>

        <section class="cmc-input-section" aria-labelledby="cmc-child-title">
          <h3 id="cmc-child-title">육아</h3>
          <div class="form-grid">
            <label class="field">
              <span>자녀 수</span>
              <input data-cmc="children" type="number" min="0" max="4" step="1" value={CMC_CONFIG.defaultInput.children} />
            </label>
            <label class="field">
              <span>어린이집·유치원</span>
              <input data-cmc="daycare" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.daycare)} />
            </label>
            <label class="field">
              <span>분유·이유식</span>
              <input data-cmc="formulaFood" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.formulaFood)} />
            </label>
            <label class="field">
              <span>기저귀·물티슈</span>
              <input data-cmc="diaper" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.diaper)} />
            </label>
            <label class="field">
              <span>병원·약</span>
              <input data-cmc="childMedical" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.childMedical)} />
            </label>
            <label class="field">
              <span>자녀 보험</span>
              <input data-cmc="childInsurance" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.childInsurance)} />
            </label>
            <label class="field field-span-full">
              <span>돌봄·학원·기타</span>
              <input data-cmc="careEducation" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.careEducation)} />
            </label>
          </div>
        </section>

        <section class="cmc-input-section" aria-labelledby="cmc-living-title">
          <h3 id="cmc-living-title">생활비</h3>
          <div class="form-grid">
            <label class="field">
              <span>식비·외식</span>
              <input data-cmc="food" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.food)} />
            </label>
            <label class="field">
              <span>교통·차량</span>
              <input data-cmc="transport" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.transport)} />
            </label>
            <label class="field">
              <span>통신·구독</span>
              <input data-cmc="telecomSubscription" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.telecomSubscription)} />
            </label>
            <label class="field">
              <span>부부 보험료</span>
              <input data-cmc="coupleInsurance" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.coupleInsurance)} />
            </label>
            <label class="field">
              <span>의료·미용·의류</span>
              <input data-cmc="medicalBeautyClothing" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.medicalBeautyClothing)} />
            </label>
            <label class="field">
              <span>경조사·부모님 용돈</span>
              <input data-cmc="familyEvents" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.familyEvents)} />
            </label>
            <label class="field field-span-full">
              <span>기타 카드비</span>
              <input data-cmc="otherCard" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.otherCard)} />
            </label>
          </div>
        </section>

        <section class="cmc-input-section" aria-labelledby="cmc-invest-title">
          <h3 id="cmc-invest-title">투자와 목표자산</h3>
          <div class="form-grid">
            <label class="field">
              <span>예적금</span>
              <input data-cmc="depositSavings" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.depositSavings)} />
            </label>
            <label class="field">
              <span>ISA</span>
              <input data-cmc="isa" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.isa)} />
            </label>
            <label class="field">
              <span>연금저축·IRP</span>
              <input data-cmc="pension" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.pension)} />
            </label>
            <label class="field">
              <span>주식·ETF</span>
              <input data-cmc="stockEtf" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.stockEtf)} />
            </label>
            <label class="field">
              <span>코인</span>
              <input data-cmc="crypto" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.crypto)} />
            </label>
            <label class="field">
              <span>현재 투자자산</span>
              <input data-cmc="currentAssets" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.currentAssets)} />
            </label>
            <label class="field">
              <span>목표자산</span>
              <input data-cmc="targetAssets" type="text" inputmode="numeric" value={moneyValue(CMC_CONFIG.defaultInput.targetAssets)} />
            </label>
            <label class="field">
              <span>기대수익률(연 %)</span>
              <input data-cmc="expectedReturn" type="number" min="0" max="20" step="0.1" value={CMC_CONFIG.defaultInput.expectedReturn} />
              <small>투자 수익률은 보장되지 않는 추정값입니다.</small>
            </label>
          </div>
        </section>
      </article>
    </Fragment>

    <section class="cmc-section cmc-result-section" aria-live="polite">
      <div class="section-header">
        <p class="section-header__eyebrow">결과 먼저 보기</p>
        <h2>우리 집 한 달 현금흐름</h2>
        <p>입력값을 바꾸면 월 실수령, 고정비, 변동비, 저축률, 목표자산 도달 기간이 바로 다시 계산됩니다.</p>
      </div>

      <div class="cmc-kpi-grid">
        <article class="cmc-kpi cmc-kpi--main">
          <span>월 실수령 합계</span>
          <strong data-cmc-result="totalMonthlyNet">-</strong>
          <small>부부 세후소득 추정 + 기타소득</small>
        </article>
        <article class="cmc-kpi">
          <span>고정비</span>
          <strong data-cmc-result="fixedCost">-</strong>
          <small>주거비, 보험료, 통신·구독</small>
        </article>
        <article class="cmc-kpi">
          <span>변동비</span>
          <strong data-cmc-result="variableCost">-</strong>
          <small>육아비와 생활비 중심</small>
        </article>
        <article class="cmc-kpi cmc-kpi--accent">
          <span>투자 가능액</span>
          <strong data-cmc-result="investableAmount">-</strong>
          <small>소비성 지출 차감 후 남는 돈</small>
        </article>
        <article class="cmc-kpi">
          <span>저축률</span>
          <strong data-cmc-result="savingRate">-</strong>
          <small><span data-cmc-result="band" class="cmc-saving-badge">-</span></small>
        </article>
        <article class="cmc-kpi">
          <span>목표자산까지</span>
          <strong data-cmc-result="targetYears">-</strong>
          <small>현재자산 + 월 투자 가능액 기준</small>
        </article>
      </div>

      <p class="cmc-summary" data-cmc-summary></p>
      <p class="cmc-band-note" data-cmc-result="bandDescription"></p>
    </section>

    <section class="cmc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">구조 보기</p>
        <h2>월급이 어디로 흘러가는지</h2>
      </div>
      <div class="cmc-flow-bars" aria-label="월 현금흐름 비중">
        <div class="cmc-flow-row"><span>주거비</span><div><i data-cmc-bar="housing"></i></div></div>
        <div class="cmc-flow-row"><span>육아비</span><div><i data-cmc-bar="childcare"></i></div></div>
        <div class="cmc-flow-row"><span>생활비</span><div><i data-cmc-bar="living"></i></div></div>
        <div class="cmc-flow-row"><span>남는 돈</span><div><i data-cmc-bar="surplus"></i></div></div>
      </div>
    </section>

    <section class="cmc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">상세 내역</p>
        <h2>월 현금흐름 표</h2>
      </div>
      <div class="cmc-table-wrap">
        <table class="cmc-breakdown-table">
          <tbody>
            {["월 실수령 합계", "주거비", "육아비", "생활비", "월 투자 입력액", "생활비 차감 후 잉여현금"].map((label) => (
              <tr>
                <th>{label}</th>
                <td data-cmc-breakdown={label}>-</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="cmc-net-grid">
        <article>
          <span>남편 월 실수령 추정</span>
          <strong data-cmc-result="husbandMonthlyNet">-</strong>
        </article>
        <article>
          <span>아내 월 실수령 추정</span>
          <strong data-cmc-result="wifeMonthlyNet">-</strong>
        </article>
        <article>
          <span>월 투자 입력액</span>
          <strong data-cmc-result="monthlyInvesting">-</strong>
          <small data-cmc-result="inputInvestmentRate">-</small>
        </article>
      </div>
    </section>

    <section class="cmc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">개선 포인트</p>
        <h2>어디부터 보면 좋을까?</h2>
        <p>현재 입력값에서 영향이 큰 항목을 기준으로 다음 행동을 제안합니다.</p>
      </div>
      <ul class="cmc-suggestion-list" data-cmc-suggestions></ul>
    </section>

    <section class="cmc-section cmc-cta-section">
      <div class="section-header">
        <p class="section-header__eyebrow">같이 계산</p>
        <h2>세부 항목을 더 정확히 보고 싶다면</h2>
      </div>
      <div class="cmc-cta-grid">
        {CMC_RELATED_LINKS.slice(0, 6).map((item) => (
          <a href={withBase(item.href)}>{item.label}</a>
        ))}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle={CMC_SEO_CONTENT.introTitle}
        intro={CMC_SEO_CONTENT.intro}
        inputPoints={CMC_SEO_CONTENT.inputPoints}
        criteria={CMC_SEO_CONTENT.criteria}
        faq={CMC_FAQ}
        related={CMC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="cmc-data" type="application/json" set:html={JSON.stringify(CMC_CONFIG)} />
  <script type="module" src={withBase("/scripts/couple-monthly-cashflow-calculator.js")}></script>
</BaseLayout>
