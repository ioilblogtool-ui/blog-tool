---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import CompareCta from "../../components/CompareCta.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import { UDTA_STOCK_PRESETS, UDTA_META, UDTA_FAQS, UDTA_TAX_BRACKETS } from "../../data/usDividendTaxCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout
  title={UDTA_META.title}
  description={UDTA_META.description}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "미국주식 배당소득세 계산기 2026",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description: UDTA_META.description,
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/us-dividend-tax-calculator/`,
  }}
>
  <SiteHeader />
  <script id="udtaConfig" type="application/json" set:html={JSON.stringify({ presets: UDTA_STOCK_PRESETS, brackets: UDTA_TAX_BRACKETS })} />

  <SimpleToolShell calculatorId="us-dividend-tax-calculator" pageClass="udta-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="미국 배당소득세"
        title="미국주식 배당소득세 계산기 2026"
        description="미국주식 배당금의 세후 실수령을 계산합니다. 미국 원천징수 15%와 국내 금융소득종합과세 기준을 모두 반영합니다."
        stats={[
          { label: "미국 원천징수", value: "15%" },
          { label: "종합과세 기준", value: "연 2,000만원" },
        ]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          "미국 배당금은 한미 조세조약에 따라 15% 원천징수됩니다.",
          "연간 금융소득(배당+이자 합산) 2,000만원 초과 시 종합소득세 신고 의무가 발생합니다.",
          "세금 신고는 반드시 세무사 또는 국세청 홈택스에서 확인하세요.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="udtaResetBtn" copyId="udtaCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel udta-input-panel" data-udta-calculator>
        <!-- 배당금 입력 -->
        <div class="udta-section">
          <h2 class="udta-section-title">받은 배당금 (달러)</h2>
          <div class="udta-field">
            <div class="udta-input-wrap">
              <input id="udtaDividend" type="text" class="udta-input" data-udta-dividend value="1,000" inputmode="numeric" />
              <span class="udta-unit">USD</span>
            </div>
            <div class="udta-hint" data-udta-krw-hint>—원 (환율 1,380원 기준)</div>
          </div>
        </div>

        <!-- 환율 -->
        <div class="udta-section">
          <h2 class="udta-section-title">적용 환율</h2>
          <div class="udta-field">
            <div class="udta-input-wrap">
              <input id="udtaRate" type="number" class="udta-input" data-udta-rate value="1380" min="1000" max="2000" />
              <span class="udta-unit">원/달러</span>
            </div>
          </div>
        </div>

        <!-- 연간 금융소득 합계 -->
        <div class="udta-section">
          <h2 class="udta-section-title">연간 금융소득 합계 (이번 배당 포함)</h2>
          <div class="udta-field">
            <div class="udta-input-wrap">
              <input id="udtaAnnualIncome" type="text" class="udta-input" data-udta-annual value="5,000,000" inputmode="numeric" />
              <span class="udta-unit">원</span>
            </div>
            <div class="udta-hint">예금이자·국내 배당 등 모든 금융소득 합산</div>
          </div>
        </div>

        <!-- 주식 종류 -->
        <div class="udta-section">
          <h2 class="udta-section-title">종목 (선택)</h2>
          <div class="udta-preset-list">
            {UDTA_STOCK_PRESETS.map((p, i) => (
              <label class={`udta-preset-item${i === 0 ? " active" : ""}`} data-udta-preset-label={p.id}>
                <input type="radio" name="udtaStock" value={p.id} data-udta-preset checked={i === 0} />
                <span>{p.name}</span>
                {p.id !== "custom" && <span class="udta-yield-badge">배당률 {p.annualYieldPct}%</span>}
              </label>
            ))}
          </div>
        </div>
      </article>
    </Fragment>

    <!-- 결과 -->
    <div class="udta-results">
      <div class="udta-summary-cards">
        <div class="udta-card udta-card--main">
          <div class="udta-card-label">세후 실수령 (원화)</div>
          <div class="udta-card-value" data-udta-net-krw>—</div>
          <div class="udta-card-sub" data-udta-net-usd>—</div>
        </div>
        <div class="udta-card">
          <div class="udta-card-label">미국 원천징수 (15%)</div>
          <div class="udta-card-value" data-udta-us-tax>—</div>
          <div class="udta-card-sub">미국에서 자동 차감</div>
        </div>
        <div class="udta-card" data-udta-comprehensive-wrap>
          <div class="udta-card-label">종합과세 추가 세금</div>
          <div class="udta-card-value" data-udta-extra-tax>—</div>
          <div class="udta-card-sub" data-udta-comprehensive-desc>—</div>
        </div>
      </div>

      <div class="udta-breakdown">
        <h3 class="udta-breakdown-title">세금 계산 상세</h3>
        <div class="udta-breakdown-rows" data-udta-breakdown>
          <!-- JS로 채움 -->
        </div>
      </div>
    </div>

    <CompareCta
      eyebrow="함께 쓰는 계산기"
      title="ETF 분배금 세금도 확인하세요"
      description="국내 상장 ETF, 미국 ETF, ISA 계좌별 세후 분배금을 한눈에 비교합니다."
      variant="hub"
      links={[
        { href: "/tools/etf-distribution-tax-calculator/", label: "ETF 분배금 세후 계산기", tone: "primary" },
        { href: "/tools/isa-tax-calculator/", label: "ISA 절세 시뮬레이터", tone: "secondary" },
      ]}
    />

    <Fragment slot="seo">
      <section class="seo-content stack">
        <article class="panel seo-panel">
          <div class="panel-heading">
            <div><p class="panel-heading__eyebrow">상세 안내</p><h2 class="panel__title">미국주식 배당소득세 계산 방법</h2></div>
          </div>
          <div class="seo-copy">
            <p>미국주식 배당금을 받으면 미국이 먼저 15%를 원천징수합니다. 한미 조세조약에 따른 세율로, 100달러 배당이라면 85달러가 실제로 입금됩니다. 이 원천징수는 자동으로 차감되므로 별도로 납부할 필요가 없습니다.</p>
            <p>문제는 국내 금융소득종합과세입니다. 한 해 동안 받은 이자·배당 등 금융소득 합계가 2,000만원을 넘으면 초과분을 다른 소득과 합산해 종합소득세를 신고해야 합니다. 이 경우 미국에 납부한 15% 원천징수세는 외국납부세액공제로 일부 환급받을 수 있어 이중과세는 어느 정도 방지됩니다.</p>
            <p>CONY·AMDY·YMAX 같은 YieldMax ETF에서 연 수천만원의 분배금을 받는 경우라면 종합과세 기준(2,000만원)을 초과할 가능성이 높습니다. 이 경우 추가 세금 부담을 미리 계산해 자금 계획을 세우는 것이 중요합니다.</p>
            <p>배당 투자를 통한 금융소득이 연 2,000만원 이하라면 15% 원천징수만으로 세금이 끝납니다. 미국 ETF는 ISA 계좌에 편입할 수 없으므로 국내 상장 해외 ETF(TIGER·ACE 등)를 ISA 계좌에서 운용하면 금융소득종합과세 부담을 줄일 수 있습니다.</p>
            <p>주의: 이 계산기는 참고용 추정치입니다. 실제 세금은 다른 소득, 공제 항목, 세무 상황에 따라 달라집니다. 정확한 세액 계산은 세무사 또는 국세청 홈택스에서 확인하세요.</p>
          </div>
        </article>
        <article class="panel seo-panel" id="faq">
          <h2 class="panel__title">자주 묻는 질문</h2>
          <div class="faq-list">
            {UDTA_FAQS.map((f, i) => (
              <details class="faq-item" open={i === 0}>
                <summary>{f.question}</summary>
                <p>{f.answer}</p>
              </details>
            ))}
          </div>
        </article>
      </section>
    </Fragment>
  </SimpleToolShell>
</BaseLayout>

<script src={withBase("scripts/us-dividend-tax-calculator.js")} defer></script>
