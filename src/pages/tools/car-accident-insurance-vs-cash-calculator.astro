---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import {
  CACC_META,
  CACC_PRESETS,
  CACC_SURCHARGE_GUIDE,
  CACC_FAQS,
  CACC_DEFAULTS,
} from "../../data/carAccidentInsuranceVsCash";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const config = { presets: CACC_PRESETS, defaults: CACC_DEFAULTS };

const faqSchema = CACC_FAQS.map((f) => ({
  "@type": "Question",
  name: f.question,
  acceptedAnswer: { "@type": "Answer", text: f.answer },
}));
---

<BaseLayout
  title={CACC_META.seoTitle}
  description={CACC_META.description}
  ogImage="/og/tools/car-accident-insurance-vs-cash-calculator.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: CACC_META.title,
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description: CACC_META.description,
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/car-accident-insurance-vs-cash-calculator/`,
    mainEntity: { "@type": "FAQPage", mainEntity: faqSchema },
  }}
>
  <SiteHeader />

  <script
    id="caccConfig"
    type="application/json"
    set:html={JSON.stringify(config)}
  />

  <SimpleToolShell calculatorId="car-accident-insurance-vs-cash" pageClass="cacc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="사고 대응"
        title="보험처리 vs 현금처리 계산기"
        description="수리비와 할증률을 입력하면 보험처리와 현금처리 중 3년 총비용 기준으로 어느 쪽이 유리한지 즉시 계산합니다."
        stats={[
          { label: "비교 기준", value: "3년 총비용" },
          { label: "판단 프리셋", value: "4종" },
        ]}
      />

      <!-- 프리셋 버튼 -->
      <div class="panel" style="padding: 1rem 1.25rem;">
        <p style="margin: 0 0 0.6rem; font-size: 0.84rem; color: var(--cacc-muted, #667085); font-weight: 700;">사고 유형 빠른 선택</p>
        <div class="cacc-preset-grid">
          {CACC_PRESETS.map((preset) => (
            <button
              class="cacc-preset-btn"
              data-cacc-preset={preset.id}
              type="button"
            >
              {preset.label}
            </button>
          ))}
        </div>
      </div>

      <InfoNotice
        title="이 계산기는 참고용입니다"
        lines={[
          "할증률은 보험사·사고이력·계약 조건에 따라 다릅니다. 정확한 내용은 가입 보험사에 확인하세요.",
          "상대방 과실이 있는 경우 상대방 보험사에 청구할 수 있어 계산이 달라질 수 있습니다.",
          "보험등급보호 특약 가입 여부에 따라 실제 유불리가 크게 달라질 수 있습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="caccResetBtn" copyId="caccCopyLinkBtn" />
    </Fragment>

    <!-- 입력 패널 -->
    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">사고 조건 입력</h2>
          </div>
          <p class="panel-heading__summary">수리비와 현재 보험 조건을 입력하면 3년 총비용을 자동 비교합니다.</p>
        </div>

        <div class="form-grid form-grid--compact">
          <!-- 수리비 -->
          <label class="field field-span-full">
            <span>수리비 견적</span>
            <input
              id="caccRepairCost"
              type="number"
              class="input-number"
              data-cacc-repair
              value={CACC_DEFAULTS.repairCost * 10000}
              min="100000"
              max="20000000"
              step="10000"
            />
            <small id="caccRepairHint"></small>
            <div class="cacc-slider-row">
              <input
                type="range"
                id="caccRepairSlider"
                class="calc-slider"
                min="10"
                max="2000"
                step="10"
                value={CACC_DEFAULTS.repairCost}
              />
              <span id="caccRepairSliderVal" class="cacc-slider-val">{CACC_DEFAULTS.repairCost}만원</span>
            </div>
          </label>

          <!-- 자기부담금 -->
          <label class="field field-span-full">
            <span>자기부담금</span>
            <input
              id="caccDeductible"
              type="number"
              class="input-number"
              data-cacc-deductible
              value={CACC_DEFAULTS.deductible * 10000}
              min="0"
              max="500000"
              step="10000"
            />
            <small id="caccDeductibleHint"></small>
            <div class="cacc-slider-row">
              <input
                type="range"
                id="caccDeductibleSlider"
                class="calc-slider"
                min="0"
                max="50"
                step="5"
                value={CACC_DEFAULTS.deductible}
              />
              <span id="caccDeductibleSliderVal" class="cacc-slider-val">{CACC_DEFAULTS.deductible}만원</span>
            </div>
          </label>

          <!-- 현재 연 보험료 -->
          <label class="field field-span-full">
            <span>현재 연 보험료</span>
            <input
              id="caccPremium"
              type="number"
              class="input-number"
              data-cacc-premium
              value={CACC_DEFAULTS.annualPremium * 10000}
              min="300000"
              max="3000000"
              step="10000"
            />
            <small id="caccPremiumHint"></small>
            <div class="cacc-slider-row">
              <input
                type="range"
                id="caccPremiumSlider"
                class="calc-slider"
                min="30"
                max="300"
                step="5"
                value={CACC_DEFAULTS.annualPremium}
              />
              <span id="caccPremiumSliderVal" class="cacc-slider-val">{CACC_DEFAULTS.annualPremium}만원</span>
            </div>
          </label>

          <!-- 예상 할증률 -->
          <label class="field field-span-full">
            <span>예상 할증률</span>
            <input
              id="caccSurcharge"
              type="number"
              class="input-number"
              data-cacc-surcharge
              value={CACC_DEFAULTS.surchargeRate}
              min="0"
              max="60"
              step="1"
            />
            <small id="caccSurchargeHint"></small>
            <div class="cacc-slider-row">
              <input
                type="range"
                id="caccSurchargeSlider"
                class="calc-slider"
                min="0"
                max="60"
                step="1"
                value={CACC_DEFAULTS.surchargeRate}
              />
              <span id="caccSurchargeSliderVal" class="cacc-slider-val">{CACC_DEFAULTS.surchargeRate}%</span>
            </div>
          </label>

          <!-- 할증 유지 기간 -->
          <label class="field field-span-full">
            <span>할증 유지 기간</span>
            <select data-cacc-period class="select">
              <option value="1">1년</option>
              <option value="2">2년</option>
              <option value="3" selected>3년 (일반적)</option>
              <option value="4">4년</option>
              <option value="5">5년</option>
            </select>
          </label>
        </div>
      </article>
    </Fragment>

    <!-- 결과 영역 -->
    <div class="cacc-result-stack" style="display: grid; gap: 1rem;">

      <!-- 판단 결과 + KPI -->
      <div class="cacc-kpi-grid">
        <!-- 판단 배지 (전체 너비) -->
        <div class="cacc-kpi-card cacc-kpi-card--verdict">
          <div class="cacc-verdict-wrap">
            <span class="cacc-verdict-label">판단 결과</span>
            <span class="cacc-verdict-badge cacc-verdict-badge--close" data-cacc-verdict>계산 중...</span>
          </div>
          <p class="cacc-verdict-desc" data-cacc-verdict-desc style="margin: 0;"></p>
        </div>

        <!-- 절약 금액 -->
        <div class="cacc-kpi-card">
          <span>유리한 선택 절약액</span>
          <strong data-cacc-saving>-</strong>
          <small>3년 기준 추정</small>
        </div>

        <!-- 손익분기 수리비 -->
        <div class="cacc-kpi-card">
          <span>손익분기 수리비</span>
          <strong data-cacc-breakeven>-</strong>
          <small>이 금액 이상이면 보험처리 유리</small>
        </div>

        <!-- 3년 총 추가 보험료 -->
        <div class="cacc-kpi-card">
          <span>보험처리 시 3년 총비용</span>
          <strong data-cacc-insurance-total>-</strong>
          <small>자기부담금 + 할증 합산</small>
        </div>
      </div>

      <!-- 연도별 비교 테이블 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">비용 비교</p>
            <h2 class="panel__title">보험처리 vs 현금처리 누적 비용</h2>
          </div>
        </div>
        <div class="cacc-table-wrap">
          <table class="cacc-compare-table">
            <thead>
              <tr>
                <th>구분</th>
                <th>즉시 비용</th>
                <th>1년 누적</th>
                <th>2년 누적</th>
                <th>3년 누적</th>
              </tr>
            </thead>
            <tbody data-cacc-table-body>
              <!-- JS로 채움 -->
            </tbody>
          </table>
        </div>
      </article>

      <!-- 추가 고려사항 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">추가 확인</p>
            <h2 class="panel__title">계산 전 반드시 확인할 것</h2>
          </div>
        </div>
        <div class="cacc-notice-grid">
          <div class="cacc-notice-item">
            <strong>상대방 과실 여부</strong>
            <p>상대방 과실이 있으면 내 보험 없이 처리 가능. 과실 비율 먼저 확인하세요.</p>
          </div>
          <div class="cacc-notice-item">
            <strong>보험등급보호 특약</strong>
            <p>특약 가입 시 1회 사고는 등급 하락 없이 보험처리 가능. 약관 확인 필요.</p>
          </div>
          <div class="cacc-notice-item">
            <strong>무사고 할인 연수</strong>
            <p>무사고 기간이 길수록 할인 폭이 커서 보험처리 시 손해가 더 클 수 있습니다.</p>
          </div>
          <div class="cacc-notice-item">
            <strong>소손해 처리 제도</strong>
            <p>일부 보험사는 소액 사고 시 할증 없는 보험처리 가능. 보험사에 직접 문의하세요.</p>
          </div>
        </div>
      </article>

      <!-- 할증률 참고 가이드 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">참고</p>
            <h2 class="panel__title">수리비별 일반적인 할증률 범위</h2>
          </div>
        </div>
        <table class="cacc-guide-table">
          <thead>
            <tr>
              <th>수리비 규모</th>
              <th>할증률 범위</th>
              <th>참고</th>
            </tr>
          </thead>
          <tbody>
            {CACC_SURCHARGE_GUIDE.map((row) => (
              <tr>
                <td>{row.range}</td>
                <td class="rate-cell">{row.rate}</td>
                <td style="color: var(--cacc-muted); font-size: 0.85rem;">{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p style="margin: 0.75rem 0 0; font-size: 0.84rem; color: var(--cacc-muted); line-height: 1.6;">
          할증률은 보험사·사고 유형·현재 등급·계약 조건에 따라 크게 달라집니다. 위 수치는 일반적인 참고 범위이며, 정확한 할증 내용은 가입 보험사에 확인하세요.
        </p>
      </article>
    </div>

    <Fragment slot="seo">
      <SeoContent
        introTitle="자동차 사고 후 보험처리 vs 현금처리 판단 기준"
        intro={[
          "자동차 사고가 나면 가장 먼저 드는 고민이 '보험처리가 나을까, 현금으로 처리하는 게 나을까'입니다. 수리비가 작으면 보험처리 후 3년간 할증되는 보험료가 더 클 수 있고, 수리비가 크면 현금처리가 오히려 부담입니다.",
          "이 계산기는 수리비, 자기부담금, 현재 보험료, 예상 할증률을 입력하면 보험처리와 현금처리 각각의 3년 총비용을 즉시 비교합니다. 손익분기 수리비를 기준으로 어느 쪽이 유리한지 명확하게 판단할 수 있습니다.",
          "다만 상대방 과실 비율, 보험등급보호 특약 가입 여부, 무사고 등급 연수에 따라 실제 유불리가 달라질 수 있습니다. 계산기 결과와 함께 이 조건들을 반드시 확인하세요.",
        ]}
        criteria={[
          "보험처리 3년 총비용 = 자기부담금 + (연 보험료 × 할증률 × 할증 유지 기간)으로 계산합니다.",
          "현금처리 비용 = 수리비 전액(자기부담금 없음)입니다.",
          "손익분기 수리비는 보험처리 3년 총비용과 같습니다. 수리비가 이 금액 이상이면 보험처리가 유리합니다.",
          "할증률은 보험사·사고이력·등급에 따라 다릅니다. 이 계산기의 값은 추정치이며 가입 보험사에 정확한 내용을 확인하세요.",
        ]}
        faq={CACC_FAQS.map((f) => ({ question: f.question, answer: f.answer }))}
        related={[
          { href: "/tools/car-insurance-premium/", label: "자동차 보험료 계산기" },
          { href: "/tools/new-vs-used-car-5year-cost/", label: "신차 vs 중고차 5년 총비용" },
          { href: "/tools/car-purchase-method-comparison/", label: "리스 vs 할부 vs 현금 비교" },
          { href: "/tools/ev-vs-ice-10year-cost/", label: "전기차 vs 내연기관 10년 비용" },
        ]}
      />
    </Fragment>
  </SimpleToolShell>
</BaseLayout>

<script src={withBase("scripts/car-accident-insurance-vs-cash-calculator.js")} defer></script>
