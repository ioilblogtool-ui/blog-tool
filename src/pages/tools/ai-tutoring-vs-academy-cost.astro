---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  AI_TUTORING_DEFAULTS,
  AI_TUTORING_FAQ,
  AI_TUTORING_GRADE_OPTIONS,
  AI_TUTORING_META,
  AI_TUTORING_PRESETS,
  AI_TUTORING_RELATED_LINKS,
  AI_TUTORING_RISK_OPTIONS,
  AI_TUTORING_SCENARIOS,
  AI_TUTORING_SUBJECTS,
  AI_TUTORING_TOOLS,
} from "../../data/aiTutoringVsAcademyCost";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const seed = {
  meta: AI_TUTORING_META,
  defaults: AI_TUTORING_DEFAULTS,
  subjects: AI_TUTORING_SUBJECTS,
  presets: AI_TUTORING_PRESETS,
  tools: AI_TUTORING_TOOLS,
};

const faqSchema = AI_TUTORING_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: {
    "@type": "Answer",
    text: item.answer,
  },
}));
---

<BaseLayout
  title={`${AI_TUTORING_META.title} | AI 학습 도구 학원비 절감 시뮬레이션`}
  description={AI_TUTORING_META.subtitle}
  ogImage="/og/sample-tool.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: AI_TUTORING_META.title,
    applicationCategory: "EducationalApplication",
    operatingSystem: "All",
    description: AI_TUTORING_META.subtitle,
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/${AI_TUTORING_META.slug}/`,
    mainEntity: {
      "@type": "FAQPage",
      mainEntity: faqSchema,
    },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={AI_TUTORING_META.slug} pageClass="atac-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="AI 교육비 계산"
        title={AI_TUTORING_META.title}
        description="학원비, 과외비, AI 구독료, 보호자 관리 시간을 함께 넣어 월 절감액과 연간 절약액을 바로 비교합니다."
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          AI_TUTORING_META.caution,
          "AI 도구 가격과 학원비는 지역·학년·과목·프로모션에 따라 달라질 수 있어 직접 수정해 계산하세요.",
          "완전 대체, 하이브리드, 학원 유지 결과는 확정 추천이 아니라 비용과 대체 가능성 기준의 참고값입니다.",
          `업데이트 기준: ${AI_TUTORING_META.updatedAt}`,
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="atacResetBtn" copyId="atacCopyLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <form id="atacForm" class="calculator-form atac-form-panel">
        <div class="atac-section-head">
          <p class="atac-eyebrow">빠른 설정</p>
          <h2>자주 쓰는 교육비 시나리오</h2>
        </div>
        <div class="atac-preset-grid">
          {AI_TUTORING_PRESETS.map((preset) => (
            <button class="atac-preset-btn" type="button" data-atac-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.description}</span>
            </button>
          ))}
        </div>

        <div class="atac-section-head">
          <p class="atac-eyebrow">자녀·과목</p>
          <h2>학년과 수업 조건</h2>
        </div>
        <div class="form-grid">
          <label>
            <span>자녀 학년</span>
            <select id="atac-grade-level">
              {AI_TUTORING_GRADE_OPTIONS.map((grade) => (
                <option value={grade.id} selected={grade.id === AI_TUTORING_DEFAULTS.gradeLevel}>
                  {grade.label}
                </option>
              ))}
            </select>
          </label>
          <label>
            <span>자녀 수</span>
            <input id="atac-child-count" type="number" min="1" max="5" step="1" value={AI_TUTORING_DEFAULTS.childCount} />
          </label>
          <label>
            <span>학원 과목 수</span>
            <input id="atac-subject-count" type="number" min="1" max="8" step="1" value={AI_TUTORING_DEFAULTS.subjectCount} />
          </label>
          <label>
            <span>주간 수업 횟수</span>
            <input id="atac-weekly-class-count" type="number" min="1" max="20" step="1" value={AI_TUTORING_DEFAULTS.weeklyClassCount} />
          </label>
          <label>
            <span>1회 수업 시간</span>
            <input id="atac-minutes-per-class" type="number" min="30" max="240" step="10" value={AI_TUTORING_DEFAULTS.minutesPerClass} />
          </label>
          <label>
            <span>월 환산 주수</span>
            <input id="atac-weeks-per-month" type="number" min="4" max="5" step="0.001" value={AI_TUTORING_DEFAULTS.weeksPerMonth} />
          </label>
        </div>
        <div class="atac-check-grid">
          {AI_TUTORING_SUBJECTS.map((subject) => (
            <label class="atac-check-card">
              <input
                type="checkbox"
                name="atac-subjects"
                value={subject.id}
                checked={AI_TUTORING_DEFAULTS.subjects.includes(subject.id)}
              />
              <span>{subject.label}</span>
            </label>
          ))}
        </div>

        <div class="atac-section-head">
          <p class="atac-eyebrow">현재 비용</p>
          <h2>학원·과외·부대비</h2>
        </div>
        <div class="form-grid">
          <label>
            <span>과목당 월 학원비</span>
            <input id="atac-academy-fee" type="number" min="0" max="2000000" step="10000" value={AI_TUTORING_DEFAULTS.academyFeePerSubject} />
          </label>
          <label>
            <span>과외 시급</span>
            <input id="atac-tutoring-hourly-rate" type="number" min="0" max="300000" step="5000" value={AI_TUTORING_DEFAULTS.tutoringHourlyRate} />
          </label>
          <label>
            <span>주간 과외 시간</span>
            <input id="atac-weekly-tutoring-hours" type="number" min="0" max="20" step="0.5" value={AI_TUTORING_DEFAULTS.weeklyTutoringHours} />
          </label>
          <label>
            <span>월 교재비</span>
            <input id="atac-material-cost" type="number" min="0" max="500000" step="5000" value={AI_TUTORING_DEFAULTS.monthlyMaterialCost} />
          </label>
          <label>
            <span>월 교통비</span>
            <input id="atac-transport-cost" type="number" min="0" max="500000" step="5000" value={AI_TUTORING_DEFAULTS.monthlyTransportCost} />
          </label>
          <label>
            <span>월 간식·기타비</span>
            <input id="atac-snack-cost" type="number" min="0" max="500000" step="5000" value={AI_TUTORING_DEFAULTS.monthlySnackCost} />
          </label>
        </div>
        <label class="atac-inline-check">
          <input id="atac-use-private-tutoring" type="checkbox" checked={AI_TUTORING_DEFAULTS.usePrivateTutoring} />
          <span>개인 과외 비용도 포함</span>
        </label>

        <div class="atac-section-head">
          <p class="atac-eyebrow">AI 비용</p>
          <h2>구독료와 보호자 관리 시간</h2>
        </div>
        <div class="atac-tool-list">
          {AI_TUTORING_TOOLS.map((tool) => (
            <label class="atac-tool-row">
              <input
                type="checkbox"
                name="atac-ai-tools"
                value={tool.id}
                checked={AI_TUTORING_DEFAULTS.selectedAiTools.includes(tool.id)}
              />
              <span>
                <strong>{tool.label}</strong>
                <small>{tool.badge}</small>
              </span>
            </label>
          ))}
        </div>
        <div class="form-grid">
          <label>
            <span>ChatGPT 월 비용</span>
            <input id="atac-chatgpt-price" type="number" min="0" max="300000" step="1000" value={AI_TUTORING_DEFAULTS.chatgptPrice} />
          </label>
          <label>
            <span>Khan Academy AI 월 비용</span>
            <input id="atac-khanmigo-price" type="number" min="0" max="300000" step="1000" value={AI_TUTORING_DEFAULTS.khanmigoPrice} />
          </label>
          <label>
            <span>뤼튼 월 비용</span>
            <input id="atac-wrtn-price" type="number" min="0" max="300000" step="1000" value={AI_TUTORING_DEFAULTS.wrtnPrice} />
          </label>
          <label>
            <span>기타 AI 월 비용</span>
            <input id="atac-other-ai-price" type="number" min="0" max="300000" step="1000" value={AI_TUTORING_DEFAULTS.otherAiPrice} />
          </label>
          <label>
            <span>AI 학습 교재·앱 추가비</span>
            <input id="atac-ai-material-cost" type="number" min="0" max="500000" step="5000" value={AI_TUTORING_DEFAULTS.aiMaterialCost} />
          </label>
          <label>
            <span>보호자 시간 가치</span>
            <input id="atac-parent-hourly-value" type="number" min="0" max="200000" step="1000" value={AI_TUTORING_DEFAULTS.parentHourlyValue} />
          </label>
          <label>
            <span>주간 보호자 점검 시간</span>
            <input id="atac-parent-weekly-care-hours" type="number" min="0" max="30" step="0.5" value={AI_TUTORING_DEFAULTS.parentWeeklyCareHours} />
          </label>
        </div>
        <label class="atac-inline-check">
          <input id="atac-include-parent-time-cost" type="checkbox" checked={AI_TUTORING_DEFAULTS.includeParentTimeCost} />
          <span>보호자 시간 비용을 총비용에 포함</span>
        </label>

        <div class="atac-section-head">
          <p class="atac-eyebrow">전환 방식</p>
          <h2>완전 대체 vs 하이브리드</h2>
        </div>
        <div class="atac-scenario-options">
          {AI_TUTORING_SCENARIOS.map((scenario) => (
            <label class="atac-scenario-option">
              <input
                type="radio"
                name="atac-scenario-type"
                value={scenario.id}
                checked={scenario.id === AI_TUTORING_DEFAULTS.scenarioType}
              />
              <strong>{scenario.label}</strong>
              <span>{scenario.description}</span>
            </label>
          ))}
        </div>
        <div class="form-grid">
          <label>
            <span>AI 대체율 <b id="atac-ai-replace-rate-value">50%</b></span>
            <input id="atac-ai-replace-rate" type="range" min="0" max="100" step="5" value={AI_TUTORING_DEFAULTS.aiReplaceRate} />
          </label>
          <label>
            <span>유지할 학원 과목 수</span>
            <input id="atac-academy-subjects-kept" type="number" min="0" max="8" step="1" value={AI_TUTORING_DEFAULTS.academySubjectsKept} />
          </label>
          <label>
            <span>부대비 감소율 <b id="atac-class-reduction-rate-value">50%</b></span>
            <input id="atac-class-reduction-rate" type="range" min="0" max="100" step="5" value={AI_TUTORING_DEFAULTS.classReductionRate} />
          </label>
          <label>
            <span>학습 리스크</span>
            <select id="atac-risk-level">
              {AI_TUTORING_RISK_OPTIONS.map((risk) => (
                <option value={risk.id} selected={risk.id === AI_TUTORING_DEFAULTS.riskLevel}>
                  {risk.label}
                </option>
              ))}
            </select>
          </label>
        </div>
      </form>
    </Fragment>

    <section class="atac-results" id="atac-result-panel" data-tone="positive">
      <div class="atac-section-head">
        <p class="atac-eyebrow">내 결과</p>
        <h2>AI 전환 시 예상 절감액</h2>
      </div>
      <div class="atac-kpi-grid">
        <article class="atac-kpi atac-kpi--primary">
          <span>월 절감액</span>
          <strong id="atac-monthly-saving">0원</strong>
          <small>현재 비용 - AI 전환 후 비용</small>
        </article>
        <article class="atac-kpi">
          <span>연간 절약액</span>
          <strong id="atac-annual-saving">0원</strong>
          <small>월 절감액 × 12개월</small>
        </article>
        <article class="atac-kpi">
          <span>현재 월 교육비</span>
          <strong id="atac-current-monthly-cost">0원</strong>
          <small>학원·과외·부대비 포함</small>
        </article>
        <article class="atac-kpi">
          <span>AI 전환 후 월 비용</span>
          <strong id="atac-ai-monthly-cost">0원</strong>
          <small>구독료·유지 학원비 포함</small>
        </article>
      </div>

      <article class="atac-recommendation">
        <div>
          <span class="atac-badge">시뮬레이션</span>
          <h3 id="atac-recommendation-label">하이브리드 전환 권장</h3>
          <p id="atac-recommendation-summary"></p>
        </div>
        <dl>
          <div>
            <dt>절감률</dt>
            <dd id="atac-saving-rate">0%</dd>
          </div>
          <div>
            <dt>회수 기준 수업 횟수</dt>
            <dd id="atac-breakeven-count">0회</dd>
          </div>
          <div>
            <dt>보호자 시간 비용</dt>
            <dd id="atac-parent-time-cost">0원</dd>
          </div>
        </dl>
      </article>

      <div class="atac-two-col">
        <section class="atac-card-section">
          <div class="atac-section-head">
            <p class="atac-eyebrow">과목별 적합도</p>
            <h2>AI 대체 가능 점수</h2>
          </div>
          <div id="atac-subject-score-list" class="atac-score-list"></div>
        </section>
        <section class="atac-card-section">
          <div class="atac-section-head">
            <p class="atac-eyebrow">시나리오 비교</p>
            <h2>완전 대체·하이브리드·유지</h2>
          </div>
          <div id="atac-scenario-comparison" class="atac-scenario-comparison"></div>
        </section>
      </div>

      <section class="atac-card-section">
        <div class="atac-section-head">
          <p class="atac-eyebrow">비용 분해</p>
          <h2>어디서 줄어드는지 확인</h2>
        </div>
        <div class="atac-table-wrap">
          <table>
            <tbody id="atac-cost-breakdown-table"></tbody>
          </table>
        </div>
      </section>

      <div class="atac-disclaimer">
        <span class="atac-badge">추정</span>
        <span class="atac-badge">가격 확인 필요</span>
        <span class="atac-badge">사용자 입력</span>
        <p>
          AI 학습 도구는 질문 풀이, 첨삭, 반복 학습을 도울 수 있지만 학습 습관, 입시 전략, 오답 검증까지 자동으로 해결하지는 않습니다.
          비용 절감액이 커도 첫 전환은 4~8주 단위로 작게 테스트하는 방식이 안전합니다.
        </p>
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="AI 과외 vs 학원 비용 계산기 활용법"
        intro={[
          "학원비 부담이 계속 오르는 가운데, AI 학습 앱이나 ChatGPT를 활용해 일부 과목을 직접 가르치거나 보조 학습 도구로 쓰는 가정이 늘고 있습니다. 다만 학원을 줄이는 게 정말 비용을 아끼는 선택인지, 어떤 과목부터 줄여야 효율적인지 판단하기는 쉽지 않습니다. 이 계산기는 현재 다니는 학원 과목 수와 과목당 월 학원비, AI 학습 앱 구독료를 입력해 학원을 줄였을 때의 월 절감액과 연간 절약액을 바로 계산해줍니다.",
          "모든 과목이 AI로 똑같이 대체되기는 어렵습니다. 영어 회화나 코딩처럼 즉각적인 피드백과 반복 연습이 중요한 과목은 AI 도구의 활용도가 높은 편이고, 수학·과학처럼 풀이 과정의 정확한 검증이 필요한 과목은 사람의 확인이 더 필요한 편입니다. 이 계산기는 과목별로 AI 대체 가능 점수를 함께 보여줘 어떤 과목부터 전환을 검토할지 가늠할 수 있게 했습니다.",
          "결과를 볼 때는 절감액 숫자만 보지 말고 AI 대체 가능 점수가 높은 과목부터 단계적으로 줄여나가는 방식으로 해석하는 것이 좋습니다. 대체 점수가 낮은 과목을 무리하게 학원에서 빼면 학습 결손으로 이어질 수 있으므로, 절감액과 학습 효과를 함께 고려해 결정하는 것을 권장합니다.",
          "이 계산기는 일반적인 학원비 시세와 AI 도구 구독료를 기준으로 한 추정치입니다. 실제 학원비는 지역, 학원 규모, 수업 형태(개인·그룹)에 따라 크게 달라질 수 있고, AI 도구의 학습 효과도 아이의 학습 습관과 자기주도 학습 역량에 따라 차이가 큽니다. 전환을 결정하기 전에 아이의 학습 성향을 함께 고려하는 것이 안전합니다.",
        ]}
        inputPoints={[
          "자녀 학년, 과목 수, 주간 수업 횟수를 먼저 입력합니다.",
          "과목당 학원비, 과외비, 교재비, 교통비처럼 현재 실제로 나가는 비용을 넣습니다.",
          "AI 구독료와 보호자 점검 시간을 넣고 완전 대체, 하이브리드, 학원 유지 시나리오를 비교합니다.",
        ]}
        criteria={[
          "계산 결과는 사용자 입력값을 바탕으로 한 교육비 절감 시뮬레이션입니다.",
          "AI 도구 가격과 학원비는 지역, 학년, 과목, 프로모션에 따라 달라질 수 있습니다.",
          "AI 학습 도구는 성적 향상이나 입시 결과를 보장하지 않으므로 학습 리스크가 높을수록 보수적으로 해석해야 합니다.",
        ]}
        faq={AI_TUTORING_FAQ}
        related={AI_TUTORING_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="atacData" type="application/json" set:html={JSON.stringify(seed)}></script>
  <script src={withBase("/scripts/ai-tutoring-vs-academy-cost.js")} defer></script>
</BaseLayout>
