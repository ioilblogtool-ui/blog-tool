---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import SummaryCards from "../../components/SummaryCards.astro";
import {
  SAC_META,
  SAC_SCHOOLS,
  SAC_LIVING_COSTS,
  SAC_FX_RATES,
  SAC_FAQ,
  SAC_RELATED_LINKS,
} from "../../data/southeastAsiaInternationalSchoolCostCalculator2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${SAC_META.slug}/`;

const countries = [
  { value: "MY", label: "말레이시아" },
  { value: "TH", label: "태국" },
  { value: "VN", label: "베트남" },
] as const;

const firstCountrySchools = SAC_SCHOOLS.filter((s) => s.country === "MY");
const firstCity = firstCountrySchools[0].city;
const firstCitySchools = firstCountrySchools.filter((s) => s.city === firstCity);
const firstSchool = firstCitySchools[0];

const faqItems = SAC_FAQ.map((f) => ({ question: f.question, answer: f.answer }));

const fmtKrw = (n: number) => {
  if (n >= 100_000_000) return `${(n / 100_000_000).toFixed(2)}억원`;
  if (n >= 10_000) return `${Math.round(n / 10_000).toLocaleString("ko-KR")}만원`;
  return `${Math.round(n).toLocaleString("ko-KR")}원`;
};
const krwForSchool = (school: (typeof SAC_SCHOOLS)[number]) => {
  const fx = SAC_FX_RATES.find((f) => f.currency === school.currency);
  if (!fx?.krwPerUnit) return null;
  return fmtKrw(school.tuitionTiers[0].annualLocal * fx.krwPerUnit);
};

// 6개 도시 전체를 대표 학년(첫 tier) 기준 원화 환산 오름차순 랭킹
const rankedSchools = SAC_SCHOOLS
  .map((school) => {
    const fx = SAC_FX_RATES.find((f) => f.currency === school.currency);
    const krw = fx?.krwPerUnit ? school.tuitionTiers[0].annualLocal * fx.krwPerUnit : null;
    return { school, krw };
  })
  .filter((row) => row.krw !== null)
  .sort((a, b) => (a.krw as number) - (b.krw as number));

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "@id": pageUrl,
    url: pageUrl,
    name: SAC_META.seoTitle,
    description: SAC_META.seoDescription,
    applicationCategory: "FinanceApplication",
    inLanguage: "ko-KR",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: SAC_FAQ.map((f) => ({
      "@type": "Question",
      name: f.question,
      acceptedAnswer: { "@type": "Answer", text: f.answer },
    })),
  },
];

const calcData = { schools: SAC_SCHOOLS, livingCosts: SAC_LIVING_COSTS, fxRates: SAC_FX_RATES };
---

<BaseLayout title={SAC_META.seoTitle} description={SAC_META.seoDescription} jsonLd={jsonLd}>
  <SiteHeader />

  <SimpleToolShell calculatorId={SAC_META.slug} pageClass="sac-page">
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="동남아 국제학교"
        title={SAC_META.title}
        description={SAC_META.description}
      />
      <InfoNotice
        title="계산 전 꼭 확인하세요"
        lines={[SAC_META.dataNote, "이 계산 결과는 재정 계획 참고용이며, 비자·이민 자격 판단과는 무관합니다."]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="sacResetBtn" copyId="sacCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel sac-input-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">국가·도시·학교·학년</h2>
          </div>
        </div>

        <section class="sac-input-section">
          <div class="form-grid">
            <label class="field">
              <span>국가</span>
              <select data-sac="country" class="input-select">
                {countries.map((c) => <option value={c.value}>{c.label}</option>)}
              </select>
            </label>
            <label class="field">
              <span>도시</span>
              <select data-sac="city" class="input-select">
                <option value={firstCity}>{firstSchool.cityLabel}</option>
              </select>
            </label>
            <label class="field">
              <span>학교</span>
              <select data-sac="school" class="input-select">
                {firstCitySchools.map((s) => <option value={s.id}>{s.name}</option>)}
              </select>
            </label>
            <label class="field">
              <span>학년 구간</span>
              <select data-sac="grade" class="input-select">
                {firstSchool.tuitionTiers.map((t) => <option value={t.tierKey}>{t.tierLabel}</option>)}
              </select>
            </label>
          </div>
        </section>

        <section class="sac-input-section">
          <div class="toggle-grid">
            <label class="mode-chip">
              <input type="radio" name="sacCompanion" value="whole_family" checked />
              <span>가족 전체 동반</span>
            </label>
            <label class="mode-chip">
              <input type="radio" name="sacCompanion" value="mother_only" />
              <span>엄마 동반</span>
            </label>
            <label class="mode-chip">
              <input type="radio" name="sacCompanion" value="none" />
              <span>미동반(기숙)</span>
            </label>
          </div>
        </section>

        <section class="sac-input-section">
          <div class="form-grid">
            <label class="field">
              <span>자녀 수</span>
              <input data-sac="children" type="number" min="1" max="3" value="1" class="input-number" />
            </label>
            <label class="field">
              <span>가구 연소득 (만원, 선택)</span>
              <input data-sac="income" type="number" min="0" step="100" placeholder="예: 15000" class="input-number" />
            </label>
          </div>
        </section>
      </article>
    </Fragment>

    <section class="sac-section sac-result-section" aria-live="polite">
      <div class="section-header">
        <p class="section-header__eyebrow">계산 결과</p>
        <h2>예상 총비용</h2>
      </div>
      <SummaryCards
        columns={4}
        items={[
          { label: "연간 학비", id: "sac-result-tuition" },
          { label: "연간 생활비", id: "sac-result-living" },
          { label: "연간 총비용", id: "sac-result-total" },
          { label: "5년 누적", id: "sac-result-5year" },
        ]}
      />
      <p class="sac-insight" data-sac-result="insight"></p>
    </section>

    <section class="sac-section">
      <div class="sac-source-row">
        <span class="sac-confidence-badge" data-sac-result="confidenceBadge" data-confidence="snippet">-</span>
        <span class="sac-source-badge">
          출처: <a data-sac-result="sourceLink" href="#" target="_blank" rel="noopener noreferrer nofollow">학교 공식 페이지</a>
          <span data-sac-result="sourceDate"></span>
        </span>
      </div>
      <p class="sac-note" data-sac-result="dataNote"></p>
    </section>

    <section class="sac-section">
      <div class="section-header">
        <p class="section-header__eyebrow">한국과 비교</p>
        <h2>한국 국제학교와 비교하면</h2>
      </div>
      <article class="sac-kr-compare-card">
        <p>계산기에서 학교·학년을 선택하면 국내 국제학교 대표 학비와 비교해 보여드립니다. 정확한 국내 비교는 <a href={withBase("/tools/international-school-tuition-calculator-2026/")}>국내 국제학교 학비 계산기</a>를 함께 확인하세요.</p>
      </article>
    </section>

    <section class="sac-section">
      <div class="section-header">
        <p class="section-header__eyebrow">국가별 비교</p>
        <h2>국가별 대표 학교 한눈에 보기</h2>
      </div>
      <div class="sac-country-tab-row" id="sacMiniCompareTabs">
        <button type="button" class="sac-tab-btn is-active" data-country-tab="MY">말레이시아</button>
        <button type="button" class="sac-tab-btn" data-country-tab="TH">태국</button>
        <button type="button" class="sac-tab-btn" data-country-tab="VN">베트남</button>
      </div>
      <div class="table-wrap">
        <table class="sac-mini-compare-table">
          <thead>
            <tr><th>학교</th><th>도시</th><th>대표 학년 학비</th><th>원화 환산</th><th>확인</th></tr>
          </thead>
          <tbody>
            {SAC_SCHOOLS.map((school) => (
              <tr data-country-row={school.country}>
                <td>{school.name}</td>
                <td>{school.cityLabel}</td>
                <td>{school.tuitionTiers[0].annualLocal.toLocaleString("en-US")} {school.currency}~</td>
                <td>{krwForSchool(school) ?? "-"}</td>
                <td>{school.dataConfidence === "official_confirmed" ? "공식 확인" : "검색 요약"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="sac-section">
      <div class="section-header">
        <p class="section-header__eyebrow">전체 랭킹</p>
        <h2>28개교, 대표 학년 원화 환산 저렴한 순</h2>
        <p class="sac-note">대표 학년(첫 번째 학년 구간) 학비를 확정 환율로 환산해 정렬했습니다. 생활비는 포함하지 않은 학비만의 순위입니다.</p>
      </div>
      <ol class="sac-ranking-list">
        {rankedSchools.map((row, idx) => (
          <li class="sac-ranking-item">
            <span class="sac-ranking-item__rank">{idx + 1}</span>
            <span class="sac-ranking-item__name">{row.school.name} <small>({row.school.cityLabel})</small></span>
            <span class="sac-ranking-item__value">{fmtKrw(row.krw as number)}</span>
          </li>
        ))}
      </ol>
    </section>

    <section class="sac-section">
      <div class="section-header">
        <p class="section-header__eyebrow">다음 확인</p>
        <h2>관련 리포트</h2>
      </div>
      <div class="sac-cta-grid">
        {SAC_RELATED_LINKS.map((link) => (
          <a href={withBase(link.href)} class="sac-cta-card">
            <strong>{link.label}</strong>
            <span>{link.description}</span>
          </a>
        ))}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="동남아 국제학교 비용 계산기 이용 가이드"
        intro={[
          "동남아 국제학교는 한국 국제학교보다 학비가 저렴하다고 알려져 있지만, 실제로는 부모 동반 여부와 거주 형태에 따라 총비용이 크게 달라집니다. 이 계산기는 학비뿐 아니라 생활비까지 합산해 실제 체감 비용을 보여줍니다.",
          "국가·도시별로 데이터 확인 수준이 다릅니다. 일부 학교는 공식 페이지 원문으로 확인했지만, 대부분은 검색 결과 요약을 기반으로 하고 있어 실제 지원 전 반드시 학교 공식 입학처에서 재확인이 필요합니다.",
          "생활비 데이터는 조호바루를 제외한 5개 도시에서 확보되었습니다. 조호바루를 선택하면 학비만 계산되며, 결과 화면에 어떤 값이 포함/미포함되었는지 명확히 표시됩니다.",
          "이 계산 결과는 재정 계획 참고용이며, 각국 장기체류·교육 비자 자격과는 무관합니다. 비자 요건은 반드시 해당국 이민청 공식 자료에서 확인하세요.",
        ]}
        criteria={[
          `학비·생활비는 학교 공식 페이지 또는 검색 결과 기준 ${SAC_META.updatedAt} 확인입니다.`,
          "학교별 데이터 신뢰도가 다르며, 각 학교 카드의 신뢰도 배지로 구분해 표시합니다.",
          "조호바루는 생활비 데이터가 없어 학비만 계산되며 총비용은 표시되지 않습니다.",
          "이 계산 결과는 재정 계획 참고용이며 비자·이민 자격 판단과는 무관합니다.",
        ]}
        faq={faqItems}
        related={SAC_RELATED_LINKS.map((l) => ({ href: l.href, label: l.label }))}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="sac-data" type="application/json" set:html={JSON.stringify(calcData)}></script>
  <script type="module" src={withBase("/scripts/southeast-asia-international-school-cost-calculator-2026.js")}></script>
</BaseLayout>
