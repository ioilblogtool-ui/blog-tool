---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import DesignTrustPanel from "../../components/DesignTrustPanel.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  ASIC_DEFAULT_INPUT,
  ASIC_FAQ,
  ASIC_JOB_PRESETS,
  ASIC_META,
  ASIC_NEXT_STEPS,
  ASIC_RELATED_LINKS,
} from "../../data/aiSideIncomeCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const config = { presets: ASIC_JOB_PRESETS, defaultInput: ASIC_DEFAULT_INPUT };
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: ASIC_META.title,
    description: ASIC_META.description,
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    url: `https://bigyocalc.com/tools/${ASIC_META.slug}/`,
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: ASIC_FAQ.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout title="AI 부업 수입 계산기 | 도구비 빼고 실제 얼마나 남을까" description={ASIC_META.description} jsonLd={jsonLd}>
  <SiteHeader />

  <SimpleToolShell calculatorId={ASIC_META.slug} pageClass="op-page asic-page" resultFirst={true}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="AI 부업 계산"
        title="AI 부업 수입 계산기"
        description="부업 시간, 예상 시급, AI 생산성 향상률, 도구 구독료를 넣으면 도구비 차감 후 실제 남는 금액을 계산합니다."
      />
      <InfoNotice title="추정 계산 안내" lines={[ASIC_META.caution, `업데이트 기준: ${ASIC_META.updatedAt}`]} />
      <DesignTrustPanel
        title="AI 부업 수입 계산 기준"
        updatedAt={ASIC_META.updatedAt}
        notes={[
          "업종별 기본 시급과 생산성 향상률은 시장 단가를 참고한 추정 프리셋입니다.",
          "세금, 플랫폼 수수료, 환율, 실제 수주 성공률은 별도로 반영해야 합니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="asicResetBtn" copyId="asicCopyLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <form id="asicForm" class="panel asic-form">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">부업 조건 입력</h2>
          </div>
        </div>

        <label class="field">
          <span>부업 업종</span>
          <select id="asicJobType" data-asic-input="job">
            {ASIC_JOB_PRESETS.map((preset) => <option value={preset.id} selected={preset.id === ASIC_DEFAULT_INPUT.jobType}>{preset.label}</option>)}
          </select>
        </label>

        <div class="asic-preset-grid" aria-label="부업 업종 프리셋">
          {ASIC_JOB_PRESETS.map((preset) => (
            <button type="button" class:list={["asic-preset-chip", { "is-active": preset.id === ASIC_DEFAULT_INPUT.jobType }]} data-asic-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.defaultHourlyRate.toLocaleString("ko-KR")}원 · +{preset.defaultProductivityBoost}%</span>
            </button>
          ))}
        </div>

        <div class="form-grid asic-input-grid">
          <label class="field">
            <span>월 부업 시간</span>
            <input id="asicHours" data-asic-input="hours" type="number" min="0" max="300" step="1" value={ASIC_DEFAULT_INPUT.hoursPerMonth} />
          </label>
          <label class="field">
            <span>AI 미사용 기준 시급</span>
            <input id="asicRate" data-asic-input="rate" type="number" min="0" step="1000" value={ASIC_DEFAULT_INPUT.baseHourlyRate} />
            <small>AI 없이도 받을 수 있는 예상 시장 단가를 입력하세요.</small>
          </label>
          <label class="field">
            <span>AI 생산성 향상률 <b id="asicBoostLabel">{ASIC_DEFAULT_INPUT.aiProductivityBoost}%</b></span>
            <input id="asicBoost" data-asic-input="boost" type="range" min="0" max="200" step="5" value={ASIC_DEFAULT_INPUT.aiProductivityBoost} />
            <small>70% 향상은 같은 시간에 1.7배 결과물을 만든다는 뜻입니다.</small>
          </label>
          <label class="field">
            <span>AI 도구 월 구독료 합산</span>
            <input id="asicToolCost" data-asic-input="toolCost" type="number" min="0" step="1000" value={ASIC_DEFAULT_INPUT.aiToolMonthlyCost} />
            <small>ChatGPT, Claude, Cursor, Midjourney 등 부업에 쓰는 월비용을 합산합니다.</small>
          </label>
        </div>
      </form>
    </Fragment>

    <section class="asic-section">
      <div class="asic-kpi-grid">
        <article class="asic-kpi asic-kpi--main">
          <p>AI 사용 후 예상 수입</p>
          <strong id="asicAiIncome">-</strong>
          <span>도구비 차감 전</span>
        </article>
        <article class="asic-kpi">
          <p>AI 미사용 기준 수입</p>
          <strong id="asicBaseIncome">-</strong>
          <span>도구 없이 일했을 때</span>
        </article>
        <article class="asic-kpi">
          <p>AI 기여 추가 수입</p>
          <strong id="asicContribution">-</strong>
          <span>AI로 더 번 금액</span>
        </article>
        <article class="asic-kpi asic-kpi--accent">
          <p>도구비 차감 순수입</p>
          <strong id="asicNetIncome">-</strong>
          <span>최종 남는 금액</span>
        </article>
        <article class="asic-kpi">
          <p>실효 시급</p>
          <strong id="asicEffectiveRate">-</strong>
          <span>순수입 ÷ 월 부업 시간</span>
        </article>
      </div>

      <article class="asic-message" id="asicMessageBox">
        <h2 id="asicMessageTitle">계산 중입니다</h2>
        <p id="asicMessageText">입력값에 맞춰 AI 부업 수입을 계산합니다.</p>
      </article>
    </section>

    <section class="asic-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">비교</p>
        <h2>기준 수입과 AI 사용 수입을 한눈에 봅니다</h2>
      </div>
      <div class="asic-compare-bar" aria-label="수입 비교 막대">
        <div class="asic-bar-row">
          <span>기준</span>
          <div class="asic-bar-track"><div id="asicBaseBar" class="asic-bar-fill asic-bar-fill--base"></div></div>
          <strong id="asicBaseBarValue">-</strong>
        </div>
        <div class="asic-bar-row">
          <span>AI 사용</span>
          <div class="asic-bar-track"><div id="asicAiBar" class="asic-bar-fill"></div></div>
          <strong id="asicAiBarValue">-</strong>
        </div>
      </div>
    </section>

    <section class="asic-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">시나리오</p>
        <h2>생산성 향상률별 결과</h2>
      </div>
      <div class="table-wrap">
        <table class="asic-scenario-table">
          <thead>
            <tr>
              <th>향상률</th>
              <th>AI 사용 수입</th>
              <th>AI 기여 수입</th>
              <th>순수입</th>
            </tr>
          </thead>
          <tbody id="asicScenarioBody"></tbody>
        </table>
      </div>
    </section>

    <section class="asic-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">업종별 팁</p>
        <h2>AI를 어디에 쓰는지에 따라 회수 속도가 달라집니다</h2>
      </div>
      <div class="asic-tip-grid">
        {ASIC_JOB_PRESETS.map((preset) => (
          <article class="asic-tip-card" data-asic-tip={preset.id}>
            <span>{preset.label}</span>
            <strong>{preset.representativeTools.join(" · ")}</strong>
            <p>{preset.incomeTip}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="asic-section">
      <div class="section-header section-header--compact">
        <p class="section-header__eyebrow">다음 계산</p>
        <h2>AI 비용과 부업 효율을 이어서 점검하세요</h2>
      </div>
      <div class="asic-next-grid">
        {ASIC_NEXT_STEPS.map((item) => (
          <a class="asic-next-card" href={withBase(item.href)}>
            <span>{item.eyebrow}</span>
            <strong>{item.label}</strong>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="AI 부업 수입 계산기, 생산성 향상률과 도구비를 함께 보는 이유"
        intro={[
          "퇴근 후나 주말에 개발 외주, 글쓰기·번역, 콘텐츠 제작, 온라인 강의, 디자인·영상, 데이터 라벨링 같은 부업을 하면서 ChatGPT Plus, Claude Pro, Cursor, Midjourney 같은 AI 도구를 같이 쓰는 경우가 늘고 있습니다. 도구 구독을 시작하기 전이나 이미 쓰고 있는 도구가 실제로 수입에 도움이 되는지 점검하고 싶을 때, 부업 시간과 시급만으로는 보이지 않는 실제 손에 남는 금액을 확인하는 용도로 이 계산기를 쓸 수 있습니다.",
          "계산 방식은 월 부업 시간에 AI 미사용 기준 시급을 곱해 기준 수입을 구하고, 여기에 생산성 향상률을 반영해 AI 사용 수입을 산출합니다. 생산성 향상률은 AI 도구를 썼을 때 같은 시간에 얼마나 더 많은 결과를 낼 수 있는지를 뜻하는 값으로, 50% 향상이라면 같은 시간에 1.5배의 결과물을 만든다는 가정입니다. 여기서 다시 월 AI 도구 구독료를 빼야 실제로 남는 순수입을 알 수 있기 때문에, 수입 증가분과 도구비 지출을 분리해서 계산하는 구조입니다.",
          "결과에서는 AI 기여 추가 수입과 도구비 회수 기간을 함께 봐야 의미가 있습니다. AI 기여 추가 수입이 도구 구독료보다 충분히 크면 투자한 비용 이상의 효과를 보고 있다는 뜻이고, 회수 기간이 짧게 나올수록 도구 비용을 빠르게 상쇄하는 구조입니다. 반대로 기여 수입이 0원에 가깝거나 회수 기간이 길게 나온다면 현재 쓰는 도구 조합이 부업 성격과 맞지 않을 가능성을 점검해볼 필요가 있습니다.",
          "이 결과는 실제 수입을 보장하지 않는 추정값입니다. 생산성 향상률은 사용자가 직접 입력하는 가정값이라 실제 작업 환경에서는 달라질 수 있고, 수주 가능성, 납품 품질, 플랫폼 수수료, 세금, 클라이언트 조건 같은 변수는 이 계산기에 포함되지 않습니다. 부업 수입을 본격적으로 계획하기 전에는 실제 몇 건의 작업을 직접 처리해보며 향상률과 시급을 현실에 맞게 보정하는 과정을 권장합니다.",
        ]}
        inputPoints={[
          "월 부업 시간은 실제로 지속 가능한 시간을 보수적으로 입력합니다.",
          "예상 시급은 AI를 쓰지 않아도 받을 수 있는 시장 단가로 잡습니다.",
          "AI 도구비는 부업에 직접 쓰는 월 구독료만 합산합니다.",
          "도구비 회수 기간이 길게 나오면 무료 플랜이나 저가 조합부터 검토합니다.",
        ]}
        criteria={[
          "기준 수입은 월 부업 시간 × AI 미사용 기준 시급으로 계산합니다.",
          "AI 사용 수입은 기준 수입 × (1 + 생산성 향상률 ÷ 100)으로 계산합니다.",
          "순수입은 AI 사용 수입에서 월 AI 도구 구독료를 뺀 금액입니다.",
          "도구비 회수 기간은 월 도구비 ÷ AI 기여 추가 수입으로 계산하며, 기여 수입이 0원이면 회수 불가로 표시합니다.",
        ]}
        faq={ASIC_FAQ}
        related={ASIC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="asicConfig" type="application/json" set:html={JSON.stringify(config)}></script>
  <script type="module" src={withBase("/scripts/ai-side-income-calculator.js")}></script>
</BaseLayout>
