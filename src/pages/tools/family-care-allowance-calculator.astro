---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  FCAC_CARE_GAP_LABELS,
  FCAC_CONFIG,
  FCAC_FAQ,
  FCAC_META,
  FCAC_PRESETS,
  FCAC_REGION_LABELS,
  FCAC_RELATED_LINKS,
  FCAC_SEO_CONTENT,
} from "../../data/familyCareAllowanceCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${FCAC_META.slug}/`;
---

<BaseLayout
  title={FCAC_META.seoTitle}
  description={FCAC_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: FCAC_META.title,
      applicationCategory: "UtilityApplication",
      operatingSystem: "All",
      description: FCAC_META.seoDescription,
      url: pageUrl,
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: FCAC_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={FCAC_META.slug} pageClass="fcac-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="가족돌봄수당 자가점검"
        title="가족돌봄수당 계산기"
        description="아이 생년월과 가구 소득, 돌봄시간을 입력하면 가족돌봄수당 신청 가능성과 예상 지원금을 빠르게 점검합니다."
        badges={["가족돌봄수당", "조부모 돌봄수당", "2026", "자가 점검"]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          FCAC_META.dataNote,
          "거주 지역의 사업 참여 여부는 반드시 별도로 확인해야 합니다.",
          "최대 지원개월은 지역에 따라 다릅니다(서울 13개월, 그 외 12개월 사례).",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="fcacResetBtn" copyId="fcacCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel fcac-quick-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">2026 기준</p>
            <h2 class="panel__title">대상 24~36개월 · 1자녀 월 30만원</h2>
          </div>
          <p class="panel-heading__summary">자녀 수에 따라 월 30만~60만원, 지역에 따라 최대 지원개월이 다릅니다.</p>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 예시</p>
            <h2 class="panel__title">상황을 골라 시작</h2>
          </div>
        </div>
        <div class="fcac-preset-grid">
          {FCAC_PRESETS.map((preset) => (
            <button type="button" class="fcac-preset-btn" data-fcac-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.summary}</span>
            </button>
          ))}
        </div>
      </article>

      <article class="panel fcac-input-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">지역·아이·소득·돌봄시간</h2>
          </div>
        </div>

        <section class="fcac-input-section" aria-labelledby="fcac-basic-title">
          <h3 id="fcac-basic-title">기본 정보</h3>
          <div class="form-grid">
            <label class="field">
              <span>거주 지역</span>
              <select data-fcac="region">
                {Object.entries(FCAC_REGION_LABELS).map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
            <label class="field">
              <span>돌봄공백 사유</span>
              <select data-fcac="careGapReason">
                {Object.entries(FCAC_CARE_GAP_LABELS).map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
          </div>
        </section>

        <section class="fcac-input-section" aria-labelledby="fcac-age-title">
          <h3 id="fcac-age-title">아이 생년월 · 신청 예정월</h3>
          <div class="form-grid">
            <label class="field">
              <span>아이 출생 연도</span>
              <input data-fcac="childBirthYear" type="number" class="input-number" value="2025" />
            </label>
            <label class="field">
              <span>아이 출생 월</span>
              <input data-fcac="childBirthMonth" type="number" min="1" max="12" class="input-number" value="3" />
            </label>
            <label class="field">
              <span>신청 예정 연도</span>
              <input data-fcac="applyYear" type="number" class="input-number" value="2027" />
            </label>
            <label class="field">
              <span>신청 예정 월</span>
              <input data-fcac="applyMonth" type="number" min="1" max="12" class="input-number" value="3" />
            </label>
          </div>
        </section>

        <section class="fcac-input-section" aria-labelledby="fcac-income-title">
          <h3 id="fcac-income-title">가구·소득</h3>
          <div class="form-grid">
            <label class="field">
              <span>돌봄대상 자녀 수</span>
              <input data-fcac="childCount" type="number" min="1" max="3" class="input-number" value="1" />
            </label>
            <label class="field">
              <span>가구원 수</span>
              <input data-fcac="householdSize" type="number" min="1" max="6" class="input-number" value="3" />
            </label>
            <label class="field">
              <span>가구 건강보험료(월)</span>
              <input data-fcac="healthInsuranceFee" type="text" inputmode="numeric" class="input-number" value="270,000" />
              <small>장기요양보험료는 제외한 금액입니다.</small>
            </label>
            <label class="field">
              <span>월 예상 돌봄시간</span>
              <input data-fcac="monthlyCareHours" type="number" class="input-number" value="40" />
            </label>
          </div>
        </section>
      </article>
    </Fragment>

    <section class="fcac-section fcac-result-section" aria-live="polite">
      <div class="section-header">
        <p class="section-header__eyebrow">계산 결과</p>
        <h2>신청 가능성과 예상 지원금</h2>
        <p>입력값을 바꾸면 판정과 예상 지원금이 즉시 다시 계산됩니다.</p>
      </div>

      <div class="fcac-judgement-card">
        <span>종합 판정</span>
        <strong data-fcac-result="judgement">-</strong>
      </div>

      <div class="fcac-check-grid">
        <article class="fcac-check-item"><span>대상 연령(24~36개월)</span><strong data-fcac-result="ageCheck">-</strong></article>
        <article class="fcac-check-item"><span>소득 기준</span><strong data-fcac-result="incomeCheck">-</strong> <small data-fcac-result="incomeBadge"></small></article>
        <article class="fcac-check-item"><span>돌봄시간(월 40시간↑)</span><strong data-fcac-result="careHoursCheck">-</strong></article>
        <article class="fcac-check-item fcac-check-item--region"><span>거주 지역 참여 여부</span><strong data-fcac-result="regionCheck">확인 필요</strong></article>
      </div>

      <div class="fcac-kpi-grid">
        <article class="fcac-kpi fcac-kpi--main"><span>예상 월 지원금</span><strong data-fcac-result="monthlyAmount">-</strong></article>
        <article class="fcac-kpi fcac-kpi--accent"><span>예상 최대 총 지원금</span><strong data-fcac-result="maxTotal">-</strong></article>
      </div>
    </section>

    <section class="fcac-section">
      <div class="section-header">
        <p class="section-header__eyebrow">다음 확인</p>
        <h2>왜 확인이 더 필요한가</h2>
      </div>
      <div class="fcac-warning-grid">
        <article class="fcac-warning"><strong>지자체별 자체 사업</strong><p>가족돌봄수당은 전국 통일 제도가 아니라 시·도 및 시군구별로 참여 여부가 다른 자체 사업입니다.</p></article>
        <article class="fcac-warning fcac-warning--warning"><strong>소득기준 판정 시점</strong><p>신청일이 아니라 해당 연도 특정 기준일(보통 3월 말경) 건강보험료로 판정하는 경우가 많습니다.</p></article>
        <article class="fcac-warning fcac-warning--warning"><strong>최대 지원개월 지역차</strong><p>서울 13개월, 그 외 지역은 12개월로 운영되는 사례가 있어 정확한 개월 수는 지자체 공고로 재확인해야 합니다.</p></article>
      </div>
      <div class="fcac-action-grid">
        {FCAC_RELATED_LINKS.map((link) => <a href={withBase(link.href)}>{link.label}</a>)}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle={FCAC_SEO_CONTENT.introTitle}
        intro={FCAC_SEO_CONTENT.intro}
        inputPoints={FCAC_SEO_CONTENT.inputPoints}
        criteria={FCAC_SEO_CONTENT.criteria}
        faq={FCAC_FAQ}
        related={FCAC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="fcac-data" type="application/json" set:html={JSON.stringify(FCAC_CONFIG)} />
  <script type="module" src={withBase("/scripts/family-care-allowance-calculator.js")}></script>
</BaseLayout>
