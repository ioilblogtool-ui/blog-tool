---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  ACQUISITION_TAX_RATE,
  REGISTRATION_FEE_RATE,
  DEFAULT_SPECIAL_LOAN_RATE,
  NRB_PRESETS,
  NRB_FAQ,
  NRB_RELATED_LINKS,
} from "../../data/newlywedRentVsBuy";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const config = {
  ACQUISITION_TAX_RATE,
  REGISTRATION_FEE_RATE,
  DEFAULT_SPECIAL_LOAN_RATE,
  PRESETS: NRB_PRESETS,
};

const faqSchema = NRB_FAQ.map((item) => ({
  "@type": "Question",
  name: item.question,
  acceptedAnswer: { "@type": "Answer", text: item.answer },
}));
---

<BaseLayout
  title="신혼집 전세 vs 매매 손익 계산기 | 기회비용·손익분기·집값 상승 시나리오 비교"
  description="전세 보증금·매매가·대출 금리·거주 기간을 입력하면 5·10년 누적 순비용과 손익분기 전환 시점을 자동 계산합니다. 신혼부부 특례대출 조건 포함."
  ogImage="/og/og-home.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "신혼집 전세 vs 매매 손익 계산기",
    applicationCategory: "FinanceApplication",
    operatingSystem: "All",
    description: "전세 기회비용, 집값 상승 시나리오, 손익분기 전환 시점을 한 번에 계산하는 도구",
    url: `${(import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "")}/tools/newlywed-rent-vs-buy/`,
    mainEntity: { "@type": "FAQPage", mainEntity: faqSchema },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="newlywed-rent-vs-buy" pageClass="nrb-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="신혼집 전세 vs 매매"
        title="신혼집 전세 vs 매매 손익 계산기"
        description="전세 기회비용, 집값 상승, 손익분기 전환 시점을 한 번에 계산합니다"
      />
      <InfoNotice
        lines={[
          "이 계산기는 일반적인 참고 시뮬레이션입니다.",
          "실제 대출 조건·세금·시세는 금융기관 및 등기소 확인이 필요합니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="nrbResetBtn" copyId="nrbCopyLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <!-- 프리셋 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">시나리오 예시</p>
            <h2 class="panel__title">버튼으로 바로 넣기</h2>
          </div>
        </div>
        <div class="nrb-preset-grid" id="nrbPresetGrid">
          {NRB_PRESETS.map((p, i) => (
            <button type="button" class={`nrb-preset-btn${i === 0 ? ' is-active' : ''}`} data-preset-id={p.id}>
              {p.label}
            </button>
          ))}
        </div>
      </article>

      <!-- 전세 조건 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">전세 조건</p>
            <h2 class="panel__title">전세 입력</h2>
          </div>
        </div>
        <div class="form-grid">
          <label class="field">
            <span>전세 보증금 (원)</span>
            <input type="text" inputmode="numeric" data-nrb-input="jeonseDeposit" id="nrbJeonseDeposit" class="input-number" value="300,000,000" />
          </label>
          <label class="field">
            <span>전세 대출금 (원)</span>
            <input type="text" inputmode="numeric" data-nrb-input="jeonseLoan" id="nrbJeonseLoan" class="input-number" value="150,000,000" />
          </label>
          <label class="field">
            <span>전세 대출 금리 (%)</span>
            <input type="number" min="0" max="10" step="0.1" data-nrb-input="jeonseLoanRate" id="nrbJeonseLoanRate" class="input-number" value="3.0" />
            <small class="nrb-field-hint">버팀목 전세대출(신혼부부 우대) 기준 연 2.0~3.5%</small>
          </label>
        </div>
      </article>

      <!-- 매매 조건 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">매매 조건</p>
            <h2 class="panel__title">매매 입력</h2>
          </div>
        </div>
        <div class="form-grid">
          <label class="field">
            <span>매매가 (원)</span>
            <input type="text" inputmode="numeric" data-nrb-input="buyPrice" id="nrbBuyPrice" class="input-number" value="500,000,000" />
          </label>
          <label class="field">
            <span>매매 대출금 (원)</span>
            <input type="text" inputmode="numeric" data-nrb-input="buyLoan" id="nrbBuyLoan" class="input-number" value="300,000,000" />
          </label>
          <label class="field">
            <span>매매 대출 금리 (%)</span>
            <input type="number" min="0" max="10" step="0.1" data-nrb-input="buyLoanRate" id="nrbBuyLoanRate" class="input-number" value="4.0" />
          </label>
          <label class="field">
            <span>대출 상환 방식</span>
            <select data-nrb-input="loanType" id="nrbLoanType" class="select">
              <option value="equal-payment" selected>원리금균등</option>
              <option value="equal-principal">원금균등</option>
              <option value="bullet">만기일시상환</option>
            </select>
          </label>
          <label class="field nrb-checkbox-field">
            <input type="checkbox" data-nrb-input="includeAcquisitionTax" id="nrbIncludeTax" checked />
            <span>취득세·등기비 포함</span>
          </label>
        </div>
      </article>

      <!-- 시나리오 슬라이더 -->
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">시나리오 설정</p>
            <h2 class="panel__title">기간·상승률·수익률</h2>
          </div>
        </div>

        <div class="nrb-slider-group">
          <div class="nrb-slider-label">
            <span>예상 거주 기간</span>
            <span class="nrb-slider-value" id="nrbLivingYearsVal">5년</span>
          </div>
          <input type="range" min="1" max="20" step="1" value="5" data-nrb-input="livingYears" id="nrbLivingYears" class="nrb-slider" />
        </div>

        <div class="nrb-slider-group">
          <div class="nrb-slider-label">
            <span>집값 연 상승률</span>
            <span class="nrb-slider-value" id="nrbGrowthRateVal">2%</span>
          </div>
          <input type="range" min="-5" max="15" step="0.5" value="2" data-nrb-input="housePriceGrowthRate" id="nrbGrowthRate" class="nrb-slider" />
          <small class="nrb-field-hint">최근 5년 수도권 평균 약 3~4%, 전국 평균 약 2%</small>
        </div>

        <div class="nrb-slider-group">
          <div class="nrb-slider-label">
            <span>보증금 운용 수익률</span>
            <span class="nrb-slider-value" id="nrbDepositReturnVal">4%</span>
          </div>
          <input type="range" min="0" max="10" step="0.5" value="4" data-nrb-input="depositReturnRate" id="nrbDepositReturn" class="nrb-slider" />
          <small class="nrb-field-hint">예금 3~4%, ETF 기대수익 4~7% 사이에서 설정하세요</small>
        </div>

        <!-- 특례대출 토글 -->
        <div class="nrb-special-toggle-row">
          <label class="nrb-toggle-label">
            <span>신혼부부 특례대출 적용</span>
            <input type="checkbox" data-nrb-input="isSpecialLoan" id="nrbIsSpecialLoan" class="nrb-toggle-checkbox" />
            <span class="nrb-toggle-slider"></span>
          </label>
        </div>
        <div class="nrb-special-field" id="nrbSpecialField">
          <div class="nrb-slider-group" style="margin-top:12px;">
            <label class="field">
              <span>특례대출 금리 (%)</span>
              <input type="number" min="0" max="10" step="0.1" data-nrb-input="specialLoanRate" id="nrbSpecialLoanRate" class="input-number" value="2.7" />
              <small class="nrb-field-hint">신혼부부 구입자금 특례대출 최저 연 1.85%~3.3% (2026 기준)</small>
            </label>
          </div>
        </div>
      </article>
    </Fragment>

    <!-- 결과 영역 -->
    <section class="nrb-section">
      <div class="nrb-section__head">
        <p class="nrb-section__eyebrow">계산 결과</p>
        <h2>기간별 전세 vs 매매 순비용 비교</h2>
        <p class="nrb-result-message" id="nrbResultMessage">입력값을 바꾸면 결과가 즉시 업데이트됩니다.</p>
      </div>

      <!-- KPI 카드 -->
      <div class="nrb-kpi-grid">
        <article class="nrb-kpi-card nrb-kpi-card--main">
          <p class="nrb-kpi-label" id="nrbKpiMainLabel">누적 순비용 차이</p>
          <strong class="nrb-kpi-value" id="nrbKpiMainValue">-</strong>
          <span class="nrb-kpi-sub" id="nrbKpiMainSub">거주 기간 기준</span>
        </article>
        <article class="nrb-kpi-card">
          <p class="nrb-kpi-label">전세 월 실부담</p>
          <strong class="nrb-kpi-value" id="nrbJeonseMonthlyValue">-</strong>
          <span class="nrb-kpi-sub">대출이자 + 기회비용 / 12</span>
        </article>
        <article class="nrb-kpi-card">
          <p class="nrb-kpi-label">매매 월 실부담</p>
          <strong class="nrb-kpi-value" id="nrbBuyMonthlyValue">-</strong>
          <span class="nrb-kpi-sub">대출 월 상환액</span>
        </article>
        <article class="nrb-kpi-card">
          <p class="nrb-kpi-label">손익분기 전환 시점</p>
          <strong class="nrb-kpi-value" id="nrbBreakevenValue">-</strong>
          <span class="nrb-kpi-sub" id="nrbBreakevenSub">매매가 유리해지는 시점</span>
        </article>
      </div>
    </section>

    <!-- 기간별 누적 비교표 -->
    <section class="nrb-section">
      <div class="nrb-section__head">
        <p class="nrb-section__eyebrow">기간별 비교</p>
        <h2>연도별 누적 순비용</h2>
      </div>
      <div class="table-wrap">
        <table class="nrb-compare-table" id="nrbCompareTable">
          <thead>
            <tr>
              <th>기간</th>
              <th>전세 누적</th>
              <th>매매 누적</th>
              <th>차이</th>
            </tr>
          </thead>
          <tbody id="nrbCompareTableBody">
            <tr><td colspan="4" style="text-align:center;color:#9ca3af;padding:20px;">계산 결과가 여기에 표시됩니다</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- 손익분기 라인 차트 -->
    <section class="nrb-section">
      <div class="nrb-section__head">
        <p class="nrb-section__eyebrow">손익분기 차트</p>
        <h2>전세 vs 매매 누적 비용 곡선</h2>
      </div>
      <div class="nrb-chart-wrap">
        <canvas id="nrbChart"></canvas>
      </div>
    </section>

    <!-- 특례대출 효과 카드 -->
    <div class="nrb-special-card" id="nrbSpecialCard">
      <p class="nrb-section__eyebrow" style="margin-bottom:12px;">신혼부부 특례대출 효과</p>
      <div class="nrb-special-row">
        <span id="nrbNormalRateLabel">일반 금리 적용 시 이자</span>
        <strong id="nrbNormalInterest">-</strong>
      </div>
      <div class="nrb-special-row">
        <span id="nrbSpecialRateLabel">특례금리 적용 시 이자</span>
        <strong id="nrbSpecialInterest">-</strong>
      </div>
      <div class="nrb-special-row" style="border-bottom:none;margin-top:4px;">
        <span>절감액</span>
        <strong class="nrb-special-saving" id="nrbSpecialSaving">-</strong>
      </div>
      <div style="margin-top:14px;">
        <a href="https://www.hf.go.kr" target="_blank" rel="noopener noreferrer" class="nrb-cta-btn" style="font-size:0.82rem;padding:6px 14px;">
          주택금융공사 특례대출 신청 →
        </a>
      </div>
    </div>

    <!-- N년 후 순자산 카드 -->
    <section class="nrb-section">
      <div class="nrb-section__head">
        <p class="nrb-section__eyebrow">자산 관점</p>
        <h2 id="nrbAssetTitle">거주 기간 후 매매 순자산</h2>
      </div>
      <div class="nrb-kpi-grid" style="grid-template-columns:repeat(2,1fr);">
        <article class="nrb-kpi-card">
          <p class="nrb-kpi-label" id="nrbHouseFinalLabel">집값 (N년 후)</p>
          <strong class="nrb-kpi-value" id="nrbHouseFinalValue">-</strong>
          <span class="nrb-kpi-sub">집값 상승률 반영</span>
        </article>
        <article class="nrb-kpi-card">
          <p class="nrb-kpi-label" id="nrbNetAssetLabel">매매 순자산 (N년 후)</p>
          <strong class="nrb-kpi-value" id="nrbNetAssetValue">-</strong>
          <span class="nrb-kpi-sub">집값 – 잔여 대출</span>
        </article>
      </div>
    </section>

    <!-- 주택금융공사 CTA 배너 -->
    <div class="nrb-cta-banner">
      <span class="nrb-cta-text">신혼부부 특례대출 조건과 한도를 공식 사이트에서 확인하세요</span>
      <a href="https://www.hf.go.kr" target="_blank" rel="noopener noreferrer" class="nrb-cta-btn">주택금융공사 바로가기 →</a>
    </div>

    <!-- 리포트 CTA -->
    <div class="nrb-cta-banner" style="margin-top:12px;background:#f0fdf4;border-color:#6ee7b7;">
      <span class="nrb-cta-text" style="color:#065f46;">신혼집 비용의 전체 그림을 확인하고 싶다면</span>
      <a href="/reports/newlywed-cost-2026/" class="nrb-cta-btn" style="background:#0f6e56;">신혼부부 비용 완전 분석 →</a>
    </div>

    <Fragment slot="seo">
      <SeoContent
        introTitle="신혼집 전세 vs 매매 손익 계산기 — 기회비용과 손익분기 시점을 숫자로 확인하세요"
        intro={[
          "신혼집 마련의 첫 고민은 전세로 시작할지, 바로 매매로 진입할지입니다. 두 선택은 월 부담액뿐 아니라 기회비용·집값 상승·자산 형성 경로가 모두 다릅니다. 이 계산기는 전세 보증금이 묶이는 기회비용과 매매 후 집값 상승으로 생기는 자산 증가를 동시에 반영해 어느 시점에 어느 선택이 유리한지를 숫자로 보여줍니다.",
          "전세의 숨겨진 비용은 보증금 기회비용입니다. 전세 보증금 3억 원을 연 4% 예금에 넣으면 연 1,200만 원의 이자를 받을 수 있습니다. 이 기회비용은 전세 대출이자와 합산해 전세의 실질 연간 비용을 구성합니다. 이 계산기는 이 기회비용을 자동으로 반영합니다.",
          "매매의 유불리는 집값 상승률에 크게 달라집니다. 집값이 전혀 오르지 않는다면 대출이자가 순비용 전체가 되지만, 집값이 연 3% 오른다면 대출이자 중 일부를 집값 상승분이 상쇄합니다. 이 계산기에서 집값 연 상승률 슬라이더를 조정하면 시나리오별 손익분기 전환 시점이 즉시 바뀝니다.",
          "신혼부부 특례대출을 이용하면 일반 주담대보다 낮은 금리로 매매 부담을 줄일 수 있습니다. 2026년 기준 신혼부부 구입자금 특례대출은 연 1.85~3.3% 수준으로 제공됩니다. 이 계산기에서 특례대출 토글을 켜면 금리 차이로 인한 이자 절감액과 손익분기 시점 변화를 자동으로 확인할 수 있습니다.",
          "이 계산기의 결과는 입력한 가정(금리·집값 상승률·수익률)에 따라 크게 달라지는 참고용 시뮬레이션입니다. 실제 대출 한도와 금리는 금융기관 상담을 통해 확인하고, 취득세 감면 등 세부 혜택은 등기소·세무사에게 확인하세요.",
        ]}
        faq={NRB_FAQ}
        related={NRB_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="nrbData" type="application/json" set:html={JSON.stringify(config)}></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script type="module" src={withBase("/scripts/newlywed-rent-vs-buy.js")}></script>
</BaseLayout>
