---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  YRSC_CONFIG,
  YRSC_EXCLUDED_LABELS,
  YRSC_FAQ,
  YRSC_META,
  YRSC_PRESETS,
  YRSC_RELATED_LINKS,
  YRSC_SEO_CONTENT,
} from "../../data/youthRentSupportCalculator";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${YRSC_META.slug}/`;
---

<BaseLayout
  title={YRSC_META.seoTitle}
  description={YRSC_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: YRSC_META.title,
      applicationCategory: "UtilityApplication",
      operatingSystem: "All",
      description: YRSC_META.seoDescription,
      url: pageUrl,
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: YRSC_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={YRSC_META.slug} pageClass="yrsc-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="청년월세지원 자가점검"
        title="청년월세지원 계산기"
        description="나이, 본인·부모님 소득과 재산, 월세를 입력하면 청년월세지원 신청 가능 여부와 예상 지원금을 빠르게 점검합니다."
        badges={["청년월세지원", "국토교통부", "2026", "자가 점검"]}
      />
      <InfoNotice
        title="계산 전 확인 (중앙정부 통일 제도)"
        lines={[
          YRSC_META.dataNote,
          "지자체 자체 청년 월세지원과는 중복 수급이 불가능합니다.",
          "월 지원금은 실제 월세와 20만원 중 작은 금액으로 계산됩니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="yrscResetBtn" copyId="yrscCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel yrsc-quick-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">2026 기준</p>
            <h2 class="panel__title">월 최대 20만원 · 최대 24개월(480만원)</h2>
          </div>
          <p class="panel-heading__summary">2026년부터 상시 신청 전환 — 연중 언제든 신청할 수 있습니다.</p>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">빠른 예시</p>
            <h2 class="panel__title">상황을 골라 시작</h2>
          </div>
        </div>
        <div class="yrsc-preset-grid">
          {YRSC_PRESETS.map((preset) => (
            <button type="button" class="yrsc-preset-btn" data-yrsc-preset={preset.id}>
              <strong>{preset.label}</strong>
              <span>{preset.summary}</span>
            </button>
          ))}
        </div>
      </article>

      <article class="panel yrsc-input-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">나이·거주형태</h2>
          </div>
        </div>

        <section class="yrsc-input-section" aria-labelledby="yrsc-basic-title">
          <h3 id="yrsc-basic-title">기본 조건</h3>
          <div class="form-grid">
            <label class="field">
              <span>만 나이</span>
              <input data-yrsc="age" type="number" class="input-number" value="26" />
            </label>
            <label class="checkbox-option">
              <input type="checkbox" data-yrsc="isHomeless" checked />
              <span>무주택자입니다</span>
            </label>
            <label class="checkbox-option">
              <input type="checkbox" data-yrsc="livesSeparately" checked />
              <span>부모와 주민등록·실거주가 분리되어 있습니다</span>
            </label>
            <label class="checkbox-option">
              <input type="checkbox" data-yrsc="hasLeaseContract" checked />
              <span>임대차계약을 맺고 월세로 거주 중입니다</span>
            </label>
          </div>
        </section>

        <section class="yrsc-input-section" aria-labelledby="yrsc-youth-title">
          <h3 id="yrsc-youth-title">청년가구(본인) 기준</h3>
          <div class="form-grid">
            <label class="field">
              <span>본인 월소득</span>
              <input data-yrsc="monthlyIncome" type="text" inputmode="numeric" class="input-number" value="1,300,000" />
            </label>
            <label class="field">
              <span>본인 재산(총재산가액)</span>
              <input data-yrsc="youthAsset" type="text" inputmode="numeric" class="input-number" value="30,000,000" />
            </label>
          </div>
        </section>

        <section class="yrsc-input-section" aria-labelledby="yrsc-origin-title">
          <h3 id="yrsc-origin-title">원가구(부모님 등) 기준</h3>
          <div class="form-grid">
            <label class="field">
              <span>원가구 가구원수</span>
              <select data-yrsc="originHouseholdSize">
                {[1, 2, 3, 4, 5, 6].map((size) => <option value={size} selected={size === 4}>{size}인</option>)}
              </select>
              <small>부모님 등 원가구의 가구원수입니다(중위소득 100% 기준이 가구원수별로 다릅니다).</small>
            </label>
            <label class="field">
              <span>원가구 월소득</span>
              <input data-yrsc="originMonthlyIncome" type="text" inputmode="numeric" class="input-number" value="4,000,000" />
            </label>
            <label class="field">
              <span>원가구 재산(총재산가액)</span>
              <input data-yrsc="originAsset" type="text" inputmode="numeric" class="input-number" value="200,000,000" />
            </label>
          </div>
        </section>

        <section class="yrsc-input-section" aria-labelledby="yrsc-rent-title">
          <h3 id="yrsc-rent-title">월세·제외요건</h3>
          <div class="form-grid">
            <label class="field">
              <span>월세 금액</span>
              <input data-yrsc="monthlyRent" type="text" inputmode="numeric" class="input-number" value="350,000" />
            </label>
            <label class="field">
              <span>제외 사유</span>
              <select data-yrsc="excludedReason">
                {Object.entries(YRSC_EXCLUDED_LABELS).map(([value, label]) => <option value={value}>{label}</option>)}
              </select>
            </label>
          </div>
        </section>
      </article>
    </Fragment>

    <section class="yrsc-section yrsc-result-section" aria-live="polite">
      <div class="section-header">
        <p class="section-header__eyebrow">계산 결과</p>
        <h2>신청 가능성과 예상 지원금</h2>
        <p>입력값을 바꾸면 판정과 예상 지원금이 즉시 다시 계산됩니다.</p>
      </div>

      <div class="yrsc-judgement-card">
        <span>종합 판정</span>
        <strong data-yrsc-result="judgement">-</strong>
      </div>

      <div class="yrsc-check-grid">
        <article class="yrsc-check-item"><span>연령(19~34세)</span><strong data-yrsc-result="ageCheck">-</strong></article>
        <article class="yrsc-check-item"><span>무주택·별거·임대차</span><strong data-yrsc-result="basicCheck">-</strong></article>
        <article class="yrsc-check-item"><span>청년가구 소득</span><strong data-yrsc-result="youthIncomeCheck">-</strong></article>
        <article class="yrsc-check-item"><span>원가구 소득</span><strong data-yrsc-result="originIncomeCheck">-</strong></article>
        <article class="yrsc-check-item"><span>청년가구 재산</span><strong data-yrsc-result="youthAssetCheck">-</strong></article>
        <article class="yrsc-check-item"><span>원가구 재산</span><strong data-yrsc-result="originAssetCheck">-</strong></article>
        <article class="yrsc-check-item yrsc-check-item--exclude"><span>제외 사유</span><strong data-yrsc-result="excludedCheck">-</strong></article>
      </div>

      <div class="yrsc-kpi-grid">
        <article class="yrsc-kpi yrsc-kpi--main"><span>예상 월 지원금</span><strong data-yrsc-result="monthlyAmount">-</strong></article>
        <article class="yrsc-kpi yrsc-kpi--accent"><span>예상 최대 총 지원금(24개월)</span><strong data-yrsc-result="maxTotal">-</strong></article>
      </div>
    </section>

    <section class="yrsc-section">
      <div class="section-header">
        <p class="section-header__eyebrow">다음 확인</p>
        <h2>왜 제외될 수 있는가</h2>
      </div>
      <div class="yrsc-warning-grid">
        <article class="yrsc-warning yrsc-warning--warning"><strong>주택 소유자</strong><p>분양권·입주권을 포함해 주택을 소유하고 있으면 제외됩니다.</p></article>
        <article class="yrsc-warning yrsc-warning--warning"><strong>2촌 이내 혈족 임차</strong><p>부모, 형제자매 등 2촌 이내 혈족(배우자의 2촌 이내 혈족 포함)의 집에 세를 들어 사는 경우 제외됩니다.</p></article>
        <article class="yrsc-warning yrsc-warning--warning"><strong>공공임대주택 거주</strong><p>공무원임대주택을 포함한 공공임대주택 거주자는 제외됩니다.</p></article>
        <article class="yrsc-warning yrsc-warning--warning"><strong>지자체 자체 사업 중복수급</strong><p>서울형 등 지자체 자체 청년 월세지원을 이미 받고 있으면 중복 수급이 불가능합니다.</p></article>
      </div>
      <div class="yrsc-action-grid">
        {YRSC_RELATED_LINKS.map((link) => <a href={withBase(link.href)}>{link.label}</a>)}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle={YRSC_SEO_CONTENT.introTitle}
        intro={YRSC_SEO_CONTENT.intro}
        inputPoints={YRSC_SEO_CONTENT.inputPoints}
        criteria={YRSC_SEO_CONTENT.criteria}
        faq={YRSC_FAQ}
        related={YRSC_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="yrsc-data" type="application/json" set:html={JSON.stringify(YRSC_CONFIG)} />
  <script type="module" src={withBase("/scripts/youth-rent-support-calculator.js")}></script>
</BaseLayout>
