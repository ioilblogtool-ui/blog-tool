---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import SummaryCards from "../../components/SummaryCards.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
---

<BaseLayout title="6+6 부모육아휴직제 계산기" description="부모 모두 육아휴직을 쓸 때 특례 적용 여부와 일반 육아휴직 대비 차액을 비교하는 도구">
  <SiteHeader />

  <main class="container page-shell calculator-page" data-calculator="six-plus-six">
    <CalculatorHero
      eyebrow="특례 비교"
      title="6+6 부모육아휴직제 계산기"
      description="부모가 모두 육아휴직을 사용할 때 6+6 특례와 18개월 연장 가능성까지 반영해 일반 육아휴직 대비 차액을 계산합니다."
    />

    <section class="calculator-grid content-section">
      <div class="stack">
        <article class="panel">
          <h2 class="panel__title">부모 육아휴직 정보 입력</h2>
          <p class="panel__intro">엄마와 아빠 각각의 월 통상임금과 사용 개월 수를 넣으면 6+6 적용 여부와 가구 총액 차이를 빠르게 볼 수 있습니다.</p>
          <div class="form-grid">
            <label class="field">
              <span>엄마 월 통상임금</span>
              <input id="sixMotherWage" type="number" value="2500000" />
            </label>
            <label class="field">
              <span>아빠 월 통상임금</span>
              <input id="sixFatherWage" type="number" value="2500000" />
            </label>
            <label class="field">
              <span>엄마 사용 개월 수</span>
              <select id="sixMotherMonths">
                <option value="1">1개월</option>
                <option value="3">3개월</option>
                <option value="6" selected>6개월</option>
                <option value="9">9개월</option>
                <option value="12">12개월</option>
                <option value="15">15개월</option>
                <option value="18">18개월</option>
              </select>
            </label>
            <label class="field">
              <span>아빠 사용 개월 수</span>
              <select id="sixFatherMonths">
                <option value="1">1개월</option>
                <option value="3">3개월</option>
                <option value="6" selected>6개월</option>
                <option value="9">9개월</option>
                <option value="12">12개월</option>
                <option value="15">15개월</option>
                <option value="18">18개월</option>
              </select>
            </label>
            <label class="field">
              <span>자녀 생후 개월 수</span>
              <input id="sixChildAgeMonths" type="number" min="0" max="18" value="0" />
            </label>
            <label class="field">
              <span>사용 방식</span>
              <select id="sixLeaveMode">
                <option value="SEQUENTIAL" selected>순차</option>
                <option value="SIMULTANEOUS">동시</option>
              </select>
            </label>
          </div>
          <button id="calcSixPlusSixBtn" class="button button--primary" type="button">6+6 가능 여부 확인하기</button>
        </article>
      </div>

      <div class="stack">
        <SummaryCards
          columns={4}
          items={[
            { label: "6+6 적용 가능 여부", id: "sixEligibilitySummary" },
            { label: "가구 총액", id: "sixHouseholdTotalSummary" },
            { label: "일반 대비 차액", id: "sixDifferenceSummary" },
            { label: "원래 월급 대비 보전율", id: "sixReplacementSummary" }
          ]}
        />

        <InfoNotice
          title="안내"
          lines={[
            "자녀 생후 18개월 내 부모 모두 육아휴직을 사용할 때 첫 6개월간 상한이 확대되는 가정으로 계산합니다.",
            "육아휴직 18개월 연장은 2025년 2월 23일 시행 기준으로 부모 모두 3개월 이상 사용 조건을 단순 반영했습니다.",
            "7개월 이후와 13~18개월 구간은 일반 육아휴직 급여 구조를 이어서 적용한 추정 비교입니다."
          ]}
        />

        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">비교 요약</p>
              <h2 class="panel__title">엄마 / 아빠 / 가구 총액 비교</h2>
            </div>
            <p class="panel-heading__summary" id="sixSummaryNote">-</p>
          </div>
          <div class="breakdown-grid">
            <article class="breakdown-chip">
              <span>엄마 총 급여</span>
              <strong id="sixMotherTotalValue">-</strong>
            </article>
            <article class="breakdown-chip">
              <span>아빠 총 급여</span>
              <strong id="sixFatherTotalValue">-</strong>
            </article>
            <article class="breakdown-chip">
              <span>가구 총액</span>
              <strong id="sixHouseholdTotalValue">-</strong>
            </article>
            <article class="breakdown-chip">
              <span>일반 육아휴직 대비 차액</span>
              <strong id="sixDifferenceValue">-</strong>
            </article>
          </div>
        </article>

        <article class="panel">
          <div class="panel-heading">
            <div>
              <p class="panel-heading__eyebrow">상세 비교</p>
              <h2 class="panel__title">일반 육아휴직 vs 6+6 비교</h2>
            </div>
            <p class="panel-heading__summary">월별 상한 차이를 기준으로 비교합니다.</p>
          </div>
          <div class="table-wrap">
            <table class="result-table">
              <thead>
                <tr>
                  <th>항목</th>
                  <th>엄마 6+6</th>
                  <th>엄마 일반</th>
                  <th>아빠 6+6</th>
                  <th>아빠 일반</th>
                </tr>
              </thead>
              <tbody id="sixComparisonTable"></tbody>
            </table>
          </div>
        </article>
      </div>
    </section>
    <SeoContent
      introTitle="6+6 부모육아휴직제 계산기를 써야 하는 이유"
      intro={[
        "6+6 부모육아휴직제 계산기는 부모가 모두 육아휴직을 사용할 때 특례 적용 가능 여부와 일반 육아휴직 대비 추가 수령액을 비교하는 페이지입니다. 맞벌이 부부가 육아휴직 계획을 세울 때 가장 궁금한 차액 중심으로 설계했습니다.",
        "단순히 제도 설명만 보는 것보다, 엄마와 아빠 각각의 월 통상임금과 사용 개월 수를 넣고 가구 총액 차이를 바로 보는 방식이 훨씬 판단하기 쉽습니다."
      ]}
      inputPoints={[
        "엄마와 아빠 각각의 월 통상임금과 사용 개월 수를 넣어 총액을 계산할 수 있습니다.",
        "자녀 생후 개월 수와 사용 방식에 따라 특례 적용 가능 여부를 바로 확인할 수 있습니다.",
        "일반 육아휴직 대비 얼마나 더 받는지 가구 총액 차액으로 비교할 수 있습니다."
      ]}
      criteria={[
        "자녀 생후 18개월 내 부모 모두 육아휴직을 사용할 때 첫 6개월간 상한이 확대되는 구조를 기준으로 계산합니다.",
        "7개월 이후와 13~18개월 구간은 일반 육아휴직 구조를 이어 적용한 비교용 추정입니다.",
        "실제 제도 적용 세부 조건은 회사, 고용 형태, 사용 시점에 따라 달라질 수 있습니다."
      ]}
      faq={[
        { question: "6+6이 항상 일반 육아휴직보다 유리한가요?", answer: "대체로 가구 총액 측면에서는 유리할 가능성이 높지만, 실제 체감은 두 사람의 급여 수준과 사용 시점에 따라 달라집니다." },
        { question: "부모가 순차 사용해도 계산할 수 있나요?", answer: "네. 동시 사용과 순차 사용 모두 비교할 수 있게 입력 구조를 두었습니다." },
        { question: "18개월 연장까지 같이 볼 수 있나요?", answer: "가능합니다. 다만 확장 구간은 제도 안내를 단순화한 비교용 계산으로 해석하는 것이 좋습니다." }
      ]}
      related={[
        { href: "/tools/parental-leave-pay/", label: "육아휴직 급여 계산기" },
        { href: "/tools/single-parental-leave-total/", label: "한 명만 육아휴직 총수령액 계산기" },
        { href: "/tools/birth-support-total/", label: "출산~2세 총지원금 계산기" }
      ]}
    />
  </main>

  <script type="module" src={withBase("/scripts/six-plus-six.js")}></script>
</BaseLayout>
