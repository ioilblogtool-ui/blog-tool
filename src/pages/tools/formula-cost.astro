---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  PAGE_META,
  BRANDS,
  MONTHLY_USAGE_RANGES,
  AFFILIATE_PRODUCTS,
  PAGE_FAQ,
  EXTERNAL_REFERENCE_LINKS,
  NEXT_CALCULATOR,
  relatedLinks,
} from "../../data/formulaCost";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;

const config = { BRANDS, MONTHLY_USAGE_RANGES };
---

<BaseLayout
  title={PAGE_META.title}
  description={PAGE_META.subtitle}
  ogImage="/og/tools/formula-cost.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "돌까지 분유값 계산기",
    url: `${import.meta.env.SITE}/tools/formula-cost/`,
    description: PAGE_META.subtitle,
    applicationCategory: "LifestyleApplication",
    operatingSystem: "All",
    inLanguage: "ko-KR",
    isAccessibleForFree: true,
    provider: { "@type": "Organization", name: "비교계산소" },
  }}
>
  <SiteHeader />

  <SimpleToolShell calculatorId="formula-cost" pageClass="formula-cost-page">
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="육아 비용 계산기"
        title="돌까지 분유값 계산기"
        description="신생아부터 돌까지 월령별 분유 사용량을 계산하고, 브랜드별 총비용을 같은 화면에서 비교합니다."
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="resetFormulaCostBtn" copyId="copyFormulaCostLinkBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">기간 설정</p>
            <h2 class="panel__title">계산 기간</h2>
          </div>
          <p class="panel-heading__summary">분유를 사용하는 기간을 선택하면 월령별 사용량이 자동 반영됩니다.</p>
        </div>

        <div class="fc-duration-wrap">
          <div class="calc-slider-row">
            <input type="range" id="fcDurationSlider" class="calc-slider" min="1" max="18" step="1" value="12" />
            <span id="fcDurationLabel" class="calc-slider-val">12개월</span>
          </div>
          <div class="fc-duration-shortcuts">
            <button class="fc-shortcut-btn" data-months="6" type="button">6개월</button>
            <button class="fc-shortcut-btn is-active" data-months="12" type="button">돌까지</button>
            <button class="fc-shortcut-btn" data-months="18" type="button">18개월</button>
          </div>
        </div>
      </article>

      <article class="panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">브랜드 선택</p>
            <h2 class="panel__title">비교할 분유</h2>
          </div>
          <p class="panel-heading__summary">최대 5개까지 동시에 비교할 수 있고, 100g당 가격도 직접 수정할 수 있습니다.</p>
        </div>

        <div class="fc-brand-list">
          {BRANDS.map((brand) => (
            <label class="fc-brand-row">
              <div class="fc-brand-row__left">
                <input
                  type="checkbox"
                  class="fc-brand-checkbox"
                  data-brand-id={brand.id}
                  data-default-price={brand.defaultPricePer100g}
                  checked={["absoluteMungjak", "imperialDreamXO", "aptamil"].includes(brand.id)}
                />
                <div>
                  <span class="fc-brand-name">{brand.name}</span>
                  <span class="fc-brand-tag">{brand.tag}</span>
                </div>
              </div>
              <div class="fc-brand-row__right">
                <span class="fc-brand-price-label">100g당</span>
                <input
                  type="number"
                  class="fc-price-input"
                  id={`price-${brand.id}`}
                  value={brand.defaultPricePer100g}
                  min="500"
                  max="20000"
                  step="50"
                />
                <span class="fc-brand-price-unit">원</span>
              </div>
            </label>
          ))}
        </div>

        <p class="fc-price-hint">100g당 가격을 직접 바꾸면 현재 쿠팡 최저가나 내가 보는 판매가 기준으로 더 정확하게 비교할 수 있습니다.</p>
      </article>
    </Fragment>

    <section class="fc-section">
      <div class="fc-section__head">
        <p class="fc-section__eyebrow">계산 결과</p>
        <h2 id="fc-result-headline">분유 총비용 요약</h2>
        <p class="fc-section__sub" id="fc-result-subcopy">기간과 브랜드를 고르면 월령별 총 사용량과 브랜드별 총액이 바로 계산됩니다.</p>
      </div>
      <div class="fc-kpi-grid">
        <article class="fc-kpi-card fc-kpi-card--accent">
          <p>총 사용량 추정 (g)</p>
          <strong id="fc-total-grams">-</strong>
          <span id="fc-total-grams-note">-</span>
        </article>
        <article class="fc-kpi-card">
          <p>최저 총비용</p>
          <strong id="fc-min-cost">-</strong>
          <span id="fc-min-brand">-</span>
        </article>
        <article class="fc-kpi-card">
          <p>최고 총비용</p>
          <strong id="fc-max-cost">-</strong>
          <span id="fc-max-brand">-</span>
        </article>
        <article class="fc-kpi-card fc-kpi-card--save">
          <p>예상 차액</p>
          <strong id="fc-save-amount">-</strong>
          <span id="fc-save-note">최고가와 최저가 차이</span>
        </article>
      </div>
    </section>

    <section class="fc-section">
      <div class="fc-section__head">
        <p class="fc-section__eyebrow">브랜드 비교</p>
        <h2>브랜드별 상세 비교</h2>
      </div>
      <div class="table-wrap">
        <table class="fc-compare-table">
          <thead>
            <tr>
              <th>브랜드</th>
              <th>100g당</th>
              <th>캔 평균</th>
              <th>총비용</th>
              <th>구매 링크</th>
            </tr>
          </thead>
          <tbody id="fc-compare-tbody">
            <tr>
              <td colspan="5" class="fc-empty-row">브랜드를 선택하면 비교표가 채워집니다.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="fc-section">
      <div class="fc-section__head">
        <p class="fc-section__eyebrow">월별 흐름</p>
        <h2>월별 분유 비용</h2>
        <p class="fc-section__sub">이유식이 시작되는 6개월 전후부터는 분유 소비가 줄어 비용도 같이 낮아집니다.</p>
      </div>
      <article class="panel">
        <div class="fc-chart-wrap">
          <canvas id="fc-monthly-chart"></canvas>
        </div>
      </article>
    </section>

    <section class="fc-section">
      <div class="fc-section__head">
        <p class="fc-section__eyebrow">계산 기준</p>
        <h2>월령별 하루 평균 사용량</h2>
        <p class="fc-section__sub">완전 분유 수유를 기준으로 단순화한 참고값입니다. 혼합 수유나 이유식 비중에 따라 실제와 차이가 날 수 있습니다.</p>
      </div>
      <div class="fc-usage-grid">
        {MONTHLY_USAGE_RANGES.map((range) => (
          <article class="fc-usage-card">
            <p class="fc-usage-card__label">{range.label}</p>
            <strong class="fc-usage-card__count">{range.dailyGrams}<small>g/일</small></strong>
            <span class="fc-usage-card__note">{range.note}</span>
          </article>
        ))}
      </div>
    </section>

    <InfoNotice
      title="안내"
      lines={[
        "월령별 사용량은 완전 분유 수유를 기준으로 단순화한 평균 추정치입니다.",
        "브랜드 가격은 판매처, 시점, 옵션 구성에 따라 달라질 수 있으니 100g당 가격을 직접 수정해 확인하세요.",
        `데이터 기준: ${PAGE_META.updatedAt}`,
      ]}
    />

    <section class="content-section fc-next-section">
      <div class="panel fc-next-card">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">{NEXT_CALCULATOR.title}</p>
            <h2 class="panel__title">{NEXT_CALCULATOR.headline}</h2>
          </div>
          <p class="panel-heading__summary">{NEXT_CALCULATOR.desc}</p>
        </div>
        <a href={NEXT_CALCULATOR.href} class="button button--secondary">{NEXT_CALCULATOR.cta}</a>
      </div>
    </section>

    <section class="content-section fc-reference-section">
      <div class="panel fc-reference-links">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">외부 참고 링크</p>
            <h2 class="panel__title">분유와 영아 수유 참고 자료</h2>
          </div>
          <p class="panel-heading__summary">브랜드 가격 비교와 별도로, 수유와 영아 영양 기준을 확인할 때 같이 보면 좋은 참고 링크입니다.</p>
        </div>
        <div class="fc-link-grid">
          {EXTERNAL_REFERENCE_LINKS.map((item) => (
            <a href={item.url} target="_blank" rel="noreferrer" class="fc-reference-link">
              <strong>{item.title}</strong>
              <span>{item.desc}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section affiliate-section">
      <div class="affiliate-box">
        <div class="affiliate-box__header">
          <span class="affiliate-box__icon">🍼</span>
          <div>
            <h3 class="affiliate-box__title">분유 추천 상품</h3>
            <p class="affiliate-box__context">계산에 사용한 대표 브랜드를 바로 확인할 수 있는 링크입니다.</p>
          </div>
        </div>
        <div class="affiliate-product-grid">
          {AFFILIATE_PRODUCTS.map((prod) => (
            <a href={prod.url} class="affiliate-product-card" target="_blank" rel="noopener noreferrer nofollow">
              <span class="affiliate-product-tag">{prod.tag}</span>
              <p class="affiliate-product-title">{prod.title}</p>
              <p class="affiliate-product-desc">{prod.desc}</p>
              <span class="affiliate-product-cta">쿠팡에서 보기 →</span>
            </a>
          ))}
        </div>
        <p class="affiliate-disclosure">이 링크는 쿠팡파트너스 활동의 일환으로, 구매 시 소정의 수수료를 받을 수 있습니다.</p>
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle="돌까지 분유값 계산기를 보는 방법"
        intro={[
          "이 페이지는 신생아부터 돌까지 분유 총비용을 월령별 사용량 기준으로 계산하고, 여러 브랜드를 같은 화면에서 바로 비교할 수 있게 만든 계산기입니다.",
          "단순히 캔 가격만 보는 것이 아니라 100g당 가격으로 맞춰 총 사용량을 계산하기 때문에, 브랜드를 바꿨을 때 실제로 얼마나 차이 나는지 더 직접적으로 확인할 수 있습니다.",
        ]}
        inputPoints={[
          "계산 기간은 1~18개월까지 조절할 수 있고, 6개월·돌까지·18개월 단축 버튼도 함께 제공합니다.",
          "브랜드는 최대 5개까지 비교할 수 있고, 각 브랜드의 100g당 가격을 직접 수정할 수 있습니다.",
          "월별 비용 차트와 브랜드별 총비용 표를 같이 보면서 어느 구간에서 비용 차이가 커지는지 확인할 수 있습니다.",
        ]}
        criteria={[
          "월령별 하루 평균 사용량은 완전 분유 수유 기준의 단순화된 참고값입니다.",
          "브랜드별 총비용은 100g당 가격과 계산 기간 내 총 사용량을 곱해 추정합니다.",
          "실제 비용은 혼합 수유 여부, 이유식 시작 시점, 행사 가격에 따라 달라질 수 있습니다.",
        ]}
        faq={PAGE_FAQ}
        related={relatedLinks}
      />
    </Fragment>
  </SimpleToolShell>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script id="formulaCostConfig" type="application/json" set:html={JSON.stringify(config)}></script>
  <script type="module" src={withBase("/scripts/formula-cost.js")}></script>
</BaseLayout>
