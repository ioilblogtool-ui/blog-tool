---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import CalculatorHero from "../../components/CalculatorHero.astro";
import InfoNotice from "../../components/InfoNotice.astro";
import SeoContent from "../../components/SeoContent.astro";
import ToolActionBar from "../../components/ToolActionBar.astro";
import SimpleToolShell from "../../components/SimpleToolShell.astro";
import {
  APP_FEE_META,
  APP_FEE_FAQ,
  APP_FEE_SEO_CONTENT,
  APP_FEE_RELATED_LINKS,
  FEE_TIER_PRESETS,
  APP_FEE_DEFAULT_INPUT,
  ADMISSION_SCHEDULE_2026,
  MAX_SUSI_COUNT,
  MAX_JEONGSI_COUNT,
} from "../../data/collegeApplicationFeeCalculator2026";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const siteBase = (import.meta.env.SITE ?? "https://bigyocalc.com").replace(/\/$/, "");
const pageUrl = `${siteBase}/tools/${APP_FEE_META.slug}/`;
const won = (value: number) => `${Math.round(value).toLocaleString("ko-KR")}원`;

const config = { tiers: FEE_TIER_PRESETS, defaultInput: APP_FEE_DEFAULT_INPUT, maxSusi: MAX_SUSI_COUNT, maxJeongsi: MAX_JEONGSI_COUNT };
---

<BaseLayout
  title={APP_FEE_META.seoTitle}
  description={APP_FEE_META.seoDescription}
  ogImage="/og/og-home.png"
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "WebApplication",
      name: APP_FEE_META.title,
      applicationCategory: "UtilityApplication",
      operatingSystem: "All",
      description: APP_FEE_META.seoDescription,
      url: pageUrl,
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: APP_FEE_FAQ.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: { "@type": "Answer", text: item.answer },
      })),
    },
  ]}
>
  <SiteHeader />

  <SimpleToolShell calculatorId={APP_FEE_META.slug} pageClass="appfee-page" resultFirst={false}>
    <Fragment slot="hero">
      <CalculatorHero
        eyebrow="대입 원서비 계산"
        title={APP_FEE_META.title}
        description="수시·정시 지원 개수와 전형료 구간을 입력하면 원서비 총액을 바로 계산합니다."
        badges={["수시", "정시", "전형료", "2026"]}
      />
      <InfoNotice
        title="계산 전 확인"
        lines={[
          APP_FEE_META.dataNote,
          "입력값은 브라우저에서만 계산되며 서버로 전송하지 않습니다.",
        ]}
      />
    </Fragment>

    <Fragment slot="actions">
      <ToolActionBar resetId="appfeeResetBtn" copyId="appfeeCopyBtn" />
    </Fragment>

    <Fragment slot="aside">
      <article class="panel appfee-input-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">수시</h2>
          </div>
        </div>
        <section class="appfee-input-section">
          <label class="field">
            <span>수시 지원 개수 (최대 {MAX_SUSI_COUNT}개)</span>
          </label>
          <div class="calc-slider-row">
            <input type="range" id="appfeeSusiCountSlider" class="calc-slider" min="0" max={MAX_SUSI_COUNT} step="1" value={APP_FEE_DEFAULT_INPUT.susiCount} />
            <span id="appfeeSusiCountVal" class="calc-slider-val">{APP_FEE_DEFAULT_INPUT.susiCount}개</span>
          </div>
          <div class="toggle-grid">
            {FEE_TIER_PRESETS.map((preset, i) => (
              <label class="mode-chip">
                <input type="radio" name="appfeeSusiTier" value={preset.tier} data-appfee-fee={preset.feePerApplication} checked={i === 1} />
                <span>{preset.label}</span>
              </label>
            ))}
          </div>
          <label class="field">
            <span>수시 전형료(1건당)</span>
            <input data-appfee="susiFee" type="text" inputmode="numeric" class="input-number" value={APP_FEE_DEFAULT_INPUT.susiFee.toLocaleString("ko-KR")} />
          </label>
        </section>
      </article>

      <article class="panel appfee-input-panel">
        <div class="panel-heading">
          <div>
            <p class="panel-heading__eyebrow">입력</p>
            <h2 class="panel__title">정시</h2>
          </div>
        </div>
        <section class="appfee-input-section">
          <label class="field">
            <span>정시 지원 개수 (최대 {MAX_JEONGSI_COUNT}개)</span>
          </label>
          <div class="calc-slider-row">
            <input type="range" id="appfeeJeongsiCountSlider" class="calc-slider" min="0" max={MAX_JEONGSI_COUNT} step="1" value={APP_FEE_DEFAULT_INPUT.jeongsiCount} />
            <span id="appfeeJeongsiCountVal" class="calc-slider-val">{APP_FEE_DEFAULT_INPUT.jeongsiCount}개</span>
          </div>
          <div class="toggle-grid">
            {FEE_TIER_PRESETS.map((preset, i) => (
              <label class="mode-chip">
                <input type="radio" name="appfeeJeongsiTier" value={preset.tier} data-appfee-fee={preset.feePerApplication} checked={i === 1} />
                <span>{preset.label}</span>
              </label>
            ))}
          </div>
          <label class="field">
            <span>정시 전형료(1건당)</span>
            <input data-appfee="jeongsiFee" type="text" inputmode="numeric" class="input-number" value={APP_FEE_DEFAULT_INPUT.jeongsiFee.toLocaleString("ko-KR")} />
          </label>
        </section>
      </article>
    </Fragment>

    <section class="appfee-section appfee-result-section" aria-live="polite">
      <div class="section-header">
        <p class="section-header__eyebrow">계산 결과</p>
        <h2>원서비 총액</h2>
        <p>입력값을 바꾸면 수시·정시 원서비가 즉시 다시 계산됩니다.</p>
      </div>
      <div class="appfee-kpi-grid">
        <article class="appfee-kpi"><span>수시 원서비</span><strong data-appfee-result="susiTotal">-</strong></article>
        <article class="appfee-kpi"><span>정시 원서비</span><strong data-appfee-result="jeongsiTotal">-</strong></article>
        <article class="appfee-kpi appfee-kpi--accent"><span>원서비 총합</span><strong data-appfee-result="grandTotal">-</strong></article>
      </div>
    </section>

    <section class="appfee-section">
      <div class="section-header">
        <p class="section-header__eyebrow">참고 데이터</p>
        <h2>전형료 구간표</h2>
      </div>
      <div class="appfee-table-wrap">
        <table class="appfee-table">
          <thead><tr><th>구간</th><th>1건당 전형료</th><th>근거</th></tr></thead>
          <tbody>
            {FEE_TIER_PRESETS.map((preset) => (
              <tr><td>{preset.label}</td><td>{won(preset.feePerApplication)}</td><td>{preset.note}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="appfee-section">
      <div class="section-header">
        <p class="section-header__eyebrow">일정</p>
        <h2>2026학년도 원서접수 일정</h2>
      </div>
      <div class="appfee-table-wrap">
        <table class="appfee-table">
          <thead><tr><th>구분</th><th>기간</th></tr></thead>
          <tbody>
            {ADMISSION_SCHEDULE_2026.map((row) => (
              <tr><td>{row.label}</td><td>{row.period}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="appfee-section">
      <div class="section-header">
        <p class="section-header__eyebrow">다음 확인</p>
        <h2>관련 계산기</h2>
      </div>
      <div class="appfee-cta-grid">
        {APP_FEE_RELATED_LINKS.map((link) => (
          <a href={withBase(link.href)} class="appfee-cta-card">
            <strong>{link.label}</strong>
            <span>{link.description}</span>
          </a>
        ))}
      </div>
    </section>

    <Fragment slot="seo">
      <SeoContent
        introTitle={APP_FEE_SEO_CONTENT.introTitle}
        intro={APP_FEE_SEO_CONTENT.intro}
        inputPoints={APP_FEE_SEO_CONTENT.inputPoints}
        criteria={APP_FEE_SEO_CONTENT.criteria}
        faq={APP_FEE_FAQ}
        related={APP_FEE_RELATED_LINKS}
      />
    </Fragment>
  </SimpleToolShell>

  <script id="appfee-data" type="application/json" set:html={JSON.stringify(config)} />
  <script type="module" src={withBase("/scripts/college-application-fee-calculator-2026.js")}></script>
</BaseLayout>
