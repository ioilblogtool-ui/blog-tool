---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

const links = [
  { href: `${base}calculators/salary/`, label: "연봉 인상" },
  { href: `${base}calculators/retirement/`, label: "퇴직금" },
  { href: `${base}calculators/negotiation/`, label: "이직" },
  { href: `${base}calculators/parental-leave/`, label: "육아휴직" }
];
---

<nav class="calculator-tabs" aria-label="계산기 이동">
  {
    links.map((link) => (
      <a
        href={link.href}
        class:list={["calculator-tabs__link", currentPath === link.href && "is-active"]}
      >
        {link.label}
      </a>
    ))
  }
</nav>
