---
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${normalizedBase}${path.replace(/^\//, "")}`;
const currentPath = Astro.url.pathname;

const links = [
  { href: withBase("/calculators/salary/"), label: "연봉 인상" },
  { href: withBase("/calculators/retirement/"), label: "퇴직금" },
  { href: withBase("/calculators/negotiation/"), label: "이직" },
  { href: withBase("/calculators/parental-leave/"), label: "육아휴직" }
];
---

<nav class="calculator-tabs" aria-label="계산기 이동">
  {
    links.map((link) => (
      <a
        href={link.href}
        class:list={["calculator-tabs__link", currentPath === link.href && "is-active"]}
      >
        {link.label}
      </a>
    ))
  }
</nav>
