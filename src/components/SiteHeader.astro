---
import { tools, MOBILE_POPULAR_SLUGS } from "../data/tools";
import { reports } from "../data/reports";

const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${normalizedBase}${path.replace(/^\//, "")}`;

// tools.ts의 category 값은 내부 분류용 영문 코드("support", "calculator" 등)와
// 표시용 한글 라벨("투자·재테크" 등)이 혼재되어 있어, 한글 라벨만 검색 결과 배지로 노출한다.
const isDisplayCategory = (value: string) => /[가-힣]/.test(value);

const searchIndex = [
  ...tools.map((t) => ({
    type: "tool" as const,
    title: t.title,
    description: t.description,
    category: t.category && isDisplayCategory(t.category) ? t.category : "",
    href: withBase(`/tools/${t.slug}/`),
  })),
  ...reports.map((r) => ({
    type: "report" as const,
    title: r.title,
    description: r.description,
    category: "",
    href: withBase(`/reports/${r.slug}/`),
  })),
];
const searchIndexJson = JSON.stringify(searchIndex).replace(/<\/script/gi, "<\\/script");

const popularTools = MOBILE_POPULAR_SLUGS
  .map((slug) => tools.find((t) => t.slug === slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));
