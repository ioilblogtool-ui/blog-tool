---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="hero">
  <p class="hero__eyebrow">{eyebrow}</p>
  <h1 class="hero__title">{title}</h1>
  <p class="hero__description">{description}</p>
</section>

