---
/**
 * KpiCard.astro — 공통 KPI 수치 표시 카드
 *
 * 사용 목적:
 *   계산 결과나 리포트에서 한 개의 핵심 숫자를 강조 표시할 때 사용합니다.
 *   JS가 값을 동적으로 바꾸는 경우엔 value를 초기값으로 두고 <strong> id로 업데이트하세요.
 *
 * ── 리팩토링 포인트 (교체 우선순위 순) ─────────────────────────────────────
 *
 * 1순위: src/pages/reports/korea-rich-top10-assets.astro
 *   → <article class="report-stat-card"> 블록 4개 (현재 1위 자산, 합산, 상속형, 자수성가형)
 *     모두 서버 사이드에서 값이 결정되므로 KpiCard로 교체 적합.
 *     예: <KpiCard label="현재 1위 자산" value={formatKrwLarge(topEntry.krwValue)}
 *                  sub={`${topEntry.name} · ${formatUsdB(topEntry.netWorthUsdB)}`} highlight />
 *
 * 2순위: src/pages/reports/korea-rich-top10-assets.astro
 *   → <article class="report-stat-card report-stat-card--primary"> (선택 인물 원화 환산)
 *     highlight={true} + badge="참고 비교" 조합으로 그대로 적용 가능.
 *
 * 3순위: src/pages/tools/salary.astro
 *   → <article class="result-summary-card result-summary-card--accent"> (케이스 1 결과)
 *     highlight 변형에 해당. value·sub는 JS가 채우므로 초기값 "-" + id 속성 병행 필요.
 *     ※ JS 동적 업데이트가 필요한 경우 value="-"로 초기화 후
 *       querySelector('#id strong.kpi-card__value') 패턴으로 업데이트하세요.
 *
 * 4순위: src/pages/tools/parental-leave.astro (SummaryCards 내 metric-card)
 *   → SummaryCards 컴포넌트가 KpiCard 배열을 감싸는 구조로 교체 가능.
 *     단, JS id 연결 방식을 유지해야 하므로 KpiCard에 id prop 추가 후 진행 권장.
 *
 * 5순위: src/pages/tools/household-income.astro, bonus-simulator.astro 등
 *   → metric-card 패턴이 동일하게 반복되는 모든 계산기 페이지.
 * ─────────────────────────────────────────────────────────────────────────────
 */

interface Props {
  /** 카드 상단의 작은 레이블 (uppercase 표시) */
  label: string;
  /** 크게 표시되는 핵심 숫자 또는 값 */
  value: string;
  /** 선택: 값 아래 보조 설명 */
  sub?: string;
  /** 선택: true이면 brand-tint 배경 + brand-primary 값 색상 */
  highlight?: boolean;
  /** 선택: 우상단 pill 배지 텍스트 ('추정' | '+5%' 등) */
  badge?: string;
}

const { label, value, sub, highlight = false, badge } = Astro.props;
---

<article class:list={["kpi-card", { "kpi-card--highlight": highlight }]}>
  {badge && <span class="kpi-card__badge">{badge}</span>}
  <p class="kpi-card__label">{label}</p>
  <strong class="kpi-card__value">{value}</strong>
  {sub && <span class="kpi-card__sub">{sub}</span>}
</article>

<style>
  /* ── 기본 카드 ─────────────────────────────────────────────────────────── */
  .kpi-card {
    position: relative;
    display: grid;
    gap: 5px;
    padding: 14px;
    background: var(--surface-soft);
    border: 1px solid var(--line);
    border-radius: 10px; /* spec: 10px (--radius-card: 12px과 의도적으로 구분) */
    box-shadow: 0 2px 8px rgba(23, 32, 51, 0.04);
    transition: box-shadow 160ms ease;
  }

  /* ── 하이라이트 카드 (brand-tint) ──────────────────────────────────────── */
  .kpi-card--highlight {
    background: var(--color-brand-tint, #e1f5ee);
    border-color: rgba(15, 110, 86, 0.18);
  }

  /* ── 레이블 (10px / uppercase / letter-spacing) ────────────────────────── */
  .kpi-card__label {
    margin: 0;
    font-size: var(--text-caption-size, 10px);
    font-weight: var(--text-label-weight, 500);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: var(--text-caption-leading, 1.5);
  }

  /* ── 핵심 숫자 (24px / weight 500) ────────────────────────────────────── */
  .kpi-card__value {
    display: block;
    font-size: 24px; /* spec: 24px — --text-display-size(28px)보다 한 단계 작게 */
    font-weight: var(--text-display-weight, 500);
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: var(--text-display-leading, 1.2);
  }

  .kpi-card--highlight .kpi-card__value {
    color: var(--color-brand-primary, #0f6e56);
  }

  /* ── 보조 설명 (11px / brand-mid or muted) ─────────────────────────────── */
  .kpi-card__sub {
    display: block;
    margin: 0;
    font-size: var(--text-label-size, 11px);
    font-weight: var(--text-body-weight, 400);
    color: var(--muted);
    line-height: var(--text-label-leading, 1.4);
  }

  .kpi-card--highlight .kpi-card__sub {
    color: var(--color-brand-mid, #1d9e75);
  }

  /* ── 배지 (우상단 pill) ────────────────────────────────────────────────── */
  .kpi-card__badge {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 3px 7px;
    border-radius: var(--radius-chip, 20px);
    background: #faeeda; /* warning tint — --color-warning: #BA7517 기반 */
    color: #854f0b;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1.4;
    white-space: nowrap;
  }
</style>
