---
const normalizedBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path: string) => `${normalizedBase}${path.replace(/^\//, "")}`;
const year = new Date().getFullYear();

const primaryLinks = [
  { href: withBase("/"), label: "홈" },
  { href: withBase("/tools/"), label: "도구 목록" },
  { href: withBase("/tools/salary/"), label: "연봉 계산기" },
  { href: withBase("/tools/retirement/"), label: "퇴직금 계산기" },
  { href: withBase("/tools/bonus-simulator/"), label: "성과급 시뮬레이터" },
  { href: withBase("/tools/parental-leave/"), label: "육아휴직 계산기" }
];

const trustLinks = [
  { href: withBase("/about/"), label: "사이트 소개" },
  { href: withBase("/privacy/"), label: "개인정보처리방침" },
  { href: withBase("/contact/"), label: "문의 안내" },
  { href: withBase("/disclaimer/"), label: "이용안내 및 면책" }
];

const allLinks = [...primaryLinks, ...trustLinks];
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <p class="site-footer__eyebrow">비교계산소</p>
      <p class="site-footer__tagline">숫자로 더 잘 판단하세요</p>
    </div>

    <nav class="site-footer__nav" aria-label="풋터 링크">
      <div class="site-footer__links-grid">
        {allLinks.map((link) => <a href={link.href}>{link.label}</a>)}
      </div>
    </nav>

    <div class="site-footer__meta">
      <p>계산 결과는 공개 기준 참고용 추정치입니다.</p>
      <p>중요한 결정 전 원문 공지와 공식 자료를 확인하세요.</p>
      <p>
        문의:
        <a href="mailto:ioilblogtool@gmail.com?subject=[비교계산소 문의]">
          ioilblogtool@gmail.com
        </a>
      </p>
    </div>

    <div class="site-footer__copyright-bar">
      <span>© {year} 비교계산소</span>
      <span></span>
    </div>
  </div>
</footer>
