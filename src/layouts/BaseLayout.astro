---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "비교해서 더 잘 판단하게 만드는 계산 도구" } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
