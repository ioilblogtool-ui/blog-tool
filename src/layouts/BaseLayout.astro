---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "연봉, 퇴직금, 이직, 육아휴직 계산기를 운영하는 정적 사이트" } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
